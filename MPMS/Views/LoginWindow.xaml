<Window x:Class="MPMS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:MPMS.Infrastructure"
        Title="MPMS — Вход" Height="520" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="StringToVis" IsStringMode="True"/>
        <infra:HexToBrushConverter      x:Key="HexToBrush"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- Account card button -->
        <Style x:Key="AccountCard" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#F0F4FF"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer shadow wrapper -->
    <Border CornerRadius="14" Background="White" Margin="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.18"
                              ShadowDepth="6" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════════
                 LEFT — Branding panel (draggable)
            ═══════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" CornerRadius="14,0,0,14"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F2038" Offset="0"/>
                        <GradientStop Color="#1A3A5C" Offset="0.6"/>
                        <GradientStop Color="#1B6EC2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Margin="30,0">

                        <!-- Logo -->
                        <Border Width="70" Height="70" CornerRadius="35"
                                Background="#1B6EC2" HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" Opacity="0.5" ShadowDepth="0"/>
                            </Border.Effect>
                            <TextBlock Text="M" Foreground="White"
                                       FontSize="38" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="MPMS" Foreground="White"
                                   FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Montage Project&#x0a;Management System"
                                   Foreground="#8CA3C0" FontSize="12"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30"/>

                        <StackPanel>
                            <TextBlock Text="✓  Управление проектами"
                                       Foreground="#C8D8EA" FontSize="12" Margin="0,4"/>
                            <TextBlock Text="✓  Контроль задач и этапов"
                                       Foreground="#C8D8EA" FontSize="12" Margin="0,4"/>
                            <TextBlock Text="✓  Офлайн режим работы"
                                       Foreground="#C8D8EA" FontSize="12" Margin="0,4"/>
                            <TextBlock Text="✓  Синхронизация данных"
                                       Foreground="#C8D8EA" FontSize="12" Margin="0,4"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="v1.0 · 2026"
                               Foreground="#4A6A8A" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════
                 RIGHT — Login form
            ═══════════════════════════════════════════════════════ -->
            <Grid Grid.Column="1">

                <!-- Close button -->
                <Button Content="✕" Click="CloseButton_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,12,12,0" Width="28" Height="28" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground"      Value="#CCCCCC"/>
                            <Setter Property="FontSize"        Value="14"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource DangerBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Form -->
                <StackPanel VerticalAlignment="Center" Margin="44,0,44,0">

                    <TextBlock Text="Добро пожаловать!"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Введите данные для входа"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,28"/>

                    <!-- Login -->
                    <TextBlock Text="ЛОГИН" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="UsernameBox"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <!-- Password -->
                    <TextBlock Text="ПАРОЛЬ" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PwdBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Margin="0,0,0,20"/>

                    <!-- Error block -->
                    <Border Background="#FFF5F5" CornerRadius="6" Padding="12,8"
                            Margin="0,0,0,12"
                            Visibility="{Binding ErrorMessage,
                                Converter={StaticResource StringToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠  " Foreground="{StaticResource DangerBrush}"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="13" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Login button -->
                    <Button Content="Войти"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"
                            Height="44" FontSize="15"/>

                    <!-- Busy indicator -->
                    <TextBlock Text="Выполняется вход..."
                               FontSize="12" HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="{Binding IsBusy,
                                   Converter={StaticResource BoolToVis}}"/>

                    <!-- ── Recent accounts ──────────────────────────────── -->
                    <StackPanel Margin="0,20,0,0"
                                Visibility="{Binding HasRecentAccounts,
                                    Converter={StaticResource BoolToVis}}">

                        <!-- Divider with label -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Separator Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="  Недавние  "
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Separator Grid.Column="2" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Account cards -->
                        <ItemsControl ItemsSource="{Binding RecentAccounts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource AccountCard}" Margin="3,0"
                                            Command="{Binding DataContext.SelectAccountCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Center" Width="72">
                                            <!-- Avatar -->
                                            <Border Width="42" Height="42" CornerRadius="21"
                                                    Background="{Binding AvatarColor,
                                                        Converter={StaticResource HexToBrush}}"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,5">
                                                <TextBlock Text="{Binding Initials}"
                                                           Foreground="White"
                                                           FontSize="15" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Username}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Role}"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
