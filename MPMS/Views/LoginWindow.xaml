<Window x:Class="MPMS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:MPMS.Infrastructure"
        Title="MPMS — Вход" Height="540" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="StringToVis" IsStringMode="True"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="White" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title / drag bar -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Background="{StaticResource SidebarBrush}"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="MPMS" Foreground="White" FontWeight="Bold"
                               FontSize="14" VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Button Content="✕" Click="CloseButton_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,12,0" Width="28" Height="28" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"     Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground"     Value="#888"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="40,24,40,40" VerticalAlignment="Center">

                <TextBlock Text="Добро пожаловать"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Войдите в систему MPMS"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,28"/>

                <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="EmailBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="ПАРОЛЬ" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PwdBox"
                             Style="{StaticResource ModernPasswordBox}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Margin="0,0,0,24"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource StringToVis}}"/>

                <Button Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        Height="42" FontSize="15"/>

                <!-- Busy -->
                <TextBlock Text="Выполняется вход..."
                           FontSize="13" HorizontalAlignment="Center" Margin="0,14,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
