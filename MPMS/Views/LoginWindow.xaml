<Window x:Class="MPMS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:MPMS.Infrastructure"
        Title="MPMS" Height="580" Width="880"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="StringToVis" IsStringMode="True"/>
        <infra:HexToBrushConverter       x:Key="HexToBrush"/>

        <!-- Input container border -->
        <Style x:Key="InputContainer" TargetType="Border">
            <Setter Property="Background"      Value="#F5F6FA"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="BorderBrush"     Value="#E2E5ED"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height"          Value="50"/>
        </Style>

        <!-- Transparent TextBox inside InputContainer -->
        <Style x:Key="InnerTextBox" TargetType="TextBox">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="FontSize"               Value="14"/>
            <Setter Property="Foreground"             Value="#172B4D"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                Value="0,0,14,0"/>
            <Setter Property="CaretBrush"             Value="#1B6EC2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transparent PasswordBox inside InputContainer -->
        <Style x:Key="InnerPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="FontSize"               Value="14"/>
            <Setter Property="Foreground"             Value="#172B4D"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                Value="0,0,14,2"/>
            <Setter Property="CaretBrush"             Value="#1B6EC2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login button -->
        <Style x:Key="LoginBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1B6EC2" Offset="0"/>
                                    <GradientStop Color="#1557A0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1557A0" Offset="0"/>
                                            <GradientStop Color="#0F4080" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Account card -->
        <Style x:Key="AccountCard" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBd"
                                Background="Transparent"
                                BorderBrush="#E2E5ED"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8,10">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBd" Property="Background"
                                        Value="#F0F4FF"/>
                                <Setter TargetName="CardBd" Property="BorderBrush"
                                        Value="#1B6EC2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root: shadow + rounded outer border -->
    <Border Margin="16" CornerRadius="16" Background="White" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Opacity="0.22"
                              ShadowDepth="8" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════
                 LEFT — Branding panel
            ═══════════════════════════════════════════════════ -->
            <Border Grid.Column="0" ClipToBounds="True"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.8,1">
                        <GradientStop Color="#0A1628" Offset="0"/>
                        <GradientStop Color="#0F2038" Offset="0.4"/>
                        <GradientStop Color="#153055" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <!-- Decorative circles -->
                <Canvas>
                    <Ellipse Canvas.Left="-60" Canvas.Top="-60"
                             Width="200" Height="200"
                             Fill="#1B6EC2" Opacity="0.07"/>
                    <Ellipse Canvas.Left="160" Canvas.Top="400"
                             Width="240" Height="240"
                             Fill="#1B6EC2" Opacity="0.07"/>
                    <Ellipse Canvas.Left="80" Canvas.Top="200"
                             Width="120" Height="120"
                             Fill="#FFFFFF" Opacity="0.03"/>

                    <!-- Content on top of circles -->
                    <StackPanel Canvas.Left="0" Canvas.Top="0"
                                Width="310"
                                HorizontalAlignment="Center">
                        <StackPanel.Margin>
                            <Thickness Left="30" Top="80" Right="30" Bottom="0"/>
                        </StackPanel.Margin>

                        <!-- Logo -->
                        <Border Width="72" Height="72" CornerRadius="22"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,22">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2980B9" Offset="0"/>
                                    <GradientStop Color="#1B6EC2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" Opacity="0.45"
                                                  ShadowDepth="0"/>
                            </Border.Effect>
                            <TextBlock Text="M" Foreground="White"
                                       FontSize="38" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- App name -->
                        <TextBlock Text="MPMS"
                                   Foreground="White" FontSize="30"
                                   FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <!-- Tagline -->
                        <TextBlock Text="Информационная система&#x0a;планирования и контроля&#x0a;монтажных проектов"
                                   Foreground="#6A8BAD" FontSize="12"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   LineHeight="20"
                                   Margin="0,0,0,36"/>

                        <!-- Divider line -->
                        <Rectangle Height="1" Fill="#1D3A5C"
                                   Margin="20,0,20,28"/>

                        <!-- Feature bullets -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <Border Width="24" Height="24" CornerRadius="12"
                                        Background="#1A3550" Margin="0,0,10,0">
                                    <TextBlock Text="✓" Foreground="#4DA3F5"
                                               FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Управление проектами"
                                           Foreground="#8AAEC8" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <Border Width="24" Height="24" CornerRadius="12"
                                        Background="#1A3550" Margin="0,0,10,0">
                                    <TextBlock Text="✓" Foreground="#4DA3F5"
                                               FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Контроль задач и этапов"
                                           Foreground="#8AAEC8" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <Border Width="24" Height="24" CornerRadius="12"
                                        Background="#1A3550" Margin="0,0,10,0">
                                    <TextBlock Text="✓" Foreground="#4DA3F5"
                                               FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Офлайн режим работы"
                                           Foreground="#8AAEC8" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <Border Width="24" Height="24" CornerRadius="12"
                                        Background="#1A3550" Margin="0,0,10,0">
                                    <TextBlock Text="✓" Foreground="#4DA3F5"
                                               FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Синхронизация данных"
                                           Foreground="#8AAEC8" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Bottom version label -->
                    <TextBlock Canvas.Left="0" Canvas.Bottom="0"
                               Width="310" TextAlignment="Center"
                               Text="v 1.0  ·  Дипломная работа 2026"
                               Foreground="#2D4A65" FontSize="10"
                               Margin="0,0,0,16"
                               Canvas.Top="530"/>
                </Canvas>
            </Border>

            <!-- ═══════════════════════════════════════════════════
                 RIGHT — Login form
            ═══════════════════════════════════════════════════ -->
            <Grid Grid.Column="1" Background="White">

                <!-- Close button -->
                <Button x:Name="CloseBtn" Click="CloseButton_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,14,16,0" Width="30" Height="30"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CloseBd" CornerRadius="15"
                                    Background="Transparent">
                                <TextBlock Text="✕" FontSize="13"
                                           Foreground="#BBBBBB"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseBd"
                                            Property="Background" Value="#FFF0F0"/>
                                    <Setter TargetName="CloseBd"
                                            Property="TextElement.Foreground"
                                            Value="#E74C3C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Centered form -->
                <StackPanel VerticalAlignment="Center"
                            Margin="52,0,52,0"
                            MaxWidth="380">

                    <!-- Heading -->
                    <TextBlock Text="Вход в систему"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#0A1628"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Введите логин и пароль для доступа"
                               FontSize="13" Foreground="#8896A8"
                               Margin="0,0,0,30"/>

                    <!-- ── Username ───────────────────── -->
                    <TextBlock Text="ЛОГИН" FontSize="11" FontWeight="SemiBold"
                               Foreground="#8896A8" Margin="0,0,0,6"/>
                    <Border x:Name="UsernameContainer"
                            Style="{StaticResource InputContainer}"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="#9EA7B4"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="UsernameBox"
                                     Grid.Column="1"
                                     Style="{StaticResource InnerTextBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="UsernameBox_GotFocus"
                                     LostFocus="UsernameBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <!-- ── Password ───────────────────── -->
                    <TextBlock Text="ПАРОЛЬ" FontSize="11" FontWeight="SemiBold"
                               Foreground="#8896A8" Margin="0,0,0,6"/>
                    <Border x:Name="PasswordContainer"
                            Style="{StaticResource InputContainer}"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="#9EA7B4"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <PasswordBox x:Name="PwdBox"
                                         Grid.Column="1"
                                         Style="{StaticResource InnerPasswordBox}"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         GotFocus="PwdBox_GotFocus"
                                         LostFocus="PwdBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <!-- ── Error ──────────────────────── -->
                    <Border Background="#FFF5F5" CornerRadius="8"
                            BorderBrush="#FFCDD2" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,14"
                            Visibility="{Binding ErrorMessage,
                                Converter={StaticResource StringToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" Foreground="#E53935"
                                       FontSize="14" Margin="0,0,8,0"
                                       VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#C62828" FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Login button ───────────────── -->
                    <Button Content="Войти в систему"
                            Style="{StaticResource LoginBtn}"
                            Command="{Binding LoginCommand}"/>

                    <!-- ── Busy ───────────────────────── -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0"
                                Visibility="{Binding IsBusy,
                                    Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⟳ " Foreground="#1B6EC2"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Выполняется вход..."
                                   FontSize="13" Foreground="#8896A8"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- ── Recent accounts ────────────── -->
                    <StackPanel Margin="0,22,0,0"
                                Visibility="{Binding HasRecentAccounts,
                                    Converter={StaticResource BoolToVis}}">

                        <!-- Separator with label -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Height="1"
                                       Fill="#E8ECF0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="  Недавние аккаунты  "
                                       FontSize="11" Foreground="#AAB4BE"
                                       VerticalAlignment="Center"/>
                            <Rectangle Grid.Column="2" Height="1"
                                       Fill="#E8ECF0"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Cards -->
                        <ItemsControl ItemsSource="{Binding RecentAccounts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource AccountCard}"
                                            Margin="3,0"
                                            Command="{Binding DataContext.SelectAccountCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Center"
                                                    Width="76">
                                            <!-- Avatar -->
                                            <Grid Width="46" Height="46"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,7">
                                                <Ellipse Fill="{Binding AvatarColor,
                                                             Converter={StaticResource HexToBrush}}"/>
                                                <TextBlock
                                                    Text="{Binding Initials}"
                                                    Foreground="White"
                                                    FontSize="16" FontWeight="Bold"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Username -->
                                            <TextBlock
                                                Text="{Binding Username}"
                                                FontSize="12" FontWeight="SemiBold"
                                                Foreground="#0A1628"
                                                HorizontalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"/>
                                            <!-- Role -->
                                            <TextBlock
                                                Text="{Binding Role}"
                                                FontSize="10"
                                                Foreground="#8896A8"
                                                HorizontalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"
                                                Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
