<Window x:Class="MPMS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:MPMS.Infrastructure"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="MPMS" Height="660" Width="880"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="StringToVis" IsStringMode="True"/>
        <infra:HexToBrushConverter       x:Key="HexToBrush"/>

        <!-- Input container border -->
        <Style x:Key="InputContainer" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height"          Value="50"/>
        </Style>

        <!-- Transparent TextBox inside InputContainer -->
        <Style x:Key="InnerTextBox" TargetType="TextBox">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="FontSize"               Value="14"/>
            <Setter Property="Foreground"             Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                Value="0,0,14,0"/>
            <Setter Property="CaretBrush"             Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="SelectionBrush"         Value="{StaticResource NeutralSelectionBrush}"/>
            <Setter Property="SelectionTextBrush"     Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transparent PasswordBox inside InputContainer -->
        <Style x:Key="InnerPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="FontSize"               Value="14"/>
            <Setter Property="Foreground"             Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                Value="0,0,14,2"/>
            <Setter Property="CaretBrush"             Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login button -->
        <Style x:Key="LoginBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="#111111">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Account card -->
        <Style x:Key="AccountCard" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBd"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8,10">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBd" Property="Background"
                                        Value="{StaticResource BackgroundBrush}"/>
                                <Setter TargetName="CardBd" Property="BorderBrush"
                                        Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root: shadow + rounded outer border -->
    <Border Margin="16" CornerRadius="14" Background="White" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Opacity="0.22"
                              ShadowDepth="8" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════
                 LEFT — Branding panel
            ═══════════════════════════════════════════════════ -->
            <Grid Grid.Column="0" ClipToBounds="True"
                  MouseLeftButtonDown="DragBar_MouseLeftButtonDown">

                <!-- Background gradient -->
                <Grid.Background>
                    <SolidColorBrush Color="#111111"/>
                </Grid.Background>

                <!-- Decorative rings with animation -->
                <Grid IsHitTestVisible="False">

                    <!-- Top-left thick ring — slow fade -->
                    <Ellipse Width="280" Height="280"
                             Stroke="#0F2540" StrokeThickness="40"
                             Fill="Transparent"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-110,-110,0,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever"
                                                AutoReverse="True">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="1" To="0.25"
                                            Duration="0:0:5">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <!-- Bottom-right ring — opposite phase -->
                    <Ellipse Width="230" Height="230"
                             Stroke="#0D2035" StrokeThickness="32"
                             Fill="Transparent" Opacity="0.25"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-75,-75">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever"
                                                AutoReverse="True">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.25" To="1"
                                            Duration="0:0:5">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <!-- Slowly rotating tilted ellipse (centre) -->
                    <Ellipse Width="160" Height="100"
                             Stroke="#152A45" StrokeThickness="1"
                             Fill="Transparent" Opacity="0.6"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            From="0" To="360"
                                            Duration="0:0:28"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <!-- Inner smaller rotating ellipse (opposite direction) -->
                    <Ellipse Width="100" Height="60"
                             Stroke="#1B3A5A" StrokeThickness="0.8"
                             Fill="Transparent" Opacity="0.5"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="45"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            From="45" To="-315"
                                            Duration="0:0:18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <!-- Radial glow — pulsing -->
                    <Ellipse Width="200" Height="200"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" Opacity="0.5">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#0E2240" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever"
                                                AutoReverse="True">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.3" To="0.8"
                                            Duration="0:0:4">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <!-- Small accent dots -->
                    <Ellipse Width="5" Height="5" Fill="#1B6EC2" Opacity="0.7"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,115,40,0"/>
                    <Ellipse Width="4" Height="4" Fill="#4DA3F5" Opacity="0.5"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="46,0,0,95"/>
                </Grid>

                <!-- ── Main content ───────────────────────────────── -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="28,0">

                    <!-- Logo МС -->
                    <Border Width="92" Height="92" CornerRadius="22"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,26">
                        <Border.Background>
                            <SolidColorBrush Color="#000000"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="М"
                                       Foreground="White"
                                       FontSize="34" FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                            <Rectangle Width="2" Height="26"
                                       Fill="White" Opacity="0.45"
                                       VerticalAlignment="Center"
                                       Margin="6,0,6,0"/>
                            <TextBlock Text="С"
                                       Foreground="#D0D0D0"
                                       FontSize="34" FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>

                    <!-- System name -->
                    <TextBlock Text="Информационная система"
                               Foreground="#DADDE3"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="планирования и контроля"
                               Foreground="#DADDE3"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="монтажных проектов"
                               Foreground="#DADDE3"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>

                </StackPanel>

                <!-- Version footer -->
                <TextBlock Text="v 1.0  ·  2026"
                           Foreground="#6B778C"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,16"/>
            </Grid>

            <!-- ═══════════════════════════════════════════════════
                 RIGHT — Login form
            ═══════════════════════════════════════════════════ -->
            <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">

                <!-- Close button -->
                <Button x:Name="CloseBtn" Click="CloseButton_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,14,16,0" Width="30" Height="30"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CloseBd" CornerRadius="15"
                                    Background="Transparent">
                                <TextBlock Text="✕" FontSize="13"
                                           Foreground="#BBBBBB"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseBd"
                                            Property="Background" Value="#FFF0F0"/>
                                    <Setter TargetName="CloseBd"
                                            Property="TextElement.Foreground"
                                            Value="#E74C3C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Centered form -->
                <StackPanel VerticalAlignment="Center"
                            Margin="52,0,52,0"
                            MaxWidth="380">

                    <!-- Heading -->
                    <TextBlock Text="Вход в систему"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Введите логин и пароль для доступа"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,30"/>

                    <!-- ── Username ───────────────────── -->
                    <TextBlock Text="ЛОГИН" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Border x:Name="UsernameContainer"
                            Style="{StaticResource InputContainer}"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="UsernameBox"
                                     Grid.Column="1"
                                     Style="{StaticResource InnerTextBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="UsernameBox_GotFocus"
                                     LostFocus="UsernameBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <!-- ── Password ───────────────────── -->
                    <TextBlock Text="ПАРОЛЬ" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Border x:Name="PasswordContainer"
                            Style="{StaticResource InputContainer}"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>

                            <!-- Lock icon -->
                            <TextBlock Grid.Column="0"
                                       Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <!-- PasswordBox (hidden mode) -->
                            <PasswordBox x:Name="PwdBox"
                                         Grid.Column="1"
                                         Style="{StaticResource InnerPasswordBox}"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         GotFocus="PwdBox_GotFocus"
                                         LostFocus="PwdBox_LostFocus"/>

                            <!-- TextBox (show mode) -->
                            <TextBox x:Name="PwdVisibleBox"
                                     Grid.Column="1"
                                     Style="{StaticResource InnerTextBox}"
                                     Visibility="Collapsed"
                                     TextChanged="PwdVisibleBox_TextChanged"
                                     GotFocus="PwdBox_GotFocus"
                                     LostFocus="PwdBox_LostFocus"/>

                            <!-- Eye toggle using SVG icons -->
                            <Grid Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Cursor="Hand"
                                  MouseLeftButtonDown="EyeIcon_Click">
                                <!-- Password hidden: crossed eye -->
                                <Image x:Name="EyeOffIcon"
                                       Width="18"
                                       Height="18"
                                       Source="{svgc:SvgImage Source=/icons/еуе2.svg, AppName=MPMS}"
                                       Opacity="0.85"/>
                                <!-- Password visible: normal eye -->
                                <Image x:Name="EyeOnIcon"
                                       Width="18"
                                       Height="18"
                                       Source="{svgc:SvgImage Source=/icons/еуе.svg, AppName=MPMS}"
                                       Opacity="0.85"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── Error ──────────────────────── -->
                    <Border Background="#FFF5F5" CornerRadius="8"
                            BorderBrush="#FFCDD2" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,14"
                            Visibility="{Binding ErrorMessage,
                                Converter={StaticResource StringToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="⚠" Foreground="#E53935"
                                       FontSize="14" Margin="0,0,8,0"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ErrorMessage}"
                                       Foreground="#C62828" FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- ── Login button ───────────────── -->
                    <Button Content="Войти в систему"
                            Style="{StaticResource LoginBtn}"
                            Command="{Binding LoginCommand}"/>

                    <!-- ── Busy ───────────────────────── -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0"
                                Visibility="{Binding IsBusy,
                                    Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⟳ " Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Выполняется вход..."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- ── Recent accounts ────────────── -->
                    <StackPanel Margin="0,22,0,0"
                                Visibility="{Binding HasRecentAccounts,
                                    Converter={StaticResource BoolToVis}}">

                        <!-- Separator with label -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Height="1"
                                       Fill="{StaticResource BorderBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="  Недавние аккаунты  "
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Rectangle Grid.Column="2" Height="1"
                                       Fill="{StaticResource BorderBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Cards -->
                        <ItemsControl ItemsSource="{Binding RecentAccounts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource AccountCard}"
                                            Margin="3,0"
                                            Command="{Binding DataContext.SelectAccountCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Center"
                                                    Width="76">
                                            <!-- Avatar -->
                                            <Grid Width="46" Height="46"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,7">
                                                <Ellipse Fill="{Binding AvatarColor,
                                                             Converter={StaticResource HexToBrush}}"/>
                                                <TextBlock
                                                    Text="{Binding Initials}"
                                                    Foreground="White"
                                                    FontSize="16" FontWeight="Bold"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Username -->
                                            <TextBlock
                                                Text="{Binding Username}"
                                                FontSize="12" FontWeight="SemiBold"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                HorizontalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"/>
                                            <!-- Role -->
                                            <TextBlock
                                                Text="{Binding Role}"
                                                FontSize="10"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                HorizontalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"
                                                Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
