<UserControl x:Class="MPMS.Views.Pages.GanttPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MPMS.Controls"
             xmlns:infra="clr-namespace:MPMS.Infrastructure"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER (title left, nav+today right — same pattern as Calendar) ── -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Диаграмма Ганта" FontSize="22" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock Text="Временная шкала задач и этапов проекта"
                               FontSize="12" Foreground="#6B778C" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- "Сегодня" + month nav — same layout as Calendar header -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Height="30" Padding="14,0" Margin="0,0,10,0"
                            Command="{Binding GoToTodayCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="#DFE1E6" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="Сегодня" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#000000" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Border Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource NavBtn}"
                                    Command="{Binding PreviousMonthCommand}">
                                <Path Data="M7,2 L2,8 L7,14" Stroke="#374151" StrokeThickness="2"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Stretch="None"/>
                            </Button>
                            <TextBlock Text="{Binding MonthTitle}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#000000" VerticalAlignment="Center"
                                       MinWidth="165" TextAlignment="Center"/>
                            <Button Style="{StaticResource NavBtn}"
                                    Command="{Binding NextMonthCommand}">
                                <Path Data="M2,2 L7,8 L2,14" Stroke="#374151" StrokeThickness="2"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Stretch="None"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── TABS ROW ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="Transparent" Padding="16,0">
            <controls:TabBarControl x:Name="GanttTabBar"
                                    GroupName="GanttTabs"
                                    SelectedTabChanged="GanttTab_SelectedTabChanged">
                <controls:TabItemModel Text="Задачи" Tag="Tasks"/>
                <controls:TabItemModel Text="Этапы"  Tag="Stages"/>
            </controls:TabBarControl>
        </Border>

        <!-- ── GANTT BODY ────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="White" Margin="16,8,16,16"
                CornerRadius="10" BorderBrush="#DFE1E6" BorderThickness="1"
                ClipToBounds="True">
            <Grid>

                <!-- ── TASKS SECTION ──────────────────────────────── -->
                <Grid x:Name="TasksSection">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <Border Grid.Row="0" Background="#F9FAFB"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0"
                                    Padding="16,8">
                                <TextBlock Text="Задача" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#6B778C"/>
                            </Border>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding DayHeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:GanttDayHeader}">
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,1,0"
                                                Padding="0,6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding DayNumber}"
                                                       TextAlignment="Center" FontSize="10"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#6B778C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Task rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding TaskRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:GanttTaskRow}">
                                    <Border x:Name="RowBorder"
                                            BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"
                                            Cursor="Hand" Tag="{Binding}"
                                            MouseLeftButtonDown="TaskRow_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid MinHeight="52">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="260"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Task info (left) -->
                                            <Border Grid.Column="0" BorderBrush="#E5E7EB"
                                                    BorderThickness="0,0,1,0" Padding="12,8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Task.Name}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#000000"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" CornerRadius="4"
                                                                Padding="5,2" VerticalAlignment="Center"
                                                                Margin="4,0,0,0"
                                                                Background="{Binding StatusColor, Converter={StaticResource HexToBrush}}">
                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                    <!-- Project name -->
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                                Margin="0,3,0,0">
                                                        <Image Width="11" Height="11"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"
                                                               Source="{svgc:SvgImage Source=/icons/project.svg, AppName=MPMS}"
                                                               Opacity="0.6"/>
                                                        <TextBlock Text="{Binding Task.ProjectName}"
                                                                   FontSize="10" Foreground="#6B778C"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <!-- Due date -->
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                                                Margin="0,2,0,0"
                                                                Visibility="{Binding Task.DueDate, Converter={StaticResource NullToVisInv}}">
                                                        <Image Width="11" Height="11"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"
                                                               Source="{svgc:SvgImage Source=/icons/time.svg, AppName=MPMS}"
                                                               Opacity="0.5"/>
                                                        <TextBlock Text="{Binding Task.DueDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                                   FontSize="10" Foreground="#9CA3AF"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Timeline area (right) -->
                                            <Grid Grid.Column="1">
                                                <!-- Day grid lines background -->
                                                <ItemsControl ItemsSource="{Binding DataContext.DayHeaders,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              IsHitTestVisible="False">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#F3F4F6" BorderThickness="0,0,1,0"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Proportional bar -->
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding BarLeft,     Converter={StaticResource FracToGL}}"/>
                                                        <ColumnDefinition Width="{Binding BarWidth,    Converter={StaticResource FracToGL}}"/>
                                                        <ColumnDefinition Width="{Binding BarRemainder,Converter={StaticResource FracToGL}}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="TaskBar"
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Height="30"
                                                            CornerRadius="5" Margin="1,0"
                                                            Opacity="0.9"
                                                            Visibility="{Binding HasBar, Converter={StaticResource BoolToVis}}"
                                                            Background="{Binding BarColorHex, Converter={StaticResource HexToBrush}}"
                                                            ToolTipService.Placement="Center"
                                                            ToolTipService.InitialShowDelay="0"
                                                            ToolTipService.ShowDuration="120000"
                                                            ToolTipService.BetweenShowDelay="0">
                                                        <Border.ToolTip>
                                                            <ToolTip Background="Transparent"
                                                                     BorderThickness="0"
                                                                     Padding="0">
                                                                <Border CornerRadius="4" Padding="8,4"
                                                                        Background="#E6000000"
                                                                        SnapsToDevicePixels="True">
                                                                    <TextBlock Text="{Binding BarRangeLabel}"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="RowBorder" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TaskBar" Property="Opacity" Value="1.0"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding TaskRows.Count, Converter={StaticResource NullToVisInv}}">
                        <TextBlock Text="Нет задач для отображения"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#97A0AF" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- ── STAGES SECTION ─────────────────────────────── -->
                <Grid x:Name="StagesSection" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <Border Grid.Row="0" Background="#F9FAFB"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0"
                                    Padding="16,8">
                                <TextBlock Text="Этап" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#6B778C"/>
                            </Border>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding DayHeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:GanttDayHeader}">
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,1,0"
                                                Padding="0,6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding DayNumber}"
                                                       TextAlignment="Center" FontSize="10"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#6B778C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Stage rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding StageRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:GanttStageRow}">
                                    <Border x:Name="StageRowBorder"
                                            BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"
                                            Cursor="Hand" Tag="{Binding}"
                                            MouseLeftButtonDown="StageRow_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid MinHeight="52">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="260"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Stage info (left) -->
                                            <Border Grid.Column="0" BorderBrush="#E5E7EB"
                                                    BorderThickness="0,0,1,0" Padding="12,8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- Name + status -->
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Stage.Stage.Name}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#000000"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" CornerRadius="4"
                                                                Padding="5,2" VerticalAlignment="Center"
                                                                Margin="4,0,0,0"
                                                                Background="{Binding StatusColor, Converter={StaticResource HexToBrush}}">
                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                    <!-- Task + Project in ONE ROW -->
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                                Margin="0,3,0,0">
                                                        <Image Width="11" Height="11"
                                                               Margin="0,0,3,0" VerticalAlignment="Center"
                                                               Source="{svgc:SvgImage Source=/icons/tasks.svg, AppName=MPMS}"
                                                               Opacity="0.6"/>
                                                        <TextBlock Text="{Binding Stage.TaskName}"
                                                                   FontSize="10" Foreground="#6B778C"
                                                                   MaxWidth="80"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text=" · " FontSize="10" Foreground="#9CA3AF"/>
                                                        <Image Width="11" Height="11"
                                                               Margin="0,0,3,0" VerticalAlignment="Center"
                                                               Source="{svgc:SvgImage Source=/icons/project.svg, AppName=MPMS}"
                                                               Opacity="0.6"/>
                                                        <TextBlock Text="{Binding Stage.ProjectName}"
                                                                   FontSize="10" Foreground="#9CA3AF"
                                                                   MaxWidth="80"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Timeline area (right) -->
                                            <Grid Grid.Column="1">
                                                <!-- Day grid lines background -->
                                                <ItemsControl ItemsSource="{Binding DataContext.DayHeaders,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              IsHitTestVisible="False">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#F3F4F6" BorderThickness="0,0,1,0"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Proportional bar -->
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding BarLeft,     Converter={StaticResource FracToGL}}"/>
                                                        <ColumnDefinition Width="{Binding BarWidth,    Converter={StaticResource FracToGL}}"/>
                                                        <ColumnDefinition Width="{Binding BarRemainder,Converter={StaticResource FracToGL}}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="StageBar"
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Height="30"
                                                            CornerRadius="5" Margin="1,0"
                                                            Opacity="0.9"
                                                            Visibility="{Binding HasBar, Converter={StaticResource BoolToVis}}"
                                                            Background="{Binding BarColorHex, Converter={StaticResource HexToBrush}}"
                                                            ToolTipService.Placement="Center"
                                                            ToolTipService.InitialShowDelay="0"
                                                            ToolTipService.ShowDuration="120000"
                                                            ToolTipService.BetweenShowDelay="0">
                                                        <Border.ToolTip>
                                                            <ToolTip Background="Transparent"
                                                                     BorderThickness="0"
                                                                     Padding="0">
                                                                <Border CornerRadius="4" Padding="8,4"
                                                                        Background="#E6000000"
                                                                        SnapsToDevicePixels="True">
                                                                    <TextBlock Text="{Binding BarRangeLabel}"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="StageRowBorder" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="StageBar" Property="Opacity" Value="1.0"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Today line overlay – drawn in code-behind -->
                <Canvas x:Name="TodayLineCanvas"
                        IsHitTestVisible="False"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="20"/>

                <!-- Loading overlay -->
                <Border Background="#80FFFFFF"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Загрузка..." FontSize="16" Foreground="#6B778C"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
