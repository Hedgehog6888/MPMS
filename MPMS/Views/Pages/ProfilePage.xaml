<UserControl x:Class="MPMS.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
      Background="#F8F9FA">

    <UserControl.Resources>
        <Style x:Key="ProfileSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="ProfileLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ProfileValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>

        <Style x:Key="ProfileCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E8E9EC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ProfileInput" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditInputBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24,28,24" MaxWidth="1100">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top">

                <!-- Avatar Card -->
                <Border Style="{StaticResource ProfileCard}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- Avatar area -->
                        <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                            <!-- Outer ring -->
                            <Border Width="96" Height="96" CornerRadius="48"
                                    HorizontalAlignment="Center"
                                    BorderBrush="#BFDBFE" BorderThickness="2"/>

                            <!-- Avatar circle -->
                            <Border x:Name="AvatarBorder" Style="{StaticResource AvatarCircle90}"
                                    HorizontalAlignment="Center"
                                    Background="#1B6EC2">
                                <TextBlock x:Name="AvatarInitials" Text="ИИ"
                                           FontSize="30" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Photo image -->
                            <Border Style="{StaticResource AvatarCircle90}"
                                    HorizontalAlignment="Center">
                                <Image x:Name="AvatarImage"
                                       Style="{StaticResource AvatarImage}"
                                       Width="90" Height="90"
                                       Visibility="Collapsed"/>
                            </Border>

                            <!-- Upload button overlay -->
                            <Border Width="90" Height="90" CornerRadius="45"
                                    HorizontalAlignment="Center"
                                    ClipToBounds="True"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="AvatarUpload_Click"
                                    MouseEnter="AvatarBtn_MouseEnter"
                                    MouseLeave="AvatarBtn_MouseLeave">
                                <Border.Clip>
                                    <EllipseGeometry Center="45,45" RadiusX="45" RadiusY="45"/>
                                </Border.Clip>
                                <Border x:Name="AvatarHoverOverlay"
                                        Background="#AA000000"
                                        CornerRadius="45"
                                        Opacity="0">
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE722;" FontSize="20"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Изменить" FontSize="9"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Border>

                            <!-- Online dot -->
                            <Border Width="18" Height="18" CornerRadius="9"
                                    Background="#22C55E"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Margin="0,0,10,4"
                                    BorderBrush="White" BorderThickness="2"/>
                        </Grid>

                        <!-- Name and role -->
                        <TextBlock x:Name="NameText"
                                   Text="Имя пользователя"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#000000"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="PositionText"
                                   Text="Должность"
                                   FontSize="13" Foreground="#6B778C"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <!-- Sub-role badge for workers -->
                        <Border x:Name="SubRoleBadge" CornerRadius="12" Padding="12,5"
                                HorizontalAlignment="Center" Margin="0,0,0,8"
                                Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1"
                                Visibility="Collapsed">
                            <TextBlock x:Name="SubRoleText" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#9A3412" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Role badge -->
                        <Border x:Name="RoleBadge" CornerRadius="20" Padding="14,6"
                                HorizontalAlignment="Center" Margin="0,0,0,20"
                                Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="RoleIcon" FontSize="13" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="RoleText" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#1D4ED8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Separator -->
                        <Border Height="1" Background="#F0F0F0" Margin="0,0,0,16"/>

                        <!-- Contact info -->
                        <StackPanel Margin="0,0,0,4">
                            <StackPanel x:Name="EmailRow" Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="28" Height="28" CornerRadius="8"
                                        Background="#F4F5F7" Margin="0,0,10,0">
                                    <TextBlock Text="✉" FontSize="13" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="#6B778C"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Email" FontSize="10" Foreground="#6B778C"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="EmailText" FontSize="12" Foreground="#000000"
                                               TextWrapping="Wrap" MaxWidth="180"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="LoginRow" Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="28" Height="28" CornerRadius="8"
                                        Background="#F4F5F7" Margin="0,0,10,0">
                                    <TextBlock Text="@" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="#6B778C"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Логин" FontSize="10" Foreground="#6B778C"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="LoginText" FontSize="12" Foreground="#000000"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <Border Width="28" Height="28" CornerRadius="8"
                                        Background="#F4F5F7" Margin="0,0,10,0">
                                    <TextBlock Text="📅" FontSize="12" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="В системе с" FontSize="10" Foreground="#6B778C"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="CreatedText" FontSize="12" Foreground="#000000"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stats card -->
                <Border Style="{StaticResource ProfileCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Статистика" Style="{StaticResource ProfileSectionTitle}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" CornerRadius="8" Padding="12"
                                    Background="#EFF6FF" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock x:Name="ProjectCountText" Text="0"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="#1D4ED8"/>
                                    <TextBlock Text="Проектов" FontSize="11"
                                               Foreground="#3B82F6"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" CornerRadius="8" Padding="12"
                                    Background="#F0FDF4" Margin="6,0,0,6">
                                <StackPanel>
                                    <TextBlock x:Name="TaskCountText" Text="0"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="#16A34A"/>
                                    <TextBlock Text="Задач" FontSize="11"
                                               Foreground="#22C55E"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" CornerRadius="8" Padding="12"
                                    Background="#FFF7ED" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock x:Name="StageCountText" Text="0"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="#EA580C"/>
                                    <TextBlock Text="Этапов" FontSize="11"
                                               Foreground="#F97316"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" CornerRadius="8" Padding="12"
                                    Background="#FDF4FF" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="ActivityCountText" Text="0"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="#9333EA"/>
                                    <TextBlock Text="Действий" FontSize="11"
                                               Foreground="#A855F7"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Change password card -->
                <Border Style="{StaticResource ProfileCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="🔑" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Пароль" Style="{StaticResource ProfileSectionTitle}"
                                       Margin="0"/>
                        </StackPanel>

                        <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,0"
                                Cursor="Hand" Background="Transparent"
                                BorderBrush="#F0F0F0" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Изменить пароль" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#000000"/>
                                    <TextBlock Text="Доступно в режиме редактирования" FontSize="11"
                                               Foreground="#6B778C" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Text="›" FontSize="18" Foreground="#C1C7D0"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="2">

                <!-- Page header -->
                <Grid Margin="0,0,0,20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Мой профиль" FontSize="22" FontWeight="Bold"
                                   Foreground="#000000"/>
                        <TextBlock Text="Управление персональными данными и настройками аккаунта"
                                   FontSize="13" Foreground="#6B778C" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="CancelBtn" Content="Отмена"
                                Click="Cancel_Click"
                                Style="{StaticResource OutlineBtn}"
                                Margin="0,0,8,0"
                                Visibility="Collapsed"/>
                        <Button x:Name="EditBtn" Content="✎  Редактировать"
                                Click="Edit_Click"
                                Style="{StaticResource OutlineBtn}"/>
                        <Button x:Name="SaveBtn" Content="✓  Сохранить"
                                Click="Save_Click"
                                Style="{StaticResource SaveBtn}"
                                Margin="8,0,0,0"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- View mode: Personal info -->
                <Border x:Name="ViewPanel" Style="{StaticResource ProfileCard}"
                        Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Личная информация" Style="{StaticResource ProfileSectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="ИМЯ" Style="{StaticResource ProfileLabel}"/>
                                <TextBlock x:Name="ViewFirstName" Style="{StaticResource ProfileValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="ФАМИЛИЯ" Style="{StaticResource ProfileLabel}"/>
                                <TextBlock x:Name="ViewLastName" Style="{StaticResource ProfileValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,16">
                                <TextBlock Text="ЛОГИН" Style="{StaticResource ProfileLabel}"/>
                                <TextBlock x:Name="ViewUsername" Style="{StaticResource ProfileValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,16">
                                <TextBlock Text="EMAIL" Style="{StaticResource ProfileLabel}"/>
                                <TextBlock x:Name="ViewEmail" Style="{StaticResource ProfileValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,0,16">
                                <TextBlock Text="РОЛЬ В СИСТЕМЕ" Style="{StaticResource ProfileLabel}"/>
                                <TextBlock x:Name="ViewRole" Style="{StaticResource ProfileValue}"/>
                            </StackPanel>
                            <StackPanel x:Name="ViewSubRolePanel" Grid.Column="2" Grid.Row="2" Margin="0,0,0,16"
                                        Visibility="Collapsed">
                                <TextBlock Text="СПЕЦИАЛИЗАЦИЯ" Style="{StaticResource ProfileLabel}"/>
                                <TextBlock x:Name="ViewSubRole" Style="{StaticResource ProfileValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="3">
                                <TextBlock Text="ДАТА РЕГИСТРАЦИИ" Style="{StaticResource ProfileLabel}"/>
                                <TextBlock x:Name="ViewCreated" Style="{StaticResource ProfileValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Edit mode: Form -->
                <Border x:Name="EditPanel" Style="{StaticResource ProfileCard}"
                        Padding="24" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Редактирование профиля" Style="{StaticResource ProfileSectionTitle}"/>

                        <!-- First name + Last name row -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Имя *" Style="{StaticResource ProfileLabel}"/>
                                <Border Style="{StaticResource ProfileInput}">
                                    <TextBox x:Name="FirstNameBox" Style="{StaticResource EditInputBox}"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Фамилия *" Style="{StaticResource ProfileLabel}"/>
                                <Border Style="{StaticResource ProfileInput}">
                                    <TextBox x:Name="LastNameBox" Style="{StaticResource EditInputBox}"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Email -->
                        <TextBlock Text="Email" Style="{StaticResource ProfileLabel}"/>
                        <Border Style="{StaticResource ProfileInput}">
                            <TextBox x:Name="EmailBox" Style="{StaticResource EditInputBox}"/>
                        </Border>

                        <!-- Current password (required to save changes) -->
                        <TextBlock Text="Текущий пароль (для подтверждения) *"
                                   Style="{StaticResource ProfileLabel}"/>
                        <Border Style="{StaticResource ProfileInput}">
                            <PasswordBox x:Name="CurrentPasswordBox"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#000000" FontSize="13"
                                         VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- New password section -->
                        <Border CornerRadius="8" Background="#F8FAFF" Padding="16"
                                BorderBrush="#BFDBFE" BorderThickness="1" Margin="0,0,0,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="🔑" FontSize="12" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Изменить пароль (необязательно)"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#1D4ED8" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Новый пароль" Style="{StaticResource ProfileLabel}"/>
                                        <Border Background="White" BorderBrush="#DFE1E6"
                                                BorderThickness="1" CornerRadius="8" Padding="12,10">
                                            <PasswordBox x:Name="NewPasswordBox"
                                                         BorderThickness="0" Background="Transparent"
                                                         Foreground="#000000" FontSize="13"
                                                         VerticalContentAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Повторите пароль" Style="{StaticResource ProfileLabel}"/>
                                        <Border Background="White" BorderBrush="#DFE1E6"
                                                BorderThickness="1" CornerRadius="8" Padding="12,10">
                                            <PasswordBox x:Name="ConfirmPasswordBox"
                                                         BorderThickness="0" Background="Transparent"
                                                         Foreground="#000000" FontSize="13"
                                                         VerticalContentAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Error message -->
                        <Border x:Name="ErrorPanel" Background="#FFF0F0"
                                CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,12" Visibility="Collapsed"
                                BorderBrush="#FCA5A5" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0"
                                           Foreground="#DC2626" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Success message -->
                        <Border x:Name="SuccessPanel" Background="#F0FDF4"
                                CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,12" Visibility="Collapsed"
                                BorderBrush="#86EFAC" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" FontSize="13" Margin="0,0,8,0"
                                           Foreground="#16A34A" VerticalAlignment="Center"/>
                                <TextBlock Text="Профиль успешно обновлён!" FontSize="12"
                                           Foreground="#16A34A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Role info card -->
                <Border x:Name="RoleInfoCard" Style="{StaticResource ProfileCard}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Информация о роли" Style="{StaticResource ProfileSectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                                    Background="#EFF6FF">
                                <TextBlock x:Name="RoleCardIcon" Text="👤" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock x:Name="RoleCardTitle" FontSize="14" FontWeight="Bold"
                                           Foreground="#000000"/>
                                <TextBlock x:Name="RoleCardDesc" FontSize="12" Foreground="#6B778C"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <!-- Permissions list -->
                        <Border Height="1" Background="#F0F0F0" Margin="0,16,0,14"/>
                        <TextBlock Text="Права доступа:" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#6B778C" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="PermissionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="✓" FontSize="11" Foreground="#22C55E"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#000000"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
