<UserControl x:Class="MPMS.Views.Pages.WarehousePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d"
             Background="#F4F5F7"
             d:DataContext="{d:DesignInstance Type=vm:WarehouseViewModel}"
             d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="WarehouseRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Склад" FontSize="24" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock FontSize="13" Foreground="#6B778C" Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding Materials.Count, StringFormat='Материалов: {0}'}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Text" Value="{Binding Equipments.Count, StringFormat='Единиц оборудования: {0}'}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1" x:Name="AddButton"
                        Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"
                        Click="AddItem_Click"
                        Height="38" Padding="18,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                               Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Добавить"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Tabs -->
        <Border Grid.Row="1" Background="Transparent" Padding="24,12,24,0">
            <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                    CornerRadius="8" Padding="6,4" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TabMaterials" GroupName="WarehouseTabs" IsChecked="True"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Materials">
                        Материалы
                    </RadioButton>
                    <RadioButton x:Name="TabEquipment" GroupName="WarehouseTabs" IsChecked="False"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Equipment">
                        Оборудование
                    </RadioButton>
                </StackPanel>
            </Border>
        </Border>

        <!-- List + плавающая панель как на странице «Задачи» -->
        <Grid Grid.Row="2" Margin="24,12,0,24" ClipToBounds="True">
            <ScrollViewer x:Name="MainListScroll"
                          VerticalScrollBarVisibility="Visible"
                          Padding="0,62,24,0"
                          Background="Transparent"
                          Panel.ZIndex="0">
                <Grid>
                    <ItemsControl x:Name="MaterialsList"
                                  ItemsSource="{Binding Materials}"
                                  Margin="0,10,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Tag="{Binding}"
                                        MouseLeftButtonDown="MaterialRow_Click">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource WarehouseRow}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#000000"/>
                                            <TextBlock Text="{Binding CategoryName}" FontSize="11"
                                                       Foreground="#6B778C"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding CategoryName, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Инв. номер" FontSize="11"
                                                       Foreground="#6B778C"/>
                                            <TextBlock Text="{Binding InventoryNumber, FallbackValue='—'}" FontSize="13"
                                                       Foreground="#000000"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Ед. изм." FontSize="11"
                                                       Foreground="#6B778C"/>
                                            <TextBlock Text="{Binding Unit, FallbackValue='—'}" FontSize="13"
                                                       Foreground="#000000"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="Количество" FontSize="11"
                                                       Foreground="#6B778C"/>
                                            <TextBlock Text="{Binding Quantity}" FontSize="13"
                                                       Foreground="#000000"/>
                                        </StackPanel>

                                        <Border Grid.Column="4" VerticalAlignment="Center" Margin="8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E3FCEF"/>
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                    <Setter Property="Padding" Value="8,3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                            <Setter Property="Background" Value="#FFF4E5"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                            <Setter Property="Background" Value="#F4F5F7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="В наличии"/>
                                                        <Setter Property="Foreground" Value="#00875A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                                <Setter Property="Text" Value="Нет в наличии"/>
                                                                <Setter Property="Foreground" Value="#FF8B00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                                <Setter Property="Text" Value="Списано"/>
                                                                <Setter Property="Foreground" Value="#6B778C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <TextBlock Grid.Column="5" Text="›" FontSize="18"
                                                   Foreground="#6B778C"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl x:Name="EquipmentList"
                                  ItemsSource="{Binding Equipments}"
                                  Margin="0,10,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Tag="{Binding}"
                                        MouseLeftButtonDown="EquipmentRow_Click">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource WarehouseRow}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#000000"/>
                                            <TextBlock Text="{Binding CategoryName}" FontSize="11"
                                                       Foreground="#6B778C"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding CategoryName, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Инв. номер" FontSize="11"
                                                       Foreground="#6B778C"/>
                                            <TextBlock Text="{Binding InventoryNumber, FallbackValue='—'}" FontSize="13"
                                                       Foreground="#000000"/>
                                        </StackPanel>

                                        <Border Grid.Column="2" VerticalAlignment="Center" Margin="8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E3FCEF"/>
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                    <Setter Property="Padding" Value="8,3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="InUse">
                                                            <Setter Property="Background" Value="#FFF4E5"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                            <Setter Property="Background" Value="#DEEBFF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                            <Setter Property="Background" Value="#F4F5F7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding StatusDisplay}"/>
                                                        <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                                <Setter Property="Text" Value="Списано"/>
                                                                <Setter Property="Foreground" Value="#6B778C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <TextBlock Grid.Column="3" Text="›" FontSize="18"
                                                   Foreground="#6B778C"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <Border VerticalAlignment="Top" Panel.ZIndex="1"
                    HorizontalAlignment="Left"
                    Width="{Binding ElementName=MainListScroll, Path=ViewportWidth}"
                    Background="White" CornerRadius="8"
                    BorderBrush="#DFE1E6" BorderThickness="1"
                    Padding="16,10,16,14"
                    PreviewMouseWheel="FilterBar_PreviewMouseWheel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.14" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#F4F5F7" CornerRadius="6"
                            Padding="10,0" Height="36" Margin="0,0,10,0"
                            BorderThickness="1.5" BorderBrush="Transparent"
                            VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="#6B778C"/>
                            <Grid Grid.Column="1" Margin="0,0,4,0">
                                <TextBlock Text="Поиск по названию, описанию, категории, инв. номеру…"
                                           Foreground="#6B778C" FontSize="12"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" FontSize="13"
                                         Foreground="#000000"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"/>
                            </Grid>
                            <Button Grid.Column="2" Click="ClearSearch_Click"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVis}}"
                                    Width="20" Height="20" Margin="0,0,0,0"
                                    Style="{StaticResource IconButton}">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#6B778C"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Категория: материалы -->
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding MaterialCategoryFilterOptions}"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedCategoryId}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource FormCombo}">
                                <Setter Property="Width" Value="160"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <!-- Категория: оборудование -->
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding EquipmentCategoryFilterOptions}"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedCategoryId}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource FormCombo}">
                                <Setter Property="Width" Value="160"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <!-- «Статус» / жизненный цикл — как первый фильтр после поиска у задач -->
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding LifecycleFilterOptions}"
                              SelectedItem="{Binding LifecycleFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160" Margin="0,0,10,0"/>

                    <!-- Материалы: остаток | Оборудование: статус -->
                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding MaterialStockFilterOptions}"
                              SelectedItem="{Binding MaterialStockFilter}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource FormCombo}">
                                <Setter Property="Width" Value="180"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding EquipmentStatusFilterOptions}"
                              SelectedItem="{Binding EquipmentStatusFilter}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource FormCombo}">
                                <Setter Property="Width" Value="180"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
