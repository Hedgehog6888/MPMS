<UserControl x:Class="MPMS.Views.Pages.WarehousePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:infra="clr-namespace:MPMS.Infrastructure"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:controls="clr-namespace:MPMS.Controls"
             mc:Ignorable="d"
             Background="#F8FAFC"
             d:DataContext="{d:DesignInstance Type=vm:WarehouseViewModel}"
             d:DesignHeight="800" d:DesignWidth="1100"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <infra:EqualityToVisibilityConverter x:Key="EqToVis"/>

        <Style x:Key="WarehouseRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Склад" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock FontSize="13" Foreground="#64748B" Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding Materials.Count, StringFormat='Материалов: {0}'}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Text" Value="{Binding Equipments.Count, StringFormat='Единиц оборудования: {0}'}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1" x:Name="AddButton"
                        Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"
                        Click="AddItem_Click"
                        Style="{StaticResource BlackBtn}"
                        Height="38" Padding="18,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Добавить материал"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                            <Setter Property="Text" Value="Добавить оборудование"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Tabs -->
        <Border Grid.Row="1" Background="Transparent" Padding="24,12,24,0">
            <controls:TabBarControl SelectedTab="{Binding ActiveTab, Mode=TwoWay}"
                                    GroupName="WarehouseTabs">
                <controls:TabBarControl.Tabs>
                    <controls:TabItemModel Text="Материалы"   Tag="Materials"/>
                    <controls:TabItemModel Text="Оборудование" Tag="Equipment"/>
                </controls:TabBarControl.Tabs>
            </controls:TabBarControl>
        </Border>

        <!-- List + плавающая панель как на странице «Задачи» -->
        <Grid Grid.Row="2" Margin="24,12,0,24" ClipToBounds="True">
            <ScrollViewer x:Name="MainListScroll"
                          VerticalScrollBarVisibility="Visible"
                          Padding="0,62,24,0"
                          Background="Transparent"
                          Panel.ZIndex="0">
                <Grid>
                    <ItemsControl x:Name="MaterialsList"
                                  ItemsSource="{Binding Materials}"
                                  Margin="0,10,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Tag="{Binding}"
                                        MouseLeftButtonDown="MaterialRow_Click">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource WarehouseRow}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#0F172A"/>
                                            <TextBlock Text="{Binding CategoryName}" FontSize="11"
                                                       Foreground="#64748B"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding CategoryName, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Инв. номер" FontSize="11"
                                                       Foreground="#64748B"/>
                                            <TextBlock Text="{Binding InventoryNumber, FallbackValue='—'}" FontSize="13"
                                                       Foreground="#0F172A"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Ед. изм." FontSize="11"
                                                       Foreground="#64748B"/>
                                            <TextBlock Text="{Binding Unit, FallbackValue='—'}" FontSize="13"
                                                       Foreground="#0F172A"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="Количество" FontSize="11"
                                                       Foreground="#64748B"/>
                                            <TextBlock Text="{Binding Quantity}" FontSize="13"
                                                       Foreground="#0F172A"/>
                                        </StackPanel>

                                        <Border Grid.Column="4" VerticalAlignment="Center" Margin="8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#ECFDF5"/>
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                    <Setter Property="Padding" Value="8,3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                            <Setter Property="Background" Value="#FFFBEB"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="В наличии"/>
                                                        <Setter Property="Foreground" Value="#059669"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                                <Setter Property="Text" Value="Нет в наличии"/>
                                                                <Setter Property="Foreground" Value="#D97706"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                                <Setter Property="Text" Value="Списано"/>
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <TextBlock Grid.Column="5" Text="›" FontSize="18"
                                                   Foreground="#64748B"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl x:Name="EquipmentList"
                                  ItemsSource="{Binding Equipments}"
                                  Margin="0,10,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Equipment">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Tag="{Binding}"
                                        MouseLeftButtonDown="EquipmentRow_Click">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource WarehouseRow}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#0F172A"/>
                                            <TextBlock Text="{Binding CategoryName}" FontSize="11"
                                                       Foreground="#64748B"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding CategoryName, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Инв. номер" FontSize="11"
                                                       Foreground="#64748B"/>
                                            <TextBlock Text="{Binding InventoryNumber, FallbackValue='—'}" FontSize="13"
                                                       Foreground="#0F172A"/>
                                        </StackPanel>

                                        <Border Grid.Column="2" VerticalAlignment="Center" Margin="8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#ECFDF5"/>
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                    <Setter Property="Padding" Value="8,3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Unavailable">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="InUse">
                                                            <Setter Property="Background" Value="#FFFBEB"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="CheckedOut">
                                                            <Setter Property="Background" Value="#FFFBEB"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Retired">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding StatusDisplay}"/>
                                                        <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsWrittenOff}" Value="True">
                                                                <Setter Property="Text" Value="Списано"/>
                                                                <Setter Property="Foreground" Value="#6B778C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <TextBlock Grid.Column="3" Text="›" FontSize="18"
                                                   Foreground="#64748B"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State (Materials) -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ActiveTab}" Value="Materials"/>
                                            <Condition Binding="{Binding Materials.Count}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Image Source="{svgc:SvgImage Source=/icons/empty_materials.svg, AppName=MPMS}" 
                               Width="48" Height="48" Opacity="0.1" Margin="0,0,0,16"/>
                        <TextBlock Text="Материалы не найдены" 
                                   FontSize="15" FontWeight="SemiBold" Foreground="#0F172A" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Добавьте первый материал" 
                                   FontSize="12" Foreground="#64748B" TextAlignment="Center" 
                                   Margin="0,8,0,0" LineHeight="18"/>
                    </StackPanel>

                    <!-- Empty State (Equipment) -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ActiveTab}" Value="Equipment"/>
                                            <Condition Binding="{Binding Equipments.Count}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Image Source="{svgc:SvgImage Source=/icons/empty_equipment.svg, AppName=MPMS}" 
                               Width="48" Height="48" Opacity="0.1" Margin="0,0,0,16"/>
                        <TextBlock Text="Оборудование не найдено" 
                                   FontSize="15" FontWeight="SemiBold" Foreground="#0F172A" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Добавьте первое оборудование" 
                                   FontSize="12" Foreground="#64748B" TextAlignment="Center" 
                                   Margin="0,8,0,0" LineHeight="18"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- ── Плавающая панель поиска ── -->
            <controls:SearchFilterBarControl
                VerticalAlignment="Top" Panel.ZIndex="1"
                HorizontalAlignment="Left"
                Width="{Binding ElementName=MainListScroll, Path=ViewportWidth}"
                IsFloating="True"
                ScrollTarget="{Binding ElementName=MainListScroll}"
                SearchText="{Binding SearchText, Mode=TwoWay}"
                Placeholder="Поиск по названию, описанию, категории, инв. номеру…">
                <controls:SearchFilterBarControl.Filters>
                    <StackPanel Orientation="Horizontal">
                        <!-- Категория: материалы -->
                        <ComboBox ItemsSource="{Binding MaterialCategoryFilterOptions}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedMaterialCategoryId}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160" Margin="0,0,10,0"
                                  Visibility="{Binding ActiveTab, Converter={StaticResource EqToVis}, ConverterParameter=Materials}"/>
                        <!-- Категория: оборудование -->
                        <ComboBox ItemsSource="{Binding EquipmentCategoryFilterOptions}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedEquipmentCategoryId}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160" Margin="0,0,10,0"
                                  Visibility="{Binding ActiveTab, Converter={StaticResource EqToVis}, ConverterParameter=Equipment}"/>
                        <!-- Жизненный цикл -->
                        <ComboBox ItemsSource="{Binding LifecycleFilterOptions}"
                                  SelectedItem="{Binding LifecycleFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160" Margin="0,0,10,0"/>
                        <!-- Остаток (материалы) -->
                        <ComboBox ItemsSource="{Binding MaterialStockFilterOptions}"
                                  SelectedItem="{Binding MaterialStockFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="180"
                                  Visibility="{Binding ActiveTab, Converter={StaticResource EqToVis}, ConverterParameter=Materials}"/>
                        <!-- Статус (оборудование) -->
                        <ComboBox ItemsSource="{Binding EquipmentStatusFilterOptions}"
                                  SelectedItem="{Binding EquipmentStatusFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="180"
                                  Visibility="{Binding ActiveTab, Converter={StaticResource EqToVis}, ConverterParameter=Equipment}"/>
                    </StackPanel>
                </controls:SearchFilterBarControl.Filters>
            </controls:SearchFilterBarControl>
        </Grid>
    </Grid>
</UserControl>
