<UserControl x:Class="MPMS.Views.Pages.TasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <!-- Row hover style -->
        <Style x:Key="TaskRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slim progress bar template -->
        <ControlTemplate x:Key="SlimPB" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                <Border x:Name="PART_Track" CornerRadius="3">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="3"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Column header style -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        

        <!-- Kanban card style -->
        <Style x:Key="KanbanCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Задачи" FontSize="24" FontWeight="Bold" Foreground="#172B4D"/>
                    <TextBlock Text="Управление всеми задачами"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- View toggle -->
                    <Border CornerRadius="6" BorderBrush="#DFE1E6"
                            BorderThickness="1" Margin="0,0,10,0" Height="38">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton IsChecked="True" Tag="List"
                                         Click="ViewMode_Click" ToolTip="Список"
                                         Style="{StaticResource ViewToggleButton}">
                                <Image Width="18" Height="18">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source"
                                                    Value="{svgc:SvgImage Source=/icons/list.svg, AppName=MPMS}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                    <Setter Property="Source"
                                                            Value="{svgc:SvgImage Source=/icons/list_white.svg, AppName=MPMS}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </RadioButton>
                            <RadioButton Tag="Kanban"
                                         Click="ViewMode_Click" ToolTip="Канбан"
                                         Style="{StaticResource ViewToggleButton}">
                                <Image Width="18" Height="18">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source"
                                                    Value="{svgc:SvgImage Source=/icons/kanban.svg, AppName=MPMS}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                    <Setter Property="Source"
                                                            Value="{svgc:SvgImage Source=/icons/kanban_white.svg, AppName=MPMS}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </RadioButton>
                        </StackPanel>
                    </Border>
                    <!-- Export button -->
                    <Button Height="38" Padding="14,0" Margin="0,0,8,0"
                            FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="#DFE1E6" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{svgc:SvgImage Source=/icons/download.svg, AppName=MPMS}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Экспорт" FontSize="13" Foreground="#172B4D" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Create task button -->
                    <Button x:Name="CreateTaskBtn" Click="CreateTask_Click" Height="38" Padding="18,0"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                               Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Создать задачу" Foreground="White"
                                                   VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── SCROLLABLE BODY ─────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <!-- Filter bar -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="16,10" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search box (максимальной ширины, как в проектах) -->
                        <Border Grid.Column="0"
                                Background="#F4F5F7" CornerRadius="6"
                                Padding="10,0" Height="36" Margin="0,0,10,0"
                                VerticalAlignment="Center" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="#6B778C"/>
                                <Grid Grid.Column="1">
                                    <TextBlock Text="Поиск по названию задачи или описанию..."
                                               Foreground="#6B778C" FontSize="12"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalAlignment="Center" FontSize="13"
                                             Foreground="#172B4D"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding StatusFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding PriorityOptions}"
                                  SelectedItem="{Binding PriorityFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="3"
                                  ItemsSource="{Binding ProjectFilterOptions}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectedValue="{Binding ProjectFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="180"/>
                    </Grid>
                </Border>

                <!-- LIST VIEW panel -->
                <StackPanel x:Name="ListPanel">
                    <Border Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            ClipToBounds="True">
                        <StackPanel>

                            <!-- Column headers — widths must match data row columns exactly -->
                            <Border Background="#F8F9FA" Padding="0,0,0,0"
                                    BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>    <!-- Name -->
                                        <ColumnDefinition Width="160"/>  <!-- Assignee -->
                                        <ColumnDefinition Width="95"/>   <!-- Priority -->
                                        <ColumnDefinition Width="100"/>  <!-- Due date -->
                                        <ColumnDefinition Width="110"/>  <!-- Status -->
                                        <ColumnDefinition Width="72"/>   <!-- Stages -->
                                        <ColumnDefinition Width="110"/>  <!-- Progress -->
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Название задачи"  Style="{StaticResource ColHeader}"/>
                                    <TextBlock Grid.Column="1" Text="Исполнитель"      Style="{StaticResource ColHeader}"/>
                                    <TextBlock Grid.Column="2" Text="Приоритет"        Style="{StaticResource ColHeader}"/>
                                    <TextBlock Grid.Column="3" Text="Срок"             Style="{StaticResource ColHeader}"/>
                                    <TextBlock Grid.Column="4" Text="Статус"           Style="{StaticResource ColHeader}"/>
                                    <TextBlock Grid.Column="5" Text="Этапы"            Style="{StaticResource ColHeader}"/>
                                    <TextBlock Grid.Column="6" Text="Прогресс"         Style="{StaticResource ColHeader}"/>
                                </Grid>
                            </Border>

                            <!-- Task rows (grouped by project) -->
                            <ItemsControl ItemsSource="{Binding TaskGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- Project header -->
                                            <Border Background="#F4F5F7" Padding="16,8"
                                                    BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding ProjectName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#6B778C"/>
                                            </Border>
                                            <!-- Tasks in project -->
                                            <ItemsControl ItemsSource="{Binding Tasks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                        <Border Style="{StaticResource TaskRow}"
                                                BorderBrush="#DFE1E6" BorderThickness="0,0,0,1"
                                                MouseLeftButtonDown="Task_Click">
                                            <Grid>
                                                <!-- Priority left border -->
                                                <Border Width="3" HorizontalAlignment="Left"
                                                        Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}"
                                                        VerticalAlignment="Stretch"/>
                                            <Grid Margin="20,10,16,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="95"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Name + description -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                                            Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#172B4D"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <!-- Overdue indicator -->
                                                        <Border CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                                                Background="#FFEBE6" VerticalAlignment="Center"
                                                                Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="Просрочено" FontSize="10"
                                                                       Foreground="#BF2600" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <!-- Deletion mark indicator -->
                                                        <Border CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                                                Background="#FFEBE6" VerticalAlignment="Center"
                                                                Visibility="{Binding IsMarkedForDeletion, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="К удалению" FontSize="10"
                                                                       Foreground="#BF2600" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11" Foreground="#6B778C"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                                </StackPanel>

                                                <!-- Assignee -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                            VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Border Width="26" Height="26" CornerRadius="13"
                                                            Background="#E8E9EC" Margin="0,0,6,0">
                                                        <TextBlock FontSize="9" FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#172B4D"
                                                                   Text="{Binding AssignedUserName}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding AssignedUserName}"
                                                               FontSize="12" Foreground="#172B4D"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="104"/>
                                                </StackPanel>

                                                <!-- Priority badge -->
                                                <Border Grid.Column="2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="4" Padding="8,3"
                                                        BorderThickness="1"
                                                        BorderBrush="{Binding Priority, Converter={StaticResource PriorityToBrush}}">
                                                    <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToString}}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding Priority, Converter={StaticResource PriorityToBrush}}"/>
                                                </Border>

                                                <!-- Due date -->
                                                <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}"
                                                           Width="14" Height="14" Margin="0,0,4,0"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.5"/>
                                                    <TextBlock Text="{Binding DueDate, Converter={StaticResource DateOnlyToString}}"
                                                               FontSize="12" Foreground="#172B4D"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Status badge -->
                                                <Border Grid.Column="4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="4" Padding="8,4"
                                                        Background="{Binding Status, Converter={StaticResource TaskStatusToBrush}}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusToString}}"
                                                               Foreground="White"
                                                               FontSize="11" FontWeight="SemiBold"/>
                                                </Border>

                                                <!-- Stage count -->
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding TotalStages, Converter={StaticResource StageCountToString}}"
                                                           FontSize="12" Foreground="#6B778C"
                                                           VerticalAlignment="Center"/>

                                                <!-- Progress -->
                                                <StackPanel Grid.Column="6" VerticalAlignment="Center">
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="6"
                                                                 Background="#E9ECEF"
                                                                 Foreground="#111111"
                                                                 Margin="0,0,0,4"
                                                                 Template="{StaticResource SlimPB}"/>
                                                    <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                                               FontSize="11" Foreground="#6B778C"/>
                                                </StackPanel>
                                            </Grid>
                                            </Grid>
                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40"
                                        Visibility="{Binding TaskGroups.Count, Converter={StaticResource IntToVisInv}}">
                                <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                                       Width="48" Height="48" HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="Задачи не найдены" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                                <TextBlock Text="Создайте первую задачу или измените фильтры"
                                           FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- KANBAN VIEW panel -->
                <Grid x:Name="KanbanPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Planned column -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            AllowDrop="True" Tag="Planned"
                            DragEnter="KanbanColumn_DragEnter"
                            DragLeave="KanbanColumn_DragLeave"
                            Drop="KanbanColumn_Drop">
                        <StackPanel>
                            <Border Background="#F4F5F7" Padding="14,10" CornerRadius="8,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#6B778C" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Запланировано" FontSize="12" FontWeight="SemiBold" Foreground="#6B778C"/>
                                    <Border CornerRadius="10" Background="#E0E0E0" Padding="6,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding PlannedTasks.Count}" FontSize="11" Foreground="#6B778C"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="10,10">
                                <ItemsControl ItemsSource="{Binding PlannedTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KanbanCard}"
                                                    MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                    MouseMove="KanbanCard_MouseMove"
                                                    PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#172B4D" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                               Foreground="#6B778C" Margin="0,4,0,0"/>
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="4" Margin="0,8,0,0"
                                                                 Background="#E0E0E0" Foreground="#111111"
                                                                 Template="{StaticResource SlimPB}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- In Progress column -->
                    <Border Grid.Column="2" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            AllowDrop="True" Tag="InProgress"
                            DragEnter="KanbanColumn_DragEnter"
                            DragLeave="KanbanColumn_DragLeave"
                            Drop="KanbanColumn_Drop">
                        <StackPanel>
                            <Border Background="#FFF8E1" Padding="14,10" CornerRadius="8,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#FF8B00" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Выполняется" FontSize="12" FontWeight="SemiBold" Foreground="#856404"/>
                                    <Border CornerRadius="10" Background="#FFD54F" Padding="6,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding InProgressTasks.Count}" FontSize="11" Foreground="#856404"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="10,10">
                                <ItemsControl ItemsSource="{Binding InProgressTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KanbanCard}"
                                                    MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                    MouseMove="KanbanCard_MouseMove"
                                                    PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#172B4D" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                               Foreground="#6B778C" Margin="0,4,0,0"/>
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="4" Margin="0,8,0,0"
                                                                 Background="#E0E0E0" Foreground="#111111"
                                                                 Template="{StaticResource SlimPB}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Paused column -->
                    <Border Grid.Column="4" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            AllowDrop="True" Tag="Paused"
                            DragEnter="KanbanColumn_DragEnter"
                            DragLeave="KanbanColumn_DragLeave"
                            Drop="KanbanColumn_Drop">
                        <StackPanel>
                            <Border Background="#F3E5F5" Padding="14,10" CornerRadius="8,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#9C27B0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Приостановлено" FontSize="12" FontWeight="SemiBold" Foreground="#6A1B9A"/>
                                    <Border CornerRadius="10" Background="#CE93D8" Padding="6,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding PausedTasks.Count}" FontSize="11" Foreground="#6A1B9A"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="10,10">
                                <ItemsControl ItemsSource="{Binding PausedTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KanbanCard}"
                                                    MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                    MouseMove="KanbanCard_MouseMove"
                                                    PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#172B4D" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                               Foreground="#6B778C" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Completed column -->
                    <Border Grid.Column="6" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            AllowDrop="True" Tag="Completed"
                            DragEnter="KanbanColumn_DragEnter"
                            DragLeave="KanbanColumn_DragLeave"
                            Drop="KanbanColumn_Drop">
                        <StackPanel>
                            <Border Background="#E8F5E9" Padding="14,10" CornerRadius="8,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#00875A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Завершено" FontSize="12" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                    <Border CornerRadius="10" Background="#A5D6A7" Padding="6,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding CompletedTasks.Count}" FontSize="11" Foreground="#1B5E20"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="10,10">
                                <ItemsControl ItemsSource="{Binding CompletedTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KanbanCard}"
                                                    MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                    MouseMove="KanbanCard_MouseMove"
                                                    PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#172B4D" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                               Foreground="#6B778C" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
