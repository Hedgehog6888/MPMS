<UserControl x:Class="MPMS.Views.Pages.TasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <!-- Row hover style -->
        <Style x:Key="TaskRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slim progress bar template -->
        <ControlTemplate x:Key="SlimPB" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                <Border x:Name="PART_Track" CornerRadius="3">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="3"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Column header style -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Задачи" FontSize="24" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock Text="Управление всеми задачами"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Export button -->
                    <Button Height="38" Padding="14,0" Margin="0,0,8,0"
                            FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="#DFE1E6" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{svgc:SvgImage Source=/icons/download.svg, AppName=MPMS}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Экспорт" FontSize="13" Foreground="#000000" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Create task button -->
                    <Button x:Name="CreateTaskBtn" Click="CreateTask_Click" Height="38" Padding="18,0"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                               Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Создать задачу" Foreground="White"
                                                   VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY: скролл справа у края, но контент/плашка с отступом справа -->
        <Grid Grid.Row="1" Margin="24,12,0,24" ClipToBounds="True">
            <ScrollViewer x:Name="MainListScroll"
                          VerticalScrollBarVisibility="Visible"
                          Padding="0,62,24,0"
                          Background="Transparent"
                          Panel.ZIndex="0">
                <StackPanel>

                            <!-- Task rows (grouped by project) -->
                            <ItemsControl ItemsSource="{Binding TaskGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- Подпись проекта -->
                                            <Grid Margin="0,10,0,6" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*" MinWidth="0"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="3" CornerRadius="1.5" Background="#0C66E4"
                                                        VerticalAlignment="Center" Margin="0,0,10,0" Height="14"/>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="10"
                                                           Foreground="#97A0AF" FontWeight="SemiBold" Margin="0,0,6,0"
                                                           Text="Проект"/>
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="#000000"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding ProjectName, Mode=OneWay}"/>
                                            </Grid>
                                            <!-- Заголовки колонок под этим проектом -->
                                            <Border Background="Transparent" Padding="15,8,15,8" Margin="0,0,0,4" Opacity="0.7"
                                                    BorderThickness="1.5" BorderBrush="Transparent">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="3*"/>
                                                        <ColumnDefinition Width="2*" MinWidth="170"/>
                                                        <ColumnDefinition Width="95"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="72"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="90"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="НАЗВАНИЕ"     Style="{StaticResource ColHeader}"/>
                                                    <TextBlock Grid.Column="1" Text="ИСПОЛНИТЕЛЬ"  Style="{StaticResource ColHeader}"/>
                                                    <TextBlock Grid.Column="2" Text="ПРИОРИТЕТ"    Style="{StaticResource ColHeader}"/>
                                                    <TextBlock Grid.Column="3" Text="СРОК"         Style="{StaticResource ColHeader}"/>
                                                    <TextBlock Grid.Column="4" Text="СТАТУС"       Style="{StaticResource ColHeader}"/>
                                                    <TextBlock Grid.Column="5" Text="ЭТАПЫ"        Style="{StaticResource ColHeader}"/>
                                                    <TextBlock Grid.Column="6" Text="ПРОГРЕСС"     Style="{StaticResource ColHeader}"/>
                                                    <TextBlock Grid.Column="7" Text="ДЕЙСТВИЯ"     Style="{StaticResource ColHeader}"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                            <!-- Tasks in project -->
                                            <ItemsControl ItemsSource="{Binding Tasks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                        <Border CornerRadius="8" Margin="0,0,0,6"
                                                Padding="15,10" BorderThickness="1.5"
                                                Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#DFE1E6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#DE350B"/>
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#000000"/>
                                                        </Trigger>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0" To="1" Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="2*" MinWidth="170"/>
                                                    <ColumnDefinition Width="95"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Name + description -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                                            Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#000000"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <!-- Overdue indicator -->
                                                        <Border CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                                                Background="#FFEBE6" VerticalAlignment="Center"
                                                                Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="Просрочено" FontSize="10"
                                                                       Foreground="#BF2600" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11" Foreground="#6B778C"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                                    <TextBlock Text="{Binding TaskInheritedDeletionHint}"
                                                               FontSize="10" Foreground="#B71C1C" Margin="0,4,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding TaskInheritedDeletionHint, Converter={StaticResource StringToVis}}"/>
                                                </StackPanel>

                                                <!-- Assignee -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                            VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Border Style="{StaticResource AvatarCircle26}"
                                                            Background="#000000" Margin="0,0,6,0">
                                                        <Grid>
                                                            <Image Style="{StaticResource AvatarImage}"
                                                                   Source="{Binding AssignedUserAvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                   Width="26" Height="26"
                                                                   Visibility="{Binding AssignedUserAvatarData, Converter={StaticResource NullToVis}}"/>
                                                            <TextBlock Text="{Binding AssignedUserInitials}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Visibility="{Binding AssignedUserAvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding AssignedUserName}"
                                                               FontSize="12" Foreground="#000000"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Priority badge -->
                                                <Border Grid.Column="2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="4" Padding="8,3"
                                                        BorderThickness="1"
                                                        BorderBrush="{Binding Priority, Converter={StaticResource PriorityToBrush}}">
                                                    <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToString}}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding Priority, Converter={StaticResource PriorityToBrush}}"/>
                                                </Border>

                                                <!-- Due date -->
                                                <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}"
                                                           Width="14" Height="14" Margin="0,0,4,0"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.5"/>
                                                    <TextBlock Text="{Binding DueDate, Converter={StaticResource DateOnlyToString}}"
                                                               FontSize="12" Foreground="#000000"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Status badge -->
                                                <Border Grid.Column="4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="4" Padding="8,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{Binding Status, Converter={StaticResource TaskStatusToBrush}}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                    <Setter Property="Background" Value="#DE350B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Foreground="White"
                                                               FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Status, Converter={StaticResource TaskStatusToString}}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Text" Value="Пометка удаления"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Stage count -->
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding TotalStages, Converter={StaticResource StageCountToString}}"
                                                           FontSize="12" Foreground="#6B778C"
                                                           VerticalAlignment="Center"/>

                                                <!-- Progress -->
                                                <StackPanel Grid.Column="6" VerticalAlignment="Center">
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="6"
                                                                 Background="#E9ECEF"
                                                                 Foreground="{Binding ProgressPercent, Converter={StaticResource ProgressPercentToBrush}}"
                                                                 Margin="0,0,0,4"
                                                                 Template="{StaticResource SlimPB}"/>
                                                    <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                                               FontSize="11" Foreground="#6B778C"/>
                                                </StackPanel>

                                                <!-- Action buttons -->
                                                <StackPanel Grid.Column="7" Orientation="Horizontal"
                                                            VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <!-- Edit (Foreman+, hidden when marked) -->
                                                    <Button ToolTip="Редактировать"
                                                            Tag="{Binding}" Click="EditTask_Click"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                               Width="14" Height="14" VerticalAlignment="Center"/>
                                                    </Button>
                                                    <!-- Mark for deletion (Manager+) -->
                                                    <Button Tag="{Binding}" Click="MarkTask_Click"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Project Manager,Administrator'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanToggleTaskDeletionMark}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Button.ToolTip>
                                                            <ToolTip>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Пометить к удалению"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </ToolTip>
                                                        </Button.ToolTip>
                                                        <Grid>
                                                            <Image Source="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"
                                                                   Width="14" Height="14" VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                            <Image Source="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"
                                                                   Width="14" Height="14" VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                        </Grid>
                                                    </Button>
                                                    <!-- Delete (Manager+) -->
                                                    <Button ToolTip="Удалить задачу"
                                                            Tag="{Binding}" Click="DeleteTask_Click"
                                                            Style="{StaticResource DangerIconButton}"
                                                            Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Project Manager,Administrator'}">
                                                        <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                               Width="14" Height="14" VerticalAlignment="Center"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40"
                                        Visibility="{Binding TaskGroups.Count, Converter={StaticResource IntToVisInv}}">
                                <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                                       Width="48" Height="48" HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="Задачи не найдены" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                                <TextBlock Text="Создайте первую задачу или измените фильтры"
                                           FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center"/>
                            </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <Border VerticalAlignment="Top" Panel.ZIndex="1"
                    HorizontalAlignment="Left"
                    Width="{Binding ElementName=MainListScroll, Path=ViewportWidth}"
                    Background="White" CornerRadius="8"
                    BorderBrush="#DFE1E6" BorderThickness="1"
                    Padding="16,10,16,14"
                    PreviewMouseWheel="FilterBar_PreviewMouseWheel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.14" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#F4F5F7" CornerRadius="6"
                            Padding="10,0" Height="36" Margin="0,0,10,0"
                            BorderThickness="1.5" BorderBrush="Transparent"
                            VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="#6B778C"/>
                            <Grid Grid.Column="1" Margin="0,0,4,0">
                                <TextBlock Text="Поиск по названию задачи или описанию..."
                                           Foreground="#6B778C" FontSize="12"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" FontSize="13"
                                         Foreground="#000000"
                                         SelectionBrush="{StaticResource NeutralSelectionBrush}"
                                         SelectionTextBrush="#000000"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"/>
                            </Grid>
                            <Button Grid.Column="2" Click="ClearSearch_Click"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVis}}"
                                    Width="20" Height="20" Margin="0,0,0,0"
                                    Style="{StaticResource IconButton}">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#6B778C"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding StatusFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding PriorityOptions}"
                              SelectedItem="{Binding PriorityFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding ProjectFilterOptions}"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectedValue="{Binding ProjectFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="180"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
