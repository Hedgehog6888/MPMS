<UserControl x:Class="MPMS.Views.Pages.ProjectDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <!-- Breadcrumb -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Проекты" Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12" Cursor="Hand"
                                   MouseLeftButtonDown="Back_Click"/>
                        <TextBlock Text=" / " FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Project.Name}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Project.Name}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,12,0"/>
                        <Border CornerRadius="12" Padding="10,4" VerticalAlignment="Center"
                                Background="{Binding Project.Status, Converter={StaticResource ProjectStatusToBrush}}">
                            <TextBlock Text="{Binding Project.Status, Converter={StaticResource ProjectStatusToString}}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="＋  Создать задачу"
                        Style="{StaticResource PrimaryButton}"
                        Click="CreateTask_Click"
                        Height="36" FontSize="13"
                        x:Name="CreateTaskBtn"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="24,0">
                <RadioButton Content="Общая информация" Tag="Info"
                             Style="{StaticResource TabButton}"
                             Click="Tab_Click"/>
                <RadioButton Content="Задачи" Tag="Tasks" IsChecked="True"
                             Style="{StaticResource TabButton}"
                             Click="Tab_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Info Tab -->
            <ScrollViewer x:Name="InfoPanel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel Margin="24,16">
                    <!-- Stats Cards -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,8,0"
                                Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalTasks}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Всего задач" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="0,0,8,0"
                                Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding InProgressTasksCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="В работе" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="White" CornerRadius="8" Margin="0,0,8,0"
                                Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding CompletedTasksCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Завершено" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="White" CornerRadius="8"
                                Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding OverdueTasksCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Просрочено" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Project Details -->
                    <Border Background="White" CornerRadius="8" Padding="20"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Описание" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Project.Description}"
                                               TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Заказчик" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Project.Client}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Адрес объекта" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Project.Address}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="24,0,0,0">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Менеджер" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Project.ManagerName}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Дата начала" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Project.StartDate, Converter={StaticResource DateOnlyToString}}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Срок завершения" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Project.EndDate, Converter={StaticResource DateOnlyToString}}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Tasks Tab -->
            <Grid x:Name="TasksPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- View toggle -->
                <Border Grid.Row="0" Background="White" Padding="24,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="📋 Список" Tag="List" IsChecked="True"
                                     Style="{StaticResource TabButton}" Click="TaskView_Click"/>
                        <RadioButton Content="📊 Канбан" Tag="Kanban"
                                     Style="{StaticResource TabButton}" Click="TaskView_Click"/>
                    </StackPanel>
                </Border>

                <!-- Task List View -->
                <ScrollViewer Grid.Row="1" x:Name="TaskListPanel"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tasks}" Margin="24,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                        Padding="14,10"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding AssignedUserName}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" CornerRadius="10" Padding="8,3"
                                                VerticalAlignment="Center" HorizontalAlignment="Left"
                                                Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}">
                                            <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToString}}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>

                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   Text="{Binding DueDate, Converter={StaticResource DateOnlyToString}}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <Border Grid.Column="3" CornerRadius="10" Padding="8,3"
                                                VerticalAlignment="Center" HorizontalAlignment="Left"
                                                Background="{Binding Status, Converter={StaticResource TaskStatusToBrush}}">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusToString}}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>

                                        <!-- Progress -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2"/>
                                            <ProgressBar Value="{Binding ProgressPercent}"
                                                         Maximum="100" Height="4"
                                                         Background="#E0E0E0"
                                                         Foreground="{StaticResource SuccessBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Button Content="✏" ToolTip="Редактировать"
                                                    Tag="{Binding}" Click="EditTask_Click"
                                                    Margin="0,0,4,0"
                                                    Style="{StaticResource IconButton}"/>
                                            <Button Content="🗑" ToolTip="Удалить"
                                                    Tag="{Binding}" Click="DeleteTask_Click"
                                                    Style="{StaticResource DangerIconButton}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Kanban View -->
                <ScrollViewer Grid.Row="1" x:Name="TaskKanbanPanel"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="24,16" VerticalAlignment="Top">
                        <!-- Column template repeated for each status -->
                        <Border x:Name="PlannedCol" Width="280" Margin="0,0,12,0">
                            <Border.Resources>
                                <SolidColorBrush x:Key="ColHeaderBrush" Color="#6B778C"/>
                            </Border.Resources>
                            <StackPanel>
                                <Border Background="#6B778C" CornerRadius="6,6,0,0" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Запланирована" Foreground="White"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                        <Border Background="#FFFFFF33" CornerRadius="10"
                                                Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding PlannedTasks.Count}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F4F5F7" CornerRadius="0,0,6,6" Padding="8" MinHeight="200">
                                    <ItemsControl ItemsSource="{Binding PlannedTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        Margin="0,0,0,6" Padding="10,8"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <Border CornerRadius="8" Padding="6,2"
                                                                    Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}">
                                                                <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToString}}"
                                                                           Foreground="White" FontSize="10"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                                    Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}">
                                                            <TextBlock Text="👤 " FontSize="11"/>
                                                            <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Width="280" Margin="0,0,12,0">
                            <StackPanel>
                                <Border Background="#0082FF" CornerRadius="6,6,0,0" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Выполняется" Foreground="White"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                        <Border Background="#FFFFFF33" CornerRadius="10"
                                                Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding InProgressTasks.Count}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F4F5F7" CornerRadius="0,0,6,6" Padding="8" MinHeight="200">
                                    <ItemsControl ItemsSource="{Binding InProgressTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        Margin="0,0,0,6" Padding="10,8"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <ProgressBar Value="{Binding ProgressPercent}"
                                                                     Maximum="100" Height="4" Margin="0,6,0,0"
                                                                     Background="#E0E0E0"
                                                                     Foreground="{StaticResource SuccessBrush}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                                    Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}">
                                                            <TextBlock Text="👤 " FontSize="11"/>
                                                            <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Width="280" Margin="0,0,12,0">
                            <StackPanel>
                                <Border Background="#FF8B00" CornerRadius="6,6,0,0" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Приостановлена" Foreground="White"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                        <Border Background="#FFFFFF33" CornerRadius="10"
                                                Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding PausedTasks.Count}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F4F5F7" CornerRadius="0,0,6,6" Padding="8" MinHeight="200">
                                    <ItemsControl ItemsSource="{Binding PausedTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        Margin="0,0,0,6" Padding="10,8"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Width="280">
                            <StackPanel>
                                <Border Background="#00875A" CornerRadius="6,6,0,0" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Завершена" Foreground="White"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                        <Border Background="#FFFFFF33" CornerRadius="10"
                                                Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding CompletedTasks.Count}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F4F5F7" CornerRadius="0,0,6,6" Padding="8" MinHeight="200">
                                    <ItemsControl ItemsSource="{Binding CompletedTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        Margin="0,0,0,6" Padding="10,8"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"
                                                               Opacity="0.7"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
