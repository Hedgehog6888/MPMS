<UserControl x:Class="MPMS.Views.Pages.ProjectDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MPMS.Controls"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <!-- Breadcrumb -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Image Source="{svgc:SvgImage Source=/icons/pathHouse.svg, AppName=MPMS}"
                               Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7"/>
                        <TextBlock Text="›" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="Проекты" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12" Cursor="Hand"
                                   MouseLeftButtonDown="Back_Click"/>
                        <TextBlock Text=" › " FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Project.Name}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Project.Name}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,12,0"/>
                        <Border CornerRadius="12" Padding="10,4" VerticalAlignment="Center"
                                Background="{Binding Project.Status, Converter={StaticResource ProjectStatusToBrush}}">
                            <TextBlock Text="{Binding Project.Status, Converter={StaticResource ProjectStatusToString}}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Edit button -->
                    <Button x:Name="EditProjectBtn" Click="EditProject_Click"
                            Height="36" Padding="14,0" Margin="0,0,8,0" FontSize="13">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Content>Редактировать</Button.Content>
                    </Button>
                    <!-- Create task button -->
                    <Button Click="CreateTask_Click"
                            Height="36" Padding="14,0" FontSize="13"
                            x:Name="CreateTaskBtn">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Black" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                               Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.9"/>
                                        <TextBlock Text="Создать задачу" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Create stage button (same style as task) -->
                    <Button Click="AddProjectStage_Click"
                            Height="36" Padding="14,0" FontSize="13"
                            x:Name="CreateStageBtn" Margin="8,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Black" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                               Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.9"/>
                                        <TextBlock Text="Создать этап" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,8">
            <Border Background="#F4F5F7" CornerRadius="10" Padding="3"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Общая информация" Tag="Info" IsChecked="True"
                                 Style="{StaticResource TabButton}"
                                 Click="Tab_Click"/>
                    <RadioButton Content="Задачи" Tag="Tasks"
                                 Style="{StaticResource TabButton}"
                                 Click="Tab_Click"/>
                    <RadioButton Content="Этапы" Tag="Stages"
                                 Style="{StaticResource TabButton}"
                                 Click="Tab_Click"/>
                    <RadioButton Content="Обсуждение" Tag="Discussion"
                                 Style="{StaticResource TabButton}"
                                 Click="Tab_Click"/>
                    <RadioButton Content="Файлы" Tag="Files"
                                 Style="{StaticResource TabButton}"
                                 Click="Tab_Click"/>
                    <RadioButton Content="Материалы" Tag="Materials"
                                 Style="{StaticResource TabButton}"
                                 Click="Tab_Click"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="2">

            <!-- ═══ INFO TAB ═══ -->
            <ScrollViewer x:Name="InfoPanel" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Project info card -->
                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Информация о проекте" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <!-- Client -->
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Top" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Заказчик" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Project.Client}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Address -->
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/location.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Top" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Адрес объекта" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Project.Address}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Period -->
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Top" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Период выполнения" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Project.StartDate, Converter={StaticResource DateOnlyToString}}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text=" — " FontSize="14"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Project.EndDate, Converter={StaticResource DateOnlyToString}}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Manager -->
                                <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Ответственный менеджер" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" CornerRadius="14"
                                                    Background="#172B4D" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Project.ManagerInitials}"
                                                           Foreground="White" FontSize="10" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Project.ManagerName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Executors (project members) -->
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Исполнители" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Members}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Border Width="28" Height="28" CornerRadius="14"
                                                            Background="#172B4D" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Initials}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   ToolTip="{Binding UserName}"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding UserName}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding UserRole}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Исполнители назначаются на задачи проекта"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding Members.Count, Converter={StaticResource IntToVisInv}}"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,16"/>

                                <!-- Progress bar -->
                                <TextBlock Text="Общий прогресс" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <ProgressBar Value="{Binding ProjectProgressPercent, Mode=OneWay}"
                                             Maximum="100" Height="10" Margin="0,0,0,8"
                                             Background="#E9ECEF" Foreground="Black">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <Border x:Name="PART_Track" CornerRadius="5">
                                                    <Border x:Name="PART_Indicator"
                                                            Background="{TemplateBinding Foreground}"
                                                            HorizontalAlignment="Left" CornerRadius="5"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                                <TextBlock Text="{Binding ProjectProgressPercent, StringFormat='{}{0}%'}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Right: Donut chart stats + quick actions -->
                        <StackPanel Grid.Column="2">

                            <!-- Task statistics card with donut chart -->
                            <Border Background="White" CornerRadius="8" Padding="20"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Статистика задач" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#172B4D" Margin="0,0,0,4"/>
                                    <TextBlock Text="Распределение задач по статусам"
                                               FontSize="12" Foreground="#6B778C" Margin="0,0,0,16"/>

                                    <!-- Donut chart -->
                                    <controls:DonutChart
                                        Segments="{Binding TaskStatsSegments}"
                                        Width="160" Height="160"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,16"/>

                                    <!-- Legend -->
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#EAB308" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="В процессе" FontSize="12" Foreground="#6B778C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Завершено" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#3B82F6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Запланировано" FontSize="12" Foreground="#6B778C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Просрочено" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Summary row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="8" Padding="12,10">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding TotalTasks}" FontSize="28" FontWeight="Bold"
                                                           Foreground="#172B4D" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Всего задач" FontSize="11" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="8" Padding="12,10">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding CompletedTasksCount}" FontSize="28" FontWeight="Bold"
                                                           Foreground="#22C55E" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Завершено" FontSize="11" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Quick actions -->
                            <Border Background="White" CornerRadius="8" Padding="16"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Быстрые действия" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="CreateTaskQuickBtn" Click="CreateTask_Click"
                                                Height="34" Padding="12,0" Margin="0,0,8,0" FontSize="13">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Black" CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.9"/>
                                                            <TextBlock Text="Добавить задачу" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Click="UploadFile_Click"
                                                Height="34" Padding="12,0" FontSize="13">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="White" CornerRadius="6"
                                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                            Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Source="{svgc:SvgImage Source=/icons/upload.svg, AppName=MPMS}"
                                                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Загрузить файл" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Project description -->
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,16,0,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Visibility="{Binding Project.Description, Converter={StaticResource StringToVis}}">
                        <StackPanel>
                            <TextBlock Text="Описание" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Project.Description}"
                                       TextWrapping="Wrap" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ TASKS TAB ═══ -->
            <Grid x:Name="TasksPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- View toggle -->
                <Border Grid.Row="0" Background="White" Padding="24,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Список" Tag="List" IsChecked="True"
                                     Style="{StaticResource TabButton}" Click="TaskView_Click"/>
                        <RadioButton Content="Kanban" Tag="Kanban"
                                     Style="{StaticResource TabButton}" Click="TaskView_Click"/>
                    </StackPanel>
                </Border>

                <!-- Tasks content with common filter bar for list & kanban -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filter bar (similar to TasksPage) -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            Padding="16,10" Margin="24,8,24,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search -->
                            <Border Grid.Column="0"
                                    Background="#F4F5F7" CornerRadius="6"
                                    Padding="10,0" Height="36" Margin="0,0,10,0"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="#6B778C"/>
                                    <Grid Grid.Column="1">
                                        <TextBlock Text="Поиск по названию задачи или описанию..."
                                                   Foreground="#6B778C" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TaskSearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding TaskSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="13"
                                                 Foreground="#172B4D"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Status filter -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TaskStatusOptions}"
                                      SelectedItem="{Binding TaskStatusFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="160" Margin="0,0,10,0"/>

                            <!-- Priority filter -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding TaskPriorityOptions}"
                                      SelectedItem="{Binding TaskPriorityFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="160"/>
                        </Grid>
                    </Border>

                    <!-- Task List View -->
                    <ScrollViewer Grid.Row="1" x:Name="TaskListPanel"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,0,24,16">
                            <!-- Column headers (inside Border to match item row padding) -->
                            <Border Background="Transparent" Padding="14,10" Margin="0,0,0,4" Opacity="0.7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="НАЗВАНИЕ" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="ПРИОРИТЕТ" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="СРОК" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="СТАТУС" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="4" Text="ПРОГРЕСС" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding FilteredTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                                Padding="14,10"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                        </Trigger>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0" To="1" Duration="0:0:0.25"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding AssignedUserName}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                </StackPanel>

                                                <Border Grid.Column="1" CornerRadius="4" Padding="8,3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left"
                                                        Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}">
                                                    <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToString}}"
                                                               Foreground="White" FontSize="11"/>
                                                </Border>

                                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                           Text="{Binding DueDate, Converter={StaticResource DateOnlyToString}}"
                                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>

                                                <Border Grid.Column="3" CornerRadius="4" Padding="8,3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left"
                                                        Background="{Binding Status, Converter={StaticResource TaskStatusToBrush}}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusToString}}"
                                                               Foreground="White" FontSize="11"/>
                                                </Border>

                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                                               FontSize="11" HorizontalAlignment="Right"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,0,0,2"/>
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="4"
                                                                 Background="#E0E0E0"
                                                                 Foreground="#111111">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                                    <Border x:Name="PART_Track" CornerRadius="2">
                                                                        <Border x:Name="PART_Indicator"
                                                                                Background="{TemplateBinding Foreground}"
                                                                                HorizontalAlignment="Left" CornerRadius="2"/>
                                                                    </Border>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>

                                                <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                            VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <!-- Deletion mark indicator -->
                                                    <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                            Background="#FFEBE6" VerticalAlignment="Center"
                                                            Visibility="{Binding IsMarkedForDeletion, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="К удалению" FontSize="10"
                                                                   Foreground="#BF2600" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Button ToolTip="Редактировать"
                                                            Tag="{Binding}" Click="EditTask_Click"
                                                            Margin="0,0,4,0"
                                                            Style="{StaticResource IconButton}"
                                                            Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Admin,Administrator,Manager,ProjectManager,Project Manager,Foreman'}">
                                                        <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                               Width="14" Height="14"
                                                               VerticalAlignment="Center"
                                                               Opacity="0.85"/>
                                                    </Button>
                                                    <!-- Mark for deletion (Foreman) -->
                                                    <Button ToolTip="Пометить для удаления"
                                                            Tag="{Binding}" Click="MarkTaskForDeletion_Click"
                                                            Margin="0,0,4,0"
                                                            Style="{StaticResource IconButton}"
                                                            Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman'}">
                                                        <TextBlock Text="🗑" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                   Opacity="0.6"/>
                                                    </Button>
                                                    <!-- Delete (Admin/Manager) -->
                                                    <Button ToolTip="Удалить"
                                                            Tag="{Binding}" Click="DeleteTask_Click"
                                                            Style="{StaticResource DangerIconButton}"
                                                            Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Admin,Administrator,Manager,ProjectManager,Project Manager'}">
                                                        <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                               Width="14" Height="14"
                                                               VerticalAlignment="Center"
                                                               Opacity="0.9"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Kanban View -->
                    <ScrollViewer Grid.Row="1" x:Name="TaskKanbanPanel"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <Grid Margin="24,16,24,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Planned column -->
                        <Border Grid.Column="0" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="True" Tag="Planned"
                                DragEnter="KanbanColumn_DragEnter"
                                DragLeave="KanbanColumn_DragLeave"
                                Drop="KanbanColumn_Drop">
                            <StackPanel>
                                <Border Background="#F4F5F7" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#6B778C"
                                                Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Запланировано" FontSize="12" FontWeight="SemiBold" Foreground="#6B778C"/>
                                        <Border CornerRadius="10" Background="#E0E0E0" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding FilteredPlannedTasks.Count}" FontSize="11" Foreground="#6B778C"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <StackPanel x:Name="PlannedColumn" Margin="8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredPlannedTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        BorderBrush="#DFE1E6" BorderThickness="1"
                                                        Padding="12,10" Margin="0,0,0,8"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                        MouseMove="KanbanCard_MouseMove"
                                                        PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F8F9FA"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#172B4D" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                                   Foreground="#6B778C" Margin="0,4,0,0"
                                                                   Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                        <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                     Maximum="100" Height="4" Margin="0,8,0,0"
                                                                     Background="#E0E0E0" Foreground="#111111">
                                                            <ProgressBar.Template>
                                                                <ControlTemplate TargetType="ProgressBar">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                                        <Border x:Name="PART_Track" CornerRadius="2">
                                                                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                                                                    HorizontalAlignment="Left" CornerRadius="2"/>
                                                                        </Border>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ProgressBar.Template>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- In Progress column -->
                        <Border Grid.Column="2" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="True" Tag="InProgress"
                                DragEnter="KanbanColumn_DragEnter"
                                DragLeave="KanbanColumn_DragLeave"
                                Drop="KanbanColumn_Drop">
                            <StackPanel>
                                <Border Background="#FFF8E1" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#FF8B00"
                                                Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Выполняется" FontSize="12" FontWeight="SemiBold" Foreground="#856404"/>
                                        <Border CornerRadius="10" Background="#FFD54F" Padding="6,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding FilteredInProgressTasks.Count}" FontSize="11" Foreground="#856404"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <StackPanel Margin="8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredInProgressTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        BorderBrush="#DFE1E6" BorderThickness="1"
                                                        Padding="12,10" Margin="0,0,0,8"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                        MouseMove="KanbanCard_MouseMove"
                                                        PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F8F9FA"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#172B4D" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                                   Foreground="#6B778C" Margin="0,4,0,0"
                                                                   Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                        <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                     Maximum="100" Height="4" Margin="0,8,0,0"
                                                                     Background="#E0E0E0" Foreground="#111111">
                                                            <ProgressBar.Template>
                                                                <ControlTemplate TargetType="ProgressBar">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                                        <Border x:Name="PART_Track" CornerRadius="2">
                                                                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                                                                    HorizontalAlignment="Left" CornerRadius="2"/>
                                                                        </Border>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ProgressBar.Template>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Paused column -->
                        <Border Grid.Column="4" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="True" Tag="Paused"
                                DragEnter="KanbanColumn_DragEnter"
                                DragLeave="KanbanColumn_DragLeave"
                                Drop="KanbanColumn_Drop">
                            <StackPanel>
                                <Border Background="#F3E5F5" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#9C27B0"
                                                Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Приостановлено" FontSize="12" FontWeight="SemiBold" Foreground="#6A1B9A"/>
                                        <Border CornerRadius="10" Background="#CE93D8" Padding="6,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding FilteredPausedTasks.Count}" FontSize="11" Foreground="#6A1B9A"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <StackPanel Margin="8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredPausedTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        BorderBrush="#DFE1E6" BorderThickness="1"
                                                        Padding="12,10" Margin="0,0,0,8"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                        MouseMove="KanbanCard_MouseMove"
                                                        PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F8F9FA"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#172B4D" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                                   Foreground="#6B778C" Margin="0,4,0,0"
                                                                   Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Completed column -->
                        <Border Grid.Column="6" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="True" Tag="Completed"
                                DragEnter="KanbanColumn_DragEnter"
                                DragLeave="KanbanColumn_DragLeave"
                                Drop="KanbanColumn_Drop">
                            <StackPanel>
                                <Border Background="#E8F5E9" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#00875A"
                                                Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Завершено" FontSize="12" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        <Border CornerRadius="10" Background="#A5D6A7" Padding="6,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding FilteredCompletedTasks.Count}" FontSize="11" Foreground="#1B5E20"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <StackPanel Margin="8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredCompletedTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" CornerRadius="6"
                                                        BorderBrush="#DFE1E6" BorderThickness="1"
                                                        Padding="12,10" Margin="0,0,0,8"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="KanbanCard_MouseLeftButtonDown"
                                                        MouseMove="KanbanCard_MouseMove"
                                                        PreviewMouseLeftButtonUp="KanbanCard_MouseUp">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F8F9FA"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#172B4D" TextWrapping="Wrap" Opacity="0.75"/>
                                                        <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                                   Foreground="#6B778C" Margin="0,4,0,0"
                                                                   Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ═══ STAGES TAB ═══ -->
            <Grid x:Name="StagesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,16">

                    <!-- Search + Filters bar for stages (similar to StagesPage) -->
                    <Border Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            Padding="16,10" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search -->
                            <Border Grid.Column="0" Background="#F4F5F7" CornerRadius="6"
                                    Padding="10,0" Height="36" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Center"
                                               Margin="0,0,8,0" Foreground="#6B778C"/>
                                    <Grid Grid.Column="1">
                                        <TextBlock Text="Поиск по этапу или задаче..."
                                                   Foreground="#6B778C" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StageSearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding StageSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="13"
                                                 Foreground="#172B4D"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Task filter inside project -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding StageTaskFilterOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding StageTaskFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="220" Margin="0,0,12,0"/>

                            <!-- Status filter -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding StageStatusOptions}"
                                      SelectedItem="{Binding StageStatusFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="160"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding FilteredStages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,8"
                                        Padding="16,14"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="2"
                                                Background="{Binding Status, Converter={StaticResource StageStatusToBrush}}"
                                                Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <!-- Deletion mark badge -->
                                                <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                        Background="#FFEBE6" VerticalAlignment="Center"
                                                        Visibility="{Binding IsMarkedForDeletion, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="К удалению" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#BF2600"/>
                                                </Border>
                                            </StackPanel>
                                            <!-- Task name -->
                                            <TextBlock Text="{Binding TaskName}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding TaskName, Converter={StaticResource StringToVis}}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                                       Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Border CornerRadius="10" Padding="8,3"
                                                        Background="{Binding Status, Converter={StaticResource StageStatusToBrush}}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StageStatusToString}}"
                                                               Foreground="White" FontSize="11"/>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center"
                                                            Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}">
                                                    <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}"
                                                           Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center" Opacity="0.6"/>
                                                    <TextBlock Text="{Binding AssignedUserName}" FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding FilteredStages.Count, Converter={StaticResource IntToVisInv}}"
                                HorizontalAlignment="Center" Margin="0,40,0,0">
                        <Image Source="{svgc:SvgImage Source=/icons/stages.svg, AppName=MPMS}"
                               Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.4"/>
                        <TextBlock Text="Этапы не найдены" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Создайте задачи и добавьте к ним этапы" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ DISCUSSION TAB ═══ -->
            <Grid x:Name="DiscussionPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" x:Name="ProjectMessagesScrollViewer"
                              VerticalScrollBarVisibility="Auto" Margin="24,16,24,8">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Avatar -->
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                Margin="0,0,10,0" VerticalAlignment="Top"
                                                Background="{Binding UserColor, Converter={StaticResource HexToBrush}}">
                                            <TextBlock Text="{Binding UserInitials}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <!-- Name + role + time -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding UserName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                        Background="{Binding UserColor, Converter={StaticResource HexToBrush}}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding UserRole}"
                                                               FontSize="11" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </StackPanel>
                                            <!-- Message bubble -->
                                            <Border Background="#F4F5F7" CornerRadius="0,8,8,8"
                                                    Padding="12,8" MaxWidth="480" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <StackPanel Visibility="{Binding Messages.Count, Converter={StaticResource IntToVisInv}}"
                                    HorizontalAlignment="Center" Margin="0,60,0,0">
                            <TextBlock Text="💬" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="Нет сообщений" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Начните обсуждение проекта" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                <!-- Message input -->
                <Border Grid.Row="1" Background="White" Padding="24,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F4F5F7" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1" Margin="0,0,10,0">
                            <TextBox x:Name="ProjectMessageInput"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="12,8" MinHeight="36"
                                     FontSize="13" Foreground="#172B4D"
                                     VerticalContentAlignment="Center"
                                     AcceptsReturn="False"
                                     KeyDown="ProjectMessageInput_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Background="Transparent"
                                                                  Foreground="{TemplateBinding Foreground}"
                                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                        <Button Grid.Column="1" Click="SendProjectMessage_Click"
                                Height="36" Padding="16,0" FontSize="13">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="Отправить" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#1558A8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ FILES TAB ═══ -->
            <Grid x:Name="FilesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="White" Padding="24,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Button Click="UploadFile_Click" Height="34" Padding="14,0" FontSize="13">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{svgc:SvgImage Source=/icons/upload.svg, AppName=MPMS}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Загрузить файлы" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,16">
                        <ItemsControl ItemsSource="{Binding Files}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                            Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                    Background="{StaticResource BackgroundBrush}" Margin="0,0,12,0">
                                                <Image Source="{svgc:SvgImage Source=/icons/file.svg, AppName=MPMS}"
                                                       Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding UploadedByName}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <StackPanel Visibility="{Binding Files.Count, Converter={StaticResource IntToVisInv}}"
                                    HorizontalAlignment="Center" Margin="0,60,0,0">
                            <Border Width="80" Height="80" CornerRadius="40"
                                    Background="{StaticResource BackgroundBrush}"
                                    HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Image Source="{svgc:SvgImage Source=/icons/files.svg, AppName=MPMS}"
                                       Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
                            </Border>
                            <TextBlock Text="Файлы ещё не загружены" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <Button Content="Загрузить файлы" Click="UploadFile_Click"
                                    Height="36" Padding="20,0" HorizontalAlignment="Center"
                                    Style="{StaticResource PrimaryButton}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ MATERIALS TAB ═══ -->
            <ScrollViewer x:Name="MaterialsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,16">
                    <TextBlock Text="Материалы использованные в этапах проекта"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,12"/>
                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                        <Image Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}"
                               Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.4"/>
                        <TextBlock Text="Материалы не найдены" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Добавьте материалы к этапам задач проекта" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
