<UserControl x:Class="MPMS.Views.Pages.ProjectDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MPMS.Controls"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <DataTemplate x:Key="StageKanbanCardTemplate">
            <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,6" BorderThickness="1.5">
                <Border.ToolTip>
                    <ToolTip Background="Transparent" BorderThickness="0" Padding="0" HasDropShadow="False"
                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" MaxWidth="300">
                            <StackPanel>
                                <TextBlock Text="КАРТОЧКА ЭТАПА" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Stage.Name}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                <Border Height="1" Background="#EBECF0" Margin="0,10,0,10"/>
                                <TextBlock Text="ЗАДАЧА" FontSize="10" FontWeight="SemiBold" Foreground="#8993A4"/>
                                <TextBlock Text="{Binding TaskName}" FontSize="12" Foreground="#000000"
                                           TextWrapping="Wrap" Margin="0,2,0,8"/>
                                <TextBlock Text="СТАТУС" FontSize="10" FontWeight="SemiBold" Foreground="#8993A4"/>
                                <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,2,0,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{Binding Stage.Status, Converter={StaticResource StageStatusToBrush}}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                                    <Setter Property="Background" Value="#DE350B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Stage.Status, Converter={StaticResource StageStatusToString}}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                                        <Setter Property="Text" Value="Пометка удаления"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="ОПИСАНИЕ" FontSize="10" FontWeight="SemiBold" Foreground="#8993A4"
                                           Visibility="{Binding Stage.Description, Converter={StaticResource StringToVis}}"/>
                                <TextBlock Text="{Binding Stage.Description}" FontSize="12" Foreground="#000000"
                                           TextWrapping="Wrap" Margin="0,2,0,8"
                                           Visibility="{Binding Stage.Description, Converter={StaticResource StringToVis}}"/>
                                <TextBlock Text="ИСПОЛНИТЕЛЬ" FontSize="10" FontWeight="SemiBold" Foreground="#8993A4"
                                           Visibility="{Binding Stage.AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                <TextBlock Text="{Binding Stage.AssignedUserName}" FontSize="12" Foreground="#000000"
                                           TextWrapping="Wrap" Margin="0,2,0,8"
                                           Visibility="{Binding Stage.AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                <TextBlock Text="{Binding Stage.StageInheritedDeletionHint}" FontSize="11"
                                           Foreground="#B71C1C" TextWrapping="Wrap" Margin="0,0,0,8"
                                           Visibility="{Binding Stage.StageInheritedDeletionHint, Converter={StaticResource StringToVis}}"/>
                                <Border Height="1" Background="#EBECF0" Margin="0,0,0,8"/>
                                <TextBlock Text="ВРЕМЕННЫЕ МЕТКИ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Stage.CreatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat=Создан: {0:dd.MM.yyyy HH\:mm}}"
                                           FontSize="11" Foreground="#6B778C"/>
                                <TextBlock Text="{Binding Stage.UpdatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat=Последнее обновление: {0:dd.MM.yyyy HH\:mm}}"
                                           FontSize="11" Foreground="#6B778C" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </ToolTip>
                </Border.ToolTip>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderBrush" Value="#DFE1E6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <EventSetter Event="MouseLeftButtonDown" Handler="StageKanbanCard_MouseLeftButtonDown"/>
                        <EventSetter Event="MouseMove" Handler="StageKanbanCard_MouseMove"/>
                        <EventSetter Event="PreviewMouseLeftButtonUp" Handler="StageKanbanCard_MouseUp"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                <Setter Property="BorderBrush" Value="#DE350B"/>
                                <Setter Property="Background" Value="#FFF5F5"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#000000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Заголовок: название | статус | drag -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Stage.Name}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border Grid.Column="1" CornerRadius="4" Padding="6,3" Margin="0,0,4,0"
                                VerticalAlignment="Top" MaxWidth="104">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{Binding Stage.Status, Converter={StaticResource StageStatusToBrush}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                            <Setter Property="Background" Value="#DE350B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"
                                       TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Stage.Status, Converter={StaticResource StageStatusToString}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                                <Setter Property="Text" Value="К удалению"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Image Grid.Column="2" Width="16" Height="16" VerticalAlignment="Top"
                               Source="{svgc:SvgImage Source=/icons/dragAndDrop.svg, AppName=MPMS}"
                               Opacity="0.55" IsHitTestVisible="False">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanDragInKanban}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                    <!-- Описание: до ~2 строк, полный текст в подсказке -->
                    <TextBlock Grid.Row="1" Text="{Binding Stage.Description}" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               LineHeight="14" MaxHeight="28" TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,4"
                               Visibility="{Binding Stage.Description, Converter={StaticResource StringToVis}}"/>
                    <!-- Задача и относительное время изменения -->
                    <Grid Grid.Row="2" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Image Source="{svgc:SvgImage Source=/icons/tasks.svg, AppName=MPMS}"
                                   Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.55"/>
                            <TextBlock Text="{Binding TaskName}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontSize="9" Foreground="#97A0AF" VerticalAlignment="Center"
                                   Margin="6,0,0,0" MaxWidth="92" TextTrimming="CharacterEllipsis"
                                   TextAlignment="Right"
                                   Text="{Binding Stage.UpdatedAt, Converter={StaticResource DateTimeToRelative}}">
                            <TextBlock.ToolTip>
                                <ToolTip Background="Transparent" BorderThickness="0" Padding="0" HasDropShadow="False"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="10,8" MaxWidth="260">
                                        <StackPanel>
                                            <TextBlock Text="Последнее обновление" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#8993A4" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Stage.UpdatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat=dd.MM.yyyy HH\:mm}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </Grid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,4"
                                Visibility="{Binding Stage.AssignedUserName, Converter={StaticResource StringToVis}}">
                        <Border Style="{StaticResource AvatarCircle20}" Background="#000000" Margin="0,0,5,0">
                            <Grid>
                                <Image Style="{StaticResource AvatarImage}"
                                       Source="{Binding Stage.AssignedUserAvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                       Width="20" Height="20"
                                       Visibility="{Binding Stage.AssignedUserAvatarData, Converter={StaticResource NullToVis}}"/>
                                <TextBlock Text="{Binding Stage.AssignedUserInitials}" FontSize="8" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding Stage.AssignedUserAvatarData, Converter={StaticResource NullToVisInv}}"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding Stage.AssignedUserName}" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Row="4" Text="{Binding Stage.StageInheritedDeletionHint}" FontSize="9"
                               Foreground="#B71C1C" TextWrapping="Wrap" Margin="0,0,0,2"
                               Visibility="{Binding Stage.StageInheritedDeletionHint, Converter={StaticResource StringToVis}}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Project.Name}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,12,0"/>
                        <Border CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{Binding Project.Status, Converter={StaticResource ProjectStatusToBrush}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Project.IsMarkedForDeletion}" Value="True">
                                            <Setter Property="Background" Value="#DE350B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Project.Status, Converter={StaticResource ProjectStatusToString}}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Project.IsMarkedForDeletion}" Value="True">
                                                <Setter Property="Text" Value="Пометка удаления"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Mark project for deletion (Manager only) -->
                    <Button x:Name="MarkProjectBtn" Click="MarkProject_Click"
                            Height="36" Padding="14,0" Margin="0,0,8,0" FontSize="13"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="#DE350B" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock x:Name="MarkBtnText" Text="Пометить к удалению"
                                               Foreground="#DE350B" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#FFF5F5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Edit button -->
                    <Button x:Name="EditProjectBtn" Click="EditProject_Click"
                            Height="36" Padding="14,0" Margin="0,0,8,0" FontSize="13">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Content>Редактировать</Button.Content>
                    </Button>
                    <!-- Create task button -->
                    <Button Click="CreateTask_Click"
                            Height="36" Padding="14,0" FontSize="13"
                            x:Name="CreateTaskBtn">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Black" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                               Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.9"/>
                                        <TextBlock Text="Создать задачу" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Create stage button - hidden (stages are added per-task in task detail) -->
                    <Button x:Name="CreateStageBtn" Visibility="Collapsed"
                            Click="AddProjectStage_Click"
                            Height="36" Padding="14,0" FontSize="13" Margin="8,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Black" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                               Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.9"/>
                                        <TextBlock Text="Добавить этап" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <Border Grid.Row="1"
                Background="#F4F5F7"
                Padding="24,4,24,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White"
                        BorderBrush="#DFE1E6"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="6,4"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Общая информация" Tag="Info" IsChecked="True"
                                     Style="{StaticResource TabButton}"
                                     Click="Tab_Click"/>
                        <RadioButton Content="Задачи" Tag="Tasks"
                                     Style="{StaticResource TabButton}"
                                     Click="Tab_Click"/>
                        <RadioButton Content="Этапы" Tag="Stages"
                                     Style="{StaticResource TabButton}"
                                     Click="Tab_Click"/>
                        <RadioButton Content="Обсуждение" Tag="Discussion"
                                     Style="{StaticResource TabButton}"
                                     Click="Tab_Click"/>
                        <RadioButton Content="Файлы" Tag="Files"
                                     Style="{StaticResource TabButton}"
                                     Click="Tab_Click"/>
                        <RadioButton Content="Материалы" Tag="Materials"
                                     Style="{StaticResource TabButton}"
                                     Click="Tab_Click"/>
                    </StackPanel>
                </Border>
                <Border x:Name="StageViewModeSwitcher" Grid.Column="1"
                        Background="White"
                        BorderBrush="#DFE1E6"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="4,4"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="StageViewListRb" Tag="List" GroupName="ProjectStageViewMode"
                                     Style="{StaticResource ViewToggleButton}" IsChecked="True"
                                     ToolTip="Список"
                                     Click="StageView_Click">
                            <Grid Width="20" Height="20">
                                <Image x:Name="StageViewListIconDark" Width="18" Height="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Source="{svgc:SvgImage Source=/icons/list.svg, AppName=MPMS}"
                                       Visibility="Collapsed"/>
                                <Image x:Name="StageViewListIconLight" Width="18" Height="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Source="{svgc:SvgImage Source=/icons/list_white.svg, AppName=MPMS}"/>
                            </Grid>
                        </RadioButton>
                        <RadioButton x:Name="StageViewKanbanRb" Tag="Kanban" GroupName="ProjectStageViewMode"
                                     Style="{StaticResource ViewToggleButton}"
                                     ToolTip="Канбан"
                                     Click="StageView_Click">
                            <Grid Width="20" Height="20">
                                <Image x:Name="StageViewKanbanIconDark" Width="18" Height="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Source="{svgc:SvgImage Source=/icons/kanban.svg, AppName=MPMS}"/>
                                <Image x:Name="StageViewKanbanIconLight" Width="18" Height="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Source="{svgc:SvgImage Source=/icons/kanban_white.svg, AppName=MPMS}"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </RadioButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="2">

            <!-- ═══ INFO TAB ═══ -->
            <ScrollViewer x:Name="InfoPanel" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Project info card -->
                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Информация о проекте" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <!-- Client -->
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Top" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Заказчик" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Project.Client}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Address -->
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/location.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Top" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Адрес объекта" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Project.Address}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Period -->
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Top" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Период выполнения" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Project.StartDate, Converter={StaticResource DateOnlyToString}}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text=" — " FontSize="14"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Project.EndDate, Converter={StaticResource DateOnlyToString}}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Manager -->
                                <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.5"/>
                                    <StackPanel>
                                        <TextBlock Text="Ответственный менеджер" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Style="{StaticResource AvatarCircle28}"
                                                    Background="{Binding Project.ManagerInitials, Converter={StaticResource InitialsToBrush}}"
                                                    Margin="0,0,8,0">
                                                <Grid>
                                                    <Image Style="{StaticResource AvatarImage}"
                                                           Source="{Binding Project.ManagerAvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                           Width="28" Height="28"
                                                           Visibility="{Binding Project.ManagerAvatarData, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Text="{Binding Project.ManagerInitials}"
                                                               Foreground="White" FontSize="10" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="{Binding Project.ManagerAvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Project.ManagerName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Foreman section -->
                                <StackPanel Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="4" Height="14" CornerRadius="2" Background="#000000" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="ПРОРАБ" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding ForemanMembers}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,6">
                                                                    <Button Style="{StaticResource PeekRowButton}" Margin="0"
                                                                            Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVis}}"
                                                                            Click="ProjectMemberPeek_Click">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Border Style="{StaticResource AvatarCircle32}"
                                                                                    Background="{Binding Initials, Converter={StaticResource InitialsToBrush}}"
                                                                                    Margin="0,0,10,0">
                                                                                <Grid>
                                                                                    <Image Style="{StaticResource AvatarImage}"
                                                                                           Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                                           Width="32" Height="32"
                                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                                    <TextBlock Text="{Binding Initials}"
                                                                                               FontSize="10" FontWeight="Bold"
                                                                                               Foreground="White"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"
                                                                                               ToolTip="{Binding UserName}"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <StackPanel VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding UserName}"
                                                                                           FontSize="13" FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <StackPanel Orientation="Horizontal"
                                                                                Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVisInv}}">
                                                                        <Border Style="{StaticResource AvatarCircle32}"
                                                                                Background="{Binding Initials, Converter={StaticResource InitialsToBrush}}"
                                                                                Margin="0,0,10,0">
                                                                            <Grid>
                                                                                <Image Style="{StaticResource AvatarImage}"
                                                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                                       Width="32" Height="32"
                                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                                <TextBlock Text="{Binding Initials}"
                                                                                           FontSize="10" FontWeight="Bold"
                                                                                           Foreground="White"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"
                                                                                           ToolTip="{Binding UserName}"/>
                                                                            </Grid>
                                                                        </Border>
                                                                        <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding UserName}"
                                                                                       FontSize="13" FontWeight="SemiBold"
                                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                    <TextBlock Text="Прораб не назначен" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic"
                                               Visibility="{Binding ForemanMembers.Count, Converter={StaticResource IntToVisInv}}"/>

                                </StackPanel>

                                <!-- Workers section -->
                                <StackPanel Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="4" Height="14" CornerRadius="2" Background="#000000" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="РАБОТНИКИ" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding WorkerMembers}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,6">
                                                                    <Button Style="{StaticResource PeekRowButton}" Margin="0"
                                                                            Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVis}}"
                                                                            Click="ProjectMemberPeek_Click">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Border Style="{StaticResource AvatarCircle32}"
                                                                                    Background="{Binding Initials, Converter={StaticResource InitialsToBrush}}"
                                                                                    Margin="0,0,10,0">
                                                                                <Grid>
                                                                                    <Image Style="{StaticResource AvatarImage}"
                                                                                           Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                                           Width="32" Height="32"
                                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                                    <TextBlock Text="{Binding Initials}"
                                                                                               FontSize="10" FontWeight="Bold"
                                                                                               Foreground="White"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"
                                                                                               ToolTip="{Binding UserName}"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <StackPanel VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding UserName}"
                                                                                           FontSize="13" FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                                <TextBlock Text="{Binding RoleLabel}" FontSize="11"
                                                                                           Foreground="{Binding WorkerLineForegroundHex, Converter={StaticResource HexToBrush}}"
                                                                                           Margin="0,2,0,0">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding RoleLabel}" Value="">
                                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <StackPanel Orientation="Horizontal"
                                                                                Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVisInv}}">
                                                                        <Border Style="{StaticResource AvatarCircle32}"
                                                                                Background="{Binding Initials, Converter={StaticResource InitialsToBrush}}"
                                                                                Margin="0,0,10,0">
                                                                            <Grid>
                                                                                <Image Style="{StaticResource AvatarImage}"
                                                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                                       Width="32" Height="32"
                                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                                <TextBlock Text="{Binding Initials}"
                                                                                           FontSize="10" FontWeight="Bold"
                                                                                           Foreground="White"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"
                                                                                           ToolTip="{Binding UserName}"/>
                                                                            </Grid>
                                                                        </Border>
                                                                        <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding UserName}"
                                                                                       FontSize="13" FontWeight="SemiBold"
                                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                            <TextBlock Text="{Binding RoleLabel}" FontSize="11"
                                                                                       Foreground="{Binding WorkerLineForegroundHex, Converter={StaticResource HexToBrush}}"
                                                                                       Margin="0,2,0,0">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding RoleLabel}" Value="">
                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                    <TextBlock Text="Работники назначаются через задачи проекта"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               FontStyle="Italic" Margin="0,4,0,0"
                                               Visibility="{Binding WorkerMembers.Count, Converter={StaticResource IntToVisInv}}"/>

                                </StackPanel>

                                <!-- Separator -->
                                <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,16"/>

                                <!-- Progress bar -->
                                <TextBlock Text="Общий прогресс" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <ProgressBar Value="{Binding ProjectProgressPercent, Mode=OneWay}"
                                             Maximum="100" Height="10" Margin="0,0,0,8"
                                             Background="#E9ECEF"
                                             Foreground="{Binding ProjectProgressPercent, Converter={StaticResource ProgressPercentToBrush}}">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <Border x:Name="PART_Track" CornerRadius="5">
                                                    <Border x:Name="PART_Indicator"
                                                            Background="{TemplateBinding Foreground}"
                                                            HorizontalAlignment="Left" CornerRadius="5"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                                <TextBlock Text="{Binding ProjectProgressPercent, StringFormat='{}{0}%'}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Right: Donut chart stats + quick actions -->
                        <StackPanel Grid.Column="2">

                            <!-- Task statistics card with donut chart -->
                            <Border Background="White" CornerRadius="8" Padding="20"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Статистика" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#000000" Margin="0,0,0,4"/>
                                    <TextBlock Text="Распределение по статусам"
                                               FontSize="12" Foreground="#6B778C" Margin="0,0,0,16"/>

                                    <!-- Donut charts -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Задачи" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#000000" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <controls:DonutChart
                                                Segments="{Binding TaskStatsSegments}"
                                                Width="140" Height="140"
                                                HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Этапы" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#000000" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <controls:DonutChart
                                                Segments="{Binding StageStatsSegments}"
                                                Width="140" Height="140"
                                                HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Legend -->
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#EAB308" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="В процессе" FontSize="12" Foreground="#6B778C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Завершено" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#3B82F6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Запланировано" FontSize="12" Foreground="#6B778C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <Border Width="10" Height="10" CornerRadius="2" Background="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Просрочено" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Summary blocks -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <Border Background="#F8F9FA" CornerRadius="8" Padding="12,10">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding TotalTasks}" FontSize="28" FontWeight="Bold"
                                                               Foreground="#000000" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Всего задачь" FontSize="11" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#E8F5E9" CornerRadius="8" Padding="12,10" Margin="0,8,0,0">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding CompletedTasksCount}" FontSize="28" FontWeight="Bold"
                                                               Foreground="#22C55E" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Завершено задачь" FontSize="11" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <Border Background="#F8F9FA" CornerRadius="8" Padding="12,10">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding TotalStagesCount}" FontSize="28" FontWeight="Bold"
                                                               Foreground="#000000" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Всего этапов" FontSize="11" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#E8F5E9" CornerRadius="8" Padding="12,10" Margin="0,8,0,0">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding CompletedStagesCount}" FontSize="28" FontWeight="Bold"
                                                               Foreground="#22C55E" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Завершено этапов" FontSize="11" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </Border>

                            <!-- Quick actions -->
                            <Border Background="White" CornerRadius="8" Padding="16"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Быстрые действия" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                    <WrapPanel>
                                        <Button x:Name="CreateTaskQuickBtn" Click="CreateTask_Click"
                                                Height="34" Padding="12,0" Margin="0,0,8,0" FontSize="13">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Black" CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.9"/>
                                                            <TextBlock Text="Добавить задачу" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="QuickTeamBtn" Click="OpenQuickTeamOverlay_Click"
                                                Height="34" Padding="12,0" Margin="0,0,8,0" FontSize="13">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="White" CornerRadius="6"
                                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                            Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Source="{svgc:SvgImage Source=/icons/plus_team_black.svg, AppName=MPMS}"
                                                                   Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Обновить состав" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Click="UploadFile_Click"
                                                Height="34" Padding="12,0" FontSize="13">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="White" CornerRadius="6"
                                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                            Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Source="{svgc:SvgImage Source=/icons/upload.svg, AppName=MPMS}"
                                                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Загрузить файл" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Project description -->
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,16,0,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Visibility="{Binding Project.Description, Converter={StaticResource StringToVis}}">
                        <StackPanel>
                            <TextBlock Text="Описание" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Project.Description}"
                                       TextWrapping="Wrap" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ TASKS TAB ═══ -->
            <Grid x:Name="TasksPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter bar (similar to TasksPage) -->
                <Border Grid.Row="0" Panel.ZIndex="1" Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="16,10" Margin="24,8,32.5,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search -->
                            <Border Grid.Column="0"
                                    Background="#F4F5F7" CornerRadius="6"
                                    Padding="10,0" Height="36" Margin="0,0,10,0"
                                    BorderThickness="1.5" BorderBrush="Transparent"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="#6B778C"/>
                                    <Grid Grid.Column="1" Margin="0,0,4,0">
                                        <TextBlock Text="Поиск по названию задачи или описанию..."
                                                   Foreground="#6B778C" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TaskSearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding TaskSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="13"
                                                 Foreground="#000000"
                                                 SelectionBrush="{StaticResource NeutralSelectionBrush}"
                                                 SelectionTextBrush="#000000"
                                                 GotFocus="LocalSearch_GotFocus"
                                                 LostFocus="LocalSearch_LostFocus"/>
                                    </Grid>
                                    <Button Grid.Column="2" Click="ClearTaskSearch_Click"
                                            Visibility="{Binding TaskSearchText, Converter={StaticResource StringToVis}}"
                                            Width="20" Height="20" Margin="0,0,0,0"
                                            Style="{StaticResource IconButton}">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="#6B778C"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Status filter -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TaskStatusOptions}"
                                      SelectedItem="{Binding TaskStatusFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="160" Margin="0,0,10,0"/>

                            <!-- Priority filter -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding TaskPriorityOptions}"
                                      SelectedItem="{Binding TaskPriorityFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="160"/>
                        </Grid>
                </Border>

                <Grid Grid.Row="0" Grid.RowSpan="2">
                    <!-- Task List View -->
                    <ScrollViewer x:Name="TaskListPanel"
                                  VerticalScrollBarVisibility="Visible"
                                  Padding="24,68,24,16"
                                  Panel.ZIndex="0">
                        <StackPanel>
                            <!-- Column headers - BorderThickness matches item rows to ensure alignment -->
                            <Border Background="Transparent" Padding="15,8,15,8" Margin="0,0,0,2" Opacity="0.7"
                                    BorderThickness="1.5" BorderBrush="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="НАЗВАНИЕ" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="ПРИОРИТЕТ" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="СРОК" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="СТАТУС" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="4" Text="ПРОГРЕСС" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="5" Text="ДЕЙСТВИЯ" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding FilteredTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Margin="0,0,0,6"
                                                Padding="15,10"
                                                BorderThickness="1.5"
                                                Cursor="Hand" MouseLeftButtonDown="Task_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#DE350B"/>
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#000000"/>
                                                        </Trigger>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0" To="1" Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding AssignedUserName}"
                                                               FontSize="11" Margin="0,2,0,0"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                    <TextBlock Text="{Binding TaskInheritedDeletionHint}" FontSize="10"
                                                               Foreground="#B71C1C" Margin="0,4,0,0" TextWrapping="Wrap"
                                                               Visibility="{Binding TaskInheritedDeletionHint, Converter={StaticResource StringToVis}}"/>
                                                </StackPanel>

                                                <Border Grid.Column="1" CornerRadius="4" Padding="8,3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left"
                                                        Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}">
                                                    <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToString}}"
                                                               Foreground="White" FontSize="11"/>
                                                </Border>

                                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                           Text="{Binding DueDate, Converter={StaticResource DateOnlyToString}}"
                                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>

                                                <Border Grid.Column="3" CornerRadius="4" Padding="8,3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{Binding Status, Converter={StaticResource TaskStatusToBrush}}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                    <Setter Property="Background" Value="#DE350B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Status, Converter={StaticResource TaskStatusToString}}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Text" Value="Пометка удаления"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                                               FontSize="11" HorizontalAlignment="Right"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,0,0,2"/>
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="4"
                                                                 Background="#E0E0E0"
                                                                 Foreground="{Binding ProgressPercent, Converter={StaticResource ProgressPercentToBrush}}">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                                    <Border x:Name="PART_Track" CornerRadius="2">
                                                                        <Border x:Name="PART_Indicator"
                                                                                Background="{TemplateBinding Foreground}"
                                                                                HorizontalAlignment="Left" CornerRadius="2"/>
                                                                    </Border>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>

                                                <!-- Action buttons -->
                                                <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                            VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <!-- Edit (Foreman+, hidden when marked) -->
                                                    <Button ToolTip="Редактировать"
                                                            Tag="{Binding}" Click="EditTask_Click"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                               Width="14" Height="14"
                                                               VerticalAlignment="Center"/>
                                                    </Button>
                                                    <!-- Mark for deletion / unmark (Foreman, Manager) — скрыто при пометке проекта -->
                                                    <Button Tag="{Binding}" Click="MarkTaskForDeletion_Click"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanToggleTaskDeletionMark}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Button.ToolTip>
                                                            <ToolTip>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Пометить к удалению"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </ToolTip>
                                                        </Button.ToolTip>
                                                        <Grid>
                                                            <Image Source="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"
                                                                   Width="14" Height="14" VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                            <Image Source="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"
                                                                   Width="14" Height="14" VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                        </Grid>
                                                    </Button>
                                                    <!-- Delete (Admin/Manager) -->
                                                    <Button ToolTip="Удалить задачу"
                                                            Tag="{Binding}" Click="DeleteTask_Click"
                                                            Style="{StaticResource DangerIconButton}"
                                                            Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Project Manager,Administrator'}">
                                                        <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                               Width="14" Height="14"
                                                               VerticalAlignment="Center"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ═══ STAGES TAB ═══ -->
            <Grid x:Name="StagesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search + Filters bar for stages (similar to StagesPage) -->
                <Border Grid.Row="0" Panel.ZIndex="1" Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="16,10" Margin="24,8,32.5,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search -->
                            <Border Grid.Column="0" Background="#F4F5F7" CornerRadius="6"
                                    Padding="10,0" Height="36" Margin="0,0,12,0"
                                    BorderThickness="1.5" BorderBrush="Transparent"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Center"
                                               Margin="0,0,8,0" Foreground="#6B778C"/>
                                    <Grid Grid.Column="1" Margin="0,0,4,0">
                                        <TextBlock Text="Поиск по этапу или задаче..."
                                                   Foreground="#6B778C" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StageSearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding StageSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="13"
                                                 Foreground="#000000"
                                                 SelectionBrush="{StaticResource NeutralSelectionBrush}"
                                                 SelectionTextBrush="#000000"
                                                 GotFocus="LocalSearch_GotFocus"
                                                 LostFocus="LocalSearch_LostFocus"/>
                                    </Grid>
                                    <Button Grid.Column="2" Click="ClearStageSearch_Click"
                                            Visibility="{Binding StageSearchText, Converter={StaticResource StringToVis}}"
                                            Width="20" Height="20" Margin="0,0,0,0"
                                            Style="{StaticResource IconButton}">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="#6B778C"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Task filter inside project -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding StageTaskFilterOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding StageTaskFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="220" Margin="0,0,12,0"/>

                            <!-- Status filter -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding StageStatusOptions}"
                                      SelectedItem="{Binding StageStatusFilter}"
                                      Style="{StaticResource FormCombo}"
                                      Width="160"/>
                        </Grid>
                </Border>

                <Grid Grid.Row="0" Grid.RowSpan="2">
                    <ScrollViewer x:Name="StageListHost" VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="24,68,24,16"
                                  Panel.ZIndex="0">
                    <StackPanel x:Name="StageListPanel">
                    <!-- Column headers -->
                    <Border Background="Transparent" Padding="15,8,15,8" Margin="0,0,0,2" Opacity="0.7"
                            BorderThickness="1.5" BorderBrush="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="НАЗВАНИЕ" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="СМЕНА СТАТУСА" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,24,0"/>
                            <TextBlock Grid.Column="2" Text="ЗАДАЧА" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="СТАТУС" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="ДЕЙСТВИЯ" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding FilteredStages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Margin="0,0,0,6"
                                        Padding="15,10"
                                        BorderThickness="1.5"
                                        Cursor="Hand" MouseLeftButtonDown="Stage_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EffectiveMarkedForDeletion}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#DE350B"/>
                                                    <Setter Property="Background" Value="#FFF5F5"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#000000"/>
                                                </Trigger>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0" To="1" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Name + description -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                            <TextBlock Text="{Binding AssignedUserName}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                            <TextBlock Text="{Binding StageInheritedDeletionHint}" FontSize="10"
                                                       Foreground="#B71C1C" Margin="0,4,0,0" TextWrapping="Wrap"
                                                       Visibility="{Binding StageInheritedDeletionHint, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>

                                        <!-- Status buttons (left of task, with margin) -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="0,0,24,0">
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding EffectiveMarkedForDeletion, Converter={StaticResource BoolToVisInv}}">
                                                <Button Tag="{Binding}"
                                                        Click="StartStageFromProject_Click" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButton}" FontSize="12"
                                                        Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Planned}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{svgc:SvgImage Source=/icons/play.svg, AppName=MPMS}"
                                                               Width="12" Height="12" Margin="0,0,4,0"
                                                               VerticalAlignment="Center" Opacity="0.8"/>
                                                        <TextBlock Text="Начать" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Tag="{Binding}"
                                                        Click="CompleteStageFromProject_Click" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButton}" FontSize="12"
                                                        Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                                                               Width="10" Height="10" Margin="0,0,4,0"
                                                               VerticalAlignment="Center" Opacity="0.9"/>
                                                        <TextBlock Text="Завершить" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Tag="{Binding}"
                                                        Click="RevertStageFromProject_Click" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButton}" FontSize="12"
                                                        ToolTip="Вернуть в запланированные"
                                                        Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}">
                                                    <TextBlock Text="Отменить" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Button>
                                                <Button Tag="{Binding}"
                                                        Click="ReopenStageFromProject_Click" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButton}" FontSize="12"
                                                        ToolTip="Открыть снова"
                                                        Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Completed}">
                                                    <TextBlock Text="Переоткрыть" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Task name -->
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   Text="{Binding TaskName}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Status badge (rectangle: Запланирован, Выполняется, Завершён) -->
                                        <Border Grid.Column="3" CornerRadius="4" Padding="10,5"
                                                VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StageStatusToBrush}}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EffectiveMarkedForDeletion}" Value="True">
                                                            <Setter Property="Background" Value="#DE350B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Status, Converter={StaticResource StageStatusToString}}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EffectiveMarkedForDeletion}" Value="True">
                                                                <Setter Property="Text" Value="Пометка удаления"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                    VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <!-- Edit stage (Foreman+, hidden when marked) -->
                                            <Button ToolTip="Редактировать"
                                                    Tag="{Binding}" Click="EditStageFromProject_Click"
                                                    Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                        <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EffectiveMarkedForDeletion}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                       Width="14" Height="14" VerticalAlignment="Center"/>
                                            </Button>
                                            <!-- Mark/unmark for deletion (Worker+) — скрыто, если пометка с задачи/проекта -->
                                            <Button Tag="{Binding}" Click="MarkStageForDeletion_Click"
                                                    Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                        <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Worker,Foreman,Project Manager,Administrator'}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanToggleStageDeletionMark}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.ToolTip>
                                                    <ToolTip>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Пометить к удалению"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                            <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Button.ToolTip>
                                                <Grid>
                                                    <Image Source="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"
                                                           Width="14" Height="14" VerticalAlignment="Center">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Image Source="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"
                                                           Width="14" Height="14" VerticalAlignment="Center">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Grid>
                                            </Button>
                                            <!-- Delete stage (Foreman+) -->
                                            <Button ToolTip="Удалить этап"
                                                    Tag="{Binding}" Click="DeleteStageFromProject_Click"
                                                    Style="{StaticResource DangerIconButton}"
                                                    Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}">
                                                <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                       Width="14" Height="14" VerticalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding FilteredStages.Count, Converter={StaticResource IntToVisInv}}"
                                HorizontalAlignment="Center" Margin="0,40,0,0">
                        <Image Source="{svgc:SvgImage Source=/icons/stages.svg, AppName=MPMS}"
                               Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.4"/>
                        <TextBlock Text="Этапы не найдены" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Создайте задачи и добавьте к ним этапы" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                    </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="StageKanbanPanel" Visibility="Collapsed" Margin="24,80,24,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Пометка удаления -->
                        <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="False" VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#FFEBEE" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#DE350B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Пометка удаления" FontSize="12" FontWeight="SemiBold" Foreground="#B71C1C"/>
                                        <Border CornerRadius="10" Background="#FFCDD2" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding FilteredMarkedStages.Count}" FontSize="11" Foreground="#B71C1C"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="8,8,8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredMarkedStages}"
                                                  ItemTemplate="{StaticResource StageKanbanCardTemplate}"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="True" Tag="Planned" VerticalAlignment="Stretch"
                                DragEnter="StageKanbanColumn_DragEnter"
                                DragLeave="StageKanbanColumn_DragLeave"
                                Drop="StageKanbanColumn_Drop">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F4F5F7" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#6B778C" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Запланировано" FontSize="12" FontWeight="SemiBold" Foreground="#6B778C"/>
                                        <Border CornerRadius="10" Background="#E0E0E0" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding FilteredPlannedStages.Count}" FontSize="11" Foreground="#6B778C"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="8,8,8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredPlannedStages}"
                                                  ItemTemplate="{StaticResource StageKanbanCardTemplate}"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Column="4" Background="White" CornerRadius="8" BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="True" Tag="InProgress" VerticalAlignment="Stretch"
                                DragEnter="StageKanbanColumn_DragEnter"
                                DragLeave="StageKanbanColumn_DragLeave"
                                Drop="StageKanbanColumn_Drop">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#E3F2FD" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#0082FF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Выполняется" FontSize="12" FontWeight="SemiBold" Foreground="#000000"/>
                                        <Border CornerRadius="10" Background="#BBDEFB" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding FilteredInProgressStages.Count}" FontSize="11" Foreground="#000000"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="8,8,8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredInProgressStages}"
                                                  ItemTemplate="{StaticResource StageKanbanCardTemplate}"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Column="6" Background="White" CornerRadius="8" BorderBrush="#DFE1E6" BorderThickness="1"
                                AllowDrop="True" Tag="Completed" VerticalAlignment="Stretch"
                                DragEnter="StageKanbanColumn_DragEnter"
                                DragLeave="StageKanbanColumn_DragLeave"
                                Drop="StageKanbanColumn_Drop">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#E8F5E9" Padding="14,10" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#00875A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Завершено" FontSize="12" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        <Border CornerRadius="10" Background="#A5D6A7" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding FilteredCompletedStages.Count}" FontSize="11" Foreground="#1B5E20"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="8,8,8,8">
                                    <ItemsControl ItemsSource="{Binding FilteredCompletedStages}"
                                                  ItemTemplate="{StaticResource StageKanbanCardTemplate}"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ═══ DISCUSSION TAB ═══ -->
            <Grid x:Name="DiscussionPanel" Visibility="Collapsed" Margin="24,8,24,16">
                <Border Background="White" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0" x:Name="ProjectMessagesScrollViewer"
                                      VerticalScrollBarVisibility="Auto" Padding="16,14,16,12">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Avatar -->
                                                <Border Grid.Column="0" Style="{StaticResource AvatarCircle36}"
                                                        Margin="0,0,12,0" VerticalAlignment="Top"
                                                        Background="{Binding UserColor, Converter={StaticResource HexToBrush}}">
                                                    <Grid>
                                                        <Image Style="{StaticResource AvatarImage}"
                                                               Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                               Width="36" Height="36"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding UserInitials}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <!-- Name + role + time -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <TextBlock Text="{Binding UserName}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center"
                                                                Background="{Binding UserRole, Converter={StaticResource ActorRoleToBrush}}"
                                                                BorderBrush="{Binding UserRole, Converter={StaticResource ActorRoleToForegroundBrush}}"
                                                                Visibility="{Binding UserRole, Converter={StaticResource ActorRoleBadgeVis}}">
                                                            <TextBlock Text="{Binding UserRole, Converter={StaticResource ActorRoleToLabel}}"
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{Binding UserRole, Converter={StaticResource ActorRoleToForegroundBrush}}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                    </StackPanel>
                                                    <!-- Message bubble -->
                                                    <Border Background="#F4F5F7" CornerRadius="2,10,10,10"
                                                            BorderBrush="#EBECF0" BorderThickness="1"
                                                            Padding="12,10" MaxWidth="520" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Text}"
                                                                   FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextWrapping="Wrap" LineHeight="19"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Empty state -->
                                <StackPanel Visibility="{Binding Messages.Count, Converter={StaticResource IntToVisInv}}"
                                            HorizontalAlignment="Center" Margin="0,36,0,40">
                                    <Border Width="56" Height="56" CornerRadius="28"
                                            Background="{StaticResource BackgroundBrush}"
                                            BorderBrush="#EBECF0" BorderThickness="1"
                                            HorizontalAlignment="Center" Margin="0,0,0,14">
                                        <Image Source="{svgc:SvgImage Source=/icons/chat.svg, AppName=MPMS}"
                                               Width="26" Height="26" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Opacity="0.42"/>
                                    </Border>
                                    <TextBlock Text="Нет сообщений" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Начните обсуждение проекта" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                               Margin="0,6,0,0" TextAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- Message input -->
                        <Border Grid.Row="1" Background="#FAFBFC" Padding="14,12,14,14"
                                BorderBrush="#EBECF0" BorderThickness="0,1,0,0"
                                CornerRadius="0,0,8,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="White" CornerRadius="8"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Margin="0,0,10,0">
                                    <TextBox x:Name="ProjectMessageInput"
                                             Background="Transparent" BorderThickness="0"
                                             Padding="12,9" MinHeight="38"
                                             FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                             VerticalContentAlignment="Center"
                                             CaretBrush="{StaticResource TextPrimaryBrush}"
                                             SelectionBrush="{StaticResource NeutralSelectionBrush}"
                                             SelectionTextBrush="{StaticResource TextPrimaryBrush}"
                                             AcceptsReturn="False"
                                             KeyDown="ProjectMessageInput_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                          Background="Transparent"
                                                                          Foreground="{TemplateBinding Foreground}"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>
                                <Button Grid.Column="1" Click="SendProjectMessage_Click"
                                        Style="{StaticResource BlackBtn}" Height="38" MinWidth="100"
                                        VerticalAlignment="Center" Content="Отправить"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ FILES TAB ═══ -->
            <Grid x:Name="FilesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="Transparent" Padding="24,8"
                        Margin="0,8,0,0">
                    <Button Click="UploadFile_Click" Height="34" Padding="14,0" FontSize="13">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="6"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{svgc:SvgImage Source=/icons/upload.svg, AppName=MPMS}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Загрузить файлы" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,8">
                        <ItemsControl ItemsSource="{Binding Files}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                            Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                    Background="{StaticResource BackgroundBrush}" Margin="0,0,12,0">
                                                <Image Source="{svgc:SvgImage Source=/icons/file.svg, AppName=MPMS}"
                                                       Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding UploadedByName}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <StackPanel Visibility="{Binding Files.Count, Converter={StaticResource IntToVisInv}}"
                                    HorizontalAlignment="Center" Margin="0,60,0,0">
                            <Border Width="80" Height="80" CornerRadius="40"
                                    Background="{StaticResource BackgroundBrush}"
                                    HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Image Source="{svgc:SvgImage Source=/icons/files.svg, AppName=MPMS}"
                                       Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
                            </Border>
                            <TextBlock Text="Файлы ещё не загружены" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <Button Content="Загрузить файлы" Click="UploadFile_Click"
                                    Height="36" Padding="20,0" HorizontalAlignment="Center"
                                    Style="{StaticResource PrimaryButton}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ MATERIALS TAB ═══ -->
            <ScrollViewer x:Name="MaterialsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,8">
                    <TextBlock Text="Материалы использованные в этапах проекта"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,12"/>
                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                        <Image Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}"
                               Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.4"/>
                        <TextBlock Text="Материалы не найдены" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Добавьте материалы к этапам задач проекта" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
