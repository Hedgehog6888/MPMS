<UserControl x:Class="MPMS.Views.Pages.ProjectsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MPMS.ViewModels">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Проекты" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Projects.Count, StringFormat='Всего: {0}'}"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="＋  Создать проект"
                        Style="{StaticResource PrimaryButton}"
                        Click="CreateProject_Click"
                        Height="36" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="White" Padding="24,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <!-- Search -->
                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6"
                        Padding="10,0" Width="280" Height="34" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center"
                                   Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalAlignment="Center" FontSize="13"/>
                    </Grid>
                </Border>
                <!-- Status filter -->
                <TextBlock Text="Статус:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                           Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding StatusFilter}"
                          Width="150" Height="34" FontSize="13"
                          VerticalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Projects List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Projects}" Margin="24,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8" Margin="0,0,0,8"
                                Padding="16,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Name + Client -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Cursor="Hand"
                                               MouseLeftButtonDown="ProjectName_Click"/>
                                    <TextBlock Text="{Binding Client}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Manager -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Менеджер" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding ManagerName}" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- Start Date -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="Начало" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding StartDate, Converter={StaticResource DateOnlyToString}}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- End Date -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="Срок" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding EndDate, Converter={StaticResource DateOnlyToString}}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- Status Badge -->
                                <Border Grid.Column="4" VerticalAlignment="Center"
                                        CornerRadius="12" Padding="10,4"
                                        Background="{Binding Status, Converter={StaticResource ProjectStatusToBrush}}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource ProjectStatusToString}}"
                                               Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>

                                <!-- Actions -->
                                <StackPanel Grid.Column="5" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Button Content="✏" ToolTip="Редактировать"
                                            Tag="{Binding}"
                                            Click="EditProject_Click"
                                            Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Setter Property="FontSize" Value="16"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Padding" Value="4"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="🗑" ToolTip="Удалить"
                                            Tag="{Binding}"
                                            Click="DeleteProject_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Setter Property="FontSize" Value="16"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Padding" Value="4"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
