<UserControl x:Class="MPMS.Views.Pages.ProjectsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <!-- Row hover style -->
        <Style x:Key="ProjectRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slim ProgressBar template -->
        <ControlTemplate x:Key="SlimPB" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                <Border x:Name="PART_Track" CornerRadius="3">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="3"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Column header text style -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Cell text style -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Secondary cell text -->
        <Style x:Key="CellTextSec" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Проекты" FontSize="24" FontWeight="Bold"
                               Foreground="#000000"/>
                    <TextBlock Text="Управление монтажными проектами"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <!-- Create button -->
                <Button x:Name="CreateProjectBtn" Grid.Column="1" Click="CreateProject_Click"
                        Height="38" Padding="18,0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Создать проект" Foreground="White"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── SCROLLABLE BODY ─────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,12,24,24">

                <!-- ACTIVITY FEED ──────────────────────────────────── -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Последние действия"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#000000"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Недавняя активность в системе"
                                   FontSize="12" Foreground="#6B778C" Margin="0,0,0,14"/>

                        <!-- Activity list -->
                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentActivities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="6"
                                            Background="#F8F9FA"
                                            BorderBrush="#EEF0F3" BorderThickness="1">
                                        <Grid>
                                            <!-- Colored left accent based on action type (delete, mark, etc.) or entity type -->
                                            <Border Width="3" HorizontalAlignment="Left" CornerRadius="6,0,0,6"
                                                    Background="{Binding Converter={StaticResource ActivityLogToAccentBrush}}"/>
                                            <Grid Margin="12,8,10,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Avatar: из БД (AvatarData) или инициалы — EllipseGeometry для идеального круга -->
                                                <Border Margin="0,0,10,0" VerticalAlignment="Top">
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource AvatarCircle28}">
                                                            <Setter Property="Background" Value="{Binding UserColor, Converter={StaticResource HexToBrush}}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AvatarData, Converter={StaticResource NullToVis}}" Value="{x:Static Visibility.Visible}">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Image Style="{StaticResource AvatarImage}"
                                                               Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                               Width="28" Height="28"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding UserInitials}"
                                                                   FontSize="10" FontWeight="Bold" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                    </Grid>
                                                </Border>
                                                <!-- Entity badge + role badge + action text -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <Border CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                                Background="{Binding Converter={StaticResource ActivityLogToAccentBrush}}">
                                                            <TextBlock Text="{Binding EntityType, Converter={StaticResource EntityTypeToLabel}}"
                                                                       FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                        <Border CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                                                                Background="{Binding ActorRole, Converter={StaticResource ActorRoleToBrush}}"
                                                                BorderBrush="{Binding ActorRole, Converter={StaticResource ActorRoleToForegroundBrush}}"
                                                                BorderThickness="1"
                                                                Visibility="{Binding ActorRole, Converter={StaticResource StringToVis}}">
                                                            <TextBlock Text="{Binding ActorRole, Converter={StaticResource ActorRoleToLabel}}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{Binding ActorRole, Converter={StaticResource ActorRoleToForegroundBrush}}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding UserName}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#000000" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ActionText}"
                                                               FontSize="12" Foreground="#000000"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <!-- Time -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                           FontSize="11" Foreground="#6B778C"
                                                           VerticalAlignment="Top" Margin="10,2,0,0"
                                                           MinWidth="45"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty activities state -->
                        <TextBlock Text="Действия появятся здесь после первых изменений"
                                   FontSize="12" Foreground="#6B778C" TextAlignment="Center"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding RecentActivities.Count, Converter={StaticResource IntToVisInv}}"/>
                    </StackPanel>
                </Border>

                <!-- SEARCH + FILTER BAR ─────────────────────────────── -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="16,10" Margin="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search box -->
                        <Border Grid.Column="0" Background="#F4F5F7" CornerRadius="6"
                                Padding="10,0" Height="36" Margin="0,0,12,0"
                                BorderThickness="1.5" BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="#6B778C"/>
                                <Grid Grid.Column="1" Margin="0,0,4,0">
                                    <TextBlock Text="Поиск по названию или заказчику..."
                                               Foreground="#6B778C" FontSize="12"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalAlignment="Center" FontSize="13"
                                             Foreground="#000000"
                                             GotFocus="SearchBox_GotFocus"
                                             LostFocus="SearchBox_LostFocus"/>
                                </Grid>
                                <Button Grid.Column="2" Click="ClearSearch_Click"
                                        Visibility="{Binding SearchText, Converter={StaticResource StringToVis}}"
                                        Width="20" Height="20" Margin="0,0,0,0"
                                        Style="{StaticResource IconButton}">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Foreground="#6B778C"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Status filter -->
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding StatusFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160"/>
                    </Grid>
                </Border>

                <!-- PROJECTS TABLE ──────────────────────────────────── -->
                <StackPanel>

                        <!-- Column headers -->
                        <Border Background="Transparent" Padding="15,8,15,8" Margin="0,0,0,4" Opacity="0.7"
                                BorderThickness="1.5" BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*" MinWidth="130" MaxWidth="180"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="НАЗВАНИЕ ПРОЕКТА"   Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="1" Text="ЗАКАЗЧИК"           Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="2" Text="ДАТА НАЧАЛА"        Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="3" Text="ДАТА ЗАВЕРШЕНИЯ"    Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="4" Text="СТАТУС"             Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="5" Text="ПРОГРЕСС"           Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="6" Text="МЕНЕДЖЕР"           Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="7" Text="ДЕЙСТВИЯ"           Style="{StaticResource ColHeader}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Project rows as cards -->
                        <ItemsControl ItemsSource="{Binding Projects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Margin="0,0,0,6"
                                            Padding="15,12" BorderThickness="1.5"
                                            Cursor="Hand" MouseLeftButtonDown="ProjectRow_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#DFE1E6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#DE350B"/>
                                                        <Setter Property="Background" Value="#FFF5F5"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#000000"/>
                                                    </Trigger>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0" To="1" Duration="0:0:0.2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*" MinWidth="130" MaxWidth="180"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>


                                            <!-- Project name -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#000000"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Cursor="Hand"
                                                       Margin="0,0,12,0"
                                                       MouseLeftButtonDown="ProjectName_Click"/>

                                            <!-- Client -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Client}"
                                                       Style="{StaticResource CellText}"
                                                       Margin="0,0,8,0"/>

                                            <!-- Start date -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StartDate, Converter={StaticResource DateOnlyToString}}"
                                                       Style="{StaticResource CellTextSec}"/>

                                            <!-- End date -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding EndDate, Converter={StaticResource DateOnlyToString}}"
                                                       Style="{StaticResource CellTextSec}"/>

                                                            <!-- Status badge (ограничена ширина, чтобы не заслонять Прогресс) -->
                                                            <Border Grid.Column="4"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    CornerRadius="4" Padding="10,5"
                                                                    MaxWidth="115" ClipToBounds="True">
                                                                <Border.ToolTip>
                                                                    <ToolTip>
                                                                        <TextBlock>
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="{Binding Status, Converter={StaticResource ProjectStatusToString}}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                            <Setter Property="Text" Value="Пометка удаления"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </ToolTip>
                                                                </Border.ToolTip>
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{Binding Status, Converter={StaticResource ProjectStatusToBrush}}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Background" Value="#DE350B"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding Status, Converter={StaticResource ProjectStatusToString}}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Text" Value="Пометка удаления"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                            <!-- Progress -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center"
                                                        Margin="8,0,12,0">
                                                <Grid Margin="0,0,0,4">
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="6"
                                                                 Background="#E9ECEF"
                                                                 Foreground="{Binding ProgressPercent, Converter={StaticResource ProgressPercentToBrush}}"
                                                                 Template="{StaticResource SlimPB}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                                           FontSize="11" Foreground="#6B778C"/>
                                            </StackPanel>

                                            <!-- Manager: аватар из БД или инициалы — EllipseGeometry для идеального круга -->
                                            <Grid Grid.Column="6" VerticalAlignment="Center"
                                                  Margin="0,0,8,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Style="{StaticResource AvatarCircle28}"
                                                        Background="#E8E9EC" Margin="0,0,8,0">
                                                    <Grid>
                                                        <Image Style="{StaticResource AvatarImage}"
                                                               Source="{Binding ManagerAvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                               Width="28" Height="28"
                                                               Visibility="{Binding ManagerAvatarData, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding ManagerInitials}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#000000"
                                                                   Visibility="{Binding ManagerAvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding ManagerName}"
                                                           FontSize="12" Foreground="#000000"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>

                                                            <!-- Actions (role-based) -->
                                                            <StackPanel Grid.Column="7" Orientation="Horizontal"
                                                                        VerticalAlignment="Center" HorizontalAlignment="Right">
                                                                <!-- Edit (Manager+, hidden for Foreman, hidden when marked) -->
                                                                <Button Tag="{Binding}" Click="EditProject_Click"
                                                                        Width="26" Height="26" Margin="0,0,2,0"
                                                                        ToolTip="Редактировать"
                                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Project Manager,Administrator'}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                                           Width="14" Height="14" VerticalAlignment="Center"/>
                                                                </Button>
                                                                <!-- Mark for deletion / Unmark (Manager role) -->
                                                                <Button Tag="{Binding}" Click="MarkProjectForDeletion_Click"
                                                                        Style="{StaticResource IconButton}"
                                                                        Width="26" Height="26" Margin="0,0,2,0"
                                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Project Manager,Administrator'}">
                                                                    <Button.ToolTip>
                                                                        <ToolTip>
                                                                            <TextBlock>
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="Пометить к удалению"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                                <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </ToolTip>
                                                                    </Button.ToolTip>
                                                                    <Grid>
                                                                        <Image Source="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"
                                                                               Width="14" Height="14" VerticalAlignment="Center">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                        <Image Source="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"
                                                                               Width="14" Height="14" VerticalAlignment="Center">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                    </Grid>
                                                                </Button>
                                                                <!-- Delete (Admin only) -->
                                                                <Button Tag="{Binding}" Click="DeleteProject_Click"
                                                                        Style="{StaticResource IconButton}"
                                                                        Width="26" Height="26"
                                                                        ToolTip="Удалить проект"
                                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Administrator'}">
                                                                    <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                                           Width="14" Height="14" VerticalAlignment="Center"/>
                                                                </Button>
                                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40"
                                    Visibility="{Binding Projects.Count, Converter={StaticResource IntToVisInv}}">
                            <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"
                                       Foreground="#DFE1E6"/>
                            <TextBlock Text="Проекты не найдены" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                            <TextBlock Text="Создайте первый проект или измените фильтры"
                                       FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center"/>
                        </StackPanel>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
