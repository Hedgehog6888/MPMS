<UserControl x:Class="MPMS.Views.Pages.ProjectsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <!-- Row hover style -->
        <Style x:Key="ProjectRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slim ProgressBar template -->
        <ControlTemplate x:Key="SlimPB" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                <Border x:Name="PART_Track" CornerRadius="3">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="3"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Column header text style -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Cell text style -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#172B4D"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Secondary cell text -->
        <Style x:Key="CellTextSec" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Проекты" FontSize="24" FontWeight="Bold"
                               Foreground="#172B4D"/>
                    <TextBlock Text="Управление монтажными проектами"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <!-- Create button -->
                <Button x:Name="CreateProjectBtn" Grid.Column="1" Click="CreateProject_Click"
                        Height="38" Padding="18,0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Создать проект" Foreground="White"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── SCROLLABLE BODY ─────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <!-- ACTIVITY FEED ──────────────────────────────────── -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Последние действия"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#172B4D"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Недавняя активность в системе"
                                   FontSize="12" Foreground="#6B778C" Margin="0,0,0,14"/>

                        <!-- Activity list -->
                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentActivities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="6"
                                            Background="#F8F9FA"
                                            BorderBrush="#EEF0F3" BorderThickness="1">
                                        <Grid>
                                            <!-- Colored left accent based on entity type -->
                                            <Border Width="3" HorizontalAlignment="Left" CornerRadius="6,0,0,6"
                                                    Background="{Binding EntityType, Converter={StaticResource EntityTypeToAccentBrush}}"/>
                                            <Grid Margin="12,8,10,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Avatar -->
                                                <Border Width="28" Height="28" CornerRadius="14"
                                                        Margin="0,0,10,0" VerticalAlignment="Top"
                                                        Background="{Binding UserColor, Converter={StaticResource HexToBrush}}">
                                                    <TextBlock Text="{Binding UserInitials}"
                                                               FontSize="10" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Entity badge + action text -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <Border CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                                Background="{Binding EntityType, Converter={StaticResource EntityTypeToAccentBrush}}">
                                                            <TextBlock Text="{Binding EntityType, Converter={StaticResource EntityTypeToLabel}}"
                                                                       FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding UserName}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#172B4D" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ActionText}"
                                                               FontSize="12" Foreground="#42526E"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <!-- Time -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                           FontSize="11" Foreground="#6B778C"
                                                           VerticalAlignment="Top" Margin="10,2,0,0"
                                                           MinWidth="45"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty activities state -->
                        <TextBlock Text="Действия появятся здесь после первых изменений"
                                   FontSize="12" Foreground="#6B778C" TextAlignment="Center"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding RecentActivities.Count, Converter={StaticResource IntToVisInv}}"/>
                    </StackPanel>
                </Border>

                <!-- SEARCH + FILTER BAR ─────────────────────────────── -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="16,10" Margin="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search box -->
                        <Border Grid.Column="0" Background="#F4F5F7" CornerRadius="6"
                                Padding="10,0" Height="36" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="#6B778C"/>
                                <Grid Grid.Column="1">
                                    <TextBlock Text="Поиск по названию или заказчику..."
                                               Foreground="#6B778C" FontSize="12"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalAlignment="Center" FontSize="13"
                                             Foreground="#172B4D"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Status filter -->
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding StatusFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160"/>
                    </Grid>
                </Border>

                <!-- PROJECTS TABLE ──────────────────────────────────── -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        ClipToBounds="True">
                    <StackPanel>

                        <!-- Column headers -->
                        <Border Background="#F8F9FA" Padding="16,10"
                                BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>          <!-- Name -->
                                    <ColumnDefinition Width="140"/>        <!-- Client -->
                                    <ColumnDefinition Width="100"/>        <!-- Start -->
                                    <ColumnDefinition Width="110"/>        <!-- End -->
                                    <ColumnDefinition Width="110"/>        <!-- Status -->
                                    <ColumnDefinition Width="150"/>        <!-- Progress -->
                                    <ColumnDefinition Width="130"/>        <!-- Manager -->
                                    <ColumnDefinition Width="80"/>         <!-- Actions -->
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Название проекта"   Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="1" Text="Заказчик"           Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="2" Text="Дата начала"        Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="3" Text="Дата завершения"    Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="4" Text="Статус"             Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="5" Text="Прогресс"           Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="6" Text="Менеджер"           Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="7" Text="Действия"           Style="{StaticResource ColHeader}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Project rows -->
                        <ItemsControl ItemsSource="{Binding Projects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ProjectRow}"
                                            Padding="0"
                                            BorderBrush="#DFE1E6" BorderThickness="0,0,0,1"
                                            MouseLeftButtonDown="ProjectRow_Click">
                                        <Grid Margin="16,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Project name -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#172B4D"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Cursor="Hand"
                                                       Margin="0,0,12,0"
                                                       MouseLeftButtonDown="ProjectName_Click"/>

                                            <!-- Client -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Client}"
                                                       Style="{StaticResource CellText}"
                                                       Margin="0,0,8,0"/>

                                            <!-- Start date -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StartDate, Converter={StaticResource DateOnlyToString}}"
                                                       Style="{StaticResource CellTextSec}"/>

                                            <!-- End date -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding EndDate, Converter={StaticResource DateOnlyToString}}"
                                                       Style="{StaticResource CellTextSec}"/>

                                            <!-- Status badge -->
                                            <Border Grid.Column="4"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="4" Padding="8,4"
                                                    Background="{Binding Status, Converter={StaticResource ProjectStatusToBrush}}">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource ProjectStatusToString}}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- Progress -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center"
                                                        Margin="0,0,12,0">
                                                <Grid Margin="0,0,0,4">
                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Maximum="100" Height="6"
                                                                 Background="#E9ECEF"
                                                                 Foreground="#111111"
                                                                 Template="{StaticResource SlimPB}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                                           FontSize="11" Foreground="#6B778C"/>
                                            </StackPanel>

                                            <!-- Manager -->
                                            <StackPanel Grid.Column="6" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Width="28" Height="28" CornerRadius="14"
                                                        Background="#E8E9EC" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding ManagerInitials}"
                                                               FontSize="10" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="#172B4D"/>
                                                </Border>
                                                <TextBlock Text="{Binding ManagerName}"
                                                           FontSize="12" Foreground="#172B4D"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="90"/>
                                            </StackPanel>

                                            <!-- Actions (role-based) -->
                                            <StackPanel Grid.Column="7" Orientation="Horizontal"
                                                        VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <!-- Deletion mark indicator -->
                                                <Border CornerRadius="4" Padding="5,2" Margin="0,0,4,0"
                                                        Background="#FFEBE6" VerticalAlignment="Center"
                                                        Visibility="{Binding IsMarkedForDeletion, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="К удалению" FontSize="10"
                                                               Foreground="#BF2600" FontWeight="SemiBold"/>
                                                </Border>
                                                <!-- Mark for deletion / Unmark (Manager role) -->
                                                <Button Tag="{Binding}" Click="MarkProjectForDeletion_Click"
                                                        Style="{StaticResource IconButton}"
                                                        Width="26" Height="26" Margin="0,0,2,0"
                                                        ToolTip="Пометить для удаления"
                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Manager,ProjectManager,Project Manager'}">
                                                    <TextBlock Text="🗑" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                               Opacity="0.6"/>
                                                </Button>
                                                <!-- Delete (Admin only) -->
                                                <Button Tag="{Binding}" Click="DeleteProject_Click"
                                                        Style="{StaticResource IconButton}"
                                                        Width="26" Height="26"
                                                        ToolTip="Удалить проект"
                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Admin,Administrator'}">
                                                    <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                           Width="12" Height="12" Opacity="0.6"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40"
                                    Visibility="{Binding Projects.Count, Converter={StaticResource IntToVisInv}}">
                            <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"
                                       Foreground="#DFE1E6"/>
                            <TextBlock Text="Проекты не найдены" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                            <TextBlock Text="Создайте первый проект или измените фильтры"
                                       FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
