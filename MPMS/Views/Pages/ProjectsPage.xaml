<UserControl x:Class="MPMS.Views.Pages.ProjectsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:controls="clr-namespace:MPMS.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             RenderOptions.ClearTypeHint="Enabled">

    <UserControl.Resources>
        <!-- Row hover style -->
        <Style x:Key="ProjectRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slim ProgressBar template -->
        <ControlTemplate x:Key="SlimPB" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                <Border x:Name="PART_Track" CornerRadius="3">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="3"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Column header text style -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Cell text style -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Secondary cell text -->
        <Style x:Key="CellTextSec" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Проекты" FontSize="24" FontWeight="Bold"
                               Foreground="#000000"/>
                    <TextBlock Text="Управление монтажными проектами"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <!-- Create button -->
                <Button x:Name="CreateProjectBtn" Grid.Column="1" Click="CreateProject_Click"
                        Height="38" Padding="18,0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Создать проект" Foreground="White"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── SCROLLABLE BODY ─────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="24,12,0,24" ClipToBounds="True">
            <ScrollViewer x:Name="MainListScroll" 
                          VerticalScrollBarVisibility="Auto"
                          ClipToBounds="True"
                          Padding="0,0,24,0"
                          Background="Transparent">
                <StackPanel Margin="0,80,0,0">
                        <ItemsControl ItemsSource="{Binding Projects}" Margin="2,0,2,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="CardBorder" CornerRadius="16" Margin="8"
                                            Padding="24" BorderThickness="1"
                                            Cursor="Hand" MouseLeftButtonDown="ProjectRow_Click"
                                            Background="White"
                                            SnapsToDevicePixels="False"
                                            UseLayoutRounding="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="12" Opacity="0.06" ShadowDepth="2" Direction="270" RenderingBias="Quality"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#DE350B"/>
                                                        <Setter Property="Background" Value="#FFF5F5"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#222222"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                        <Setter Property="Background" Value="#F8F9FA"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="16" Opacity="0.1" ShadowDepth="3" Direction="270" RenderingBias="Quality"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0" To="1" Duration="0:0:0.3"/>
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                                    From="8,20,8,0" To="8" Duration="0:0:0.3">
                                                                    <ThicknessAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </ThicknessAnimation.EasingFunction>
                                                                </ThicknessAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 1: Title & Status -->
                                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="#111111"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <Image Source="{svgc:SvgImage Source=/icons/client.svg, AppName=MPMS}" Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Client}" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Border Grid.Column="1" VerticalAlignment="Top" CornerRadius="6" Padding="10,5">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{Binding Status, Converter={StaticResource ProjectStatusToBrush}}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                    <Setter Property="Background" Value="#DE350B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="Bold" Foreground="White">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Status, Converter={StaticResource ProjectStatusToString}}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Text" Value="ПОМЕТКА УДАЛЕНИЯ"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <!-- Row 2: Manager & Dates -->
                                            <Grid Grid.Row="1" Margin="0,0,0,24">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Style="{StaticResource AvatarCircle48}" Background="#F4F5F7" Margin="0,0,16,0">
                                                        <Grid>
                                                            <Image Style="{StaticResource AvatarImage}"
                                                                   Source="{Binding ManagerAvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                   Visibility="{Binding ManagerAvatarData, Converter={StaticResource NullToVis}}"/>
                                                            <TextBlock Text="{Binding ManagerInitials}" FontSize="14" FontWeight="Bold" 
                                                                       Foreground="#6B778C" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Visibility="{Binding ManagerAvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ManagerName}" FontSize="14" FontWeight="SemiBold" Foreground="#111111"/>
                                                        <TextBlock Text="Менеджер проекта" FontSize="11" Foreground="#6B778C"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock FontSize="12" Foreground="#6B778C" HorizontalAlignment="Right">
                                                        <Run Text="{Binding StartDate, Converter={StaticResource DateOnlyToString}}"/>
                                                        <Run Text=" — "/>
                                                        <Run Text="{Binding EndDate, Converter={StaticResource DateOnlyToString}}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="Период реализации" FontSize="10" Foreground="#6B778C" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Row 3: Progress -->
                                            <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="ПРОГРЕСС" FontSize="10" FontWeight="Bold" Foreground="#6B778C"/>
                                                    <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}" 
                                                               FontSize="13" FontWeight="Bold" Foreground="#111111" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                             Maximum="100" Height="8"
                                                             Background="#E9ECEF"
                                                             Foreground="{Binding ProgressPercent, Converter={StaticResource ProgressPercentToBrush}}"
                                                             Template="{StaticResource SlimPB}"/>
                                            </StackPanel>

                                            <!-- Actions (role-based) -->
                                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,-4">
                                                <!-- Edit (Manager+, hidden when marked) -->
                                                <Button Tag="{Binding}" Click="EditProject_Click" Margin="0,0,8,0" ToolTip="Редактировать">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                            <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Project Manager,Administrator'}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Image Width="16" Height="16">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ElementName=CardBorder, Path=IsMouseOver}" Value="True">
                                                                        <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/editing_black.svg, AppName=MPMS}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Button>

                                                <!-- Mark for deletion / Unmark (Manager role) -->
                                                <Button Tag="{Binding}" Click="MarkProjectForDeletion_Click" Style="{StaticResource IconButton}" Margin="0,0,8,0"
                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Project Manager,Administrator'}">
                                                    <Button.ToolTip>
                                                        <ToolTip>
                                                            <TextBlock>
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="Пометить к удалению"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </ToolTip>
                                                    </Button.ToolTip>
                                                    <Grid>
                                                        <Image Width="16" Height="16">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ElementName=CardBorder, Path=IsMouseOver}" Value="True">
                                                                            <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                        <Image Width="16" Height="16">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ElementName=CardBorder, Path=IsMouseOver}" Value="True">
                                                                            <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/removeMarkDelete_black.svg, AppName=MPMS}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                    </Grid>
                                                </Button>

                                                <!-- Delete (Admin only) -->
                                                <Button Tag="{Binding}" Click="DeleteProject_Click" Style="{StaticResource IconButton}" ToolTip="Удалить проект"
                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Administrator'}">
                                                    <Image Width="16" Height="16">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/trash_red.svg, AppName=MPMS}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ElementName=CardBorder, Path=IsMouseOver}" Value="True">
                                                                        <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    <Grid Visibility="{Binding Projects.Count, Converter={StaticResource IntToVisInv}}" Margin="0,60,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{svgc:SvgImage Source=/icons/empty_activities.svg, AppName=MPMS}" 
                                   Width="64" Height="64" Opacity="0.1" Margin="0,0,0,20"/>
                            <TextBlock Text="Проекты не найдены" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#111111" HorizontalAlignment="Center"/>
                            <TextBlock Text="Создайте первый проект или измените параметры фильтрации"
                                       FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- ── Плавающая панель поиска ── -->
            <controls:SearchFilterBarControl
                VerticalAlignment="Top" Panel.ZIndex="1"
                HorizontalAlignment="Stretch" Margin="0,0,24,0"
                IsFloating="True"
                ScrollTarget="{Binding ElementName=MainListScroll}"
                SearchText="{Binding SearchText, Mode=TwoWay}"
                Placeholder="Поиск по названию или заказчику...">
                <controls:SearchFilterBarControl.Filters>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding StatusFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160"/>
                </controls:SearchFilterBarControl.Filters>
            </controls:SearchFilterBarControl>
        </Grid>
    </Grid>
</UserControl>
