<UserControl x:Class="MPMS.Views.Pages.StagesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="StageRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PAGE HEADER -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Этапы" FontSize="24" FontWeight="Bold" Foreground="#172B4D"/>
                    <TextBlock Text="Все этапы задач проектов"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <Button x:Name="CreateStageBtn" Grid.Column="1"
                        Click="CreateStage_Click"
                        Height="38" Padding="18,0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить этап" Foreground="White"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- BODY: скролл справа у края, контент и фильтр с отступом справа -->
        <Grid Grid.Row="1" Margin="24,12,0,24" ClipToBounds="True">
            <ScrollViewer x:Name="MainListScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,62,24,0"
                          Background="Transparent"
                          Panel.ZIndex="0">
                <StackPanel>

                        <!-- Проекты → задачи → этапы -->
                        <ItemsControl ItemsSource="{Binding ProjectStageGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding TaskGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Margin" Value="12,0,0,0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFirstInProject}" Value="True">
                                                                        <Setter Property="Margin" Value="0"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <!-- Первая задача: проект и задача в одной строке -->
                                                        <Grid Margin="0,10,0,6" VerticalAlignment="Center"
                                                              Visibility="{Binding IsFirstInProject, Converter={StaticResource BoolToVis}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*" MinWidth="0"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="3" CornerRadius="1.5" Background="#0C66E4"
                                                                    VerticalAlignment="Center" Margin="0,0,10,0" Height="14"/>
                                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="10"
                                                                       Foreground="#97A0AF" FontWeight="SemiBold" Margin="0,0,6,0"
                                                                       Text="Проект"/>
                                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="#172B4D"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="240"
                                                                       Text="{Binding ProjectName, Mode=OneWay}" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="10"
                                                                       Foreground="#C1C7D0" Margin="0,0,6,0" Text="·"/>
                                                            <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="10"
                                                                       Foreground="#97A0AF" FontWeight="SemiBold" Margin="0,0,4,0"
                                                                       Text="Задача"/>
                                                            <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="#42526E"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding TaskName, Mode=OneWay}"/>
                                                        </Grid>
                                                        <!-- Следующие задачи: только строка задачи -->
                                                        <Grid Margin="0,8,0,4" VerticalAlignment="Center"
                                                              Visibility="{Binding IsFirstInProject, Converter={StaticResource BoolToVisInv}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*" MinWidth="0"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="2" CornerRadius="1" Background="#97A0AF"
                                                                    VerticalAlignment="Center" Margin="0,0,8,0" Height="12"/>
                                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="10"
                                                                       Foreground="#97A0AF" FontWeight="SemiBold" Margin="0,0,6,0"
                                                                       Text="Задача"/>
                                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="#42526E"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding TaskName, Mode=OneWay}"/>
                                                        </Grid>
                                        <!-- Заголовки колонок под этой задачей -->
                                        <Border Background="Transparent" Padding="15,8,15,8" Margin="0,0,0,2" Opacity="0.7"
                                                BorderThickness="1.5" BorderBrush="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="НАЗВАНИЕ"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="СМЕНА СТАТУСА"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,24,0"/>
                                                <TextBlock Grid.Column="2" Text="ЗАДАЧА"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="3" Text="СТАТУС"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="4" Text="ИСПОЛНИТЕЛЬ"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="5" Text="ДЕЙСТВИЯ"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                        <!-- Stages in task -->
                                        <ItemsControl ItemsSource="{Binding Stages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="8" Margin="0,0,0,6"
                                                            Padding="15,10" BorderThickness="1.5"
                                                            Cursor="Hand" MouseLeftButtonDown="Stage_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="White"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#DE350B"/>
                                                                        <Setter Property="Background" Value="#FFF5F5"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#172B4D"/>
                                                                    </Trigger>
                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                 From="0" To="1" Duration="0:0:0.2"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="90"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Name + description -->
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding Stage.Name}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Stage.Description}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                                                           Visibility="{Binding Stage.Description, Converter={StaticResource StringToVis}}"/>
                                                                <TextBlock Text="{Binding Stage.StageInheritedDeletionHint}"
                                                                           FontSize="10" Foreground="#B71C1C" Margin="0,4,0,0"
                                                                           TextWrapping="Wrap"
                                                                           Visibility="{Binding Stage.StageInheritedDeletionHint, Converter={StaticResource StringToVis}}"/>
                                                            </StackPanel>

                                                            <!-- Status buttons (left of task, with margin) — скрываются при пометке удаления -->
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                        VerticalAlignment="Center" Margin="0,0,24,0"
                                                                        Visibility="{Binding Stage.EffectiveMarkedForDeletion, Converter={StaticResource BoolToVisInv}}">
                                                                    <Button Tag="{Binding}"
                                                                            Click="StartStage_Click" Margin="0,0,4,0"
                                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                                            Visibility="{Binding Stage.Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Planned}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Source="{svgc:SvgImage Source=/icons/play.svg, AppName=MPMS}"
                                                                                   Width="12" Height="12" Margin="0,0,4,0"
                                                                                   VerticalAlignment="Center" Opacity="0.8"/>
                                                                            <TextBlock Text="Начать" VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Button Tag="{Binding}"
                                                                            Click="CompleteStage_Click" Margin="0,0,4,0"
                                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                                            Visibility="{Binding Stage.Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                                                                                   Width="10" Height="10" Margin="0,0,4,0"
                                                                                   VerticalAlignment="Center" Opacity="0.9"/>
                                                                            <TextBlock Text="Завершить" VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Button Tag="{Binding}"
                                                                            Click="RevertStage_Click" Margin="0,0,4,0"
                                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                                            ToolTip="Вернуть в запланированные"
                                                                            Visibility="{Binding Stage.Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}">
                                                                        <TextBlock Text="Отменить" VerticalAlignment="Center"
                                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                    </Button>
                                                                    <Button Tag="{Binding}"
                                                                            Click="ReopenStage_Click" Margin="0,0,4,0"
                                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                                            ToolTip="Открыть снова"
                                                                            Visibility="{Binding Stage.Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Completed}">
                                                                        <TextBlock Text="Переоткрыть" VerticalAlignment="Center"
                                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                    </Button>
                                                            </StackPanel>

                                                            <!-- Task name -->
                                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                                       Text="{Binding TaskName}" FontSize="12"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <!-- Status badge (rectangle: Запланирован, Выполняется, Завершён) -->
                                                            <Border Grid.Column="3" CornerRadius="4" Padding="10,5"
                                                                    VerticalAlignment="Center" HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{Binding Stage.Status, Converter={StaticResource StageStatusToBrush}}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Background" Value="#DE350B"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding Stage.Status, Converter={StaticResource StageStatusToString}}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Text" Value="Пометка удаления"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                            <!-- Assignee -->
                                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                                                                        Visibility="{Binding Stage.AssignedUserName, Converter={StaticResource StringToVis}}">
                                                                <Border Style="{StaticResource AvatarCircle26}"
                                                                        Background="{Binding Stage.AssignedUserInitials, Converter={StaticResource InitialsToBrush}}"
                                                                        Margin="0,0,6,0">
                                                                    <Grid>
                                                                        <Image Style="{StaticResource AvatarImage}"
                                                                               Source="{Binding Stage.AssignedUserAvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                               Width="26" Height="26"
                                                                               Visibility="{Binding Stage.AssignedUserAvatarData, Converter={StaticResource NullToVis}}"/>
                                                                        <TextBlock Text="{Binding Stage.AssignedUserInitials}"
                                                                                   FontSize="9" FontWeight="Bold"
                                                                                   Foreground="White"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Visibility="{Binding Stage.AssignedUserAvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                                    </Grid>
                                                                </Border>
                                                                <TextBlock Text="{Binding Stage.AssignedUserName}"
                                                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>

                                                            <!-- Action buttons -->
                                                            <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                                        VerticalAlignment="Center" HorizontalAlignment="Right">
                                                                <!-- Edit (Foreman+, hidden when marked) -->
                                                                <Button ToolTip="Редактировать" Tag="{Binding}"
                                                                        Click="EditStage_Click" Margin="0,0,4,0">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                            <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Stage.EffectiveMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                                           Width="14" Height="14"
                                                                           VerticalAlignment="Center"/>
                                                                </Button>
                                                                <!-- Mark/unmark for deletion (Worker+) -->
                                                                <Button Tag="{Binding}" Click="MarkStage_Click"
                                                                        Margin="0,0,4,0">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                            <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Worker,Foreman,Project Manager,Administrator'}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Stage.CanToggleStageDeletionMark}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Button.ToolTip>
                                                                        <ToolTip>
                                                                            <TextBlock>
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="Пометить к удалению"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                                                <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </ToolTip>
                                                                    </Button.ToolTip>
                                                                    <Grid>
                                                                        <Image Source="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"
                                                                               Width="14" Height="14" VerticalAlignment="Center">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                        <Image Source="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"
                                                                               Width="14" Height="14" VerticalAlignment="Center">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                    </Grid>
                                                                </Button>
                                                                <!-- Delete (Foreman+) -->
                                                                <Button ToolTip="Удалить этап" Tag="{Binding}"
                                                                        Click="DeleteStage_Click"
                                                                        Style="{StaticResource DangerIconButton}"
                                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}">
                                                                    <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                                           Width="14" Height="14"
                                                                           VerticalAlignment="Center"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40"
                                    Visibility="{Binding ProjectStageGroups.Count, Converter={StaticResource IntToVisInv}}">
                            <Image Source="{svgc:SvgImage Source=/icons/stages.svg, AppName=MPMS}" Width="48" Height="48" HorizontalAlignment="Center" Opacity="0.4"/>
                            <TextBlock Text="Этапы не найдены" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                            <TextBlock Text="Создайте первый этап или измените фильтры"
                                       FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center"/>
                        </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <Border VerticalAlignment="Top" Panel.ZIndex="1"
                    HorizontalAlignment="Left"
                    Width="{Binding ElementName=MainListScroll, Path=ViewportWidth}"
                    Background="White" CornerRadius="8"
                    BorderBrush="#DFE1E6" BorderThickness="1"
                    Padding="16,10,16,14"
                    PreviewMouseWheel="FilterBar_PreviewMouseWheel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.14" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F4F5F7" CornerRadius="6"
                            Padding="10,0" Height="36" Margin="0,0,12,0"
                            BorderThickness="1.5" BorderBrush="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"
                                       Margin="0,0,8,0" Foreground="#6B778C"/>
                            <Grid Grid.Column="1" Margin="0,0,4,0">
                                <TextBlock Text="Поиск по этапу, задаче или проекту..."
                                           Foreground="#6B778C" FontSize="12"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" FontSize="13"
                                         Foreground="#172B4D"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"/>
                            </Grid>
                            <Button Grid.Column="2" Click="ClearSearch_Click"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVis}}"
                                    Width="20" Height="20" Margin="0,0,0,0"
                                    Style="{StaticResource IconButton}">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#6B778C"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ProjectFilterOptions}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding ProjectFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="200" Margin="0,0,8,0"/>

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding TaskFilterOptions}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding TaskFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="220" Margin="0,0,8,0"/>

                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding StatusFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160"/>
                </Grid>
            </Border>

            <!-- Loading indicator -->
            <Border Background="#80FFFFFF"
                    Panel.ZIndex="2"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Загрузка..." FontSize="16" Foreground="#6B778C"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
