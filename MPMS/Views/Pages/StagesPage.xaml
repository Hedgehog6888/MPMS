<UserControl x:Class="MPMS.Views.Pages.StagesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <Style x:Key="StageRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PAGE HEADER -->
        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Этапы" FontSize="24" FontWeight="Bold" Foreground="#172B4D"/>
                    <TextBlock Text="Все этапы задач проектов"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <Button x:Name="CreateStageBtn" Grid.Column="1"
                        Click="CreateStage_Click"
                        Height="38" Padding="18,0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить этап" Foreground="White"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- BODY -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <!-- Search + Filter bar -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#DFE1E6" BorderThickness="1"
                        Padding="16,10" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search -->
                        <Border Grid.Column="0" Background="#F4F5F7" CornerRadius="6"
                                Padding="10,0" Height="36" Margin="0,0,12,0"
                                BorderThickness="1.5" BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,8,0" Foreground="#6B778C"/>
                                <Grid Grid.Column="1">
                                    <TextBlock Text="Поиск по этапу, задаче или проекту..."
                                               Foreground="#6B778C" FontSize="12"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalAlignment="Center" FontSize="13"
                                             Foreground="#172B4D"
                                             GotFocus="SearchBox_GotFocus"
                                             LostFocus="SearchBox_LostFocus"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Project filter -->
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ProjectFilterOptions}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding ProjectFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="200" Margin="0,0,8,0"/>

                        <!-- Task filter -->
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding TaskFilterOptions}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding TaskFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="220" Margin="0,0,8,0"/>

                        <!-- Status filter -->
                        <ComboBox Grid.Column="3"
                                  ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding StatusFilter}"
                                  Style="{StaticResource FormCombo}"
                                  Width="160"/>
                    </Grid>
                </Border>

                <!-- Stages list -->
                <StackPanel>

                        <!-- Column headers -->
                        <Border Background="Transparent" Padding="15,8,15,8" Margin="0,0,0,4" Opacity="0.7"
                                BorderThickness="1.5" BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="НАЗВАНИЕ ЭТАПА"
                                           FontSize="11" FontWeight="SemiBold" Foreground="#6B778C"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="СТАТУС"
                                           FontSize="11" FontWeight="SemiBold" Foreground="#6B778C"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="ДЕЙСТВИЯ" MinWidth="90"
                                           FontSize="11" FontWeight="SemiBold" Foreground="#6B778C"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Rows (grouped by task) -->
                        <ItemsControl ItemsSource="{Binding StageGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <!-- Task/Project header -->
                                        <Border Background="#F4F5F7" Padding="10,6" Margin="0,8,0,4" CornerRadius="6">
                                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#6B778C">
                                                <Run Text="{Binding TaskName, Mode=OneWay}"/>
                                                <Run Text=" — " Foreground="#C1C7D0"/>
                                                <Run Text="{Binding ProjectName, Mode=OneWay}" Foreground="#6B778C"/>
                                            </TextBlock>
                                        </Border>
                                        <!-- Stages in task -->
                                        <ItemsControl ItemsSource="{Binding Stages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="8" Margin="0,0,0,6"
                                                            Padding="15,10" BorderThickness="1.5"
                                                            Cursor="Hand" MouseLeftButtonDown="Stage_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="White"/>
                                                                <Setter Property="BorderBrush" Value="#DFE1E6"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#DE350B"/>
                                                                        <Setter Property="Background" Value="#FFF5F5"/>
                                                                        <Setter Property="Opacity" Value="0.85"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#172B4D"/>
                                                                    </Trigger>
                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                 From="0" To="1" Duration="0:0:0.2"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding Stage.Name}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="#172B4D" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Stage.AssignedUserName}"
                                                                           FontSize="11" Foreground="#6B778C"
                                                                           Margin="0,2,0,0"
                                                                           Visibility="{Binding Stage.AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                            </StackPanel>

                                                            <!-- Status area (hidden when marked for deletion) -->
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <!-- Marked for deletion badge -->
                                                                <Border CornerRadius="4" Padding="8,4" Background="#DE350B"
                                                                        Visibility="{Binding Stage.IsMarkedForDeletion, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="Пометка удаления" FontSize="11"
                                                                               Foreground="White" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <!-- Normal status buttons (hidden when marked) -->
                                                                <StackPanel Orientation="Horizontal"
                                                                            Visibility="{Binding Stage.IsMarkedForDeletion, Converter={StaticResource BoolToVisInv}}">
                                                                    <Button Tag="{Binding}"
                                                                            Click="StartStage_Click" Margin="0,0,4,0"
                                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                                            Visibility="{Binding Stage.Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Planned}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Source="{svgc:SvgImage Source=/icons/play.svg, AppName=MPMS}"
                                                                                   Width="12" Height="12" Margin="0,0,4,0"
                                                                                   VerticalAlignment="Center" Opacity="0.8"/>
                                                                            <TextBlock Text="Начать" VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Button Tag="{Binding}"
                                                                            Click="CompleteStage_Click" Margin="0,0,4,0"
                                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                                            Visibility="{Binding Stage.Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                                                                                   Width="10" Height="10" Margin="0,0,4,0"
                                                                                   VerticalAlignment="Center" Opacity="0.9"/>
                                                                            <TextBlock Text="Завершить" VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Border Visibility="{Binding Stage.Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Completed}"
                                                                            CornerRadius="4" Padding="8,4" Background="#E8F5E9">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Source="{svgc:SvgImage Source=/icons/check_green.svg, AppName=MPMS}"
                                                                                   Width="10" Height="10" Margin="0,0,4,0"
                                                                                   VerticalAlignment="Center" Opacity="0.9"/>
                                                                            <TextBlock Text="Завершено" FontSize="11"
                                                                                       Foreground="#1B5E20" FontWeight="SemiBold"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                <!-- Edit (Foreman+, hidden when marked) -->
                                                                <Button ToolTip="Редактировать" Tag="{Binding}"
                                                                        Click="EditStage_Click" Margin="0,0,4,0">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                            <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                                           Width="14" Height="14"
                                                                           VerticalAlignment="Center" Opacity="0.85"/>
                                                                </Button>
                                                                <!-- Mark/unmark for deletion (Worker+) -->
                                                                <Button Tag="{Binding}" Click="MarkStage_Click"
                                                                        Margin="0,0,4,0" Style="{StaticResource IconButton}"
                                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Worker,Foreman,Project Manager,Administrator'}">
                                                                    <Button.ToolTip>
                                                                        <ToolTip>
                                                                            <TextBlock>
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="Пометить к удалению"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                                                <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </ToolTip>
                                                                    </Button.ToolTip>
                                                                    <Grid>
                                                                        <Image Source="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"
                                                                               Width="14" Height="14" VerticalAlignment="Center" Opacity="0.5">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                        <Image Source="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"
                                                                               Width="14" Height="14" VerticalAlignment="Center">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Stage.IsMarkedForDeletion}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                    </Grid>
                                                                </Button>
                                                                <!-- Delete (Foreman+) -->
                                                                <Button ToolTip="Удалить" Tag="{Binding}"
                                                                        Click="DeleteStage_Click"
                                                                        Style="{StaticResource DangerIconButton}"
                                                                        Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}">
                                                                    <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                                           Width="14" Height="14"
                                                                           VerticalAlignment="Center" Opacity="0.9"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40"
                                    Visibility="{Binding StageGroups.Count, Converter={StaticResource IntToVisInv}}">
                            <Image Source="{svgc:SvgImage Source=/icons/stages.svg, AppName=MPMS}" Width="48" Height="48" HorizontalAlignment="Center" Opacity="0.4"/>
                            <TextBlock Text="Этапы не найдены" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                            <TextBlock Text="Создайте первый этап или измените фильтры"
                                       FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center"/>
                        </StackPanel>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading indicator -->
        <Border Grid.Row="1" Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Загрузка..." FontSize="16" Foreground="#6B778C"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
