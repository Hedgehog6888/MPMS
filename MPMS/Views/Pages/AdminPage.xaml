<UserControl x:Class="MPMS.Views.Pages.AdminPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d"
             Background="#F4F5F7"
             d:DataContext="{d:DesignInstance Type=vm:AdminViewModel}"
             d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Table header cell -->
        <Style x:Key="ThCell" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="#6B778C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Small icon button for rows -->
        <Style x:Key="RowIconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Root grid: main content + overlay layers -->
    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Tab bar -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>      <!-- Tab panels -->
            </Grid.RowDefinitions>

            <!-- ── Tab bar (matches ProjectDetailPage style) ──────────── -->
            <Border Grid.Row="0"
                    Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                    CornerRadius="8" Padding="6,4" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TabUsers"    GroupName="AdminMain" IsChecked="True"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Users">
                        Пользователи
                    </RadioButton>
                    <RadioButton x:Name="TabArchive"  GroupName="AdminMain" IsChecked="False"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Archive">
                        Архив
                    </RadioButton>
                    <RadioButton x:Name="TabHistory"  GroupName="AdminMain" IsChecked="False"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="History">
                        История
                    </RadioButton>
                    <RadioButton x:Name="TabActivity" GroupName="AdminMain" IsChecked="False"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Activity">
                        Активность
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ── Tab panels ─────────────────────────────────────────── -->
            <Grid Grid.Row="2">

                <!-- ══════════════ USERS PANEL ═══════════════════════════ -->
                <Grid x:Name="UsersPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Stat cards -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>     <!-- Table -->
                    </Grid.RowDefinitions>

                    <!-- Stat cards (only in Users tab) -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Пользователей" FontSize="11" Foreground="#6B778C" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalUsersCount}" FontSize="24" FontWeight="Bold" Foreground="#000000" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Активных" FontSize="11" Foreground="#6B778C" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ActiveUsersCount}" FontSize="24" FontWeight="Bold" Foreground="#00875A" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Заблокировано" FontSize="11" Foreground="#6B778C" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding BlockedUsersCount}" FontSize="24" FontWeight="Bold" Foreground="#DE350B" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Users toolbar -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search -->
                            <Border Grid.Column="0" x:Name="UserSearchBorder"
                                    Background="#F4F5F7" CornerRadius="6"
                                    Padding="10,0" Height="36"
                                    BorderThickness="1.5" BorderBrush="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="#6B778C"/>
                                    <Grid Grid.Column="1">
                                        <TextBlock Text="Поиск по имени, логину или email..."
                                                   Foreground="#6B778C" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserSearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding UserSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="13"
                                                 Foreground="#000000"
                                                 GotFocus="UserSearch_GotFocus"
                                                 LostFocus="UserSearch_LostFocus"/>
                                    </Grid>
                                    <Button Grid.Column="2"
                                            Visibility="{Binding UserSearchText, Converter={StaticResource StringToVis}}"
                                            Width="20" Height="20"
                                            Style="{StaticResource IconButton}"
                                            Click="ClearUserSearch_Click">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="#6B778C"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Role filter -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{x:Static vm:AdminViewModel.RoleFilterOptions}"
                                      SelectedItem="{Binding UserRoleFilter}"
                                      Style="{StaticResource FormCombo}"/>

                            <!-- Status filter -->
                            <ComboBox Grid.Column="4"
                                      ItemsSource="{x:Static vm:AdminViewModel.StatusFilterOptions}"
                                      SelectedItem="{Binding UserStatusFilter}"
                                      Style="{StaticResource FormCombo}"/>

                            <!-- Add user button -->
                            <Button Grid.Column="6" Style="{StaticResource BlackBtn}"
                                    Click="CreateUser_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                           Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Добавить" Foreground="White"
                                               FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Users table -->
                    <Border Grid.Row="4" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header -->
                            <Border Grid.Row="0" Background="#F4F5F7" CornerRadius="8,8,0,0"
                                    BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Пользователь" Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="1" Text="Email"        Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="2" Text="Роль"         Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="3" Text="Статус"       Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="4" Text="Действия"     Style="{StaticResource ThCell}" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Rows -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredUsers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:AdminUserRow}">
                                            <Border Padding="16,10"
                                                    BorderBrush="#F4F5F7" BorderThickness="0,0,0,1"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="UserRow_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FAFBFC"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Avatar + name -->
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Border Style="{StaticResource AvatarCircle36}"
                                                                Background="{Binding Initials, Converter={StaticResource InitialsToBrush}}"
                                                                Margin="0,0,10,0">
                                                            <Grid>
                                                                <Image Style="{StaticResource AvatarImage}"
                                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                       Width="36" Height="36"
                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           FontSize="12" FontWeight="Bold" Foreground="White"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#000000"/>
                                                            <TextBlock Text="{Binding Username, StringFormat='@{0}'}"
                                                                       FontSize="11" Foreground="#6B778C" Margin="0,1,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Email -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Email}" FontSize="12" Foreground="#344563"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                                    <!-- Role badge -->
                                                    <Border Grid.Column="2"
                                                            Background="{Binding RoleColor}"
                                                            CornerRadius="4" Padding="8,3"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding RoleDisplay}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{Binding RoleForeground}"/>
                                                    </Border>

                                                    <!-- Status badge -->
                                                    <Border Grid.Column="3" CornerRadius="4" Padding="8,3"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#166534"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                            <Setter Property="Foreground" Value="#991B1B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- Actions -->
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button Style="{StaticResource RowIconBtn}" ToolTip="Редактировать"
                                                                Command="{Binding DataContext.OpenEditFormCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                        </Button>
                                                        <Button Style="{StaticResource RowIconBtn}" ToolTip="{Binding BlockLabel}"
                                                                Command="{Binding DataContext.OpenBlockOverlayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Grid Width="14" Height="14">
                                                                <Image Source="{svgc:SvgImage Source=/icons/block.svg, AppName=MPMS}" Width="14" Height="14"
                                                                       Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVisInv}}"/>
                                                                <Image Source="{svgc:SvgImage Source=/icons/unblock.svg, AppName=MPMS}" Width="14" Height="14"
                                                                       Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVis}}"/>
                                                            </Grid>
                                                        </Button>
                                                        <Button Style="{StaticResource RowIconBtn}" ToolTip="Удалить"
                                                                Command="{Binding DataContext.OpenDeleteUserConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══════════════ ARCHIVE PANEL ══════════════════════════ -->
                <Grid x:Name="ArchivePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>  <!-- Sub-tabs -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>     <!-- Tables -->
                    </Grid.RowDefinitions>

                    <!-- Archive toolbar -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,10">
                        <Border x:Name="ArchiveSearchBorder"
                                Background="#F4F5F7" CornerRadius="6"
                                Padding="10,0" Height="36"
                                BorderThickness="1.5" BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B778C"/>
                                <Grid Grid.Column="1">
                                    <TextBlock Text="Поиск по архиву..."
                                               Foreground="#6B778C" FontSize="12" VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ArchiveSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding ArchiveSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalAlignment="Center" FontSize="13" Foreground="#000000"
                                             GotFocus="ArchiveSearch_GotFocus" LostFocus="ArchiveSearch_LostFocus"/>
                                </Grid>
                                <Button Grid.Column="2"
                                        Visibility="{Binding ArchiveSearchText, Converter={StaticResource StringToVis}}"
                                        Width="20" Height="20" Style="{StaticResource IconButton}"
                                        Click="ClearArchiveSearch_Click">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Foreground="#6B778C"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Archive sub-tabs -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" Padding="6,4" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ArchTabProjects" GroupName="ArchiveSub"
                                         Style="{StaticResource TabButton}" IsChecked="True"
                                         Click="ArchiveTab_Click" Tag="Projects">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Проекты" VerticalAlignment="Center"/>
                                    <Border Background="#DFE1E6" CornerRadius="4" Padding="6,1" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding ArchiveProjectCount}" FontSize="10" FontWeight="Bold" Foreground="#344563"/>
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="ArchTabTasks" GroupName="ArchiveSub"
                                         Style="{StaticResource TabButton}" IsChecked="False"
                                         Click="ArchiveTab_Click" Tag="Tasks">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Задачи" VerticalAlignment="Center"/>
                                    <Border Background="#DFE1E6" CornerRadius="4" Padding="6,1" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding ArchiveTaskCount}" FontSize="10" FontWeight="Bold" Foreground="#344563"/>
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="ArchTabStages" GroupName="ArchiveSub"
                                         Style="{StaticResource TabButton}" IsChecked="False"
                                         Click="ArchiveTab_Click" Tag="Stages">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Этапы" VerticalAlignment="Center"/>
                                    <Border Background="#DFE1E6" CornerRadius="4" Padding="6,1" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding ArchiveStageCount}" FontSize="10" FontWeight="Bold" Foreground="#344563"/>
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <!-- Archive tables -->
                    <Grid Grid.Row="4">
                        <!-- Projects -->
                        <Border x:Name="ArchProjPanel" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F4F5F7" CornerRadius="8,8,0,0"
                                        BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Padding="16,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Название"     Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="1" Text="Заказчик"     Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="2" Text="Статус"       Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="3" Text="Дата удаления" Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="4" Text="Действия"     Style="{StaticResource ThCell}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredArchivedProjects}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ArchiveRow}">
                                                <Border Padding="16,10" BorderBrush="#F4F5F7" BorderThickness="0,0,0,1"
                                                        Cursor="Hand" MouseLeftButtonDown="ArchiveRow_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FAFBFC"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="150"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="90"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ParentName}" FontSize="12" Foreground="#344563" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding DeletedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" FontSize="11" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Восстановить"
                                                                    Command="{Binding DataContext.OpenRestoreProjectConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Image Source="{svgc:SvgImage Source=/icons/restore.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                            </Button>
                                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Удалить навсегда"
                                                                    Command="{Binding DataContext.OpenPermanentDeleteProjectConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Tasks -->
                        <Border x:Name="ArchTaskPanel" Visibility="Collapsed" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F4F5F7" CornerRadius="8,8,0,0"
                                        BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Padding="16,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Задача"       Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="1" Text="Проект"       Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="2" Text="Статус"       Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="3" Text="Дата удаления" Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="4" Text="Действия"     Style="{StaticResource ThCell}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredArchivedTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ArchiveRow}">
                                                <Border Padding="16,10" BorderBrush="#F4F5F7" BorderThickness="0,0,0,1"
                                                        Cursor="Hand" MouseLeftButtonDown="ArchiveRow_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FAFBFC"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="160"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="90"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ParentName}" FontSize="12" Foreground="#344563" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding DeletedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" FontSize="11" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Восстановить"
                                                                    Command="{Binding DataContext.OpenRestoreTaskConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Image Source="{svgc:SvgImage Source=/icons/restore.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                            </Button>
                                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Удалить навсегда"
                                                                    Command="{Binding DataContext.OpenPermanentDeleteTaskConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Stages -->
                        <Border x:Name="ArchStagePanel" Visibility="Collapsed" Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F4F5F7" CornerRadius="8,8,0,0"
                                        BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Padding="16,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Этап"         Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="1" Text="Задача"       Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="2" Text="Статус"       Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="3" Text="Дата удаления" Style="{StaticResource ThCell}"/>
                                        <TextBlock Grid.Column="4" Text="Действия"     Style="{StaticResource ThCell}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredArchivedStages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ArchiveRow}">
                                                <Border Padding="16,10" BorderBrush="#F4F5F7" BorderThickness="0,0,0,1"
                                                        Cursor="Hand" MouseLeftButtonDown="ArchiveRow_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FAFBFC"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="160"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="90"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ParentName}" FontSize="12" Foreground="#344563" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="12" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding DeletedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" FontSize="11" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Восстановить"
                                                                    Command="{Binding DataContext.OpenRestoreStageConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Image Source="{svgc:SvgImage Source=/icons/restore.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                            </Button>
                                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Удалить навсегда"
                                                                    Command="{Binding DataContext.OpenPermanentDeleteStageConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}" Width="14" Height="14"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ══════════════ HISTORY PANEL ══════════════════════════ -->
                <Grid x:Name="HistoryPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- History toolbar -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Search -->
                            <Border Grid.Column="0" x:Name="HistorySearchBorder"
                                    Background="#F4F5F7" CornerRadius="6"
                                    Padding="10,0" Height="36" BorderThickness="1.5" BorderBrush="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B778C"/>
                                    <Grid Grid.Column="1">
                                        <TextBlock Text="Поиск по истории..."
                                                   Foreground="#6B778C" FontSize="12" VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HistorySearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="13" Foreground="#000000"
                                                 GotFocus="HistorySearch_GotFocus" LostFocus="HistorySearch_LostFocus"/>
                                    </Grid>
                                    <Button Grid.Column="2"
                                            Visibility="{Binding HistorySearchText, Converter={StaticResource StringToVis}}"
                                            Width="20" Height="20" Style="{StaticResource IconButton}"
                                            Click="ClearHistorySearch_Click">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="#6B778C"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- Action type filter -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{x:Static vm:AdminViewModel.HistoryActionOptions}"
                                      SelectedItem="{Binding HistoryActionFilter}"
                                      Style="{StaticResource FormCombo}"/>
                            <!-- User filter -->
                            <ComboBox Grid.Column="4"
                                      ItemsSource="{Binding HistoryUserList}"
                                      SelectedItem="{Binding HistoryUserFilter}"
                                      Style="{StaticResource FormCombo}"/>
                            <Button Grid.Column="6"
                                    Content="Очистить историю"
                                    Style="{StaticResource OutlineBtn}"
                                    Command="{Binding OpenClearHistoryConfirmCommand}"/>
                        </Grid>
                    </Border>

                    <!-- History table + load more -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F4F5F7" CornerRadius="8,8,0,0"
                                    BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Пользователь" Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="1" Text="Тип действия" Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="2" Text="Описание"     Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="3" Text="Дата и время" Style="{StaticResource ThCell}"/>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredHistoryLogs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,10" BorderBrush="#F4F5F7" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="130"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Border Style="{StaticResource AvatarCircle28}"
                                                                Background="{Binding UserColor}"
                                                                Margin="0,0,8,0">
                                                            <Grid>
                                                                <Image Style="{StaticResource AvatarImage}"
                                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                       Width="28" Height="28"
                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding UserInitials}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="White"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="{Binding UserName}"
                                                                   FontSize="12" FontWeight="SemiBold" Foreground="#000000"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="110"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,3"
                                                            Background="{Binding ActionType, Converter={StaticResource ActionKindToBrush}}"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ActionType, Converter={StaticResource ActionKindToLabel}}"
                                                                   FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding ActionText}"
                                                               FontSize="12" Foreground="#344563"
                                                               TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding CreatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat='{}{0:dd.MM.yy HH:mm}'}"
                                                               FontSize="11" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <!-- Load more -->
                            <Border Grid.Row="2" Padding="16,8"
                                    BorderBrush="#DFE1E6" BorderThickness="0,1,0,0"
                                    Visibility="{Binding HasMoreHistory, Converter={StaticResource BoolToVis}}">
                                <Button Content="Загрузить ещё…"
                                        Style="{StaticResource OutlineBtn}"
                                        HorizontalAlignment="Center"
                                        Command="{Binding LoadMoreHistoryCommand}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══════════════ ACTIVITY PANEL ═════════════════════════ -->
                <Grid x:Name="ActivityPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Activity toolbar -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="ActivitySearchBorder"
                                    Background="#F4F5F7" CornerRadius="6"
                                    Padding="10,0" Height="36" BorderThickness="1.5" BorderBrush="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B778C"/>
                                    <Grid Grid.Column="1">
                                        <TextBlock Text="Поиск по активности..."
                                                   Foreground="#6B778C" FontSize="12" VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActivitySearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding ActivitySearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="13" Foreground="#000000"
                                                 GotFocus="ActivitySearch_GotFocus" LostFocus="ActivitySearch_LostFocus"/>
                                    </Grid>
                                    <Button Grid.Column="2"
                                            Visibility="{Binding ActivitySearchText, Converter={StaticResource StringToVis}}"
                                            Width="20" Height="20" Style="{StaticResource IconButton}"
                                            Click="ClearActivitySearch_Click">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="#6B778C"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- Event type filter -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{x:Static vm:AdminViewModel.ActivityEventOptions}"
                                      SelectedItem="{Binding ActivityEventFilter}"
                                      Style="{StaticResource FormCombo}"/>
                            <!-- User filter -->
                            <ComboBox Grid.Column="4"
                                      ItemsSource="{Binding ActivityUserList}"
                                      SelectedItem="{Binding ActivityUserFilter}"
                                      Style="{StaticResource FormCombo}"/>
                            <Button Grid.Column="6"
                                    Content="Очистить журнал"
                                    Style="{StaticResource OutlineBtn}"
                                    Command="{Binding OpenClearActivityConfirmCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Activity table + load more -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F4F5F7" CornerRadius="8,8,0,0"
                                    BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Пользователь" Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="1" Text="Событие"      Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="2" Text="Описание"     Style="{StaticResource ThCell}"/>
                                    <TextBlock Grid.Column="3" Text="Дата и время" Style="{StaticResource ThCell}"/>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredActivityLogs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,10" BorderBrush="#F4F5F7" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="130"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Border Style="{StaticResource AvatarCircle28}"
                                                                Background="{Binding UserColor}"
                                                                Margin="0,0,8,0">
                                                            <Grid>
                                                                <Image Style="{StaticResource AvatarImage}"
                                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                       Width="28" Height="28"
                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding UserInitials}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="White"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="{Binding UserName}"
                                                                   FontSize="12" FontWeight="SemiBold" Foreground="#000000"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="110"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,3"
                                                            Background="{Binding ActionType, Converter={StaticResource ActionKindToBrush}}"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ActionType, Converter={StaticResource ActionKindToLabel}}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding ActionText}"
                                                               FontSize="12" Foreground="#344563"
                                                               TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding CreatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat='{}{0:dd.MM.yy HH:mm}'}"
                                                               FontSize="11" Foreground="#6B778C" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <!-- Load more -->
                            <Border Grid.Row="2" Padding="16,8"
                                    BorderBrush="#DFE1E6" BorderThickness="0,1,0,0"
                                    Visibility="{Binding HasMoreActivity, Converter={StaticResource BoolToVis}}">
                                <Button Content="Загрузить ещё…"
                                        Style="{StaticResource OutlineBtn}"
                                        HorizontalAlignment="Center"
                                        Command="{Binding LoadMoreActivityCommand}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             BLOCK USER OVERLAY (жёлтый)
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsBlockOverlayOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="Transparent" MouseLeftButtonDown="BlockOverlayBackdrop_Click"/>
            <Border Background="White" Width="440"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" BorderBrush="#DFE1E6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="28" Opacity="0.18" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="#FFF8E1" CornerRadius="12,12,0,0" Padding="24,20,24,16">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,14,0" VerticalAlignment="Center"
                                        Background="#FFEFC6">
                                    <Image Source="{svgc:SvgImage Source=/icons/block_amber.svg, AppName=MPMS}"
                                           Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Заблокировать пользователя?" FontSize="16" FontWeight="Bold" Foreground="#000000"/>
                                    <TextBlock Text="Пользователь не сможет войти в систему" FontSize="12" Margin="0,3,0,0" Foreground="#92400E"/>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Command="{Binding CancelBlockOverlayCommand}"
                                    Width="26" Height="26">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="13">
                                            <TextBlock Text="✕" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="#6B778C"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <StackPanel Margin="24,16,24,0">
                        <Border Background="#F4F5F7" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Пользователь" FontSize="11" Foreground="#6B778C" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding BlockTargetName}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#000000"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Причина блокировки (необязательно)" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#344563" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Margin="0,0,0,4">
                                <TextBox Text="{Binding BlockReason, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#000000" FontSize="13"
                                         Height="72" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalContentAlignment="Top"/>
                            </Border>
                            <TextBlock Text="Причина будет показана пользователю при входе."
                                       FontSize="11" Foreground="#8993A4" Margin="0,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Padding="24,16,24,20">
                        <Grid>
                            <Button HorizontalAlignment="Left" Height="38" Padding="20,0"
                                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                    Command="{Binding CancelBlockOverlayCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="White" CornerRadius="8"
                                                BorderBrush="#DFE1E6" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}"
                                                Height="{TemplateBinding Height}">
                                            <TextBlock Text="Отмена" Foreground="#000000"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button HorizontalAlignment="Right" Height="38" Padding="20,0"
                                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                    Command="{Binding SubmitBlockCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="#D97706" CornerRadius="8"
                                                Padding="{TemplateBinding Padding}"
                                                Height="{TemplateBinding Height}">
                                            <TextBlock Text="Заблокировать" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#B45309"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             UNBLOCK USER OVERLAY (зелёный)
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsUnblockOverlayOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="Transparent" MouseLeftButtonDown="UnblockOverlayBackdrop_Click"/>
            <Border Background="White" Width="440"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" BorderBrush="#DFE1E6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="28" Opacity="0.18" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="#C8E6C9" CornerRadius="12,12,0,0" Padding="24,20,24,16">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,14,0" VerticalAlignment="Center"
                                        Background="#81C784">
                                    <Image Source="{svgc:SvgImage Source=/icons/unblock_green.svg, AppName=MPMS}"
                                           Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Разблокировать пользователя?" FontSize="16" FontWeight="Bold" Foreground="#000000"/>
                                    <TextBlock Text="Пользователь снова сможет войти в систему" FontSize="12" Margin="0,3,0,0" Foreground="#2E7D32"/>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Command="{Binding CancelUnblockOverlayCommand}"
                                    Width="26" Height="26">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="13">
                                            <TextBlock Text="✕" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="#6B778C"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <StackPanel Margin="24,16,24,0">
                        <Border Background="#F4F5F7" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Пользователь" FontSize="11" Foreground="#6B778C" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding BlockTargetName}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#000000"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Visibility="{Binding BlockTargetReason, Converter={StaticResource StringToVis}}">
                            <TextBlock Text="Причина блокировки" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#344563" Margin="0,0,0,6"/>
                            <Border Background="#F4F5F7" CornerRadius="8" Padding="12,10" Margin="0,0,0,0">
                                <TextBlock Text="{Binding BlockTargetReason}" FontSize="13" Foreground="#6B778C"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <Border Padding="24,16,24,20">
                        <Grid>
                            <Button HorizontalAlignment="Left" Height="38" Padding="20,0"
                                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                    Command="{Binding CancelUnblockOverlayCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="White" CornerRadius="8"
                                                BorderBrush="#DFE1E6" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}"
                                                Height="{TemplateBinding Height}">
                                            <TextBlock Text="Отмена" Foreground="#000000"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button HorizontalAlignment="Right" Height="38" Padding="20,0"
                                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                    Command="{Binding SubmitBlockCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="#00875A" CornerRadius="8"
                                                Padding="{TemplateBinding Padding}"
                                                Height="{TemplateBinding Height}">
                                            <TextBlock Text="Разблокировать" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#006B47"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             CONFIRM OVERLAY — matches ConfirmDeleteDialog style
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="200"
              Visibility="{Binding IsConfirmOverlayOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="Transparent" MouseLeftButtonDown="ConfirmOverlayBackdrop_Click"/>
            <Border Background="White" Width="440"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" BorderBrush="#DFE1E6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="28" Opacity="0.18" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Header: red for destructive, blue for safe — with icon + close -->
                    <Border CornerRadius="12,12,0,0" Padding="24,20,24,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EBF2FF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConfirmIsDestructive}" Value="True">
                                        <Setter Property="Background" Value="#FFF5F5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <!-- Icon circle: red for destructive, blue for restore -->
                                <Border Width="40" Height="40" CornerRadius="20"
                                        Margin="0,0,14,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ConfirmIsDestructive}" Value="True">
                                                    <Setter Property="Background" Value="#FFEBE6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="↩"/>
                                                <Setter Property="Foreground" Value="#1D4ED8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConfirmIsDestructive}" Value="True">
                                                        <Setter Property="Text" Value="⚠"/>
                                                        <Setter Property="Foreground" Value="#DE350B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ConfirmTitle}"
                                               FontSize="16" FontWeight="Bold" Foreground="#000000"/>
                                    <TextBlock FontSize="12" Margin="0,3,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Это действие нельзя отменить"/>
                                                <Setter Property="Foreground" Value="#1D4ED8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConfirmIsDestructive}" Value="True">
                                                        <Setter Property="Text" Value="Это действие необратимо"/>
                                                        <Setter Property="Foreground" Value="#B91C1C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Command="{Binding CancelConfirmCommand}"
                                    Width="26" Height="26">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="13">
                                            <TextBlock Text="✕" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="#6B778C"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <!-- Content -->
                    <StackPanel Margin="24,16,24,0">
                        <Border Background="#F4F5F7" CornerRadius="8" Padding="14,12" Margin="0,0,0,0">
                            <TextBlock Text="{Binding ConfirmEntityName}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#000000"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <!-- Footer -->
                    <Border Padding="24,16,24,20">
                        <Grid>
                            <Button HorizontalAlignment="Left" Height="38" Padding="20,0"
                                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                    Command="{Binding CancelConfirmCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="White" CornerRadius="8"
                                                BorderBrush="#DFE1E6" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}"
                                                Height="{TemplateBinding Height}">
                                            <TextBlock Text="Отмена" Foreground="#000000"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button HorizontalAlignment="Right" Height="38" Padding="20,0"
                                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                    Content="{Binding ConfirmButtonText}"
                                    Command="{Binding ExecuteConfirmCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="8"
                                                Padding="{TemplateBinding Padding}"
                                                Height="{TemplateBinding Height}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1D4ED8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ConfirmIsDestructive}" Value="True">
                                                            <Setter Property="Background" Value="#DE350B"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding ConfirmIsDestructive}" Value="False"/>
                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#1E40AF"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding ConfirmIsDestructive}" Value="True"/>
                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#BF2600"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
