<UserControl x:Class="MPMS.Views.Pages.AdminPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:admin="clr-namespace:MPMS.Views.Components.Admin"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d"
             Background="#F4F5F7"
             d:DataContext="{d:DesignInstance Type=vm:AdminViewModel}"
             d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Components/Admin/AdminStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Root grid: main content + overlay layers -->
    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Tab bar -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>      <!-- Tab panels -->
            </Grid.RowDefinitions>

            <!-- ── Tab bar (matches ProjectDetailPage style) ──────────── -->
            <Border Grid.Row="0"
                    Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                    CornerRadius="8" Padding="6,4" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TabUsers"    GroupName="AdminMain" IsChecked="True"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Users">
                        Пользователи
                    </RadioButton>
                    <RadioButton x:Name="TabArchive"  GroupName="AdminMain" IsChecked="False"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Archive">
                        Архив
                    </RadioButton>
                    <RadioButton x:Name="TabHistory"  GroupName="AdminMain" IsChecked="False"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="History">
                        История
                    </RadioButton>
                    <RadioButton x:Name="TabActivity" GroupName="AdminMain" IsChecked="False"
                                 Style="{StaticResource TabButton}" Click="Tab_Click" Tag="Activity">
                        Активность
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ── Tab panels ─────────────────────────────────────────── -->
            <Grid Grid.Row="2">
                <admin:AdminUsersPanel    x:Name="UsersPanel"    Visibility="Visible"/>
                <admin:AdminArchivePanel  x:Name="ArchivePanel"  Visibility="Collapsed"/>
                <admin:AdminHistoryPanel  x:Name="HistoryPanel"  Visibility="Collapsed"/>
                <admin:AdminActivityPanel x:Name="ActivityPanel" Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             OVERLAYS (Confirmations, Blocking, etc.)
        ═══════════════════════════════════════════════════════════════════ -->
        <admin:AdminOverlays/>

    </Grid>
</UserControl>
