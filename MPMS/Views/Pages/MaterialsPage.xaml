<UserControl x:Class="MPMS.Views.Pages.MaterialsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Материалы" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Materials.Count, StringFormat='Всего: {0}'}"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="＋  Добавить материал"
                        Style="{StaticResource PrimaryButton}"
                        Click="CreateMaterial_Click"
                        Height="36" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Search -->
        <Border Grid.Row="1" Background="Transparent" Padding="24,6,24,10">
            <Border Background="#F4F5F7" CornerRadius="6"
                    Padding="10,0" Width="280" Height="36" HorizontalAlignment="Left"
                    BorderThickness="1.5" BorderBrush="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="#6B778C"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent"
                             VerticalAlignment="Center" FontSize="13" Foreground="#000000"
                             GotFocus="SearchBox_GotFocus"
                             LostFocus="SearchBox_LostFocus"/>
                    <Button Grid.Column="2" Click="ClearSearch_Click"
                            Visibility="{Binding SearchText, Converter={StaticResource StringToVis}}"
                            Width="20" Height="20" Margin="4,0,0,0"
                            Style="{StaticResource IconButton}">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" Foreground="#6B778C"/>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- Materials List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Content>
                <ItemsControl ItemsSource="{Binding Materials}" Margin="24,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                Padding="16,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Ед. изм." FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Unit}" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                           Text="{Binding Description}"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Button ToolTip="Редактировать"
                                            Tag="{Binding}" Click="EditMaterial_Click"
                                            Margin="0,0,4,0" Style="{StaticResource IconButton}">
                                        <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                               Width="14" Height="14"
                                               VerticalAlignment="Center"
                                               Opacity="0.85"/>
                                    </Button>
                                    <Button ToolTip="Удалить"
                                            Tag="{Binding}" Click="DeleteMaterial_Click"
                                            Style="{StaticResource DangerIconButton}">
                                        <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                               Width="14" Height="14"
                                               VerticalAlignment="Center"
                                               Opacity="0.9"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer.Content>
        </ScrollViewer>
    </Grid>
</UserControl>
