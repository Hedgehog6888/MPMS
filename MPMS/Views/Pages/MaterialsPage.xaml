<UserControl x:Class="MPMS.Views.Pages.MaterialsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <Grid Background="#F4F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PAGE HEADER -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Материалы" FontSize="24" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock Text="Справочник материалов и остатков"
                               FontSize="13" Foreground="#6B778C" Margin="0,3,0,0"/>
                </StackPanel>
                <Button x:Name="AddMaterialBtn" Click="CreateMaterial_Click" Height="38" Padding="18,0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Grid.Column="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#111111" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить материал" Foreground="White"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,12,0,24" ClipToBounds="True">
            <ScrollViewer x:Name="MainListScroll"
                          VerticalScrollBarVisibility="Visible"
                          Padding="0,62,24,0"
                          Background="Transparent"
                          Panel.ZIndex="0">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Materials}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                        Padding="16,12"
                                        BorderBrush="#DFE1E6" BorderThickness="1.5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#000000"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Ед. изм." FontSize="11"
                                                       Foreground="#6B778C"/>
                                            <TextBlock Text="{Binding Unit}" FontSize="13"
                                                       Foreground="#000000"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   Text="{Binding Description}"
                                                   FontSize="13" Foreground="#6B778C"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Button ToolTip="Редактировать"
                                                    Tag="{Binding}" Click="EditMaterial_Click"
                                                    Margin="0,0,4,0" Style="{StaticResource IconButton}">
                                                <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                       Width="14" Height="14"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.85"/>
                                            </Button>
                                            <Button ToolTip="Удалить"
                                                    Tag="{Binding}" Click="DeleteMaterial_Click"
                                                    Style="{StaticResource DangerIconButton}">
                                                <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                       Width="14" Height="14"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.9"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40"
                                Visibility="{Binding Materials.Count, Converter={StaticResource IntToVisInv}}">
                        <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                               Width="48" Height="48" HorizontalAlignment="Center" Opacity="0.4"/>
                        <TextBlock Text="Материалы не найдены" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                        <TextBlock Text="Добавьте материал или измените фильтры"
                                   FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border VerticalAlignment="Top" Panel.ZIndex="1"
                    HorizontalAlignment="Left"
                    Width="{Binding ElementName=MainListScroll, Path=ViewportWidth}"
                    Background="White" CornerRadius="8"
                    BorderBrush="#DFE1E6" BorderThickness="1"
                    Padding="16,10,16,14"
                    PreviewMouseWheel="FilterBar_PreviewMouseWheel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.14" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#F4F5F7" CornerRadius="6"
                            Padding="10,0" Height="36" Margin="0,0,10,0"
                            BorderThickness="1.5" BorderBrush="Transparent"
                            VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="#6B778C"/>
                            <Grid Grid.Column="1" Margin="0,0,4,0">
                                <TextBlock Text="Поиск по названию материала или описанию..."
                                           Foreground="#6B778C" FontSize="12"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" FontSize="13"
                                         Foreground="#000000"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"/>
                            </Grid>
                            <Button Grid.Column="2" Click="ClearSearch_Click"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVis}}"
                                    Width="20" Height="20" Margin="0,0,0,0"
                                    Style="{StaticResource IconButton}">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#6B778C"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding CategoryFilterOptions}"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectedValue="{Binding CategoryFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding UnitFilterOptions}"
                              SelectedItem="{Binding UnitFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding StockFilterOptions}"
                              SelectedItem="{Binding StockFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="180"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
