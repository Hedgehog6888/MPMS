<UserControl x:Class="MPMS.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:infra="clr-namespace:MPMS.Infrastructure"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" >
             <!-- d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}" -->

    <UserControl.Resources>
        <infra:ActivityLogToAccentBrushConverter x:Key="ActivityLogToAccentBrush"/>
        <infra:HexToBrushConverter x:Key="HexToBrush"/>
        <infra:AvatarBytesToImageSourceConverter x:Key="AvatarBytesToImage"/>
        <infra:NullToVisibilityConverter x:Key="NullToVis"/>
        <infra:NullToVisibilityConverter x:Key="NullToVisInv" Invert="True"/>
        <infra:EntityTypeToBadgeLabelConverter x:Key="EntityTypeToLabel"/>
        <infra:ActorRoleToBrushConverter x:Key="ActorRoleToBrush"/>
        <infra:ActorRoleToForegroundBrushConverter x:Key="ActorRoleToForegroundBrush"/>
        <infra:ActorRoleToLabelConverter x:Key="ActorRoleToLabel"/>
        <infra:DateTimeToRelativeConverter x:Key="DateTimeToRelative"/>
        <infra:DateOnlyToStringConverter x:Key="DateOnlyToString"/>
        <infra:ProjectStatusToStringConverter x:Key="ProjectStatusToString"/>
        <infra:ProjectStatusToBrushConverter x:Key="ProjectStatusToBrush"/>
        <infra:ProgressPercentToBrushConverter x:Key="ProgressPercentToBrush"/>
        <infra:IntGreaterThanZeroConverter x:Key="IntToVis"/>
        <infra:IntGreaterThanZeroConverter x:Key="IntToVisInv" Invert="True"/>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <infra:IntToStarGridLengthConverter x:Key="IntToStar"/>

        <!-- Stat Card Style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="FormatButton" TargetType="ButtonBase">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0.5,1"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#EEF0F3"/>
                            </Trigger>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#111111"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="ToggleButton.IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NoteActionButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlackNoteButton" TargetType="Button" BasedOn="{StaticResource NoteActionButton}">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhiteNoteButton" TargetType="Button" BasedOn="{StaticResource NoteActionButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F5F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Premium Bento Card Styles -->
        <Style x:Key="BentoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20,18"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style x:Key="BentoTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <Style x:Key="BentoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111111"/>
        </Style>

        <Style x:Key="BentoIconContainer" TargetType="Border">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="BentoGlow" TargetType="Border">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="-20,-18,-20,-18"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Opacity" Value="0.3"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.5"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.8"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Slim ProgressBar template from projects -->
        <ControlTemplate x:Key="SlimPB" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                <Border x:Name="PART_Track" CornerRadius="3">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="3"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Premium Tooltip Style (Matching Sync Popup) -->
        <Style x:Key="PremiumTooltip" TargetType="ToolTip">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" Opacity="0.12" ShadowDepth="4" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TooltipHeaderSection" TargetType="Border">
            <Setter Property="CornerRadius" Value="10,10,0,0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Background" Value="#F8F9FA"/>
        </Style>

        <Style x:Key="TooltipHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#172B4D"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TooltipDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TooltipContentSection" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <Style x:Key="TooltipInfoBlock" TargetType="Border">
            <Setter Property="Background" Value="#F4F5F7"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <ScrollViewer x:Name="MainScroll" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Stretch" Padding="32,24,32,20">
            <Grid Height="{Binding ViewportHeight, ElementName=MainScroll}" MinHeight="500">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- ── WELCOME BANNER ───────────────────────────────────── -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <!-- Left side: Greeting and Date -->
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding WelcomeMessage}" FontSize="28" FontWeight="Bold" Foreground="#111111"/>
                        <TextBlock Text="{Binding CurrentDateText}" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Right side: Clock (aligned with date row) -->
                    <TextBlock Text="{Binding CurrentTime}" FontSize="28" FontWeight="Light" Foreground="#111111" 
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>

                <!-- ── ROLE-AWARE STATS PULSE ───────────────────────────── -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                    <!-- Card 1: Status Line -->
                    <Border Style="{StaticResource BentoCardStyle}" Background="White">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource PremiumTooltip}" ToolTipService.InitialShowDelay="400">
                                <StackPanel Width="280">
                                    <!-- Header matching Sync Popup -->
                                    <Border Style="{StaticResource TooltipHeaderSection}" Background="#EFF6FF">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Card1TooltipHeader}" Style="{StaticResource TooltipHeader}"/>
                                            <TextBlock Text="{Binding Card1TooltipDesc}" Style="{StaticResource TooltipDesc}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{StaticResource TooltipContentSection}">
                                        <StackPanel>
                                            <TextBlock Text="ДЕТАЛИЗАЦИЯ ПО СТАТУСАМ" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                            <Border Style="{StaticResource TooltipInfoBlock}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Ellipse Grid.Row="0" Width="8" Height="8" Fill="#10B981" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Завершено:" FontSize="11" Foreground="#333333"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Card1Completed}" FontWeight="Bold" FontSize="11" Foreground="#10B981" HorizontalAlignment="Right"/>

                                                    <Ellipse Grid.Row="1" Width="8" Height="8" Fill="#3B82F6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Выполняется:" FontSize="11" Foreground="#333333" Margin="0,6"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Card1InProgress}" FontWeight="Bold" FontSize="11" Foreground="#3B82F6" Margin="0,6" HorizontalAlignment="Right"/>

                                                    <Ellipse Grid.Row="2" Width="8" Height="8" Fill="#64748B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Запланировано:" FontSize="11" Foreground="#333333"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Card1Planned}" FontWeight="Bold" FontSize="11" Foreground="#333333" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                            <Border Margin="0,12,0,0" Padding="0,12,0,0" BorderBrush="#F4F5F7" BorderThickness="0,1,0,0">
                                                <TextBlock Text="{Binding Card1Total, StringFormat='ВСЕГО ОБЪЕКТОВ: {0}'}" FontSize="10" FontWeight="Bold" Foreground="#333333"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <Grid>
                            <StackPanel VerticalAlignment="Top" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Card1Title}" Style="{StaticResource BentoTitle}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                                    <TextBlock Text="{Binding Card1Value}" Style="{StaticResource BentoValue}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Card1SubValue}" FontSize="11" Foreground="#64748B" Opacity="0.7"/>
                                
                                <!-- Segmented Progress Line (Styled as project SlimPB with non-distorted rounding) -->
                                <ProgressBar Value="100" Maximum="100" Height="6" 
                                             Background="#E9ECEF" Margin="0,8,0,0"
                                             Template="{StaticResource SlimPB}">
                                    <ProgressBar.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#10B981" Offset="{Binding Card1DoneOffset}"/>
                                            <GradientStop Color="#3B82F6" Offset="{Binding Card1DoneOffset}"/>
                                            <GradientStop Color="#3B82F6" Offset="{Binding Card1InProgressOffset}"/>
                                            <GradientStop Color="#CBD5E1" Offset="{Binding Card1InProgressOffset}"/>
                                            <GradientStop Color="#CBD5E1" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </ProgressBar.Foreground>
                                </ProgressBar>
                            </StackPanel>
                            <Border Style="{StaticResource BentoGlow}">
                                <Border.Background>
                                    <RadialGradientBrush Center="1,0" GradientOrigin="1,0" RadiusX="1.2" RadiusY="1.5">
                                        <GradientStop Color="#503B82F6" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border Style="{StaticResource BentoIconContainer}">
                                <Image Source="{svgc:SvgImage Source=/icons/list_blue.svg, AppName=MPMS}" Width="24" Height="24" Opacity="0.8"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Card 2: Next Action / Deletion (Admin) -->
                    <Border Style="{StaticResource BentoCardStyle}" Background="White">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource PremiumTooltip}" ToolTipService.InitialShowDelay="400">
                                <StackPanel Width="280">
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource TooltipHeaderSection}">
                                                <Setter Property="Background" Value="#F5F3FF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                        <Setter Property="Background" Value="#FFF1F0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Card2TooltipHeader}" Style="{StaticResource TooltipHeader}"/>
                                            <TextBlock Text="{Binding Card2TooltipDesc}" Style="{StaticResource TooltipDesc}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource TooltipContentSection}">
                                        <Grid>
                                            <!-- Standard Next Action -->
                                            <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisInv}}">
                                                <TextBlock Text="СЛЕДУЮЩИЙ ШАГ" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                                <Border Style="{StaticResource TooltipInfoBlock}">
                                                    <TextBlock Text="{Binding Card2Value}" FontSize="12" FontWeight="SemiBold" Foreground="#333333" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                            
                                            <!-- Admin Deletion Breakdown -->
                                            <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="ДЕТАЛИЗАЦИЯ ПО ТИПАМ" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                                <Border Style="{StaticResource TooltipInfoBlock}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Ellipse Grid.Row="0" Width="8" Height="8" Fill="#EF4444" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Проекты:" FontSize="11" Foreground="#333333"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Card2Segment1}" FontWeight="Bold" FontSize="11" Foreground="#EF4444" HorizontalAlignment="Right"/>

                                                        <Ellipse Grid.Row="1" Width="8" Height="8" Fill="#F59E0B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Задачи:" FontSize="11" Foreground="#333333" Margin="0,6"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Card2Segment2}" FontWeight="Bold" FontSize="11" Foreground="#F59E0B" Margin="0,6" HorizontalAlignment="Right"/>

                                                        <Ellipse Grid.Row="2" Width="8" Height="8" Fill="#64748B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Этапы:" FontSize="11" Foreground="#333333"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Card2Segment3}" FontWeight="Bold" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <Grid>
                            <StackPanel VerticalAlignment="Top" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Card2Title}" Style="{StaticResource BentoTitle}"/>
                                <TextBlock Text="{Binding Card2Value}" TextTrimming="CharacterEllipsis" MaxWidth="160" HorizontalAlignment="Left" Margin="0,2,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BentoValue}">
                                            <Setter Property="FontSize" Value="18"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                    <Setter Property="FontSize" Value="24"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Card2SubValue}" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource BentoGlow}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <RadialGradientBrush Center="1,0" GradientOrigin="1,0" RadiusX="1.2" RadiusY="1.5">
                                                    <GradientStop Color="#508B5CF6" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <RadialGradientBrush Center="1,0" GradientOrigin="1,0" RadiusX="1.2" RadiusY="1.5">
                                                            <GradientStop Color="#50EF4444" Offset="0"/>
                                                            <GradientStop Color="Transparent" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <!-- Explicitly re-add hover trigger since BasedOn might not merge triggers correctly in some XAML contexts -->
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.5"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.8"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <Border Style="{StaticResource BentoIconContainer}">
                                <Image Width="24" Height="24" Opacity="0.8">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/time_purple.svg, AppName=MPMS}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                    <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/trash_red.svg, AppName=MPMS}"/>
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Card 3: Attention Required -->
                    <Border Style="{StaticResource BentoCardStyle}" Background="White">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource PremiumTooltip}" ToolTipService.InitialShowDelay="400">
                                <StackPanel Width="280">
                                    <Border Style="{StaticResource TooltipHeaderSection}" Background="#FFFBEB">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Card3TooltipHeader}" Style="{StaticResource TooltipHeader}"/>
                                            <TextBlock Text="{Binding Card3TooltipDesc}" Style="{StaticResource TooltipDesc}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource TooltipContentSection}">
                                        <StackPanel>
                                            <TextBlock Text="РАСПРЕДЕЛЕНИЕ ПО УРОВНЯМ" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                            <Border Style="{StaticResource TooltipInfoBlock}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Ellipse Grid.Row="0" Width="8" Height="8" Fill="#EF4444" Margin="0,0,10,0" VerticalAlignment="Center" Visibility="{Binding Card3Segment1Label, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Card3Segment1Label}" FontSize="11" Foreground="#333333" Visibility="{Binding Card3Segment1Label, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Card3Segment1}" FontWeight="Bold" FontSize="11" Foreground="#EF4444" HorizontalAlignment="Right" Visibility="{Binding Card3Segment1Label, Converter={StaticResource NullToVis}}"/>

                                                    <Ellipse Grid.Row="1" Width="8" Height="8" Fill="#F59E0B" Margin="0,0,10,0" VerticalAlignment="Center" Visibility="{Binding Card3Segment2Label, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Card3Segment2Label}" FontSize="11" Foreground="#333333" Margin="0,6" Visibility="{Binding Card3Segment2Label, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Card3Segment2}" FontWeight="Bold" FontSize="11" Foreground="#F59E0B" Margin="0,6" HorizontalAlignment="Right" Visibility="{Binding Card3Segment2Label, Converter={StaticResource NullToVis}}"/>

                                                    <Ellipse Grid.Row="2" Width="8" Height="8" Fill="#64748B" Margin="0,0,10,0" VerticalAlignment="Center" Visibility="{Binding Card3Segment3Label, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Card3Segment3Label}" FontSize="11" Foreground="#333333" Visibility="{Binding Card3Segment3Label, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Card3Segment3}" FontWeight="Bold" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" Visibility="{Binding Card3Segment3Label, Converter={StaticResource NullToVis}}"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <Grid>
                            <StackPanel VerticalAlignment="Top" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Card3Title}" Style="{StaticResource BentoTitle}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                                    <TextBlock Text="{Binding Card3Value}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BentoValue}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Card3Value, Converter={StaticResource IntToVis}}" Value="Visible">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding Card3SubValue}" FontSize="11" Foreground="#64748B" Opacity="0.7"/>

                                <!-- Risk Breakdown Line (Styled as project SlimPB with non-distorted rounding) -->
                                <ProgressBar Value="100" Maximum="100" Height="6" 
                                             Background="#E9ECEF" Margin="0,8,0,0"
                                             Template="{StaticResource SlimPB}">
                                    <ProgressBar.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#EF4444" Offset="0"/>
                                            <GradientStop Color="#EF4444" Offset="{Binding Card3Offset1}"/>
                                            <GradientStop Color="#F59E0B" Offset="{Binding Card3Offset1}"/>
                                            <GradientStop Color="#F59E0B" Offset="{Binding Card3Offset2}"/>
                                            <GradientStop Color="#64748B" Offset="{Binding Card3Offset2}"/>
                                            <GradientStop Color="#64748B" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </ProgressBar.Foreground>
                                </ProgressBar>
                            </StackPanel>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource BentoGlow}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <RadialGradientBrush Center="1,0" GradientOrigin="1,0" RadiusX="1.2" RadiusY="1.5">
                                                    <GradientStop Color="#50F59E0B" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Card3Value, Converter={StaticResource IntToVis}}" Value="Visible">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <RadialGradientBrush Center="1,0" GradientOrigin="1,0" RadiusX="1.2" RadiusY="1.5">
                                                            <GradientStop Color="#50EF4444" Offset="0"/>
                                                            <GradientStop Color="Transparent" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <!-- Explicitly re-add hover trigger -->
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.5"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.8"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <Border Style="{StaticResource BentoIconContainer}">
                                <Image Source="{svgc:SvgImage Source=/icons/sync_warning.svg, AppName=MPMS}" Width="24" Height="24">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Opacity" Value="0.8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Card3Value, Converter={StaticResource IntToVis}}" Value="Visible">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Card 4: System Status -->
                    <Border Style="{StaticResource BentoCardStyle}" Background="White" Margin="0,0,0,0">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource PremiumTooltip}" ToolTipService.InitialShowDelay="400">
                                <StackPanel Width="280">
                                    <Border Style="{StaticResource TooltipHeaderSection}" Background="#F0FDF4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Card4TooltipHeader}" Style="{StaticResource TooltipHeader}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Card4TooltipDesc}" Style="{StaticResource TooltipDesc}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource TooltipContentSection}">
                                        <StackPanel>
                                            <TextBlock Text="ПАРАМЕТРЫ СЕТИ" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                            <Border Style="{StaticResource TooltipInfoBlock}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Синхронизация:" FontSize="11" Foreground="#64748B"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding LastSyncTime}" FontSize="11" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                            <Border Margin="0,12,0,0" Padding="0,12,0,0" BorderBrush="#F4F5F7" BorderThickness="0,1,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#10B981"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                        <Setter Property="Fill" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock FontSize="10" FontWeight="Bold" Foreground="#333333">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="СИСТЕМА ОНЛАЙН"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                        <Setter Property="Text" Value="АВТОНОМНЫЙ РЕЖИМ"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <Grid>
                            <StackPanel VerticalAlignment="Top" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Card4Title}" Style="{StaticResource BentoTitle}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                                    <Ellipse Width="8" Height="8" Margin="0,0,8,6" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#10B981"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                        <Setter Property="Fill" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Card4Value}" Style="{StaticResource BentoValue}" FontSize="18"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Card4SubValue}" FontSize="11" Foreground="#64748B" Opacity="0.7"/>
                            </StackPanel>
                            <Border Style="{StaticResource BentoGlow}">
                                <Border.Background>
                                    <RadialGradientBrush Center="1,0" GradientOrigin="1,0" RadiusX="1.2" RadiusY="1.5">
                                        <GradientStop Color="#5010B981" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border Style="{StaticResource BentoIconContainer}">
                                <Image Source="{svgc:SvgImage Source=/icons/sync_status_ok.svg, AppName=MPMS}" Width="24" Height="24" Opacity="0.8"/>
                            </Border>
                        </Grid>
                    </Border>
                </UniformGrid>
                <!-- ── ACTIVITY FEED SECTION ───────────────────────────────── -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*"/>
                        <ColumnDefinition Width="40*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 60% ACTIVITY FEED -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            Padding="16,12" MinHeight="300">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Последние действия"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#000000"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="Недавняя активность в системе"
                                           FontSize="12" Foreground="#64748B" Margin="0,0,0,14"/>
                            </StackPanel>

                            <Grid>
                                <!-- Activity list -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MouseWheel="PreventScrollBubbling">
                                    <ItemsControl ItemsSource="{Binding RecentActivities}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,6" CornerRadius="6"
                                                        Background="#F8F9FA"
                                                        BorderBrush="#EEF0F3" BorderThickness="1">
                                                    <Grid>
                                                        <!-- Colored left accent based on action type (delete, mark, etc.) or entity type -->
                                                        <Border Width="3" HorizontalAlignment="Left" CornerRadius="6,0,0,6"
                                                                Background="{Binding Converter={StaticResource ActivityLogToAccentBrush}}"/>
                                                        <Grid Margin="10,6,8,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Avatar: из БД (AvatarData) или инициалы — EllipseGeometry для идеального круга -->
                                                            <Border Margin="0,0,10,0" VerticalAlignment="Top">
                                                                <Border.Style>
                                                                    <Style TargetType="Border" BasedOn="{StaticResource AvatarCircle28}">
                                                                        <Setter Property="Background" Value="{Binding UserColor, Converter={StaticResource HexToBrush}}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AvatarData, Converter={StaticResource NullToVis}}" Value="{x:Static Visibility.Visible}">
                                                                                <Setter Property="Background" Value="Transparent"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <Image Style="{StaticResource AvatarImage}"
                                                                           Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                           Width="28" Height="28"
                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                    <TextBlock Text="{Binding UserInitials}"
                                                                               FontSize="10" FontWeight="Bold" Foreground="White"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                                </Grid>
                                                            </Border>
                                                            <!-- Entity badge + role badge + action text -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                                            Background="{Binding Converter={StaticResource ActivityLogToAccentBrush}}">
                                                                        <TextBlock Text="{Binding EntityType, Converter={StaticResource EntityTypeToLabel}}"
                                                                                   FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                                    </Border>
                                                                    <Border CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                                                                            Background="{Binding ActorRole, Converter={StaticResource ActorRoleToBrush}}"
                                                                            BorderBrush="{Binding ActorRole, Converter={StaticResource ActorRoleToForegroundBrush}}"
                                                                            BorderThickness="1"
                                                                            Visibility="{Binding ActorRole, Converter={StaticResource NullToVis}}">
                                                                        <TextBlock Text="{Binding ActorRole, Converter={StaticResource ActorRoleToLabel}}"
                                                                                   FontSize="9" FontWeight="SemiBold"
                                                                                   Foreground="{Binding ActorRole, Converter={StaticResource ActorRoleToForegroundBrush}}"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding UserName}"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               Foreground="#000000" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding ActionText}"
                                                                           FontSize="12" Foreground="#000000"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                            <!-- Time -->
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                                       FontSize="11" Foreground="#64748B"
                                                                       VerticalAlignment="Top" Margin="10,2,0,0"
                                                                       MinWidth="40"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Empty activities state -->
                                <Grid Visibility="{Binding RecentActivities.Count, Converter={StaticResource IntToVisInv}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Image Source="{svgc:SvgImage Source=/icons/empty_activities.svg, AppName=MPMS}" 
                                               Width="48" Height="48" Opacity="0.1" Margin="0,0,0,16"/>
                                        <TextBlock Text="История пуста" 
                                                   FontSize="15" FontWeight="SemiBold" Foreground="#111111" 
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Здесь будут отображаться последние&#x0a;действия в системе" 
                                                   FontSize="12" Foreground="#64748B" TextAlignment="Center" 
                                                   Margin="0,8,0,0" LineHeight="18"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <!-- 40% SIDE PANEL (My Notes) -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            Margin="16,0,0,0" Padding="16,12" MinHeight="300">
                        <Grid>
                            <!-- ── LIST VIEW ────────────────────────────────────── -->
                            <DockPanel Visibility="{Binding IsNoteEditing, Converter={StaticResource BoolToVisInv}}">
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Личные заметки" FontSize="14" FontWeight="SemiBold" Foreground="#111111" Margin="0,0,0,2"/>
                                        <TextBlock Text="Быстрые записи и идеи" FontSize="12" Foreground="#64748B"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding CreateNoteCommand}" HorizontalAlignment="Right" Style="{StaticResource BlackNoteButton}" ToolTip="Новая заметка">
                                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}" Width="14" Height="14"/>
                                    </Button>
                                </Grid>

                                <Grid>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MouseWheel="PreventScrollBubbling">
                                        <ItemsControl ItemsSource="{Binding Notes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.SelectNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="0" Background="Transparent" BorderThickness="0" 
                                                            HorizontalContentAlignment="Stretch">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Grid x:Name="Root" Background="Transparent">
                                                                    <!-- Линия-разделитель внизу каждого слота -->
                                                                    <Border x:Name="Separator" Height="1" Background="#EEF0F3" VerticalAlignment="Bottom" Margin="12,0"/>
                                                                    
                                                                    <!-- Основная плашка заметки -->
                                                                    <Border x:Name="NoteBorder" Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,1">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold" Foreground="#111111" TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Text="{Binding DisplayDate}" FontSize="11" Foreground="#64748B" Margin="0,4,0,0"/>
                                                                            </StackPanel>

                                                                            <!-- Delete Actions -->
                                                                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                                                                <!-- Trigger for Confirm State -->
                                                                                <CheckBox x:Name="ConfirmDeleteCheck" Visibility="Collapsed"/>
                                                                                
                                                                                <!-- Initial Trash Button -->
                                                                                <Button x:Name="DeleteBtn" Style="{StaticResource WhiteNoteButton}" Width="28" Height="28" Padding="0" Visibility="Collapsed" ToolTip="Удалить">
                                                                                    <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}" Width="14" Height="14" Opacity="0.9"/>
                                                                                    <Button.Triggers>
                                                                                        <EventTrigger RoutedEvent="Button.Click">
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ConfirmDeleteCheck" Storyboard.TargetProperty="IsChecked">
                                                                                                        <DiscreteBooleanKeyFrame KeyTime="0" Value="True"/>
                                                                                                    </BooleanAnimationUsingKeyFrames>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </EventTrigger>
                                                                                    </Button.Triggers>
                                                                                </Button>

                                                                                <!-- Confirm/Cancel Group -->
                                                                                <StackPanel x:Name="ConfirmPanel" Orientation="Horizontal" Visibility="Collapsed">
                                                                                    <Button Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                            CommandParameter="{Binding}"
                                                                                            Style="{StaticResource WhiteNoteButton}" Width="28" Height="28" Padding="0" ToolTip="Подтвердить">
                                                                                        <Image Source="{svgc:SvgImage Source=/icons/note_confirm.svg, AppName=MPMS}" Width="14" Height="14" Opacity="0.9"/>
                                                                                    </Button>
                                                                                    <Button Style="{StaticResource WhiteNoteButton}" Width="28" Height="28" Padding="0" Margin="4,0,0,0" ToolTip="Отмена">
                                                                                        <Image Source="{svgc:SvgImage Source=/icons/note_cancel.svg, AppName=MPMS}" Width="14" Height="14" Opacity="0.9"/>
                                                                                        <Button.Triggers>
                                                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                                                <BeginStoryboard>
                                                                                                    <Storyboard>
                                                                                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ConfirmDeleteCheck" Storyboard.TargetProperty="IsChecked">
                                                                                                            <DiscreteBooleanKeyFrame KeyTime="0" Value="False"/>
                                                                                                        </BooleanAnimationUsingKeyFrames>
                                                                                                    </Storyboard>
                                                                                                </BeginStoryboard>
                                                                                            </EventTrigger>
                                                                                        </Button.Triggers>
                                                                                    </Button>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Grid>
                                                                    </Border>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Panel.ZIndex" Value="10"/>
                                                                        <Setter TargetName="NoteBorder" Property="Background" Value="#F4F5F7"/>
                                                                        <Setter TargetName="NoteBorder" Property="Margin" Value="0,0"/>
                                                                        <Setter TargetName="NoteBorder" Property="Padding" Value="12,11"/>
                                                                        <Setter TargetName="Separator" Property="Visibility" Value="Hidden"/>
                                                                        <Setter TargetName="DeleteBtn" Property="Visibility" Value="Visible"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=ConfirmDeleteCheck}" Value="True">
                                                                        <Setter TargetName="ConfirmPanel" Property="Visibility" Value="Visible"/>
                                                                        <Setter TargetName="DeleteBtn" Property="Visibility" Value="Collapsed"/>
                                                                        <!-- Keep the hover state visible while confirming -->
                                                                        <Setter Property="Panel.ZIndex" Value="10"/>
                                                                        <Setter TargetName="NoteBorder" Property="Background" Value="#F4F5F7"/>
                                                                        <Setter TargetName="NoteBorder" Property="Margin" Value="0,0"/>
                                                                        <Setter TargetName="NoteBorder" Property="Padding" Value="12,11"/>
                                                                        <Setter TargetName="Separator" Property="Visibility" Value="Hidden"/>
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Empty state -->
                                    <Grid Visibility="{Binding Notes.Count, Converter={StaticResource IntToVisInv}}">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Image Source="{svgc:SvgImage Source=/icons/empty_notes.svg, AppName=MPMS}" 
                                                   Width="48" Height="48" Opacity="0.1" Margin="0,0,0,16"/>
                                            <TextBlock Text="Заметок пока нет" 
                                                       FontSize="15" FontWeight="SemiBold" Foreground="#0F172A" 
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Нажмите «+» в углу, чтобы&#x0a;создать первую запись" 
                                                       FontSize="12" Foreground="#64748B" TextAlignment="Center" 
                                                       Margin="0,8,0,0" LineHeight="18"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DockPanel>

                            <!-- ── EDITOR VIEW ──────────────────────────────────── -->
                            <DockPanel Visibility="{Binding IsNoteEditing, Converter={StaticResource BoolToVis}}">
                                <!-- Header -->
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                                    <Button x:Name="BackBtn" Command="{Binding BackToListCommand}" Style="{StaticResource WhiteNoteButton}" HorizontalAlignment="Left" ToolTip="Назад">
                                        <Image Source="{svgc:SvgImage Source=/icons/back_arrow_thin.svg, AppName=MPMS}" Width="18" Height="18"/>
                                    </Button>
                                    
                                    <Border Margin="38,0,40,0" Padding="0,2" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#DFE1E6"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter Property="BorderBrush" Value="#111111"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <TextBlock Text="Название" FontSize="14" FontWeight="Bold" Foreground="#64748B" 
                                                       IsHitTestVisible="False" VerticalAlignment="Center" Opacity="0.5">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=NoteTitleTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Text, ElementName=NoteTitleTextBox}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox x:Name="NoteTitleTextBox" Text="{Binding SelectedNote.Title, UpdateSourceTrigger=PropertyChanged}" 
                                                     FontSize="14" FontWeight="Bold" BorderThickness="0" Background="Transparent"
                                                     VerticalAlignment="Center" MaxLength="100" SelectionBrush="#DFE1E6"/>
                                        </Grid>
                                    </Border>

                                    <Button Command="{Binding SaveNoteCommand}" HorizontalAlignment="Right" Style="{StaticResource WhiteNoteButton}" ToolTip="Сохранить">
                                        <Image Source="{svgc:SvgImage Source=/icons/save_note.svg, AppName=MPMS}" Width="16" Height="16"/>
                                    </Button>
                                </Grid>

                                <!-- Toolbar -->
                                                                <Border DockPanel.Dock="Top" Background="#F8F9FA" CornerRadius="6" Padding="2" Margin="0,0,0,10" BorderBrush="#DFE1E6" BorderThickness="1" HorizontalAlignment="Center">
                                     <Border.Style>
                                         <Style TargetType="Border">
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=NoteTitleTextBox}" Value="True">
                                                     <Setter Property="IsEnabled" Value="False"/>
                                                     <Setter Property="Opacity" Value="0.5"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </Border.Style>

                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton x:Name="BoldBtn" Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=NotesRTB}" Click="FormatButton_Click" ToolTip="Жирный (Ctrl+B)" Style="{StaticResource FormatButton}">
                                            <TextBlock Text="B" FontWeight="Bold" FontSize="14"/>
                                        </ToggleButton>
                                        <ToggleButton x:Name="ItalicBtn" Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=NotesRTB}" Click="FormatButton_Click" ToolTip="Курсив (Ctrl+I)" Style="{StaticResource FormatButton}">
                                            <TextBlock Text="I" FontStyle="Italic" FontSize="14" FontFamily="Georgia"/>
                                        </ToggleButton>
                                        <ToggleButton x:Name="UnderlineBtn" Command="EditingCommands.ToggleUnderline" CommandTarget="{Binding ElementName=NotesRTB}" Click="FormatButton_Click" ToolTip="Подчеркнутый (Ctrl+U)" Style="{StaticResource FormatButton}">
                                            <TextBlock Text="U" TextDecorations="Underline" FontSize="14"/>
                                        </ToggleButton>
                                        <ToggleButton x:Name="StrikethroughBtn" Click="Strikethrough_Click" ToolTip="Зачеркнутый" Style="{StaticResource FormatButton}">
                                            <Image x:Name="StrikethroughIcon" Width="14" Height="14">
                                                 <Image.Style>
                                                     <Style TargetType="Image">
                                                         <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/strikethrough.svg, AppName=MPMS}"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                 <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/strikethrough_white.svg, AppName=MPMS}"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Image.Style>
                                             </Image>
                                        </ToggleButton>
                                        <ToggleButton x:Name="HighlightBtn" Click="Highlight_Click" ToolTip="Маркер" Style="{StaticResource FormatButton}">
                                            <Image Width="16" Height="16">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/marker.svg, AppName=MPMS}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/marker_white.svg, AppName=MPMS}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </ToggleButton>
                                        <Border Width="1" Background="#D1D4D9" Margin="3,5"/>
                                        <ToggleButton x:Name="BulletsBtn" Command="EditingCommands.ToggleBullets" CommandTarget="{Binding ElementName=NotesRTB}" Click="FormatButton_Click" ToolTip="Маркированный список" Style="{StaticResource FormatButton}">
                                            <Image Width="14" Height="14">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/list_bullet.svg, AppName=MPMS}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/list_bullet_white.svg, AppName=MPMS}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </ToggleButton>
                                        <ToggleButton x:Name="NumberingBtn" Command="EditingCommands.ToggleNumbering" CommandTarget="{Binding ElementName=NotesRTB}" Click="FormatButton_Click" ToolTip="Нумерованный список" Style="{StaticResource FormatButton}">
                                            <TextBlock Text="1." FontSize="12" FontWeight="Bold"/>
                                        </ToggleButton>
                                        <ToggleButton x:Name="ChecklistBtn" Click="Checklist_Click" ToolTip="Чек-лист" Style="{StaticResource FormatButton}">
                                            <Image Width="14" Height="14">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/checkbox_check.svg, AppName=MPMS}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                <Setter Property="Source" Value="{svgc:SvgImage Source=/icons/checkbox_check_white.svg, AppName=MPMS}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </ToggleButton>
                                        <Border Width="1" Background="#D1D4D9" Margin="3,5"/>
                                        <ToggleButton x:Name="BlockquoteBtn" Click="Blockquote_Click" ToolTip="Цитата" Style="{StaticResource FormatButton}">
                                            <TextBlock Text="“" FontSize="30" FontWeight="Bold" Margin="0,-4,0,0"/>
                                        </ToggleButton>
                                        <Border Width="1" Background="#D1D4D9" Margin="3,5"/>
                                        <Button Click="ClearFormatting_Click" ToolTip="Очистить форматирование" Style="{StaticResource FormatButton}">
                                            <Image Source="{svgc:SvgImage Source=/icons/eraser.svg, AppName=MPMS}" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Editor -->
                                <RichTextBox x:Name="NotesRTB" 
                                             infra:RichTextHelper.DocumentXaml="{Binding CurrentNoteXaml}"
                                             Loaded="NotesRichTextBox_Loaded"
                                             SelectionChanged="NotesRTB_SelectionChanged"
                                             BorderThickness="0" AcceptsTab="True" 
                                             VerticalScrollBarVisibility="Auto" 
                                             MouseWheel="PreventScrollBubbling"
                                             FontSize="13" Foreground="#0F172A" SelectionBrush="#DFE1E6">
                                    <RichTextBox.Resources>
                                        <Style TargetType="{x:Type Paragraph}">
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="LineHeight" Value="1.4"/>
                                        </Style>
                                        <Style TargetType="{x:Type List}">
                                            <Setter Property="Margin" Value="25,0,0,8"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </RichTextBox.Resources>
                                </RichTextBox>
                            </DockPanel>

                            <!-- Confirmation Overlay -->
                            <Border Background="Transparent" CornerRadius="8" Margin="-20,-16"
                                    Visibility="{Binding IsBackConfirmPopupOpen, Converter={StaticResource BoolToVis}}"
                                    UseLayoutRounding="True" SnapsToDevicePixels="True"
                                    TextOptions.TextFormattingMode="Display"
                                    RenderOptions.ClearTypeHint="Enabled"
                                    Panel.ZIndex="100">
                                <Border Background="White" VerticalAlignment="Top" HorizontalAlignment="Center" 
                                        Margin="0,80,0,0" Padding="24,20" CornerRadius="12" 
                                        BorderBrush="#DFE1E6" BorderThickness="1" Width="260">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="4" Direction="270"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Сохранить изменения?" FontSize="15" FontWeight="Bold" Foreground="#111111" Margin="0,0,0,18" HorizontalAlignment="Center" TextAlignment="Center"/>
                                        
                                        <Button Command="{Binding SaveNoteAndBackCommand}" Style="{StaticResource BlackNoteButton}" 
                                                Width="Auto" Height="38" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                            <TextBlock Text="Сохранить" FontSize="13" FontWeight="Bold"/>
                                        </Button>
                                        
                                        <Button Command="{Binding DiscardAndBackCommand}" Style="{StaticResource WhiteNoteButton}" 
                                                Width="Auto" Height="38" HorizontalAlignment="Stretch">
                                            <TextBlock Text="Не сохранять" FontSize="13" FontWeight="Bold"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
