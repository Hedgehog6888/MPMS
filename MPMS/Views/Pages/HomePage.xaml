<UserControl x:Class="MPMS.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:infra="clr-namespace:MPMS.Infrastructure"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" >
             <!-- d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}" -->

    <UserControl.Resources>
        <infra:ActivityLogToAccentBrushConverter x:Key="ActivityLogToAccentBrush"/>
        <infra:HexToBrushConverter x:Key="HexToBrush"/>
        <infra:AvatarBytesToImageSourceConverter x:Key="AvatarBytesToImage"/>
        <infra:NullToVisibilityConverter x:Key="NullToVis"/>
        <infra:NullToVisibilityConverter x:Key="NullToVisInv" Invert="True"/>
        <infra:EntityTypeToBadgeLabelConverter x:Key="EntityTypeToLabel"/>
        <infra:ActorRoleToBrushConverter x:Key="ActorRoleToBrush"/>
        <infra:ActorRoleToForegroundBrushConverter x:Key="ActorRoleToForegroundBrush"/>
        <infra:ActorRoleToLabelConverter x:Key="ActorRoleToLabel"/>
        <infra:DateTimeToRelativeConverter x:Key="DateTimeToRelative"/>
        <infra:DateOnlyToStringConverter x:Key="DateOnlyToString"/>
        <infra:ProjectStatusToStringConverter x:Key="ProjectStatusToString"/>
        <infra:ProjectStatusToBrushConverter x:Key="ProjectStatusToBrush"/>
        <infra:ProgressPercentToBrushConverter x:Key="ProgressPercentToBrush"/>
        <infra:IntGreaterThanZeroConverter x:Key="IntToVisInv" Invert="True"/>

        <!-- Stat Card Style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F5F7">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,20">
                
                <!-- ── WELCOME BANNER ───────────────────────────────────── -->
                <Grid Margin="0,0,0,8">
                    <!-- Left side: Greeting and Date -->
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding WelcomeMessage}" FontSize="28" FontWeight="Bold" Foreground="#111111"/>
                        <TextBlock Text="{Binding CurrentDateText}" FontSize="14" Foreground="#6B778C" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Right side: Clock (aligned with date row) -->
                    <TextBlock Text="{Binding CurrentTime}" FontSize="28" FontWeight="Light" Foreground="#111111" 
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>

                <!-- ── STATS ROW ────────────────────────────────────────── -->
                <UniformGrid Columns="4" Margin="0,0,0,16">
                    <!-- Active Projects -->
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Border Background="#E3F2FD" CornerRadius="8" Width="40" Height="40" HorizontalAlignment="Left">
                                    <Image Source="{svgc:SvgImage Source=/icons/project.svg, AppName=MPMS}" Width="20" Height="20"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Проекты в работе" Style="{StaticResource StatTitle}"/>
                            <TextBlock Text="{Binding ActiveProjectsCount}" Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </Border>

                    <!-- My Tasks -->
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Border Background="#E8F5E9" CornerRadius="8" Width="40" Height="40" HorizontalAlignment="Left">
                                    <Image Source="{svgc:SvgImage Source=/icons/tasks.svg, AppName=MPMS}" Width="20" Height="20"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Мои задачи" Style="{StaticResource StatTitle}"/>
                            <TextBlock Text="{Binding MyTasksCount}" Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </Border>

                    <!-- Deadlines -->
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Border Background="#FFF3E0" CornerRadius="8" Width="40" Height="40" HorizontalAlignment="Left">
                                    <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}" Width="20" Height="20"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Дедлайны (24ч)" Style="{StaticResource StatTitle}"/>
                            <TextBlock Text="{Binding UpcomingDeadlinesCount}" Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </Border>

                    <!-- Files -->
                    <Border Style="{StaticResource StatCard}" Margin="0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Border Background="#F3E5F5" CornerRadius="8" Width="40" Height="40" HorizontalAlignment="Left">
                                    <Image Source="{svgc:SvgImage Source=/icons/files.svg, AppName=MPMS}" Width="20" Height="20"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Всего файлов" Style="{StaticResource StatTitle}"/>
                            <TextBlock Text="{Binding TotalFilesCount}" Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── RECENT PROJECTS ──────────────────────────────────── -->
                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                        <TextBlock Text="Последние проекты" FontSize="18" FontWeight="Bold" Foreground="#111111" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding RecentProjects}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,12,12"
                                            BorderBrush="#DFE1E6" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="#111111" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Client}" FontSize="13" Foreground="#6B778C" Margin="0,2,0,8"/>
                                            
                                            <Grid Margin="0,8,0,0">
                                                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100" Height="6" Background="#F4F5F7"
                                                           Foreground="{Binding ProgressPercent, Converter={StaticResource ProgressPercentToBrush}, Mode=OneWay}"/>
                                            </Grid>
                                            <Grid Margin="0,4,0,0">
                                                <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}% выполнено'}" FontSize="11" Foreground="#6B778C"/>
                                                <TextBlock Text="{Binding Status, Converter={StaticResource ProjectStatusToString}}" 
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#1B6EC2" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── MY UPCOMING TASKS ────────────────────────────────── -->
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#DFE1E6" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Ближайшие задачи" FontSize="16" FontWeight="Bold" Foreground="#111111" Margin="0,0,0,16"/>
                            <ItemsControl ItemsSource="{Binding MyUpcomingTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,8" BorderBrush="#F4F5F7" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#111111" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding ProjectName}" FontSize="11" Foreground="#6B778C"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DueDate, Converter={StaticResource DateOnlyToString}}" FontSize="10" FontWeight="Bold" Foreground="#E65100"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="На сегодня задач нет 🎉" FontSize="13" Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,20"
                                       Visibility="{Binding MyUpcomingTasks.Count, Converter={StaticResource IntToVisInv}}"/>
                        </StackPanel>
                    </Border>
                </Grid>



                <!-- ── ACTIVITY FEED SECTION ───────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*"/>
                        <ColumnDefinition Width="40*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 60% ACTIVITY FEED -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="Последние действия"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#000000"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Недавняя активность в системе"
                                   FontSize="12" Foreground="#6B778C" Margin="0,0,0,14"/>

                        <!-- Activity list -->
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentActivities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="6"
                                            Background="#F8F9FA"
                                            BorderBrush="#EEF0F3" BorderThickness="1">
                                        <Grid>
                                            <!-- Colored left accent based on action type (delete, mark, etc.) or entity type -->
                                            <Border Width="3" HorizontalAlignment="Left" CornerRadius="6,0,0,6"
                                                    Background="{Binding Converter={StaticResource ActivityLogToAccentBrush}}"/>
                                            <Grid Margin="12,8,10,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Avatar: из БД (AvatarData) или инициалы — EllipseGeometry для идеального круга -->
                                                <Border Margin="0,0,10,0" VerticalAlignment="Top">
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource AvatarCircle28}">
                                                            <Setter Property="Background" Value="{Binding UserColor, Converter={StaticResource HexToBrush}}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AvatarData, Converter={StaticResource NullToVis}}" Value="{x:Static Visibility.Visible}">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Image Style="{StaticResource AvatarImage}"
                                                               Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                               Width="28" Height="28"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding UserInitials}"
                                                                   FontSize="10" FontWeight="Bold" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                    </Grid>
                                                </Border>
                                                <!-- Entity badge + role badge + action text -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <Border CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                                Background="{Binding Converter={StaticResource ActivityLogToAccentBrush}}">
                                                            <TextBlock Text="{Binding EntityType, Converter={StaticResource EntityTypeToLabel}}"
                                                                       FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                        <Border CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                                                                Background="{Binding ActorRole, Converter={StaticResource ActorRoleToBrush}}"
                                                                BorderBrush="{Binding ActorRole, Converter={StaticResource ActorRoleToForegroundBrush}}"
                                                                BorderThickness="1"
                                                                Visibility="{Binding ActorRole, Converter={StaticResource StringToVis}}">
                                                            <TextBlock Text="{Binding ActorRole, Converter={StaticResource ActorRoleToLabel}}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{Binding ActorRole, Converter={StaticResource ActorRoleToForegroundBrush}}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding UserName}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#000000" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ActionText}"
                                                               FontSize="12" Foreground="#000000"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <!-- Time -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                           FontSize="11" Foreground="#6B778C"
                                                           VerticalAlignment="Top" Margin="10,2,0,0"
                                                           MinWidth="45"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty activities state -->
                        <TextBlock Text="Действия появятся здесь после первых изменений"
                                   FontSize="12" Foreground="#6B778C" TextAlignment="Center"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding RecentActivities.Count, Converter={StaticResource IntToVisInv}}"/>
                    </StackPanel>
                    </Border>

                    <!-- 40% SIDE PANEL -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8"
                            BorderBrush="#DFE1E6" BorderThickness="1"
                            Margin="20,0,0,0" Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Дополнительно"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#000000"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Панель для быстрой информации"
                                       FontSize="12" Foreground="#6B778C" Margin="0,0,0,14"/>

                            <!-- Placeholder content -->
                            <Border BorderBrush="#F4F5F7" BorderThickness="0,1,0,0" Padding="0,20">
                                <TextBlock Text="Здесь может быть ваша статистика, быстрые ссылки или заметки."
                                           FontSize="12" Foreground="#6B778C" TextWrapping="Wrap" TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
