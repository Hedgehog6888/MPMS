<UserControl x:Class="MPMS.Views.Pages.FilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MPMS.Controls"
             xmlns:components="clr-namespace:MPMS.Views.Components"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Файлы" FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding FilesControlVM.ImagesCount, StringFormat='Изображений: {0}'}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilesControlVM.CurrentTab}" Value="Documents">
                                        <Setter Property="Text" Value="{Binding FilesControlVM.DocumentsCount, StringFormat='Документов: {0}'}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Click="UploadFile_Click" Style="{StaticResource BlackBtn}" Height="38" Padding="18,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{svgc:SvgImage Source=/icons/upload_white.svg, AppName=MPMS}" 
                                   Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Загрузить изображение"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilesControlVM.CurrentTab}" Value="Documents">
                                                <Setter Property="Text" Value="Загрузить документ"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1" Background="Transparent" Padding="24,8,24,24">
            <components:FilesControl DataContext="{Binding FilesControlVM}"/>
        </Border>

        <!-- Global Drag & Drop Overlay -->
        <controls:DragDropOverlay Grid.RowSpan="2" 
                                  UploadCommand="{Binding FilesControlVM.ProcessFilesCommand}"
                                  Panel.ZIndex="100"/>
    </Grid>
</UserControl>
