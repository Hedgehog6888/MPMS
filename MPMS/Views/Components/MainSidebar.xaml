<UserControl x:Class="MPMS.Views.Components.MainSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    
    <UserControl.Resources>
        <!-- Nav button style (light theme, white sidebar) -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"     Value="#000000"/>
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Padding"        Value="0"/>
            <Setter Property="Height"         Value="46"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="GroupName"      Value="Navigation"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="6"
                                Margin="8,2"
                                Padding="0">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <!-- Активный пункт без синего цвета -->
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0">
        <StackPanel Margin="0,16,0,0">
            <!-- Проекты (скрыт для Работника) -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Projects, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Projects"
                         Visibility="{Binding IsProjectsVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/project.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Проекты"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <!-- Задачи -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Tasks, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Tasks">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/tasks.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Задачи"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <!-- Этапы -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Stages, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Stages">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/stages.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Этапы"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>


            <!-- Gantt -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Gantt, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Gantt">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/gantt.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Gantt"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <!-- Календарь -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Calendar, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Calendar">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Календарь"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <!-- Склад -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Warehouse, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Warehouse">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Склад"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <!-- Файлы -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Files, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Files">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/files.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Файлы"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <!-- Администрирование (только для Administrator) -->
            <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Admin, Mode=OneWay}"
                         Style="{StaticResource NavButton}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Admin"
                         Visibility="{Binding IsAdminPanelVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <Image Width="20" Height="20"
                           Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Source="{svgc:SvgImage Source=/icons/admin_gear.svg, AppName=MPMS}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="Администрирование"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>
    </Border>
</UserControl>
