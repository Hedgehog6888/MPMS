<UserControl x:Class="MPMS.Views.Components.FilesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:viewmodels="clr-namespace:MPMS.ViewModels"
             xmlns:controls="clr-namespace:MPMS.Controls"
             xmlns:infrastructure="clr-namespace:MPMS.Infrastructure"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewmodels:FilesControlViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <infrastructure:FileSizeConverter x:Key="FileSizeConverter" />
                
        <!-- Style for the circular delete button that appears on hover -->
        <Style x:Key="CircularDeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="14" 
                                Opacity="0.95">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.12" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#EBECF0"/>
                                <Setter TargetName="Bg" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Show button when the parent card (Border) is hovered -->
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Template for Image Cards -->
        <DataTemplate x:Key="ImageCardTemplate">
            <Border Width="160" Height="180" Background="White" CornerRadius="8" Margin="0,0,16,16"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Image Preview -->
                    <Border Grid.Row="0" CornerRadius="8,8,0,0" Background="#F4F5F7" SnapsToDevicePixels="True">
                        <Grid UseLayoutRounding="True">
                            <!-- Actual Image with rounding and highest quality scaling (Fant) -->
                            <Border CornerRadius="8,8,0,0">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding FileData, Converter={StaticResource AvatarBytesToImage}, ConverterParameter=480}" 
                                                Stretch="UniformToFill"
                                                RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border.Background>
                            </Border>

                            <!-- Fallback Icon (shows when image data is missing) -->
                            <Image Source="{svgc:SvgImage Source=/icons/image.svg, AppName=MPMS}" Width="32" Height="32" Opacity="0.3"
                                   Visibility="{Binding FileData, Converter={StaticResource NullToVisInv}}"/>
                        </Grid>
                    </Border>
                    
                    <!-- Delete Button overlay (Circular, visible on hover) -->
                    <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6"
                            ToolTip="Удалить"
                            Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                            Style="{StaticResource CircularDeleteButtonStyle}">
                        <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}" Width="14" Height="14" Opacity="0.8"/>
                    </Button>

                    <StackPanel Grid.Row="1" Margin="8,6">
                        <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" 
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding ProjectName, StringFormat=П: \{0\}}" FontSize="10" Foreground="#0052CC" TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding ProjectName, Converter={StaticResource NullToVis}}"/>
                        <TextBlock Text="{Binding StageName, StringFormat=Э: \{0\}}" FontSize="10" Foreground="#00875A" TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding StageName, Converter={StaticResource NullToVis}}"/>
                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat=Загружен: dd.MM.yyyy HH\:mm}" 
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for Document List -->
        <DataTemplate x:Key="DocumentListTemplate">
            <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                    Padding="16,12"
                    BorderBrush="#DFE1E6" BorderThickness="1.5"
                    Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Margin="0,0,16,0"
                            Background="{Binding FileType, Converter={StaticResource FileExtensionToBackgroundBrush}}">
                        <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{Binding FileType, Converter={StaticResource FileExtensionToForegroundBrush}}" 
                                      StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
                                <Path Stroke="{Binding FileType, Converter={StaticResource FileExtensionToForegroundBrush}}" 
                                      StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M14 2v4a2 2 0 0 0 2 2h4"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FileName}" FontSize="15" FontWeight="SemiBold" 
                                   Foreground="#000000" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding UploadedByName}" FontSize="13" Foreground="#6B778C"/>
                            <TextBlock Text=" • " FontSize="13" Foreground="#6B778C"/>
                            <TextBlock Text="{Binding CreatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat=dd.MM.yyyy HH\:mm}" 
                                       FontSize="13" Foreground="#6B778C"/>
                            <TextBlock Text=" • " FontSize="13" Foreground="#6B778C" Visibility="{Binding ProjectName, Converter={StaticResource NullToVis}}"/>
                            <TextBlock Text="{Binding ProjectName, StringFormat=Проект: \{0\}}" FontSize="13" Foreground="#0052CC" Visibility="{Binding ProjectName, Converter={StaticResource NullToVis}}"/>
                            <TextBlock Text=" • " FontSize="13" Foreground="#6B778C" Visibility="{Binding StageName, Converter={StaticResource NullToVis}}"/>
                            <TextBlock Text="{Binding StageName, StringFormat=Этап: \{0\}}" FontSize="13" Foreground="#00875A" Visibility="{Binding StageName, Converter={StaticResource NullToVis}}"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="2" Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" FontSize="13" Foreground="#6B778C"
                               VerticalAlignment="Center" Margin="0,0,24,0"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button ToolTip="Удалить"
                                Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                Style="{StaticResource IconButton}">
                            <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                   Width="14" Height="14"
                                   VerticalAlignment="Center" Opacity="0.9"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Files View Templates -->
        <DataTemplate x:Key="FilesGridViewTemplate">
            <ItemsControl ItemsSource="{Binding DisplayedFiles}" ItemTemplate="{StaticResource ImageCardTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>

        <DataTemplate x:Key="FilesListViewTemplate">
            <ItemsControl ItemsSource="{Binding DisplayedFiles}" ItemTemplate="{StaticResource DocumentListTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Tabs & View Switcher ── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- TabBar: Изображения / Документы -->
            <controls:TabBarControl Grid.Column="0"
                                    SelectedTab="{Binding CurrentTab, Mode=TwoWay}"
                                    GroupName="FilesTabs">
                <controls:TabBarControl.Tabs>
                    <controls:TabItemModel Text="Изображения" Tag="Images"/>
                    <controls:TabItemModel Text="Документы"   Tag="Documents"/>
                </controls:TabBarControl.Tabs>
            </controls:TabBarControl>

            <!-- View Mode Switcher (List / Grid) -->
            <Border Grid.Column="1" Background="White"
                    BorderBrush="#DFE1E6" BorderThickness="1"
                    CornerRadius="8" Padding="4,4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Tag="List" GroupName="FilesViewMode"
                                 Style="{StaticResource ViewToggleButton}"
                                 IsChecked="{Binding ViewMode, Mode=TwoWay, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=List}"
                                 ToolTip="Список">
                        <Grid Width="20" Height="20">
                            <Image Width="18" Height="18" Source="{svgc:SvgImage Source=/icons/list.svg, AppName=MPMS}">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Image Width="18" Height="18" Source="{svgc:SvgImage Source=/icons/list_white.svg, AppName=MPMS}">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </RadioButton>
                    <RadioButton Tag="Grid" GroupName="FilesViewMode"
                                 Style="{StaticResource ViewToggleButton}"
                                 IsChecked="{Binding ViewMode, Mode=TwoWay, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Grid}"
                                 ToolTip="Плитка">
                        <Grid Width="20" Height="20">
                            <Image Width="18" Height="18" Source="{svgc:SvgImage Source=/icons/kanban.svg, AppName=MPMS}">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Image Width="18" Height="18" Source="{svgc:SvgImage Source=/icons/kanban_white.svg, AppName=MPMS}">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </RadioButton>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Content Area ── -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="MainListScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,62,0,0">
                <Grid Margin="0,10,0,24">
                    <!-- Loading State -->
                    <TextBlock Text="Загрузка..." HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                    <!-- Empty State -->
                    <TextBlock Text="Файлы не найдены" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                               Visibility="{Binding DisplayedFiles.Count, Converter={StaticResource IntToVisInv}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Files List / Grid -->
                    <ContentControl Content="{Binding}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate" Value="{StaticResource FilesListViewTemplate}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewMode}" Value="Grid">
                                        <Setter Property="ContentTemplate" Value="{StaticResource FilesGridViewTemplate}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </ScrollViewer>

            <!-- ── Floating Search Panel ── -->
            <controls:SearchFilterBarControl
                VerticalAlignment="Top" Panel.ZIndex="1"
                HorizontalAlignment="Stretch"
                IsFloating="True"
                ScrollTarget="{Binding ElementName=MainListScroll}"
                SearchText="{Binding SearchText, Mode=TwoWay}"
                Placeholder="Поиск по названию файла...">
                <controls:SearchFilterBarControl.Filters>
                    <!-- Extension Filter -->
                    <ComboBox ItemsSource="{Binding ExtensionFilterOptions}"
                              SelectedItem="{Binding ExtensionFilter}"
                              Style="{StaticResource FormCombo}"
                              Width="160" VerticalAlignment="Center"/>
                </controls:SearchFilterBarControl.Filters>
            </controls:SearchFilterBarControl>
        </Grid>
    </Grid>
</UserControl>
