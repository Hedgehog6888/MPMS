<UserControl x:Class="MPMS.Views.Components.Admin.AdminUsersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:MPMS.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:AdminViewModel}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Components/Admin/AdminStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Stat cards -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>     <!-- Table -->
        </Grid.RowDefinitions>

        <!-- Stat cards (only in Users tab) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="8"
                    BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Пользователей" FontSize="11" Foreground="#6B778C" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalUsersCount}" FontSize="24" FontWeight="Bold" Foreground="#000000" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="White" CornerRadius="8"
                    BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Активных" FontSize="11" Foreground="#6B778C" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ActiveUsersCount}" FontSize="24" FontWeight="Bold" Foreground="#00875A" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="White" CornerRadius="8"
                    BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Заблокировано" FontSize="11" Foreground="#6B778C" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding BlockedUsersCount}" FontSize="24" FontWeight="Bold" Foreground="#DE350B" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Users toolbar -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                BorderBrush="#DFE1E6" BorderThickness="1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Border Grid.Column="0" x:Name="UserSearchBorder"
                        Background="#F4F5F7" CornerRadius="6"
                        Padding="10,0" Height="36"
                        BorderThickness="1.5" BorderBrush="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="#6B778C"/>
                        <Grid Grid.Column="1">
                            <TextBlock Text="Поиск по имени, логину или email..."
                                       Foreground="#6B778C" FontSize="12"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UserSearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding UserSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalAlignment="Center" FontSize="13"
                                     Foreground="#000000"
                                     SelectionBrush="{StaticResource NeutralSelectionBrush}"
                                     SelectionTextBrush="#000000"
                                     GotFocus="UserSearch_GotFocus"
                                     LostFocus="UserSearch_LostFocus"/>
                        </Grid>
                        <Button Grid.Column="2"
                                Visibility="{Binding UserSearchText, Converter={StaticResource StringToVis}}"
                                Style="{StaticResource IconButton}"
                                Click="ClearUserSearch_Click">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Foreground="#6B778C"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Role filter -->
                <ComboBox Grid.Column="2"
                          ItemsSource="{x:Static vm:AdminViewModel.RoleFilterOptions}"
                          SelectedItem="{Binding UserRoleFilter}"
                          Style="{StaticResource FormCombo}"/>

                <!-- Status filter -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{x:Static vm:AdminViewModel.StatusFilterOptions}"
                          SelectedItem="{Binding UserStatusFilter}"
                          Style="{StaticResource FormCombo}"/>

                <!-- Add user button -->
                <Button Grid.Column="6" Style="{StaticResource BlackBtn}"
                        Click="CreateUser_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{svgc:SvgImage Source=/icons/plus.svg, AppName=MPMS}"
                               Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Добавить" Foreground="White"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Users table -->
        <Border Grid.Row="4" Background="White" CornerRadius="8"
                BorderBrush="#DFE1E6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Header -->
                <Border Grid.Row="0" Background="#F4F5F7" CornerRadius="8,8,0,0"
                        BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Пользователь" Style="{StaticResource ThCell}"/>
                        <TextBlock Grid.Column="1" Text="Email"        Style="{StaticResource ThCell}"/>
                        <TextBlock Grid.Column="2" Text="Роль"         Style="{StaticResource ThCell}"/>
                        <TextBlock Grid.Column="3" Text="Статус"       Style="{StaticResource ThCell}"/>
                        <TextBlock Grid.Column="4" Text="Действия"     Style="{StaticResource ThCell}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
                <!-- Rows -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredUsers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AdminUserRow}">
                                <Border Padding="16,10"
                                        BorderBrush="#F4F5F7" BorderThickness="0,0,0,1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="UserRow_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FAFBFC"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar + name -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Style="{StaticResource AvatarCircle36}"
                                                    Background="{Binding Initials, Converter={StaticResource InitialsToBrush}}"
                                                    Margin="0,0,10,0">
                                                <Grid>
                                                    <Image Style="{StaticResource AvatarImage}"
                                                           Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                           Width="36" Height="36"
                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Text="{Binding Initials}"
                                                               FontSize="12" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#000000"/>
                                                <TextBlock Text="{Binding Username, StringFormat='@{0}'}"
                                                           FontSize="11" Foreground="#6B778C" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Email -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Email}" FontSize="12" Foreground="#344563"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                        <!-- Role badge -->
                                        <Border Grid.Column="2"
                                                Background="{Binding RoleColor}"
                                                CornerRadius="4" Padding="8,3"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding RoleDisplay}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding RoleForeground}"/>
                                        </Border>

                                        <!-- Status badge -->
                                        <Border Grid.Column="3" CornerRadius="4" Padding="8,3"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#166534"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                <Setter Property="Foreground" Value="#991B1B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Редактировать"
                                                    Command="{Binding DataContext.OpenEditFormCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}" Width="14" Height="14"/>
                                            </Button>
                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="{Binding BlockLabel}"
                                                    Command="{Binding DataContext.OpenBlockOverlayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding ShowBlockActionButton, Converter={StaticResource BoolToVis}}">
                                                <Grid Width="14" Height="14">
                                                    <Image Source="{svgc:SvgImage Source=/icons/block.svg, AppName=MPMS}" Width="14" Height="14"
                                                           Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVisInv}}"/>
                                                    <Image Source="{svgc:SvgImage Source=/icons/unblock.svg, AppName=MPMS}" Width="14" Height="14"
                                                           Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </Button>
                                            <Button Style="{StaticResource RowIconBtn}" ToolTip="Удалить"
                                                    Command="{Binding DataContext.OpenDeleteUserConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding ShowDeleteActionButton, Converter={StaticResource BoolToVis}}">
                                                <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}" Width="14" Height="14"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
