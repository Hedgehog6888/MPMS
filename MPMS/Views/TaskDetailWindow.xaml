<Window x:Class="MPMS.Views.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="Детали задачи"
        Width="460" Height="720"
        MinWidth="420" MinHeight="500"
        MaxWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <!-- Tab button style for the inner tabs -->
        <Style x:Key="InnerTabButton" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- close + badges -->
            <RowDefinition Height="Auto"/>
            <!-- title + desc -->
            <RowDefinition Height="Auto"/>
            <!-- progress -->
            <RowDefinition Height="Auto"/>
            <!-- assignee + due -->
            <RowDefinition Height="Auto"/>
            <!-- tabs -->
            <RowDefinition Height="*"/>
            <!-- tab content -->
            <RowDefinition Height="Auto"/>
            <!-- bottom buttons -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Close + Status + Priority badges ── -->
        <Grid Grid.Row="0" Background="White" Margin="0,0,0,0">
            <Grid Margin="16,12,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Status + Priority badges -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="12" Padding="10,4" Margin="0,0,6,0"
                            Background="{Binding Task.Status, Converter={StaticResource TaskStatusToBrush}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◉ " FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Task.Status, Converter={StaticResource TaskStatusToString}}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="12" Padding="10,4"
                            BorderBrush="{Binding Task.Priority, Converter={StaticResource PriorityToBrush}}"
                            BorderThickness="1.5">
                        <TextBlock Text="{Binding Task.Priority, Converter={StaticResource PriorityToString}}"
                                   Foreground="{Binding Task.Priority, Converter={StaticResource PriorityToBrush}}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <!-- Close button -->
                <Button Grid.Column="1" Content="✕" Width="28" Height="28"
                        Click="Close_Click" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                                CornerRadius="14" Padding="2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>

        <!-- ── Row 1: Title + Description ── -->
        <Border Grid.Row="1" Background="White" Padding="16,0,16,14">
            <StackPanel>
                <TextBlock Text="{Binding Task.Name}" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" LineHeight="24"/>
                <TextBlock Text="{Binding Task.Description}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="20"
                           Visibility="{Binding Task.Description, Converter={StaticResource StringToVis}}"/>
            </StackPanel>
        </Border>

        <!-- ── Row 2: Progress ── -->
        <Border Grid.Row="2" Background="White" Padding="16,14"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Прогресс выполнения" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Task.ProgressPercent, StringFormat='{}{0}%'}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Grid>
                <ProgressBar Value="{Binding Task.ProgressPercent, Mode=OneWay}"
                             Maximum="100" Height="8"
                             Background="#E9ECEF" Foreground="Black">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <Border x:Name="PART_Track" CornerRadius="4">
                                    <Border x:Name="PART_Indicator"
                                            Background="{TemplateBinding Foreground}"
                                            HorizontalAlignment="Left" CornerRadius="4"/>
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </StackPanel>
        </Border>

        <!-- ── Row 3: Assignee + Due date ── -->
        <Border Grid.Row="3" Background="White" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Assignee -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Исполнитель" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="17"
                                Background="{StaticResource PrimaryBrush}" Margin="0,0,10,0">
                            <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}"
                                   Width="16" Height="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.8"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Task.AssignedUserName}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="—" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Due date -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Срок выполнения" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}"
                               Width="16" Height="16" Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Opacity="0.5"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Task.DueDate, Converter={StaticResource DateOnlyToString}}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Row 4: Inner tabs (Stages, Materials, Files) ── -->
        <Border Grid.Row="4" Background="White" Padding="8,6"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1">
            <Border Background="#F4F5F7" CornerRadius="10" Padding="3"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton IsChecked="True" Tag="Stages" Click="InnerTab_Click"
                                 Style="{StaticResource TabButton}">
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="Этапы "/>
                            <Run Text="("/>
                            <Run Text="{Binding Stages.Count}"/>
                            <Run Text=")"/>
                        </TextBlock>
                    </RadioButton>
                    <RadioButton Tag="Materials" Click="InnerTab_Click"
                                 Style="{StaticResource TabButton}">
                        <TextBlock Text="Материалы" VerticalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton Tag="Files" Click="InnerTab_Click"
                                 Style="{StaticResource TabButton}">
                        <TextBlock Text="Файлы" VerticalAlignment="Center"/>
                    </RadioButton>
                </StackPanel>
            </Border>
        </Border>

        <!-- ── Row 5: Tab Content ── -->
        <Grid Grid.Row="5">

            <!-- STAGES panel -->
            <ScrollViewer x:Name="StagesTabPanel" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,12,12,0">
                    <ItemsControl ItemsSource="{Binding Stages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,8"
                                        Padding="14,12"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0" To="1" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                                       Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Border CornerRadius="8" Padding="8,3" Margin="0,0,8,0"
                                                        Background="{Binding Status, Converter={StaticResource StageStatusToBrush}}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StageStatusToString}}"
                                                               Foreground="White" FontSize="11"/>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                            Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}">
                                                    <Border Width="22" Height="22" CornerRadius="11"
                                                            Background="#E3EBF6" Margin="0,0,6,0">
                                                        <TextBlock Text="👤" FontSize="10"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding AssignedUserName}" FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal">
                                                <Button ToolTip="Редактировать"
                                                        Tag="{Binding}" Click="EditStage_Click"
                                                        Margin="0,0,4,0" Style="{StaticResource IconButton}">
                                                    <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                           Width="14" Height="14"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.85"/>
                                                </Button>
                                                <Button ToolTip="Удалить"
                                                        Tag="{Binding}" Click="DeleteStage_Click"
                                                        Style="{StaticResource DangerIconButton}">
                                                    <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                           Width="14" Height="14"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.9"/>
                                                </Button>
                                            </StackPanel>
                                            <ComboBox Margin="0,6,0,0" Width="120" FontSize="11"
                                                      Height="28" Tag="{Binding}"
                                                      SelectionChanged="StageStatus_Changed"
                                                      VerticalContentAlignment="Center">
                                                <ComboBoxItem Content="Запланирован" Tag="Planned"/>
                                                <ComboBoxItem Content="Выполняется" Tag="InProgress"/>
                                                <ComboBoxItem Content="Завершён" Tag="Completed"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding Stages.Count, Converter={StaticResource IntToVisInv}}"
                                HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Этапы не добавлены" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- MATERIALS panel -->
            <ScrollViewer x:Name="MaterialsTabPanel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,12,12,0">
                    <ItemsControl ItemsSource="{Binding AllMaterials}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                        Padding="14,12"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                                                Background="{StaticResource BackgroundBrush}" Margin="0,0,10,0">
                                            <TextBlock Text="📦" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding MaterialName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="{Binding Quantity}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Unit}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding AllMaterials.Count, Converter={StaticResource IntToVisInv}}"
                                HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="📦" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Материалы не добавлены" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- FILES panel -->
            <Grid x:Name="FilesTabPanel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,12,12,0">
                        <ItemsControl ItemsSource="{Binding Files}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                            Padding="12,10"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                                    Background="{StaticResource BackgroundBrush}" Margin="0,0,10,0">
                                                <TextBlock Text="📄" FontSize="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding UploadedByName}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <StackPanel Visibility="{Binding Files.Count, Converter={StaticResource IntToVisInv}}"
                                    HorizontalAlignment="Center" Margin="0,40,0,0">
                            <Border Width="72" Height="72" CornerRadius="36"
                                    Background="{StaticResource BackgroundBrush}"
                                    HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Image Source="{svgc:SvgImage Source=/icons/files.svg, AppName=MPMS}" Width="36" Height="36"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                            </Border>
                            <TextBlock Text="Файлы ещё не загружены" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <Button Click="UploadFiles_Click" Height="34" Padding="16,0" HorizontalAlignment="Center"
                                    FontSize="13">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="White" CornerRadius="6"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Image Source="{svgc:SvgImage Source=/icons/upload.svg, AppName=MPMS}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Загрузить файлы" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ── Row 6: Bottom action buttons ── -->
        <Border Grid.Row="6" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Add stage button -->
                <Button Grid.Column="0" Height="34" Padding="12,0"
                        Click="CreateStage_Click" HorizontalAlignment="Left" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="White" CornerRadius="6"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="{svgc:SvgImage Source=/icons/plus_black.svg, AppName=MPMS}"
                                           Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Этап" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Close -->
                <Button Grid.Column="1" Content="Закрыть" Height="34" Padding="14,0"
                        Margin="0,0,8,0" Click="Close_Click" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="White" CornerRadius="6"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Change status -->
                <Button Grid.Column="2" Content="Изменить статус" Height="34" Padding="14,0"
                        Margin="0,0,8,0" Click="ChangeStatus_Click" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="White" CornerRadius="6"
                                    BorderBrush="{StaticResource TextSecondaryBrush}" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Edit -->
                <Button Grid.Column="3" Content="Редактировать" Height="34" Padding="14,0"
                        Click="EditTask_Click" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Black" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="White"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
