<UserControl x:Class="MPMS.Views.Overlays.ChangePasswordOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20,16" BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Width="28" Height="28" CornerRadius="8" Background="#EFF6FF" Margin="0,0,10,0">
                        <Image Source="{svgc:SvgImage Source=/icons/profile_key.svg, AppName=MPMS}"
                               Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Сменить пароль" FontSize="18" FontWeight="Bold" Foreground="#000000"/>
                        <TextBlock Text="Введите текущий и новый пароль" FontSize="12" Foreground="#6B778C"/>
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Width="30" Height="30" Click="Cancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="15" Background="#F4F5F7">
                                <TextBlock Text="✕" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,16,20,10">
            <TextBlock Text="Текущий пароль *" FontSize="11" FontWeight="SemiBold" Foreground="#6B778C" Margin="0,0,0,4"/>
            <Border Background="#F8F9FA" BorderBrush="#DFE1E6" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                <PasswordBox x:Name="CurrentPasswordBox" BorderThickness="0" Background="Transparent" FontSize="13"/>
            </Border>

            <TextBlock Text="Новый пароль *" FontSize="11" FontWeight="SemiBold" Foreground="#6B778C" Margin="0,0,0,4"/>
            <Border Background="#F8F9FA" BorderBrush="#DFE1E6" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                <PasswordBox x:Name="NewPasswordBox" BorderThickness="0" Background="Transparent" FontSize="13"/>
            </Border>

            <TextBlock Text="Повторите новый пароль *" FontSize="11" FontWeight="SemiBold" Foreground="#6B778C" Margin="0,0,0,4"/>
            <Border Background="#F8F9FA" BorderBrush="#DFE1E6" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                <PasswordBox x:Name="ConfirmPasswordBox" BorderThickness="0" Background="Transparent" FontSize="13"/>
            </Border>

            <Border x:Name="ErrorPanel" Background="#FFF0F0" BorderBrush="#FCA5A5" BorderThickness="1"
                    CornerRadius="8" Padding="12,9" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Padding="20,12" BorderBrush="#E8E9EC" BorderThickness="0,1,0,0" Background="White">
            <Grid>
                <Button Content="Отмена" HorizontalAlignment="Left" Click="Cancel_Click" Style="{StaticResource OutlineBtn}"/>
                <Button x:Name="SaveBtn" Content="Сменить пароль" HorizontalAlignment="Right" Click="Save_Click" Style="{StaticResource BlackBtn}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
