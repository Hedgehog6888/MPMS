<UserControl x:Class="MPMS.Views.Overlays.AddQuantityOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Добавить количество"
                               FontSize="20" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Cancel_Click" Width="32" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="24,20,24,8">

            <!-- Amount -->
            <TextBlock Text="Количество *" Style="{StaticResource FormLabel}"/>
            <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                    CornerRadius="8" Padding="12,10" Margin="0,0,0,16" Height="42">
                <TextBox x:Name="AmountBox" BorderThickness="0" Background="Transparent"
                         Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                         Padding="0" Text="1"/>
            </Border>

            <!-- Comment -->
            <TextBlock Text="Комментарий" Style="{StaticResource FormLabel}"/>
            <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                    CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                <TextBox x:Name="CommentBox" BorderThickness="0" Background="Transparent"
                         Foreground="#000000" FontSize="13"
                         Height="72" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalContentAlignment="Top" Padding="0"
                         VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- Error -->
            <Border x:Name="ErrorPanel" Background="#FFF0F0"
                    CornerRadius="8" Padding="14,10"
                    Margin="0,0,0,8" Visibility="Collapsed"
                    BorderBrush="#FCA5A5" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0"
                               Foreground="#DC2626" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626"
                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0"
                Background="White">
            <Grid>
                <Button Content="Отмена" HorizontalAlignment="Left"
                        Click="Cancel_Click" Style="{StaticResource OutlineBtn}"/>
                <Button Content="Добавить"
                        HorizontalAlignment="Right"
                        Click="Save_Click" Style="{StaticResource BlackBtn}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
