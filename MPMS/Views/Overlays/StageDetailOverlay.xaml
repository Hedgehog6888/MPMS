<UserControl x:Class="MPMS.Views.Overlays.StageDetailOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#172B4D"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20,14" BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleLabel" Text="Этап" FontSize="18" FontWeight="Bold" Foreground="#172B4D"/>
                    <TextBlock x:Name="StageNameText" FontSize="14" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="Close_Click" Width="28" Height="28">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="14">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,12">
                    <TextBlock x:Name="StatusText" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Описание" FontSize="12" FontWeight="SemiBold" Foreground="#172B4D" Margin="0,0,0,6"/>
                <TextBlock x:Name="DescriptionText" FontSize="13" Foreground="#6B778C" TextWrapping="Wrap" Margin="0,0,0,16"/>
                <TextBlock Text="Исполнитель" FontSize="12" FontWeight="SemiBold" Foreground="#172B4D" Margin="0,0,0,6"/>
                <TextBlock x:Name="AssigneeText" FontSize="13" Foreground="#6B778C" Margin="0,0,0,16"/>
                <TextBlock Text="Материалы" FontSize="12" FontWeight="SemiBold" Foreground="#172B4D" Margin="0,0,0,6"/>
                <ItemsControl x:Name="MaterialsList"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="16,12" BorderBrush="#DFE1E6" BorderThickness="0,1,0,0" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Закрыть" Click="Close_Click" Style="{StaticResource OutlineBtn}" Margin="0,0,8,0"/>
                <Button x:Name="EditButton" Content="Редактировать" Click="Edit_Click" Style="{StaticResource OutlineBtn}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
