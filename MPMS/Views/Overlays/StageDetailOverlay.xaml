<UserControl x:Class="MPMS.Views.Overlays.StageDetailOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:MPMS.Infrastructure"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             Background="#F8F9FA">

    <UserControl.Resources>
        <!-- Slim progress bar template -->
        <ControlTemplate x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                <Border x:Name="PART_Track" CornerRadius="4">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="4"/>
                </Border>
            </Border>
        </ControlTemplate>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlackBtn" TargetType="Button">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#DE350B"/>
            <Setter Property="BorderBrush" Value="#FFBDAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFEBE6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Прямоугольные кнопки статуса (как в оверлее редактирования) -->
        <Style x:Key="StatusSegmentedBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Scrollable content -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── HEADER ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="White" Padding="20,16"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1">
            <Grid>
                <!-- Left: status badge + task chip -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusBadge" CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="6" Height="6" CornerRadius="2" Background="White"
                                    Opacity="0.8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="6" Padding="8,4" Background="#F4F5F7" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Задача: " FontSize="11" Foreground="#8993A4"/>
                            <TextBlock x:Name="TaskNameText" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#000000" MaxWidth="140"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Close button -->
                <Button HorizontalAlignment="Right" Click="Close_Click"
                        Width="32" Height="32" ToolTip="Закрыть">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── CONTENT ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Stage title + срок (как блок срока в оверлее задачи) -->
                <Border Background="White" Padding="20,16,20,16"
                        BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" MinWidth="0">
                            <TextBlock Text="ЭТАП" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8993A4" Margin="0,0,0,4"/>
                            <TextBlock x:Name="StageNameText" FontSize="22" FontWeight="Bold"
                                       Foreground="#000000" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel x:Name="StageDueDatePanel" Grid.Column="1"
                                    VerticalAlignment="Top" HorizontalAlignment="Right"
                                    Margin="16,0,0,0" Visibility="Collapsed">
                            <TextBlock Text="СРОК ВЫПОЛНЕНИЯ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8993A4" Margin="0,0,0,8"/>
                            <TextBlock x:Name="StageDueDateLongText" FontSize="15" FontWeight="Bold"
                                       Foreground="#000000" Margin="0,0,0,2" TextAlignment="Right"/>
                            <TextBlock x:Name="StageDueDayNameText" FontSize="12" Foreground="#6B778C"
                                       TextAlignment="Right"/>
                            <Border x:Name="StageOverdueBadge" CornerRadius="4" Padding="6,3"
                                    Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                    HorizontalAlignment="Right" Margin="0,4,0,0" Visibility="Collapsed">
                                <TextBlock Text="Просрочено" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#DC2626"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Deletion mark warning -->
                <Border x:Name="DeletionWarningBorder" CornerRadius="8" Padding="14,10"
                        Background="#FFEBE6" BorderBrush="#FFBDAD" BorderThickness="1"
                        Margin="16,0,16,12" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Top"
                                   Foreground="#BF2600"/>
                        <StackPanel>
                            <TextBlock Text="Пометка удаления" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#BF2600"/>
                            <TextBlock x:Name="DeletionHintText" FontSize="12" Foreground="#BF2600"
                                       Margin="0,4,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Cards area -->
                <StackPanel Margin="16,0,16,16">

                    <!-- Status change card -->
                    <Border Background="White" CornerRadius="10" Padding="16"
                            BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="СТАТУС" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8993A4" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnPlanned" Grid.Column="0" Style="{StaticResource StatusSegmentedBtn}"
                                        Click="SetStatusPlanned_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="#6B778C" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Запланирован" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnInProgress" Grid.Column="2" Style="{StaticResource StatusSegmentedBtn}"
                                        Click="SetStatusInProgress_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="#0082FF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Выполняется" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnCompleted" Grid.Column="4" Style="{StaticResource StatusSegmentedBtn}"
                                        Click="SetStatusCompleted_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="#00875A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Завершён" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Description card -->
                    <Border Background="White" CornerRadius="10" Padding="16"
                            BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="ОПИСАНИЕ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8993A4" Margin="0,0,0,8"/>
                            <TextBlock x:Name="DescriptionText" FontSize="13" Foreground="#6B778C"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <!-- Assignees card -->
                    <Border Background="White" CornerRadius="10" Padding="16"
                            BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="ИСПОЛНИТЕЛИ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8993A4" Margin="0,0,0,10"/>

                            <ItemsControl x:Name="AssigneesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Style="{StaticResource AvatarCircle34}"
                                                    Background="#000000" Margin="0,0,10,0">
                                                <Grid>
                                                    <Image Style="{StaticResource AvatarImage}"
                                                           Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                           Width="34" Height="34"
                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Text="{Binding Initials}" FontSize="11"
                                                               FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UserName}" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="#000000"/>
                                                <TextBlock Text="{Binding RoleDisplay}" FontSize="11" Margin="0,1,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#8993A4"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RoleDisplay}" Value="Прораб">
                                                                    <Setter Property="Foreground" Value="#166534"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="NoAssigneesText" Text="Не назначено"
                                       FontSize="13" Foreground="#97A0AF"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Materials card -->
                    <Border x:Name="MaterialsCard" Background="White" CornerRadius="10" Padding="16"
                            BorderBrush="#E8E9EC" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="МАТЕРИАЛЫ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8993A4" Margin="0,0,0,10"/>

                            <ItemsControl x:Name="MaterialsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F9FA" CornerRadius="8" Padding="12,10"
                                                Margin="0,0,0,6" BorderBrush="#EEF0F3" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                                                        Background="#EEF0F3" Margin="0,0,10,0">
                                                    <Image Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}"
                                                           Width="16" Height="16" Opacity="0.6"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding MaterialName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" CornerRadius="6" Padding="8,4"
                                                        Background="#EBF2FF">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#1B6EC2">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1}">
                                                                <Binding Path="Quantity"/>
                                                                <Binding Path="Unit"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel x:Name="NoMaterialsState" Visibility="Collapsed"
                                        HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Image Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}"
                                       Width="28" Height="28" Opacity="0.25"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Материалы не добавлены" FontSize="12"
                                           Foreground="#97A0AF" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ── FOOTER ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="20,14" Background="White"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="MarkDeletionBtn" Click="MarkDeletion_Click"
                            Style="{StaticResource DangerBtn}" Margin="0,0,8,0">
                        <TextBlock x:Name="MarkDeletionBtnText" Text="Пометить к удалению"
                                   Foreground="#DE350B" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Button>
                    <Button Content="Закрыть" Click="Close_Click"
                            Style="{StaticResource OutlineBtn}"/>
                </StackPanel>
                <Button x:Name="EditButton" HorizontalAlignment="Right"
                        Click="Edit_Click" Style="{StaticResource BlackBtn}">
                    <TextBlock Text="Редактировать" Foreground="White"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
