<UserControl x:Class="MPMS.Views.Overlays.CreateTaskOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>

        <Style x:Key="UserPickerItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <!-- Прямоугольные кнопки приоритета (как статусы в CreateStageOverlay) -->
        <Style x:Key="PrioritySegmentedBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleLabel" Text="Создать задачу"
                               FontSize="20" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock Text="Добавьте задачу для отслеживания выполнения"
                               FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Cancel_Click" Width="32" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Form content -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,8">

                <!-- Section: Основная информация -->
                <TextBlock Text="ОСНОВНАЯ ИНФОРМАЦИЯ" Style="{StaticResource SectionHeader}"/>

                <!-- Task name -->
                <TextBlock Text="Название задачи *" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Height="42">
                    <TextBox x:Name="NameBox" BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                             Padding="0"/>
                </Border>

                <!-- Description -->
                <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                    <TextBox x:Name="DescriptionBox" BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13"
                             Height="72" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="0"
                             VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Project -->
                <TextBlock Text="Проект *" Style="{StaticResource FormLabel}"/>
                <ComboBox x:Name="ProjectCombo" Style="{StaticResource FormCombo}"
                          Margin="0,0,0,12"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="ProjectCombo_SelectionChanged"/>

                <!-- Priority — четыре прямоугольные кнопки -->
                <TextBlock Text="Приоритет *" Style="{StaticResource FormLabel}"/>
                <Grid Margin="0,6,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnPriorityLow" Grid.Column="0" Style="{StaticResource PrioritySegmentedBtn}"
                            Click="PriorityLow_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#00875A"
                                    Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Низкий" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPriorityMedium" Grid.Column="2" Style="{StaticResource PrioritySegmentedBtn}"
                            Click="PriorityMedium_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#0082FF"
                                    Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Средний" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPriorityHigh" Grid.Column="4" Style="{StaticResource PrioritySegmentedBtn}"
                            Click="PriorityHigh_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#FF8B00"
                                    Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Высокий" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPriorityCritical" Grid.Column="6" Style="{StaticResource PrioritySegmentedBtn}"
                            Click="PriorityCritical_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#DE350B"
                                    Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Критический" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Status row (edit mode only) -->
                <StackPanel x:Name="StatusRow" Visibility="Collapsed" Margin="0,0,0,12">
                    <TextBlock Text="Статус" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="StatusCombo" Style="{StaticResource FormCombo}">
                        <ComboBoxItem Content="Запланирована" Tag="Planned"/>
                        <ComboBoxItem Content="Выполняется" Tag="InProgress"/>
                        <ComboBoxItem Content="Приостановлена" Tag="Paused"/>
                        <ComboBoxItem Content="Завершена" Tag="Completed"/>
                    </ComboBox>
                </StackPanel>

                <!-- Due date -->
                <TextBlock Text="Срок выполнения *" Style="{StaticResource FormLabel}"/>
                <DatePicker x:Name="DueDatePicker" Height="42" FontSize="13" Margin="0,0,0,4"/>

                <!-- Section: Исполнители -->
                <TextBlock Text="ИСПОЛНИТЕЛИ" Style="{StaticResource SectionHeader}"/>

                <!-- Info hint when no project selected -->
                <Border x:Name="NoProjHint" Background="#FFFBEB" CornerRadius="8"
                        Padding="12,10" Margin="0,0,0,12"
                        BorderBrush="#FCD34D" BorderThickness="1">
                    <TextBlock x:Name="NoProjHintText" Text="Выберите проект, чтобы увидеть доступных исполнителей"
                               FontSize="12" Foreground="#92400E" TextWrapping="Wrap"/>
                </Border>

                <!-- Selected assignees chips -->
                <WrapPanel x:Name="SelectedAssigneesPanel" Margin="0,0,0,8" Visibility="Collapsed"/>

                <TextBlock Text="Прорабы" Style="{StaticResource FormLabel}"/>
                <Border x:Name="ForemanPickerBorder" Background="White" BorderBrush="#DFE1E6"
                        BorderThickness="1" CornerRadius="8" MaxHeight="180"
                        Visibility="Collapsed" Margin="0,0,0,10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                        <StackPanel>
                            <ItemsControl x:Name="ForemanPickerList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Tag="{Binding}" MouseLeftButtonDown="ForemanItem_Click">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource UserPickerItem}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8F9FA"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Style="{StaticResource AvatarCircle32}"
                                                            Background="{Binding AvatarBrush}"
                                                            Margin="0,0,10,0">
                                                        <Grid>
                                                            <Image Style="{StaticResource AvatarImage}"
                                                                   Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                   Width="32" Height="32"
                                                                   Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                            <TextBlock Text="{Binding Initials}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#000000"/>
                                                        <TextBlock Text="{Binding RoleDisplay}"
                                                                   FontSize="11"
                                                                   Foreground="{Binding RoleColor}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Width="22" Height="22" CornerRadius="11"
                                                        Background="#111111"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsSelectedVis}">
                                                    <TextBlock Text="✓" FontSize="10" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoForemenHint"
                                       Text="В проекте нет назначенных прорабов"
                                       FontSize="12" Foreground="#97A0AF"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,12" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <TextBlock Text="Работники" Style="{StaticResource FormLabel}"/>
                <Border x:Name="WorkerPickerBorder" Background="White" BorderBrush="#DFE1E6"
                        BorderThickness="1" CornerRadius="8" MaxHeight="220"
                        Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                        <StackPanel>
                            <ItemsControl x:Name="WorkerPickerList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Tag="{Binding}" MouseLeftButtonDown="WorkerItem_Click">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource UserPickerItem}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8F9FA"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Style="{StaticResource AvatarCircle32}"
                                                            Background="{Binding AvatarBrush}"
                                                            Margin="0,0,10,0">
                                                        <Grid>
                                                            <Image Style="{StaticResource AvatarImage}"
                                                                   Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                   Width="32" Height="32"
                                                                   Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                            <TextBlock Text="{Binding Initials}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#000000"/>
                                                        <TextBlock Text="{Binding RoleDisplay}"
                                                                   FontSize="11"
                                                                   Foreground="{Binding RoleColor}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Width="22" Height="22" CornerRadius="11"
                                                        Background="#111111"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsSelectedVis}">
                                                    <TextBlock Text="✓" FontSize="10" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="NoWorkersHint"
                                       Text="В проекте нет назначенных работников"
                                       FontSize="12" Foreground="#97A0AF"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,12" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Error -->
                <Border x:Name="ErrorPanel" Background="#FFF0F0"
                        CornerRadius="8" Padding="14,10"
                        Margin="0,8,0,4" Visibility="Collapsed"
                        BorderBrush="#FCA5A5" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0"
                                   Foreground="#DC2626" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0"
                Background="White">
            <Grid>
                <Button Content="Отмена" HorizontalAlignment="Left"
                        Click="Cancel_Click" Style="{StaticResource OutlineBtn}"/>
                <Button x:Name="SaveButton" Content="Создать задачу"
                        HorizontalAlignment="Right"
                        Click="Save_Click" Style="{StaticResource BlackBtn}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
