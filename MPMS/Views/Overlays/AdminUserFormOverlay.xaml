<UserControl x:Class="MPMS.Views.Overlays.AdminUserFormOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="520">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin"     Value="0,20,0,10"/>
        </Style>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#344563"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FormField" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="24,18"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleLabel" Text="Создать пользователя"
                               FontSize="20" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock x:Name="SubtitleLabel"
                               Text="Заполните данные нового пользователя"
                               FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Cancel_Click" Width="32" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Form Body ════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,8">

                <!-- PERSONAL INFO -->
                <TextBlock Text="ЛИЧНЫЕ ДАННЫЕ" Style="{StaticResource SectionHeader}"/>

                <!-- First + Last name -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Имя *" Style="{StaticResource FormLabel}"/>
                        <Border Style="{StaticResource FormField}" Margin="0,0,0,0">
                            <TextBox x:Name="FirstNameBox"
                                     BorderThickness="0" Background="Transparent"
                                     Foreground="#000000" FontSize="13"
                                     VerticalContentAlignment="Center" Padding="0"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Фамилия *" Style="{StaticResource FormLabel}"/>
                        <Border Style="{StaticResource FormField}" Margin="0,0,0,0">
                            <TextBox x:Name="LastNameBox"
                                     BorderThickness="0" Background="Transparent"
                                     Foreground="#000000" FontSize="13"
                                     VerticalContentAlignment="Center" Padding="0"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Username -->
                <TextBlock Text="Логин *" Style="{StaticResource FormLabel}"/>
                <Border Style="{StaticResource FormField}">
                    <TextBox x:Name="UsernameBox"
                             BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13"
                             VerticalContentAlignment="Center" Padding="0"/>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                <Border Style="{StaticResource FormField}">
                    <TextBox x:Name="EmailBox"
                             BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13"
                             VerticalContentAlignment="Center" Padding="0"/>
                </Border>

                <!-- Role -->
                <TextBlock Text="Роль *" Style="{StaticResource FormLabel}"/>
                <ComboBox x:Name="RoleCombo"
                          Style="{StaticResource FormCombo}"
                          Margin="0,0,0,12"
                          DisplayMemberPath="Display"/>

                <!-- CREDENTIALS -->
                <TextBlock Text="УЧЁТНЫЕ ДАННЫЕ" Style="{StaticResource SectionHeader}"/>

                <Border BorderBrush="#DFE1E6" BorderThickness="1" CornerRadius="8" Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Пароль *" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Height="42" Margin="0,0,0,12">
                            <PasswordBox x:Name="PasswordBox"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#000000" FontSize="13"
                                         VerticalContentAlignment="Center" Padding="0"/>
                        </Border>

                        <TextBlock Text="Подтвердить пароль *" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Height="42" Margin="0">
                            <PasswordBox x:Name="PasswordConfirmBox"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#000000" FontSize="13"
                                         VerticalContentAlignment="Center" Padding="0"/>
                        </Border>

                        <TextBlock x:Name="PasswordHint"
                                   Text="Оставьте пустым, чтобы не менять пароль"
                                   FontSize="11" Foreground="#8993A4" Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Error message -->
                <Border x:Name="ErrorBorder"
                        Background="#FEE2E2" CornerRadius="6" Padding="12,8"
                        Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               Foreground="#991B1B" FontSize="12" TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Footer ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="24,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource OutlineBtn}"
                        Click="Cancel_Click" Margin="0,0,10,0"/>
                <Button x:Name="SaveButton" Content="Сохранить"
                        Style="{StaticResource BlackBtn}"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
