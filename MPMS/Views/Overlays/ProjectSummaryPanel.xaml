<UserControl x:Class="MPMS.Views.Overlays.ProjectSummaryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InfoRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="IconBox" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F0F1F3"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#E8E9EC" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,16">

                <!-- Project header band -->
                <Border x:Name="StatusHeaderBand" Padding="16,14,16,14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F0F9FF"/>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- Label -->
                        <TextBlock Text="ПРОЕКТ" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,6"/>

                        <!-- Project name -->
                        <TextBlock x:Name="ProjectNameText"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#172B4D"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <!-- Status badge -->
                        <Border x:Name="StatusBadge" CornerRadius="6" Padding="10,5"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        x:Name="StatusDot" Background="White"
                                        Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Foreground="White"
                                           FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Progress section -->
                <Border Padding="16,14,16,14" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Прогресс" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#172B4D" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="CompletedTasksText" FontSize="12"
                                           Foreground="#6B778C"/>
                                <TextBlock Text=" / " FontSize="12" Foreground="#6B778C"/>
                                <TextBlock x:Name="TotalTasksText" FontSize="12" Foreground="#6B778C"/>
                                <TextBlock Text=" задач" FontSize="12" Foreground="#6B778C"/>
                            </StackPanel>
                        </Grid>

                        <!-- Progress bar -->
                        <Border Background="#EEF0F3" CornerRadius="4" Height="8" Margin="0,0,0,6">
                            <Border x:Name="ProgressFill" CornerRadius="4" HorizontalAlignment="Left"
                                    Background="#0082FF" Width="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#0082FF"/>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>

                        <Grid>
                            <TextBlock x:Name="ProgressText" FontSize="20" FontWeight="Bold"
                                       Foreground="#172B4D"/>
                            <TextBlock x:Name="ProgressLabel" Text="выполнено"
                                       FontSize="11" Foreground="#6B778C"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Details section -->
                <StackPanel Margin="16,14,16,0">

                    <!-- Client -->
                    <StackPanel Style="{StaticResource InfoRow}">
                        <Border Style="{StaticResource IconBox}">
                            <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}"
                                   Width="16" Height="16" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ЗАКАЗЧИК" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="ClientText" FontSize="13" Foreground="#172B4D"
                                       FontWeight="SemiBold" TextWrapping="Wrap" MaxWidth="180"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Address -->
                    <StackPanel Style="{StaticResource InfoRow}">
                        <Border Style="{StaticResource IconBox}">
                            <Image Source="{svgc:SvgImage Source=/icons/location.svg, AppName=MPMS}"
                                   Width="16" Height="16" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Top">
                            <TextBlock Text="АДРЕС ОБЪЕКТА" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="AddressText" FontSize="12" Foreground="#172B4D"
                                       TextWrapping="Wrap" MaxWidth="180"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Dates -->
                    <StackPanel Style="{StaticResource InfoRow}">
                        <Border Style="{StaticResource IconBox}">
                            <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}"
                                   Width="16" Height="16" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="СРОКИ" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="DatesText" FontSize="12" Foreground="#172B4D"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="DaysLeftText" FontSize="11"
                                       Foreground="#6B778C" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Background="#F0F0F0" Height="1" Margin="0,4,0,16"/>

                    <!-- Manager -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="МЕНЕДЖЕР" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="ManagerAvatar" Style="{StaticResource AvatarCircle32}"
                                    Background="#172B4D" Margin="0,0,8,0">
                                <Grid>
                                    <Image x:Name="ManagerAvatarImage" Style="{StaticResource AvatarImage}"
                                           Width="32" Height="32"/>
                                    <TextBlock x:Name="ManagerInitialsText" Foreground="White"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="ManagerNameText" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#172B4D"/>
                                <TextBlock Text="Менеджер проекта" FontSize="11"
                                           Foreground="#6B778C" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Foreman -->
                    <StackPanel x:Name="ForemanSection" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock Text="ПРОРАБ" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl x:Name="ForemanList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource AvatarCircle32}"
                                                Background="#166534" Margin="0,0,8,0">
                                            <Grid>
                                                <Image Style="{StaticResource AvatarImage}"
                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                       Width="32" Height="32"
                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                <TextBlock Text="{Binding Initials}" Foreground="White"
                                                       FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding UserName}" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="#172B4D"/>
                                            <TextBlock Text="Прораб" FontSize="11"
                                                       Foreground="#166534" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Workers -->
                    <StackPanel x:Name="WorkersSection" Margin="0,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="РАБОТНИКИ" Style="{StaticResource SectionLabel}"/>

                        <!-- Avatar strip for workers -->
                        <StackPanel x:Name="WorkersAvatarStrip" Orientation="Horizontal" Margin="0,0,0,8">
                            <!-- Avatars added in code-behind -->
                        </StackPanel>

                        <ItemsControl x:Name="WorkersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource AvatarCircle28}"
                                                Background="#EA580C" Margin="0,0,8,0">
                                            <Grid>
                                                <Image Style="{StaticResource AvatarImage}"
                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                       Width="28" Height="28"
                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                <TextBlock Text="{Binding Initials}" Foreground="White"
                                                           FontSize="10" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding UserName}" FontSize="12"
                                                   Foreground="#172B4D"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
