<UserControl x:Class="MPMS.Views.Overlays.ProjectSummaryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <Border Background="#F8F9FA" Padding="16" BorderBrush="#DFE1E6" BorderThickness="0,0,1,0">
        <StackPanel>
            <TextBlock Text="Проект" FontSize="11" FontWeight="SemiBold"
                       Foreground="#6B778C" Margin="0,0,0,8"/>
            <TextBlock x:Name="ProjectNameText" FontSize="15" FontWeight="SemiBold"
                       Foreground="#172B4D" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,4"
                    HorizontalAlignment="Left" Margin="0,0,0,12">
                <TextBlock x:Name="StatusText" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
            </Border>
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.6"/>
                <StackPanel>
                    <TextBlock Text="Заказчик" FontSize="11" Foreground="#6B778C" Margin="0,0,0,2"/>
                    <TextBlock x:Name="ClientText" FontSize="13" Foreground="#172B4D"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <Image Source="{svgc:SvgImage Source=/icons/location.svg, AppName=MPMS}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.6"/>
                <StackPanel>
                    <TextBlock Text="Адрес" FontSize="11" Foreground="#6B778C" Margin="0,0,0,2"/>
                    <TextBlock x:Name="AddressText" FontSize="12" Foreground="#172B4D"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Прогресс" FontSize="11" Foreground="#6B778C" Margin="0,0,0,4"/>
                <ProgressBar x:Name="ProgressBar" Maximum="100" Height="6"
                             Background="#E0E0E0" Foreground="#111111">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                <Border x:Name="PART_Track" CornerRadius="3">
                                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                            HorizontalAlignment="Left" CornerRadius="3"/>
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
                <TextBlock x:Name="ProgressText" FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Image Source="{svgc:SvgImage Source=/icons/person.svg, AppName=MPMS}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.6"/>
                <Border x:Name="ManagerAvatar" Width="28" Height="28" CornerRadius="14"
                        Background="#172B4D" Margin="0,0,8,0">
                    <TextBlock x:Name="ManagerInitialsText" Foreground="White" FontSize="10"
                               FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="ManagerNameText" FontSize="13" Foreground="#172B4D"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
