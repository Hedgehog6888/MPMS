<UserControl x:Class="MPMS.Views.Overlays.AdminUserInfoOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="520">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin"     Value="0,20,0,10"/>
        </Style>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#6B778C"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#172B4D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="24,18"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Информация о пользователе"
                               FontSize="20" FontWeight="Bold" Foreground="#172B4D"/>
                    <TextBlock x:Name="HeaderSubtitle"
                               Text="Просмотр и управление пользователем"
                               FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Cancel_Click" Width="32" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Body ═════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">

                <!-- Avatar + Name -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Style="{StaticResource AvatarCircle72}"
                            x:Name="AvatarBorder"
                            Background="{Binding Initials, Converter={StaticResource InitialsToBrush}}"
                            Margin="0,0,16,0">
                        <Grid>
                            <Image x:Name="AvatarImage"
                                   Style="{StaticResource AvatarImage}"
                                   Width="72" Height="72"/>
                            <TextBlock x:Name="AvatarInitials"
                                       FontSize="22" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="FullNameText"
                                   FontSize="18" FontWeight="Bold" Foreground="#172B4D"/>
                        <TextBlock x:Name="UsernameText"
                                   FontSize="13" Foreground="#6B778C" Margin="0,3,0,4"/>
                        <Border x:Name="RoleBadge" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                            <TextBlock x:Name="RoleBadgeText" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Status badge -->
                <Border x:Name="StatusBar" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="BlockReasonText"
                                   FontSize="12" Foreground="#6B778C" Margin="8,0,0,0"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- CONTACT INFO -->
                <TextBlock Text="КОНТАКТНАЯ ИНФОРМАЦИЯ" Style="{StaticResource SectionHeader}"/>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="Email" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="EmailText" Style="{StaticResource InfoValue}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0">
                        <TextBlock Text="Роль" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="RoleText" Style="{StaticResource InfoValue}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="2">
                        <TextBlock Text="Дата регистрации" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="CreatedAtText" Style="{StaticResource InfoValue}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="2">
                        <TextBlock Text="Последний вход" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="LastLoginText" Style="{StaticResource InfoValue}"/>
                    </StackPanel>
                </Grid>

                <!-- RECENT ACTIVITY -->
                <TextBlock Text="ПОСЛЕДНЯЯ АКТИВНОСТЬ" Style="{StaticResource SectionHeader}"/>
                <ItemsControl x:Name="ActivityList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F4F5F7" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ActionText}"
                                               FontSize="12" Foreground="#172B4D"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CreatedAt, Converter={StaticResource UtcToLocalDateTime}, StringFormat='{}{0:dd.MM HH:mm}'}"
                                               FontSize="11" Foreground="#6B778C" Margin="8,0,0,0"
                                               VerticalAlignment="Top"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="NoActivityText"
                           Text="Активность не найдена"
                           FontSize="12" Foreground="#8993A4" Margin="0,4,0,0"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Footer ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="24,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0" Background="White">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="BlockButton"
                            Style="{StaticResource OutlineBtn}"
                            Click="Block_Click" Margin="0,0,10,0"/>
                    <Button x:Name="DeleteButton"
                            Background="#FEE2E2" Foreground="#991B1B"
                            BorderBrush="#FECACA" BorderThickness="1"
                            Padding="16,9" FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand" Content="Удалить"
                            Click="Delete_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#FEE2E2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <Button Content="Редактировать"
                        Style="{StaticResource BlackBtn}"
                        HorizontalAlignment="Right"
                        Click="Edit_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
