<UserControl x:Class="MPMS.Views.Overlays.CreateWarehouseItemOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin"     Value="0,20,0,10"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleLabel" Text="Добавить материал"
                               FontSize="20" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock x:Name="SubtitleLabel" Text="Заполните информацию"
                               FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Cancel_Click" Width="32" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,8">

                <TextBlock Text="ОСНОВНАЯ ИНФОРМАЦИЯ" Style="{StaticResource SectionHeader}"/>

                <!-- Name -->
                <TextBlock Text="Название *" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Height="42">
                    <TextBox x:Name="NameBox" BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                             Padding="0"/>
                </Border>

                <!-- Category (with add button) -->
                <TextBlock x:Name="CategoryLabel" Text="Категория" Style="{StaticResource FormLabel}"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="CategoryCombo" Grid.Column="0" Style="{StaticResource FormCombo}"
                              Height="42" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    <Button Grid.Column="1" Content="＋" Margin="8,0,0,0"
                            Style="{StaticResource OutlineBtn}" Height="42" Width="42"
                            ToolTip="Создать новую категорию"
                            Click="AddCategory_Click"/>
                </Grid>

                <!-- Unit (materials only — ComboBox with predefined list) -->
                <StackPanel x:Name="UnitPanel">
                    <TextBlock Text="Единица измерения" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="UnitCombo" Style="{StaticResource FormCombo}"
                              Height="42" Margin="0,0,0,12"
                              DisplayMemberPath="Display"
                              SelectionChanged="UnitCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Inventory number (equipment only) -->
                <StackPanel x:Name="InvNumberPanel" Visibility="Collapsed">
                    <TextBlock Text="Инвентарный номер" Style="{StaticResource FormLabel}"/>
                    <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Height="42">
                        <TextBox x:Name="InvNumberBox" BorderThickness="0" Background="Transparent"
                                 Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                                 Padding="0"/>
                    </Border>
                </StackPanel>

                <!-- Initial quantity + cost (materials create mode only) -->
                <StackPanel x:Name="QuantityCostPanel">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="QuantityLabel" Text="Начальное количество"
                                       Style="{StaticResource FormLabel}"/>
                            <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Height="42">
                                <TextBox x:Name="QuantityBox" BorderThickness="0" Background="Transparent"
                                         Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                                         Padding="0" Text="0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Стоимость за ед., ₽" Style="{StaticResource FormLabel}"/>
                            <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Height="42">
                                <TextBox x:Name="CostBox" BorderThickness="0" Background="Transparent"
                                         Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                                         Padding="0"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Cost only (edit mode) -->
                <StackPanel x:Name="CostOnlyPanel" Visibility="Collapsed" Margin="0,0,0,12">
                    <TextBlock Text="Стоимость за ед., ₽" Style="{StaticResource FormLabel}"/>
                    <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" Padding="12,10" Height="42">
                        <TextBox x:Name="CostEditBox" BorderThickness="0" Background="Transparent"
                                 Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                                 Padding="0"/>
                    </Border>
                </StackPanel>

                <!-- Description -->
                <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                    <TextBox x:Name="DescriptionBox" BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13"
                             Height="76" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="0"
                             VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Photo -->
                <TextBlock Text="ФОТО" Style="{StaticResource SectionHeader}"/>

                <!-- Preview -->
                <Border x:Name="PhotoPreviewBorder" Height="160" Background="#F4F5F7"
                        CornerRadius="8" Margin="0,0,0,10" Visibility="Collapsed"
                        BorderBrush="#DFE1E6" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <Image x:Name="PhotoPreview" Stretch="Uniform"/>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="8" Click="RemovePhoto_Click"
                                Width="28" Height="28" ToolTip="Удалить фото">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="#BF000000" CornerRadius="14">
                                        <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#E00000"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" Padding="12,10" Height="42">
                        <TextBox x:Name="ImagePathBox" BorderThickness="0" Background="Transparent"
                                 Foreground="#6B778C" FontSize="13" VerticalContentAlignment="Center"
                                 Padding="0" IsReadOnly="True"/>
                    </Border>
                    <Button Grid.Column="1" Content="Обзор…" Margin="8,0,0,0"
                            Click="BrowseImage_Click" Style="{StaticResource OutlineBtn}"
                            Height="42"/>
                </Grid>
                <TextBlock Text="Поддерживаются: JPG, PNG, BMP"
                           FontSize="11" Foreground="#6B778C" Margin="0,0,0,12"/>

                <!-- Error -->
                <Border x:Name="ErrorPanel" Background="#FFF0F0"
                        CornerRadius="8" Padding="14,10"
                        Margin="0,0,0,8" Visibility="Collapsed"
                        BorderBrush="#FCA5A5" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0"
                                   Foreground="#DC2626" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0"
                Background="White">
            <Grid>
                <Button Content="Отмена" HorizontalAlignment="Left"
                        Click="Cancel_Click" Style="{StaticResource OutlineBtn}"/>
                <Button x:Name="SaveButton" Content="Добавить"
                        HorizontalAlignment="Right"
                        Click="Save_Click" Style="{StaticResource BlackBtn}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
