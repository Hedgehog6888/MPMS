<UserControl x:Class="MPMS.Views.Overlays.TaskSummaryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InfoRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="IconBox" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F0F1F3"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#E8E9EC" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,16">

                <!-- Task header band -->
                <Border x:Name="StatusHeaderBand" Padding="16,14,16,14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F0F9FF"/>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- Label -->
                        <TextBlock Text="ЗАДАЧА" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,6"/>

                        <!-- Task name -->
                        <TextBlock x:Name="TaskNameText"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#000000"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <!-- Status badge -->
                        <Border x:Name="StatusBadge" CornerRadius="6" Padding="10,5"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        x:Name="StatusDot" Background="White"
                                        Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Foreground="White"
                                           FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Progress section -->
                <Border Padding="16,14,16,14" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Прогресс" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#000000" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="CompletedStagesText" FontSize="12"
                                           Foreground="#6B778C"/>
                                <TextBlock Text=" / " FontSize="12" Foreground="#6B778C"/>
                                <TextBlock x:Name="TotalStagesText" FontSize="12" Foreground="#6B778C"/>
                                <TextBlock Text=" этапов" FontSize="12" Foreground="#6B778C"/>
                            </StackPanel>
                        </Grid>

                        <!-- Progress bar -->
                        <Border x:Name="ProgressTrack" Background="#EEF0F3" CornerRadius="4" Height="8" Margin="0,0,0,6">
                            <Border x:Name="ProgressFill" CornerRadius="4" HorizontalAlignment="Left"
                                    Background="#0082FF" Width="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#0082FF"/>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>

                        <Grid>
                            <TextBlock x:Name="ProgressText" FontSize="20" FontWeight="Bold"
                                       Foreground="#000000"/>
                            <TextBlock x:Name="ProgressLabel" Text="выполнено"
                                       FontSize="11" Foreground="#6B778C"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Details section -->
                <StackPanel Margin="16,14,16,0">

                    <!-- Due date -->
                    <StackPanel Style="{StaticResource InfoRow}">
                        <Border Style="{StaticResource IconBox}">
                            <Image Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}"
                                   Width="16" Height="16" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="СРОК" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="DueDateText" FontSize="12" Foreground="#000000"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="DaysLeftText" FontSize="11"
                                       Foreground="#6B778C" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Project (if available) -->
                    <StackPanel x:Name="ProjectSection" Style="{StaticResource InfoRow}" Visibility="Collapsed">
                        <Border Style="{StaticResource IconBox}">
                            <Image Source="{svgc:SvgImage Source=/icons/project.svg, AppName=MPMS}"
                                   Width="16" Height="16" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ПРОЕКТ" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="ProjectNameText" FontSize="12" Foreground="#000000"
                                       TextWrapping="Wrap" MaxWidth="180"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="#F0F0F0" Height="1" Margin="0,4,0,16"/>

                    <!-- Прораб (как в сводке проекта) -->
                    <StackPanel x:Name="ForemanSection" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock Text="ПРОРАБ" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl x:Name="ForemanList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Button Style="{StaticResource PeekRowButton}" Margin="0"
                                                Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVis}}"
                                                Click="AssigneePeek_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Style="{StaticResource AvatarCircle32}"
                                                        Background="#166534" Margin="0,0,8,0">
                                                    <Grid>
                                                        <Image Style="{StaticResource AvatarImage}"
                                                               Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                               Width="32" Height="32"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding Initials}" Foreground="White"
                                                               FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding UserName}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="#000000"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVisInv}}">
                                            <Border Style="{StaticResource AvatarCircle32}"
                                                    Background="#166534" Margin="0,0,8,0">
                                                <Grid>
                                                    <Image Style="{StaticResource AvatarImage}"
                                                           Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                           Width="32" Height="32"
                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Text="{Binding Initials}" Foreground="White"
                                                           FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UserName}" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="#000000"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Работники (как в сводке проекта) -->
                    <StackPanel x:Name="WorkersSection" Margin="0,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="РАБОТНИКИ" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl x:Name="WorkersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Button Style="{StaticResource PeekRowButton}" Margin="0"
                                                Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVis}}"
                                                Click="AssigneePeek_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Style="{StaticResource AvatarCircle28}"
                                                        Background="#EA580C" Margin="0,0,8,0">
                                                    <Grid>
                                                        <Image Style="{StaticResource AvatarImage}"
                                                               Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                               Width="28" Height="28"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding Initials}" Foreground="White"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding UserName}" FontSize="12"
                                                               Foreground="#000000" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding RoleLabel}" FontSize="10"
                                                               Foreground="{Binding WorkerLineForegroundHex, Converter={StaticResource HexToBrush}}"
                                                               Margin="0,1,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RoleLabel}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsUserPeekInteractive, Converter={StaticResource BoolToVisInv}}">
                                            <Border Style="{StaticResource AvatarCircle28}"
                                                    Background="#EA580C" Margin="0,0,8,0">
                                                <Grid>
                                                    <Image Style="{StaticResource AvatarImage}"
                                                           Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                           Width="28" Height="28"
                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Text="{Binding Initials}" Foreground="White"
                                                               FontSize="10" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UserName}" FontSize="12"
                                                           Foreground="#000000" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding RoleLabel}" FontSize="10"
                                                           Foreground="{Binding WorkerLineForegroundHex, Converter={StaticResource HexToBrush}}"
                                                           Margin="0,1,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RoleLabel}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock x:Name="NoAssigneesText"
                               Text="Не назначено"
                               FontSize="12"
                               Foreground="#97A0AF"
                               Visibility="Collapsed"/>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
