<UserControl x:Class="MPMS.Views.Overlays.TaskSummaryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#F8F9FA" Padding="16" BorderBrush="#DFE1E6" BorderThickness="0,0,1,0">
        <StackPanel>
            <TextBlock Text="Задача" FontSize="11" FontWeight="SemiBold"
                       Foreground="#6B778C" Margin="0,0,0,8"/>
            <TextBlock x:Name="TaskNameText" FontSize="15" FontWeight="SemiBold"
                       Foreground="#172B4D" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,4"
                    HorizontalAlignment="Left" Margin="0,0,0,12">
                <TextBlock x:Name="StatusText" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
            </Border>
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Исполнитель" FontSize="11" Foreground="#6B778C" Margin="0,0,0,2"/>
                <TextBlock x:Name="AssigneeText" FontSize="13" Foreground="#172B4D"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Срок" FontSize="11" Foreground="#6B778C" Margin="0,0,0,2"/>
                <TextBlock x:Name="DueDateText" FontSize="13" Foreground="#172B4D"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Прогресс" FontSize="11" Foreground="#6B778C" Margin="0,0,0,4"/>
                <ProgressBar x:Name="ProgressBar" Maximum="100" Height="6"
                             Background="#E0E0E0" Foreground="#111111">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                <Border x:Name="PART_Track" CornerRadius="3">
                                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                            HorizontalAlignment="Left" CornerRadius="3"/>
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
                <TextBlock x:Name="ProgressText" FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
