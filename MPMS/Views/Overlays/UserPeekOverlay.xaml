<UserControl x:Class="MPMS.Views.Overlays.UserPeekOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:MPMS.Infrastructure"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             MinWidth="480" MaxWidth="480"
             MinHeight="624" MaxHeight="664" Height="648">

    <UserControl.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <ControlTemplate x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                <Border x:Name="PART_Track" CornerRadius="4">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="4"/>
                </Border>
            </Border>
        </ControlTemplate>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="BorderBrush"     Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlackBtn" TargetType="Button">
            <Setter Property="Background"      Value="#111111"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Шапка с бейджами -->
            <RowDefinition Height="Auto"/>  <!-- Профиль + вкладки (только хаб) -->
            <RowDefinition Height="*"/>     <!-- Скролл-контент -->
            <RowDefinition Height="Auto"/>  <!-- Футер -->
        </Grid.RowDefinitions>

        <!-- ── ШАПКА ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="White" Padding="20,16"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Кнопка "Назад" (детали задачи/этапа) -->
                    <Button x:Name="BackButton" Click="Back_Click"
                            Width="32" Height="32" Margin="0,0,10,0"
                            Visibility="Collapsed" ToolTip="Назад">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                    <TextBlock Text="←" FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#374151"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Хаб: бейдж роли -->
                    <Border x:Name="HubRoleBadge" CornerRadius="6" Padding="10,5" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="6" Height="6" CornerRadius="3" Background="White"
                                    Opacity="0.8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="HubRoleBadgeText" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <!-- Хаб: контекстный чип -->
                    <Border x:Name="HubContextChip" CornerRadius="6" Padding="8,4" Background="#F4F5F7">
                        <TextBlock Text="Карточка участника" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#8993A4"/>
                    </Border>

                </StackPanel>

                <!-- Кнопка закрыть -->
                <Button HorizontalAlignment="Right" Click="Close_Click"
                        Width="32" Height="32" ToolTip="Закрыть">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── ПРОФИЛЬ + ВКЛАДКИ (только в режиме хаба) ─────────── -->
        <StackPanel x:Name="HubFixedSection" Grid.Row="1">

            <!-- Блок профиля -->
            <Border Background="White" Padding="20,14,20,14"
                    BorderBrush="#E8E9EC" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Аватар -->
                    <Border x:Name="AvatarBorder" Width="80" Height="80" CornerRadius="40"
                            Background="#111111" Margin="0,0,16,0" VerticalAlignment="Top">
                        <Grid>
                            <Image x:Name="AvatarImage" Width="80" Height="80"
                                   Stretch="UniformToFill" Visibility="Collapsed"/>
                            <TextBlock x:Name="AvatarInitialsText" FontSize="26" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Имя + инфо -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="UserNameText" FontSize="17" FontWeight="Bold"
                                   Foreground="#000000" TextWrapping="Wrap"/>
                        <TextBlock x:Name="RoleLineText" FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                        <WrapPanel x:Name="SpecialtiesWrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                        <StackPanel x:Name="EmailRow" Orientation="Horizontal"
                                    Margin="0,3,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="EmailText" FontSize="12" Foreground="#6B778C"
                                       TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                        </StackPanel>
                        <TextBlock x:Name="JoinedText" FontSize="11" Foreground="#97A0AF"
                                   Margin="0,2,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Вкладки (как на странице проекта: белая «пилюля», без линии снизу) -->
            <Border Background="#F4F5F7" Padding="20,4,20,6">
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="6,4" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TabProjects" GroupName="UserPeekTabs"
                                     Style="{StaticResource TabButton}" Click="TabProjects_Click">
                            <TextBlock x:Name="TabProjectsLabel" Text="Проекты" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton x:Name="TabTasks" GroupName="UserPeekTabs"
                                     Style="{StaticResource TabButton}" Click="TabTasks_Click">
                            <TextBlock x:Name="TabTasksLabel" Text="Задачи" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton x:Name="TabStages" GroupName="UserPeekTabs"
                                     Style="{StaticResource TabButton}" Click="TabStages_Click">
                            <TextBlock x:Name="TabStagesLabel" Text="Этапы" VerticalAlignment="Center"/>
                        </RadioButton>
                    </StackPanel>
                </Border>
            </Border>
        </StackPanel>

        <!-- ── СКРОЛЛ-КОНТЕНТ ─────────────────────────────────────── -->
        <ScrollViewer x:Name="BodyScroll" Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Background="#F4F5F7">
            <Grid>

                <!-- ── ХАБ: списки ── -->
                <StackPanel x:Name="HubPanel" Margin="16,12,16,12">

                    <!-- Ошибка -->
                    <Border x:Name="ErrorPanel" CornerRadius="8" Padding="14,10"
                            Background="#FFEBE6" BorderBrush="#FFBDAD" BorderThickness="1"
                            Margin="0,0,0,10" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="14" Margin="0,0,8,0"
                                       VerticalAlignment="Top" Foreground="#BF2600"/>
                            <TextBlock x:Name="ErrorText" FontSize="13" Foreground="#BF2600"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Список проектов -->
                    <Grid x:Name="ProjectsTabPanel" Visibility="Visible">
                        <StackPanel>
                            <ItemsControl x:Name="ProjectsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Margin="0,0,0,4"
                                                Padding="12,10" BorderThickness="1.5"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ProjectRow_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#DFE1E6"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#000000"/>
                                                        </Trigger>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0" To="1" Duration="0:0:0.18"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#000000" TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <Image Source="{svgc:SvgImage Source=/icons/peek-arrow-right.svg, AppName=MPMS}"
                                                               Width="11" Height="11" Opacity="0.65" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Перейти в проект"
                                                                   FontSize="11" Foreground="#6B778C"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                                        VerticalAlignment="Top"
                                                        Background="{Binding Status, Converter={StaticResource ProjectStatusToBrush}}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource ProjectStatusToString}}"
                                                               Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoProjectsText" Text="Нет проектов в зоне вашего доступа"
                                       FontSize="13" Foreground="#97A0AF"
                                       Margin="4,6,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Список задач -->
                    <Grid x:Name="TasksTabPanel" Visibility="Collapsed">
                        <StackPanel>
                            <ItemsControl x:Name="TasksList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Margin="0,0,0,4"
                                                Padding="12,10" BorderThickness="1.5"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="TaskRow_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#DFE1E6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#DE350B"/>
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#000000"/>
                                                        </Trigger>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0" To="1" Duration="0:0:0.18"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#000000" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DueDateLine}" FontSize="11"
                                                           Foreground="#6B778C" Margin="0,3,0,0"/>
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource TaskStatusToBrush}}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                            <Setter Property="Background" Value="#DE350B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding Status, Converter={StaticResource TaskStatusToString}}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EffectiveTaskMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Text" Value="Пометка удаления"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding ProjectName}"
                                                                   FontSize="11" Foreground="#6B778C"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                            Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                                            Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="Просрочена" FontSize="10"
                                                                   FontWeight="SemiBold" Foreground="#DC2626"/>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoTasksText" Text="Нет назначенных задач"
                                       FontSize="13" Foreground="#97A0AF"
                                       Margin="4,6,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <!-- Список этапов -->
                    <Grid x:Name="StagesTabPanel" Visibility="Collapsed">
                        <StackPanel>
                            <ItemsControl x:Name="StagesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Margin="0,0,0,4"
                                                Padding="12,10" BorderThickness="1.5"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="StageRow_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#DFE1E6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EffectiveMarkedForDeletion}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#DE350B"/>
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#000000"/>
                                                        </Trigger>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0" To="1" Duration="0:0:0.18"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding StageName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#000000" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding TaskSubtitle}"
                                                           FontSize="11" Foreground="#6B778C"
                                                           Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DueDateLine}" FontSize="11"
                                                           Foreground="#6B778C" Margin="0,2,0,0"/>
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StageStatusToBrush}}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding EffectiveMarkedForDeletion}" Value="True">
                                                                            <Setter Property="Background" Value="#DE350B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding Status, Converter={StaticResource StageStatusToString}}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EffectiveMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Text" Value="Пометка удаления"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding ProjectName}"
                                                                   FontSize="11" Foreground="#6B778C"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                            Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                                            Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="Просрочен" FontSize="10"
                                                                   FontWeight="SemiBold" Foreground="#DC2626"/>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoStagesText" Text="Нет назначенных этапов"
                                       FontSize="13" Foreground="#97A0AF"
                                       Margin="4,6,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- ── ДЕТАЛИ ЗАДАЧИ ── -->
                <StackPanel x:Name="TaskDetailPanel" Visibility="Collapsed">

                    <!-- Заголовок задачи (фон по статусу — как в TaskSummaryPanel) -->
                    <Border x:Name="TaskDetailTitleBand" Padding="20,18,20,18" MinHeight="76"
                            Background="#F8F9FA"
                            BorderBrush="#E8E9EC" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TaskDetailTitle" FontSize="20" FontWeight="Bold"
                                   Foreground="#000000" TextWrapping="Wrap" LineHeight="28"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Карточки -->
                    <StackPanel Margin="16,12,16,16">

                        <!-- Прогресс -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ПРОГРЕСС ВЫПОЛНЕНИЯ"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#8993A4" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TaskDetailStagesInfo"
                                                   FontSize="13" Foreground="#6B778C"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TaskDetailProgressPct"
                                               FontSize="32" FontWeight="Bold" Foreground="#000000"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="TaskDetailProgressBar"
                                             Value="0" Maximum="100" Height="8"
                                             Background="#EEF0F3" Foreground="#0082FF"
                                             Template="{StaticResource SlimProgressBar}"/>
                            </StackPanel>
                        </Border>

                        <!-- Срок + приоритет -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16"
                                    BorderBrush="#E8E9EC" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="СРОК ВЫПОЛНЕНИЯ" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#8993A4" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TaskDetailDue" FontSize="15" FontWeight="Bold"
                                               Foreground="#000000"/>
                                    <TextBlock x:Name="TaskDetailDayName" FontSize="12"
                                               Foreground="#6B778C" Margin="0,2,0,0"/>
                                    <Border x:Name="TaskDetailOverdueBadge" CornerRadius="4" Padding="6,3"
                                            Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                            HorizontalAlignment="Left" Margin="0,6,0,0" Visibility="Collapsed">
                                        <TextBlock Text="Просрочена" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="#DC2626"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16"
                                    BorderBrush="#E8E9EC" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ПРИОРИТЕТ" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#8993A4" Margin="0,0,0,8"/>
                                    <Border x:Name="TaskPriorityBodyBadge" CornerRadius="6" Padding="10,5"
                                            BorderThickness="1.5" HorizontalAlignment="Left">
                                        <TextBlock x:Name="TaskDetailPriority" FontSize="13" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Описание -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ОПИСАНИЕ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TaskDetailDescription" FontSize="13"
                                           Foreground="#6B778C" TextWrapping="Wrap" LineHeight="22"/>
                            </StackPanel>
                        </Border>

                        <!-- Быстрые действия -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E8E9EC" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="БЫСТРЫЕ ДЕЙСТВИЯ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Открыть задачу" Click="OpenFullTask_Click"
                                            Style="{StaticResource BlackBtn}" Margin="0,0,8,0"/>
                                    <Button Content="Перейти в проект" Click="GoToTaskProject_Click"
                                            Style="{StaticResource OutlineBtn}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>

                <!-- ── ДЕТАЛИ ЭТАПА ── -->
                <StackPanel x:Name="StageDetailPanel" Visibility="Collapsed">

                    <!-- Заголовок этапа (фон по статусу этапа — как палитра сводки задачи) -->
                    <Border x:Name="StageDetailTitleBand" Padding="20,18,20,18" MinHeight="76"
                            Background="#F8F9FA"
                            BorderBrush="#E8E9EC" BorderThickness="0,0,0,1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ЭТАП" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#8993A4" Margin="0,0,0,6"/>
                            <TextBlock x:Name="StageDetailTitle" FontSize="20" FontWeight="Bold"
                                       Foreground="#000000" TextWrapping="Wrap" LineHeight="28"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточки -->
                    <StackPanel Margin="16,12,16,16">

                        <!-- Срок -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="СРОК ВЫПОЛНЕНИЯ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,8"/>
                                <TextBlock x:Name="StageDetailDue" FontSize="15" FontWeight="Bold"
                                           Foreground="#000000"/>
                                <TextBlock x:Name="StageDetailDayName" FontSize="12"
                                           Foreground="#6B778C" Margin="0,2,0,0"/>
                                <Border x:Name="StageDetailOverdueBadge" CornerRadius="4" Padding="6,3"
                                        Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                        HorizontalAlignment="Left" Margin="0,6,0,0" Visibility="Collapsed">
                                    <TextBlock Text="Просрочен" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#DC2626"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Описание -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ОПИСАНИЕ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,8"/>
                                <TextBlock x:Name="StageDetailDescription" FontSize="13"
                                           Foreground="#6B778C" TextWrapping="Wrap" LineHeight="22"/>
                            </StackPanel>
                        </Border>

                        <!-- Связь: задача + проект -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E8E9EC" BorderThickness="1" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="СВЯЗАНО С" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Задача" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#8993A4"
                                               VerticalAlignment="Top" Margin="0,1,0,0"/>
                                    <TextBlock x:Name="StageDetailTaskLine" Grid.Column="1"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#000000" TextWrapping="Wrap"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Проект" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#8993A4"
                                               VerticalAlignment="Top" Margin="0,1,0,0"/>
                                    <TextBlock x:Name="StageDetailProjectLine" Grid.Column="1"
                                               FontSize="13" Foreground="#6B778C" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Быстрые действия -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E8E9EC" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="БЫСТРЫЕ ДЕЙСТВИЯ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8993A4" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Открыть этап" Click="OpenFullStage_Click"
                                            Style="{StaticResource BlackBtn}" Margin="0,0,8,0"/>
                                    <Button Content="Открыть задачу" Click="OpenFullTaskFromStage_Click"
                                            Style="{StaticResource OutlineBtn}" Margin="0,0,8,0"/>
                                    <Button Content="Перейти в проект" Click="GoToStageProject_Click"
                                            Style="{StaticResource OutlineBtn}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- ── ФУТЕР ──────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="White" Padding="20,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0">
            <Button Content="Закрыть" Click="Close_Click"
                    Style="{StaticResource OutlineBtn}"
                    HorizontalAlignment="Right"/>
        </Border>

    </Grid>
</UserControl>
