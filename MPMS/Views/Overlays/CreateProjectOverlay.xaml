<UserControl x:Class="MPMS.Views.Overlays.CreateProjectOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>

        <Style x:Key="MemberChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,2,6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="UserPickerItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleLabel" Text="Создать проект"
                               FontSize="20" FontWeight="Bold" Foreground="#000000"/>
                    <TextBlock x:Name="SubtitleLabel" Text="Заполните информацию о монтажном проекте"
                               FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Cancel_Click" Width="32" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Form -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,8,24,8">

                <!-- Section: Основная информация -->
                <TextBlock Text="ОСНОВНАЯ ИНФОРМАЦИЯ" Style="{StaticResource SectionHeader}"/>

                <!-- Name -->
                <TextBlock Text="Название проекта *" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Height="42">
                    <TextBox x:Name="NameBox" BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                             Padding="0"/>
                </Border>

                <!-- Description -->
                <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                    <TextBox x:Name="DescriptionBox" BorderThickness="0" Background="Transparent"
                             Foreground="#000000" FontSize="13"
                             Height="76" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="0"
                             VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Client + Address -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Заказчик *" Style="{StaticResource FormLabel}"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Height="42">
                            <TextBox x:Name="ClientBox" BorderThickness="0" Background="Transparent"
                                     Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                                     Padding="0"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Адрес объекта" Style="{StaticResource FormLabel}"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Height="42">
                            <TextBox x:Name="AddressBox" BorderThickness="0" Background="Transparent"
                                     Foreground="#000000" FontSize="13" VerticalContentAlignment="Center"
                                     Padding="0"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Dates -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Дата начала *" Style="{StaticResource FormLabel}"/>
                        <DatePicker x:Name="StartDatePicker" Height="42"
                                    FontSize="13" Foreground="#000000"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Дата завершения *" Style="{StaticResource FormLabel}"/>
                        <DatePicker x:Name="EndDatePicker" Height="42"
                                    FontSize="13" Foreground="#000000"/>
                    </StackPanel>
                </Grid>

                <!-- Section: Команда -->
                <TextBlock Text="КОМАНДА ПРОЕКТА" Style="{StaticResource SectionHeader}"/>

                <!-- Manager (один выбор, тот же вид списка, что у прорабов/работников) -->
                <TextBlock Text="Менеджер проекта *" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                <Border x:Name="ManagerPickerHost" Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" MaxHeight="200" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                        <StackPanel>
                            <ItemsControl x:Name="ManagerPickerList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Tag="{Binding}"
                                                MouseLeftButtonDown="ManagerItem_Click">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource UserPickerItem}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8F9FA"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Style="{StaticResource AvatarCircle32}"
                                                            Background="{Binding AvatarBrush}"
                                                            Margin="0,0,10,0">
                                                        <Grid>
                                                            <Image Style="{StaticResource AvatarImage}"
                                                                   Source="{Binding User.AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                   Width="32" Height="32"
                                                                   Visibility="{Binding User.AvatarData, Converter={StaticResource NullToVis}}"/>
                                                            <TextBlock Text="{Binding Initials}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding User.AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                        </Grid>
                                                    </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#000000"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                <Border Width="22" Height="22" CornerRadius="11"
                                                        Background="#111111"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsSelectedVis}">
                                                    <TextBlock Text="✓" FontSize="10" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoManagerHint"
                                       Text="Нет доступных менеджеров"
                                       FontSize="12" Foreground="#97A0AF"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,12" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Foreman picker -->
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Прораб" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>

                    <!-- Selected foremen chips -->
                    <WrapPanel x:Name="SelectedForemenPanel" Grid.Row="1"
                               Margin="0,0,0,8"
                               Visibility="Collapsed"/>

                    <!-- Foreman list (как в CreateTaskOverlay/CreateStageOverlay) -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                            <StackPanel>
                                <ItemsControl x:Name="ForemanPickerList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Tag="{Binding}"
                                                    MouseLeftButtonDown="ForemanItem_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource UserPickerItem}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F8F9FA"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource AvatarCircle32}"
                                                                Background="{Binding AvatarBrush}"
                                                                Margin="0,0,10,0">
                                                            <Grid>
                                                                <Image Style="{StaticResource AvatarImage}"
                                                                       Source="{Binding User.AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                       Width="32" Height="32"
                                                                       Visibility="{Binding User.AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           FontSize="11" FontWeight="Bold"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding User.AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#000000"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Width="22" Height="22" CornerRadius="11"
                                                            Background="#111111"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsSelectedVis}">
                                                        <TextBlock Text="✓" FontSize="10" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoForemanHint"
                                           Text="Нет доступных прорабов"
                                           FontSize="12" Foreground="#97A0AF"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,12" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Workers multi-picker -->
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Работники" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>

                    <!-- Selected workers chips -->
                    <WrapPanel x:Name="SelectedWorkersPanel" Grid.Row="1"
                               Margin="0,0,0,8" Visibility="Collapsed"/>

                    <!-- Workers list (как в CreateTaskOverlay/CreateStageOverlay) -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                            <StackPanel>
                                <ItemsControl x:Name="WorkerPickerList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Tag="{Binding}"
                                                    MouseLeftButtonDown="WorkerItem_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource UserPickerItem}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F8F9FA"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource AvatarCircle32}"
                                                                Background="{Binding AvatarBrush}"
                                                                Margin="0,0,10,0">
                                                            <Grid>
                                                                <Image Style="{StaticResource AvatarImage}"
                                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                       Width="32" Height="32"
                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           FontSize="11" FontWeight="Bold"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#000000"/>
                                                            <TextBlock Text="{Binding RoleSubtitle}"
                                                                       FontSize="11"
                                                                       Foreground="{Binding RoleSubtitleBrush}"
                                                                       Visibility="{Binding RoleSubtitleVis}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Width="22" Height="22" CornerRadius="11"
                                                            Background="#111111"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsSelectedVis}">
                                                        <TextBlock Text="✓" FontSize="10" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoWorkersHint"
                                           Text="Нет доступных работников"
                                           FontSize="12" Foreground="#97A0AF"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,12" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Status row (edit mode only) -->
                <StackPanel x:Name="StatusRow" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="СТАТУС" Style="{StaticResource SectionHeader}"/>
                    <ComboBox x:Name="StatusCombo" Style="{StaticResource FormCombo}"
                              Height="42" Margin="0,0,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0"
                Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Отмена" HorizontalAlignment="Left"
                        Click="Cancel_Click" Style="{StaticResource OutlineBtn}"/>
                <Border x:Name="ErrorPanel" Grid.Column="1"
                        Background="#FFF0F0" BorderBrush="#FCA5A5" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="16,0"
                        MaxWidth="520" Visibility="Collapsed"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>
                <Button Grid.Column="2" x:Name="SaveButton" Content="Создать проект"
                        HorizontalAlignment="Right"
                        Click="Save_Click" Style="{StaticResource BlackBtn}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
