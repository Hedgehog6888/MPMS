<UserControl x:Class="MPMS.Views.Overlays.CreateProjectOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8993A4"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>

        <Style x:Key="MemberChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,2,6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="UserPickerItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleLabel" Text="Создать проект"
                               FontSize="20" FontWeight="Bold" Foreground="#172B4D"/>
                    <TextBlock Text="Заполните информацию о монтажном проекте"
                               FontSize="12" Foreground="#6B778C" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Cancel_Click" Width="32" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,8">

                <!-- Section: Основная информация -->
                <TextBlock Text="ОСНОВНАЯ ИНФОРМАЦИЯ" Style="{StaticResource SectionHeader}"/>

                <!-- Name -->
                <TextBlock Text="Название проекта *" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Height="42">
                    <TextBox x:Name="NameBox" BorderThickness="0" Background="Transparent"
                             Foreground="#172B4D" FontSize="13" VerticalContentAlignment="Center"
                             Padding="0"/>
                </Border>

                <!-- Description -->
                <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
                <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                    <TextBox x:Name="DescriptionBox" BorderThickness="0" Background="Transparent"
                             Foreground="#172B4D" FontSize="13"
                             Height="76" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="0"
                             VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Client + Address -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Заказчик *" Style="{StaticResource FormLabel}"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Height="42">
                            <TextBox x:Name="ClientBox" BorderThickness="0" Background="Transparent"
                                     Foreground="#172B4D" FontSize="13" VerticalContentAlignment="Center"
                                     Padding="0"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Адрес объекта" Style="{StaticResource FormLabel}"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Height="42">
                            <TextBox x:Name="AddressBox" BorderThickness="0" Background="Transparent"
                                     Foreground="#172B4D" FontSize="13" VerticalContentAlignment="Center"
                                     Padding="0"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Dates -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Дата начала *" Style="{StaticResource FormLabel}"/>
                        <DatePicker x:Name="StartDatePicker" Height="42"
                                    FontSize="13" Foreground="#172B4D"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Дата завершения *" Style="{StaticResource FormLabel}"/>
                        <DatePicker x:Name="EndDatePicker" Height="42"
                                    FontSize="13" Foreground="#172B4D"/>
                    </StackPanel>
                </Grid>

                <!-- Section: Команда -->
                <TextBlock Text="КОМАНДА ПРОЕКТА" Style="{StaticResource SectionHeader}"/>

                <!-- Manager -->
                <TextBlock Text="Менеджер проекта *" Style="{StaticResource FormLabel}"/>
                <ComboBox x:Name="ManagerCombo" Style="{StaticResource FormCombo}"
                          Margin="0,0,0,16"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>

                <!-- Foreman picker -->
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Прораб" Style="{StaticResource FormLabel}" Margin="0"/>
                        <TextBlock Text=" (один)" FontSize="11" Foreground="#6B778C"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- Selected foreman chip -->
                    <StackPanel x:Name="SelectedForemanPanel" Grid.Row="1"
                                Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="Collapsed">
                        <Border Style="{StaticResource MemberChip}"
                                Background="#ECFDF5" BorderBrush="#6EE7B7" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="SelectedForemanName"
                                           FontSize="12" Foreground="#166534"
                                           VerticalAlignment="Center"/>
                                <Button Style="{StaticResource ChipRemoveButton}"
                                        Click="RemoveForeman_Click" Margin="6,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="✕" FontSize="10" Foreground="#6B778C"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Foreman list (как в CreateTaskOverlay/CreateStageOverlay) -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <ItemsControl x:Name="ForemanPickerList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Tag="{Binding}"
                                                    MouseLeftButtonDown="ForemanItem_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource UserPickerItem}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F8F9FA"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource AvatarCircle32}"
                                                                Background="{Binding AvatarBrush}"
                                                                Margin="0,0,10,0">
                                                            <Grid>
                                                                <Image Style="{StaticResource AvatarImage}"
                                                                       Source="{Binding User.AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                       Width="32" Height="32"
                                                                       Visibility="{Binding User.AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           FontSize="11" FontWeight="Bold"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding User.AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#172B4D"/>
                                                            <TextBlock Text="{Binding RoleDisplay}"
                                                                       FontSize="11"
                                                                       Foreground="{Binding RoleColorBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Width="22" Height="22" CornerRadius="11"
                                                            Background="#111111"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsSelectedVis}">
                                                        <TextBlock Text="✓" FontSize="10" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoForemanHint"
                                           Text="Нет доступных прорабов"
                                           FontSize="12" Foreground="#97A0AF"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,12" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Workers multi-picker -->
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Работники" Style="{StaticResource FormLabel}" Margin="0"/>
                        <TextBlock Text=" (можно несколько)" FontSize="11" Foreground="#6B778C"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- Selected workers chips -->
                    <WrapPanel x:Name="SelectedWorkersPanel" Grid.Row="1"
                               Margin="0,0,0,8" Visibility="Collapsed"/>

                    <!-- Workers list (как в CreateTaskOverlay/CreateStageOverlay) -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                            CornerRadius="8" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <ItemsControl x:Name="WorkerPickerList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Tag="{Binding}"
                                                    MouseLeftButtonDown="WorkerItem_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource UserPickerItem}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F8F9FA"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource AvatarCircle32}"
                                                                Background="{Binding AvatarBrush}"
                                                                Margin="0,0,10,0">
                                                            <Grid>
                                                                <Image Style="{StaticResource AvatarImage}"
                                                                       Source="{Binding AvatarData, Converter={StaticResource AvatarBytesToImage}}"
                                                                       Width="32" Height="32"
                                                                       Visibility="{Binding AvatarData, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           FontSize="11" FontWeight="Bold"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding AvatarData, Converter={StaticResource NullToVisInv}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#172B4D"/>
                                                            <TextBlock Text="{Binding RoleDisplay}"
                                                                       FontSize="11"
                                                                       Foreground="{Binding RoleColorBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Width="22" Height="22" CornerRadius="11"
                                                            Background="#111111"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsSelectedVis}">
                                                        <TextBlock Text="✓" FontSize="10" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoWorkersHint"
                                           Text="Нет доступных работников"
                                           FontSize="12" Foreground="#97A0AF"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,12" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Status row (edit mode only) -->
                <StackPanel x:Name="StatusRow" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="СТАТУС" Style="{StaticResource SectionHeader}"/>
                    <ComboBox x:Name="StatusCombo" Style="{StaticResource FormCombo}"/>
                </StackPanel>

                <!-- Error message -->
                <Border x:Name="ErrorPanel" Background="#FFF0F0"
                        CornerRadius="8" Padding="14,10"
                        Margin="0,0,0,8" Visibility="Collapsed"
                        BorderBrush="#FCA5A5" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0"
                                   Foreground="#DC2626" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0"
                Background="White">
            <Grid>
                <Button Content="Отмена" HorizontalAlignment="Left"
                        Click="Cancel_Click" Style="{StaticResource OutlineBtn}"/>
                <Button x:Name="SaveButton" Content="Создать проект"
                        HorizontalAlignment="Right"
                        Click="Save_Click" Style="{StaticResource BlackBtn}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
