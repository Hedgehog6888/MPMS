<UserControl x:Class="MPMS.Views.Overlays.TaskDetailOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:MPMS.Infrastructure"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <UserControl.Resources>
        <!-- Slim progress bar template -->
        <ControlTemplate x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                <Border x:Name="PART_Track" CornerRadius="4">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="4"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Outline button style -->
        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#172B4D"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button style (mark for deletion) -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#DE350B"/>
            <Setter Property="BorderBrush" Value="#FFBDAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFEBE6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Black button style -->
        <Style x:Key="BlackBtn" TargetType="Button">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header badges + close -->
            <RowDefinition Height="*"/>      <!-- Scrollable content -->
            <RowDefinition Height="Auto"/>   <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- ── HEADER ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="20,16"
                BorderBrush="#E8E9EC" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <!-- Status + Priority badges -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status badge -->
                    <Border x:Name="StatusBadge" CornerRadius="6" Padding="10,5" Margin="0,0,8,0"
                            Background="{Binding Task.Status, Converter={StaticResource TaskStatusToBrush}}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="White" Opacity="0.8"
                                    Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Task.Status, Converter={StaticResource TaskStatusToString}}"
                                       FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Priority badge -->
                    <Border CornerRadius="6" Padding="10,5"
                            BorderThickness="1.5"
                            BorderBrush="{Binding Task.Priority, Converter={StaticResource PriorityToBrush}}">
                        <TextBlock Text="{Binding Task.Priority, Converter={StaticResource PriorityToString}}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{Binding Task.Priority, Converter={StaticResource PriorityToBrush}}"/>
                    </Border>
                </StackPanel>

                <!-- Close button -->
                <Button HorizontalAlignment="Right" Click="Close_Click"
                        Width="32" Height="32"
                        ToolTip="Закрыть">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#F4F5F7" CornerRadius="16">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8E9EC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── CONTENT (no overlay scroll; only tab lists scroll) ───── -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fixed: title, description, progress, assignee, tabs -->
            <StackPanel Grid.Row="0" Margin="20,16,20,12">

                <!-- Task title -->
                <TextBlock Text="{Binding Task.Name}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#172B4D"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>

                <!-- Description -->
                <TextBlock Text="{Binding Task.Description}"
                           FontSize="13" Foreground="#6B778C"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Visibility="{Binding Task.Description, Converter={StaticResource StringToVis}}"/>

                <!-- Deletion mark warning -->
                <Border x:Name="DeletionWarningBorder" CornerRadius="8" Padding="14,10"
                        Background="#FFEBE6" BorderBrush="#FFBDAD" BorderThickness="1"
                        Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                   Foreground="#BF2600"/>
                        <TextBlock Text="Задача помечена для удаления" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#BF2600" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#DFE1E6" Height="1" Margin="0,0,0,16"/>

                <!-- Progress section -->
                <Grid Margin="0,0,0,10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ПРОГРЕСС ВЫПОЛНЕНИЯ"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#8993A4" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Task.CompletedStages}"
                                       FontSize="13" Foreground="#6B778C"/>
                            <TextBlock Text=" из " FontSize="13" Foreground="#6B778C"/>
                            <TextBlock Text="{Binding Task.TotalStages}"
                                       FontSize="13" Foreground="#6B778C"/>
                            <TextBlock Text=" этапов" FontSize="13" Foreground="#6B778C"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding Task.ProgressPercent, StringFormat='{}{0}%'}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#172B4D"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
                <ProgressBar Value="{Binding Task.ProgressPercent, Mode=OneWay}"
                             Maximum="100" Height="8" Margin="0,0,0,16"
                             Background="#EEF0F3"
                             Foreground="{Binding Task.ProgressPercent, Converter={StaticResource ProgressPercentToBrush}}"
                             Template="{StaticResource SlimProgressBar}"/>

                <Border Background="#DFE1E6" Height="1" Margin="0,0,0,16"/>

                <!-- Assignees + Due Date layout -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Assignees (multi) -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ИСПОЛНИТЕЛИ" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#8993A4" Margin="0,0,0,8"/>

                        <!-- Multi-assignee avatar strip (populated in code-behind) -->
                        <ItemsControl x:Name="AssigneesDisplay">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Width="30" Height="30" CornerRadius="15"
                                                Background="#1B6EC2" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding UserName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#172B4D"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Fallback: no assignees -->
                        <TextBlock x:Name="NoAssigneesText"
                                   Text="Не назначено" FontSize="12"
                                   Foreground="#97A0AF" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Due Date -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="СРОК ВЫПОЛНЕНИЯ" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#8993A4" Margin="0,0,0,8"/>
                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="#172B4D"
                                   Text="{Binding Task.DueDate, Converter={StaticResource DateOnlyToString}, ConverterParameter=long}"
                                   Margin="0,0,0,2"/>
                        <TextBlock FontSize="12" Foreground="#6B778C"
                                   Text="{Binding Task.DueDate, Converter={StaticResource DateOnlyToString}, ConverterParameter=dayname}"/>

                        <!-- Overdue badge -->
                        <Border x:Name="OverdueBadge" CornerRadius="4" Padding="6,3"
                                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                HorizontalAlignment="Left" Margin="0,4,0,0"
                                Visibility="{Binding Task.IsOverdue, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Просрочена" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#DC2626"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Background="#DFE1E6" Height="1" Margin="0,0,0,0"/>

                <!-- Inner Tabs -->
                <Border Margin="0,4,0,8">
                    <Border Background="#F4F5F7" CornerRadius="10" Padding="3"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="StagesTab" Tag="Stages" IsChecked="True"
                                         Style="{StaticResource TabButton}" Click="InnerTab_Click">
                                <TextBlock Text="{Binding StagesTabLabel}" VerticalAlignment="Center"/>
                            </RadioButton>
                            <RadioButton x:Name="MaterialsTab" Tag="Materials"
                                         Style="{StaticResource TabButton}" Click="InnerTab_Click">
                                <TextBlock Text="Материалы" VerticalAlignment="Center"/>
                            </RadioButton>
                            <RadioButton x:Name="FilesTab" Tag="Files"
                                         Style="{StaticResource TabButton}" Click="InnerTab_Click">
                                <TextBlock Text="Файлы" VerticalAlignment="Center"/>
                            </RadioButton>
                            <RadioButton x:Name="MessagesTab" Content="Сообщения"
                                         Tag="Messages"
                                         Style="{StaticResource TabButton}"
                                         Click="InnerTab_Click"/>
                        </StackPanel>
                    </Border>
                </Border>

            </StackPanel>

            <!-- Tab content area: only list scrolls, buttons/input at bottom -->
            <Grid Grid.Row="1" Margin="20,0,20,16" MinHeight="200">
                <!-- STAGES tab content -->
                <Grid x:Name="StagesPanel" Margin="0,0,0,0" MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scrollable list / empty state -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Stages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Margin="0,0,0,4"
                                                Padding="10,6" BorderThickness="1.5"
                                                Cursor="Hand" HorizontalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#DE350B"/>
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#172B4D"/>
                                                        </Trigger>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0" To="1" Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Name -->
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"/>
                                                <!-- Description -->
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,2,0,4" TextWrapping="Wrap"
                                                           Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                                <!-- Status | Assignee | Actions row -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Border CornerRadius="4" Padding="5,2" Margin="0,0,6,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StageStatusToBrush}}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                            <Setter Property="Background" Value="#DE350B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding Status, Converter={StaticResource StageStatusToString}}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Text" Value="Пометка удаления"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding AssignedUserName}"
                                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Visibility="{Binding AssignedUserName, Converter={StaticResource StringToVis}}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Start: Planned → InProgress -->
                                                    <Button Tag="{Binding}" Click="StartStage_Click" Margin="0,0,4,0"
                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                            Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Planned}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image Source="{svgc:SvgImage Source=/icons/play.svg, AppName=MPMS}"
                                                                   Width="12" Height="12" Margin="0,0,4,0"
                                                                   VerticalAlignment="Center" Opacity="0.8"/>
                                                            <TextBlock Text="Начать" VerticalAlignment="Center"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <!-- Complete: InProgress → Completed -->
                                                    <Button Tag="{Binding}" Click="CompleteStage_Click" Margin="0,0,4,0"
                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                            Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                                                                   Width="10" Height="10" Margin="0,0,4,0"
                                                                   VerticalAlignment="Center" Opacity="0.9"/>
                                                            <TextBlock Text="Завершить" VerticalAlignment="Center"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <!-- Revert: InProgress → Planned -->
                                                    <Button Tag="{Binding}" Click="RevertStage_Click" Margin="0,0,4,0"
                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                            ToolTip="Вернуть в запланированные"
                                                            Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}">
                                                        <TextBlock Text="Отменить" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Button>
                                                    <!-- Reopen: Completed → InProgress -->
                                                    <Button Tag="{Binding}" Click="ReopenStage_Click" Margin="0,0,4,0"
                                                            Style="{StaticResource IconButton}" FontSize="12"
                                                            ToolTip="Открыть снова"
                                                            Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Completed}">
                                                        <TextBlock Text="Переоткрыть" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Button>
                                                    <!-- Edit (hidden when marked) -->
                                                    <Button ToolTip="Редактировать" Tag="{Binding}"
                                                            Click="EditStage_Click" Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                <Setter Property="Visibility" Value="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Image Source="{svgc:SvgImage Source=/icons/editing.svg, AppName=MPMS}"
                                                               Width="14" Height="14" VerticalAlignment="Center"/>
                                                    </Button>
                                                    <!-- Mark/unmark for deletion -->
                                                    <Button Tag="{Binding}" Click="MarkStageForDeletion_Click"
                                                            Margin="0,0,4,0" Style="{StaticResource IconButton}"
                                                            Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Worker,Foreman'}">
                                                        <Button.ToolTip>
                                                            <ToolTip>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Пометить к удалению"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                    <Setter Property="Text" Value="Снять пометку удаления"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </ToolTip>
                                                        </Button.ToolTip>
                                                        <Grid>
                                                            <Image Source="{svgc:SvgImage Source=/icons/markDelete.svg, AppName=MPMS}"
                                                                   Width="14" Height="14" VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                            <Image Source="{svgc:SvgImage Source=/icons/removeMarkDelete.svg, AppName=MPMS}"
                                                                   Width="14" Height="14" VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                        </Grid>
                                                    </Button>
                                                    <!-- Delete stage -->
                                                    <Button ToolTip="Удалить этап" Tag="{Binding}"
                                                            Click="DeleteStage_Click"
                                                            Style="{StaticResource DangerIconButton}"
                                                            Visibility="{Binding Converter={StaticResource RoleToVis}, ConverterParameter='Foreman,Project Manager,Administrator'}">
                                                        <Image Source="{svgc:SvgImage Source=/icons/trash.svg, AppName=MPMS}"
                                                               Width="14" Height="14" VerticalAlignment="Center"/>
                                                    </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state for stages -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,24,0,8"
                                        Visibility="{Binding HasNoStages, Converter={StaticResource BoolToVis}}">
                                <Border Width="56" Height="56" CornerRadius="28" Background="#F4F5F7"
                                        HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Image Source="{svgc:SvgImage Source=/icons/check.svg, AppName=MPMS}"
                                           Width="28" Height="28" HorizontalAlignment="Center" Opacity="0.35"/>
                                </Border>
                                <TextBlock Text="Этапы ещё не добавлены" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Разбейте задачу на этапы для лучшего отслеживания" FontSize="12"
                                           Foreground="#97A0AF" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Add stage button pinned to bottom of tab area -->
                    <Button x:Name="AddStageBtn" Grid.Row="1" Click="AddStage_Click"
                            Margin="0,10,0,0" Height="36" FontSize="13"
                            Style="{StaticResource OutlineBtn}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{svgc:SvgImage Source=/icons/plus_black.svg, AppName=MPMS}"
                                   Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Добавить этап" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- MATERIALS tab content: scroll only list -->
                <Grid x:Name="MaterialsPanel" Visibility="Collapsed" Margin="0,0,0,0" MinHeight="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding AllMaterials}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                                Padding="14,12"
                                                BorderBrush="#DFE1E6" BorderThickness="1">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.7"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding MaterialName}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#172B4D"/>
                                                        <TextBlock Text="{Binding StageName, StringFormat='Этап: {0}'}"
                                                                   FontSize="11" Foreground="#6B778C" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="#172B4D">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} {1}">
                                                            <Binding Path="Quantity"/>
                                                            <Binding Path="Unit"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty materials -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,24,0,8"
                                        Visibility="{Binding HasNoMaterials, Converter={StaticResource BoolToVis}}">
                                <Image Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}" Width="36" Height="36" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Материалы ещё не добавлены" FontSize="13"
                                           Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- FILES tab content: scroll only list, button at bottom -->
                <Grid x:Name="FilesPanel" Visibility="Collapsed" Margin="0,0,0,0" MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Files}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                                Padding="14,12"
                                                BorderBrush="#DFE1E6" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{svgc:SvgImage Source=/icons/file.svg, AppName=MPMS}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.7"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="#172B4D"/>
                                                    <TextBlock Text="{Binding FileType}" FontSize="11"
                                                               Foreground="#6B778C" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty files -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,24,0,8"
                                        Visibility="{Binding HasNoFiles, Converter={StaticResource BoolToVis}}">
                                <Image Source="{svgc:SvgImage Source=/icons/files.svg, AppName=MPMS}" Width="36" Height="36" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Файлы ещё не загружены" FontSize="13"
                                           Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <Button Grid.Row="1" Click="UploadFiles_Click" Margin="0,10,0,0" Height="36" FontSize="13"
                            Style="{StaticResource OutlineBtn}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{svgc:SvgImage Source=/icons/upload.svg, AppName=MPMS}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Загрузить файлы" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- MESSAGES tab content: scroll only messages, input at bottom -->
                <Grid x:Name="MessagesPanel" Visibility="Collapsed" Margin="0,0,0,0" MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Messages list -->
                    <ScrollViewer Grid.Row="0" x:Name="MessagesScrollViewer"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Avatar -->
                                            <Border Width="34" Height="34" CornerRadius="17"
                                                    Margin="0,0,10,0" VerticalAlignment="Top"
                                                    Background="{Binding UserColor, Converter={StaticResource HexToBrush}}">
                                                <TextBlock Text="{Binding UserInitials}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- Message bubble -->
                                            <StackPanel Grid.Column="1">
                                                <!-- Name + role + time row -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding UserName}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#172B4D" Margin="0,0,6,0"/>
                                                    <Border CornerRadius="4" Padding="5,1"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#EBF2FF"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UserRole}" Value="Прораб">
                                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding UserRole}" Value="Работник">
                                                                        <Setter Property="Background" Value="#FFF8E1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding UserRole}"
                                                                   FontSize="10" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#1B6EC2"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UserRole}" Value="Прораб">
                                                                            <Setter Property="Foreground" Value="#00875A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding UserRole}" Value="Работник">
                                                                            <Setter Property="Foreground" Value="#856404"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                               FontSize="10" Foreground="#97A0AF"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </StackPanel>
                                                <!-- Message text bubble -->
                                                <Border Background="#F4F5F7" CornerRadius="0,8,8,8"
                                                        Padding="10,8" MaxWidth="340" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="13" Foreground="#172B4D"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty messages state -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,16,0,16"
                                        Visibility="{Binding Messages.Count, Converter={StaticResource IntToVisInv}}">
                                <TextBlock Text="Нет сообщений" FontSize="13" Foreground="#97A0AF"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Начните обсуждение задачи" FontSize="12"
                                           Foreground="#C1C7D0" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Message input -->
                    <Border Grid.Row="1" Background="#F4F5F7" CornerRadius="8"
                            Margin="0,10,0,0" Padding="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MessageInput" Grid.Column="0"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#172B4D" FontSize="13"
                                     Padding="8,8" VerticalContentAlignment="Center"
                                     KeyDown="MessageInput_KeyDown"
                                     AcceptsReturn="False"/>
                            <Button Grid.Column="1" Content="Отправить"
                                    Click="SendMessage_Click"
                                    Height="34" Padding="14,0"
                                    Style="{StaticResource BlackBtn}"/>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Grid>

        <!-- ── FOOTER ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="20,14"
                BorderBrush="#E8E9EC" BorderThickness="0,1,0,0"
                Background="White">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="MarkDeletionBtn" Click="MarkTaskForDeletion_Click"
                            Style="{StaticResource DangerBtn}" Margin="0,0,8,0">
                        <TextBlock x:Name="MarkDeletionBtnText" Text="Пометить к удалению"
                                   Foreground="#DE350B" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Button>
                    <Button Content="Закрыть" Click="Close_Click"
                            Style="{StaticResource OutlineBtn}" Margin="0,0,8,0"/>
                    <Button x:Name="ChangeStatusBtn" Click="ChangeStatus_Click"
                            Style="{StaticResource OutlineBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳  " FontSize="13"/>
                            <TextBlock Text="Изменить статус"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button x:Name="EditTaskBtn" HorizontalAlignment="Right"
                        Click="EditTask_Click"
                        Style="{StaticResource BlackBtn}">
                    <TextBlock Text="Редактировать" Foreground="White"/>
                </Button>
            </Grid>
        </Border>

    </Grid>
</UserControl>
