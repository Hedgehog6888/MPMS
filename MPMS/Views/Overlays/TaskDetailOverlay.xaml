<UserControl x:Class="MPMS.Views.Overlays.TaskDetailOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:MPMS.Infrastructure">

    <UserControl.Resources>
        <!-- Slim progress bar template -->
        <ControlTemplate x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                <Border x:Name="PART_Track" CornerRadius="4">
                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left" CornerRadius="4"/>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- Outline button style -->
        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#172B4D"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Black button style -->
        <Style x:Key="BlackBtn" TargetType="Button">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header badges + close -->
            <RowDefinition Height="*"/>      <!-- Scrollable content -->
            <RowDefinition Height="Auto"/>   <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- ── HEADER ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="20,14"
                BorderBrush="#DFE1E6" BorderThickness="0,0,0,1">
            <Grid>
                <!-- Status + Priority badges -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status badge -->
                    <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                            Background="{Binding Task.Status, Converter={StaticResource TaskStatusToBrush}}">
                        <TextBlock Text="{Binding Task.Status, Converter={StaticResource TaskStatusToString}}"
                                   FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                    </Border>

                    <!-- Priority badge -->
                    <Border CornerRadius="4" Padding="8,4"
                            BorderThickness="1"
                            BorderBrush="{Binding Task.Priority, Converter={StaticResource PriorityToBrush}}">
                        <TextBlock Text="{Binding Task.Priority, Converter={StaticResource PriorityToString}}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{Binding Task.Priority, Converter={StaticResource PriorityToBrush}}"/>
                    </Border>
                </StackPanel>

                <!-- Close button -->
                <Button HorizontalAlignment="Right" Click="Close_Click"
                        Width="28" Height="28"
                        ToolTip="Закрыть">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="14">
                                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#6B778C"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── SCROLLABLE CONTENT ──────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,16">

                <!-- Task title -->
                <TextBlock Text="{Binding Task.Name}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#172B4D"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>

                <!-- Description -->
                <TextBlock Text="{Binding Task.Description}"
                           FontSize="13" Foreground="#6B778C"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Visibility="{Binding Task.Description, Converter={StaticResource StringToVis}}"/>

                <Border Background="#DFE1E6" Height="1" Margin="0,0,0,16"/>

                <!-- Progress section -->
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Прогресс выполнения"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#172B4D" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Task.ProgressPercent, StringFormat='{}{0}%'}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#172B4D"
                               HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar Value="{Binding Task.ProgressPercent, Mode=OneWay}"
                             Maximum="100" Height="10" Margin="0,0,0,16"
                             Background="#E9ECEF" Foreground="#111111"
                             Template="{StaticResource SlimProgressBar}"/>

                <Border Background="#DFE1E6" Height="1" Margin="0,0,0,16"/>

                <!-- Assignee + Due Date two-column layout -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Assignee -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="👤  " FontSize="12" Foreground="#6B778C"/>
                            <TextBlock Text="Исполнитель" FontSize="12" Foreground="#6B778C"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <!-- Avatar circle -->
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="#E8E9EC" Margin="0,0,10,0">
                                <TextBlock FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#172B4D">
                                    <TextBlock.Text>
                                        <Binding Path="Task.AssignedUserName">
                                            <Binding.TargetNullValue>?</Binding.TargetNullValue>
                                        </Binding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#172B4D">
                                    <TextBlock.Text>
                                        <Binding Path="Task.AssignedUserName" TargetNullValue="Не назначен"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Due Date -->
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📅  " FontSize="12" Foreground="#6B778C"/>
                            <TextBlock Text="Срок выполнения" FontSize="12" Foreground="#6B778C"/>
                        </StackPanel>
                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="#172B4D"
                                   Text="{Binding Task.DueDate, Converter={StaticResource DateOnlyToString}, ConverterParameter=long}"
                                   Margin="0,0,0,2"/>
                        <TextBlock FontSize="12" Foreground="#6B778C"
                                   Text="{Binding Task.DueDate, Converter={StaticResource DateOnlyToString}, ConverterParameter=dayname}"/>
                    </StackPanel>
                </Grid>

                <Border Background="#DFE1E6" Height="1" Margin="0,0,0,0"/>

                <!-- Inner Tabs -->
                <Border BorderBrush="#DFE1E6" BorderThickness="0,0,0,1" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="StagesTab" Content="{Binding StagesTabLabel}"
                                     Tag="Stages" IsChecked="True"
                                     Style="{StaticResource TabButton}"
                                     Click="InnerTab_Click"/>
                        <RadioButton x:Name="MaterialsTab" Content="Материалы"
                                     Tag="Materials"
                                     Style="{StaticResource TabButton}"
                                     Click="InnerTab_Click"/>
                        <RadioButton x:Name="FilesTab" Content="Файлы"
                                     Tag="Files"
                                     Style="{StaticResource TabButton}"
                                     Click="InnerTab_Click"/>
                        <RadioButton x:Name="MessagesTab" Content="Сообщения"
                                     Tag="Messages"
                                     Style="{StaticResource TabButton}"
                                     Click="InnerTab_Click"/>
                    </StackPanel>
                </Border>

                <!-- STAGES tab content -->
                <StackPanel x:Name="StagesPanel" Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding Stages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,8"
                                        Padding="14,12"
                                        BorderBrush="#DFE1E6" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Stage name + status + actions -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#172B4D"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="▶ Начать" Tag="{Binding}"
                                                        Click="StartStage_Click" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButton}" FontSize="11"
                                                        Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Planned}"/>
                                                <Button Content="✓ Завершить" Tag="{Binding}"
                                                        Click="CompleteStage_Click" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButton}" FontSize="11"
                                                        Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=InProgress}"/>
                                                <Border Visibility="{Binding Status, Converter={StaticResource EqualityToVis}, ConverterParameter=Completed}"
                                                        CornerRadius="4" Padding="6,3" Background="#E8F5E9">
                                                    <TextBlock Text="✓ Завершено" FontSize="10" Foreground="#1B5E20" FontWeight="SemiBold"/>
                                                </Border>
                                                <Button Content="✏" ToolTip="Редактировать" Tag="{Binding}"
                                                        Click="EditStage_Click" Margin="4,0,0,0"
                                                        Style="{StaticResource IconButton}"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Description -->
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12" Foreground="#6B778C"
                                                   TextWrapping="Wrap" Margin="0,0,0,6"
                                                   Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                        <!-- Assignee -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Border Width="22" Height="22" CornerRadius="11"
                                                    Background="#E8E9EC" Margin="0,0,6,0">
                                                <TextBlock FontSize="9" FontWeight="Bold"
                                                           Foreground="#172B4D"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding AssignedUserName}"/>
                                            </Border>
                                            <TextBlock Text="{Binding AssignedUserName}"
                                                       FontSize="12" Foreground="#6B778C"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state for stages -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,24,0,8"
                                Visibility="{Binding HasNoStages, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="✓" FontSize="36" HorizontalAlignment="Center" Foreground="#DFE1E6"/>
                        <TextBlock Text="Этапы ещё не созданы" FontSize="13"
                                   Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Add stage button -->
                    <Button Content="+ Добавить этап" Click="AddStage_Click"
                            Margin="0,8,0,0" Height="36" FontSize="13"
                            Style="{StaticResource OutlineBtn}"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- MATERIALS tab content -->
                <StackPanel x:Name="MaterialsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding AllMaterials}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                        Padding="14,12"
                                        BorderBrush="#DFE1E6" BorderThickness="1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MaterialName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#172B4D"/>
                                                <TextBlock Text="{Binding StageName, StringFormat='Этап: {0}'}"
                                                           FontSize="11" Foreground="#6B778C" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#172B4D">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} {1}">
                                                    <Binding Path="Quantity"/>
                                                    <Binding Path="Unit"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty materials -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,24,0,8"
                                Visibility="{Binding HasNoMaterials, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="📦" FontSize="36" HorizontalAlignment="Center" Foreground="#DFE1E6"/>
                        <TextBlock Text="Материалы ещё не добавлены" FontSize="13"
                                   Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- FILES tab content -->
                <StackPanel x:Name="FilesPanel" Visibility="Collapsed" Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding Files}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,6"
                                        Padding="14,12"
                                        BorderBrush="#DFE1E6" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📄" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="#172B4D"/>
                                            <TextBlock Text="{Binding FileType}" FontSize="11"
                                                       Foreground="#6B778C" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty files -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,24,0,8"
                                Visibility="{Binding HasNoFiles, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="📁" FontSize="36" HorizontalAlignment="Center" Foreground="#DFE1E6"/>
                        <TextBlock Text="Файлы ещё не загружены" FontSize="13"
                                   Foreground="#6B778C" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Button Content="↑ Загрузить файлы" Click="UploadFiles_Click"
                            Margin="0,8,0,0" Height="36" FontSize="13"
                            Style="{StaticResource OutlineBtn}"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- MESSAGES tab content -->
                <StackPanel x:Name="MessagesPanel" Visibility="Collapsed" Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,8"
                                        Padding="14,12"
                                        BorderBrush="#DFE1E6" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Width="32" Height="32" CornerRadius="16"
                                                    Margin="0,0,10,0"
                                                    Background="{Binding UserColor, Converter={StaticResource HexToBrush}}">
                                                <TextBlock Text="{Binding UserInitials}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UserName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#172B4D"/>
                                                <TextBlock Text="{Binding UserRole}"
                                                           FontSize="11"
                                                           Foreground="#6B778C"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                       FontSize="11" Foreground="#6B778C"
                                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                                       Margin="0,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="13" Foreground="#172B4D"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBox x:Name="MessageInput" Width="300" Height="36"
                                 VerticalContentAlignment="Center" FontSize="13"
                                 Padding="10,6" Margin="0,0,8,0"
                                 KeyDown="MessageInput_KeyDown"/>
                        <Button Content="Отправить" Click="SendMessage_Click"
                                Height="36" Padding="16,0"
                                Style="{StaticResource BlackBtn}"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── FOOTER ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="16,12"
                BorderBrush="#DFE1E6" BorderThickness="0,1,0,0"
                Background="White">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Закрыть" Click="Close_Click"
                            Style="{StaticResource OutlineBtn}" Margin="0,0,8,0"/>
                    <Button Content="Изменить статус" Click="ChangeStatus_Click"
                            Style="{StaticResource OutlineBtn}"/>
                </StackPanel>
                <Button Content="Редактировать" HorizontalAlignment="Right"
                        Click="EditTask_Click"
                        Style="{StaticResource BlackBtn}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
