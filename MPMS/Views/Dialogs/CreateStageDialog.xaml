<Window x:Class="MPMS.Views.Dialogs.CreateStageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый этап"
        Width="460" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}" Padding="24,16">
            <TextBlock x:Name="TitleText" Text="Создать этап" FontSize="18" FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,16">
            <TextBlock Text="Название *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Описание" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="DescriptionBox" Style="{StaticResource ModernTextBox}"
                     Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

            <TextBlock Text="Исполнитель" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <ComboBox x:Name="AssigneeCombo" DisplayMemberPath="Name"
                      SelectedValuePath="Id" Height="38"
                      VerticalContentAlignment="Center" Margin="0,0,0,12"/>

            <!-- Status (edit mode only) -->
            <StackPanel x:Name="StatusPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Статус" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="StatusCombo" Height="38" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Запланирован" Tag="Planned" IsSelected="True"/>
                    <ComboBoxItem Content="Выполняется" Tag="InProgress"/>
                    <ComboBoxItem Content="Завершён" Tag="Completed"/>
                </ComboBox>
            </StackPanel>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}"
                       FontSize="12" Visibility="Collapsed"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" Padding="24,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="Cancel_Click" Height="36" Width="90" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="SaveButton" Content="Создать" Click="Save_Click"
                        Style="{StaticResource PrimaryButton}" Height="36" Width="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
