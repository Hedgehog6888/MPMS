<Window x:Class="MPMS.Views.Dialogs.CreateWarehouseItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый материал"
        Width="480" Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}" Padding="24,16">
            <TextBlock x:Name="TitleText" Text="Добавить материал"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="24,16">

            <!-- Name -->
            <TextBlock Text="Название *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <!-- Category -->
            <TextBlock x:Name="CategoryLabel" Text="Категория" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <ComboBox x:Name="CategoryCombo" Style="{StaticResource FormCombo}"
                      Height="36" Margin="0,0,0,12"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <!-- Unit (materials only) -->
            <StackPanel x:Name="UnitPanel">
                <TextBlock Text="Единица измерения" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="UnitBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            </StackPanel>

            <!-- Initial quantity (materials only, create mode) -->
            <StackPanel x:Name="QuantityPanel">
                <TextBlock Text="Начальное количество" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="QuantityBox" Style="{StaticResource ModernTextBox}"
                         Text="0" Margin="0,0,0,12"/>
            </StackPanel>

            <!-- Inventory number (equipment only) -->
            <StackPanel x:Name="InvNumberPanel" Visibility="Collapsed">
                <TextBlock Text="Инвентарный номер" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="InvNumberBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            </StackPanel>

            <!-- Description -->
            <TextBlock Text="Описание" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="DescriptionBox" Style="{StaticResource ModernTextBox}"
                     Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

            <!-- Photo path -->
            <TextBlock Text="Фото (путь к файлу)" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ImagePathBox" Grid.Column="0"
                         Style="{StaticResource ModernTextBox}" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="Обзор..." Margin="8,0,0,0"
                        Click="BrowseImage_Click" Height="36" Padding="12,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#000000"/>
                            <Setter Property="BorderBrush" Value="#DFE1E6"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            <TextBlock x:Name="ImagePreviewHint" FontSize="11" Foreground="#6B778C"
                       Margin="0,2,0,8" Text="Поддерживаются: JPG, PNG, BMP"/>

            <!-- Error -->
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}"
                       FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="24,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="Cancel_Click" Height="36" Width="90" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="SaveButton" Content="Добавить" Click="Save_Click"
                        Style="{StaticResource PrimaryButton}" Height="36" Width="110"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
