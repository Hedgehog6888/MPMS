<Window x:Class="MPMS.Views.Dialogs.AvatarCropDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Загрузить фото профиля"
        Width="780" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#18181B">

    <Window.Resources>
        <Style x:Key="FooterBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#DFE1E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0082FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006ED6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>         <!-- Crop canvas -->
                <ColumnDefinition Width="190"/>       <!-- Preview panel -->
            </Grid.ColumnDefinitions>

            <!-- ── CROP CANVAS AREA ──────────────────────────── -->
            <Grid Grid.Column="0" Background="#18181B">
                <!-- Hint text -->
                <TextBlock Text="Перетащите круг для позиционирования · Тяните за край для изменения размера"
                           FontSize="11" Foreground="#71717A"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="0,0,0,8" IsHitTestVisible="False"/>

                <Canvas x:Name="CropCanvas"
                        Cursor="Arrow"
                        ClipToBounds="True"
                        SizeChanged="CropCanvas_SizeChanged"
                        MouseLeftButtonDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseUp"
                        MouseLeave="Canvas_MouseLeave">

                    <!-- Source image (positioned by code-behind) -->
                    <Image x:Name="SourceImage"
                           Stretch="None"
                           IsHitTestVisible="False"/>

                    <!-- Dim overlay (path drawn in code-behind) -->
                    <Path x:Name="DimOverlay"
                          Fill="#BB000000"
                          IsHitTestVisible="False"/>

                    <!-- Dashed crop circle border -->
                    <Ellipse x:Name="CropRing"
                             Stroke="White" StrokeThickness="1.5"
                             StrokeDashArray="6,3"
                             IsHitTestVisible="False"/>

                    <!-- Grid lines inside crop circle (rule of thirds) -->
                    <Line x:Name="GridH1" Stroke="White" StrokeThickness="0.5"
                          Opacity="0.25" IsHitTestVisible="False"/>
                    <Line x:Name="GridH2" Stroke="White" StrokeThickness="0.5"
                          Opacity="0.25" IsHitTestVisible="False"/>
                    <Line x:Name="GridV1" Stroke="White" StrokeThickness="0.5"
                          Opacity="0.25" IsHitTestVisible="False"/>
                    <Line x:Name="GridV2" Stroke="White" StrokeThickness="0.5"
                          Opacity="0.25" IsHitTestVisible="False"/>

                    <!-- Resize handles: N / S / E / W -->
                    <Ellipse x:Name="HandleN" Width="14" Height="14"
                             Fill="White" Stroke="#0082FF" StrokeThickness="2"
                             Cursor="SizeNS"/>
                    <Ellipse x:Name="HandleS" Width="14" Height="14"
                             Fill="White" Stroke="#0082FF" StrokeThickness="2"
                             Cursor="SizeNS"/>
                    <Ellipse x:Name="HandleW" Width="14" Height="14"
                             Fill="White" Stroke="#0082FF" StrokeThickness="2"
                             Cursor="SizeWE"/>
                    <Ellipse x:Name="HandleE" Width="14" Height="14"
                             Fill="White" Stroke="#0082FF" StrokeThickness="2"
                             Cursor="SizeWE"/>
                </Canvas>
            </Grid>

            <!-- ── PREVIEW PANEL ─────────────────────────────── -->
            <StackPanel Grid.Column="1" Background="#27272A"
                        VerticalAlignment="Center" Margin="0"
                        Opacity="1">
                <TextBlock Text="ПРЕДПРОСМОТР"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#A1A1AA"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Large preview 120px -->
                <Border Width="120" Height="120" CornerRadius="60"
                        HorizontalAlignment="Center"
                        ClipToBounds="True"
                        BorderBrush="#3F3F46" BorderThickness="2"
                        Margin="0,0,0,8">
                    <Image x:Name="PreviewLarge" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="120 × 120 px"
                           FontSize="10" Foreground="#71717A"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Medium preview 56px -->
                <Border Width="56" Height="56" CornerRadius="28"
                        HorizontalAlignment="Center"
                        ClipToBounds="True"
                        BorderBrush="#3F3F46" BorderThickness="2"
                        Margin="0,0,0,8">
                    <Image x:Name="PreviewMedium" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="56 × 56 px"
                           FontSize="10" Foreground="#71717A"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Small preview 32px -->
                <Border Width="32" Height="32" CornerRadius="16"
                        HorizontalAlignment="Center"
                        ClipToBounds="True"
                        BorderBrush="#3F3F46" BorderThickness="2"
                        Margin="0,0,0,8">
                    <Image x:Name="PreviewSmall" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="32 × 32 px"
                           FontSize="10" Foreground="#71717A"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ── FOOTER ────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="White" Padding="20,12"
                BorderBrush="#E4E4E7" BorderThickness="0,1,0,0">
            <Grid>
                <Button Content="Выбрать другое фото"
                        HorizontalAlignment="Left"
                        Style="{StaticResource FooterBtn}"
                        Click="BrowseAgain_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена"
                            Style="{StaticResource FooterBtn}"
                            Margin="0,0,10,0"
                            Click="Cancel_Click"/>
                    <Button Content="✓  Применить"
                            Style="{StaticResource PrimaryBtn}"
                            Click="Apply_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
