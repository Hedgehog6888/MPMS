<Window x:Class="MPMS.Views.Dialogs.CreateUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid>
        <!-- Header bar -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111111" Padding="24,18">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Создать пользователя"
                               FontSize="17" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="SubtitleText"
                               Text="Заполните данные для нового аккаунта"
                               FontSize="12" Foreground="#AAAAAA" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource IconButton}" Foreground="White">
                    <TextBlock Text="✕" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- Form content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,4">

                <!-- Avatar preview + name initials row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar circle preview -->
                    <Border x:Name="AvatarCircle" Width="64" Height="64" CornerRadius="32"
                            Background="#1B6EC2" Margin="0,0,16,0">
                        <TextBlock x:Name="AvatarInitials" Text="?"
                                   FontSize="22" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Аватар по умолчанию"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#172B4D"/>
                        <TextBlock Text="Автоматически создаётся из инициалов имени пользователя"
                                   FontSize="11" Foreground="#6B778C" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Full name -->
                <TextBlock Text="Полное имя *" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource FormInput}"
                         Margin="0,0,0,16" TextChanged="Name_TextChanged"
                         ToolTip="Например: Иван Петрович Смирнов"/>

                <!-- Username + Email row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Логин (username) *" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="UsernameBox" Style="{StaticResource FormInput}"
                                 ToolTip="Используется для входа в систему"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="EmailBox" Style="{StaticResource FormInput}"
                                 ToolTip="Необязательно"/>
                    </StackPanel>
                </Grid>

                <!-- Role -->
                <TextBlock Text="Роль в системе *" Style="{StaticResource FormLabel}"/>
                <ComboBox x:Name="RoleCombo" Style="{StaticResource FormCombo}"
                          Margin="0,0,0,16"
                          DisplayMemberPath="Name"
                          SelectionChanged="Role_SelectionChanged"/>

                <!-- Role description badge -->
                <Border x:Name="RoleDescPanel" CornerRadius="8" Padding="12,10"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="RoleDescIcon" FontSize="14" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="RoleDescText" FontSize="12" TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Password section -->
                <Border CornerRadius="10" Background="#F8FAFF" Padding="16"
                        BorderBrush="#BFDBFE" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="🔑" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PasswordSectionTitle"
                                       Text="Задать пароль"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1D4ED8" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock x:Name="PasswordLabel" Style="{StaticResource FormLabel}"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="6" Padding="10,0" Margin="0,0,0,12">
                            <PasswordBox x:Name="PasswordBox"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#172B4D" FontSize="13"
                                         Height="38" VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Подтвердите пароль" Style="{StaticResource FormLabel}"/>
                        <Border Background="White" BorderBrush="#DFE1E6" BorderThickness="1"
                                CornerRadius="6" Padding="10,0">
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#172B4D" FontSize="13"
                                         Height="38" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Error panel -->
                <Border x:Name="ErrorPanel" Background="#FFF0F0"
                        CornerRadius="8" Padding="14,10" Margin="0,0,0,8"
                        Visibility="Collapsed" BorderBrush="#FCA5A5" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0"
                                   Foreground="#DC2626" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#DFE1E6" BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="Cancel_Click"
                        Style="{StaticResource OutlineBtn}" Margin="0,0,8,0"/>
                <Button x:Name="SaveBtn" Click="Save_Click"
                        Style="{StaticResource BlackBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SaveBtnIcon" Text="✓" FontSize="13"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SaveBtnText" Text="Создать" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
