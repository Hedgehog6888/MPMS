<Window x:Class="MPMS.Views.Dialogs.BlockUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Блокировка пользователя"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Width="40" Height="40" CornerRadius="20" Background="#FEE2E2" Margin="0,0,12,0">
                <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Заблокировать пользователя" FontSize="16" FontWeight="Bold"
                           Foreground="#172B4D"/>
                <TextBlock Text="Пользователь не сможет войти в систему" FontSize="12"
                           Foreground="#6B778C" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Reason field -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Причина блокировки (необязательно)"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#172B4D" Margin="0,0,0,6"/>
            <TextBox x:Name="ReasonBox"
                     Style="{StaticResource FormInput}"
                     MinHeight="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"/>
        </StackPanel>

        <!-- Warning banner -->
        <Border Grid.Row="2" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1"
                CornerRadius="8" Padding="12,10" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="14" Foreground="#D97706" Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Заблокированный пользователь немедленно потеряет доступ к системе."
                           FontSize="12" Foreground="#92400E" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Click="Cancel_Click"
                    Style="{StaticResource OutlineBtn}" Margin="0,0,8,0"/>
            <Button Click="Confirm_Click"
                    Padding="16,9" FontSize="13" FontWeight="SemiBold"
                    Foreground="White" Cursor="Hand" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="#EF4444" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔒" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Заблокировать" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
