<UserControl x:Class="MPMS.Controls.DragDropOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             AllowDrop="True"
             Background="Transparent"
             PreviewDragEnter="OnDragEnter"
             PreviewDragLeave="OnDragLeave"
             PreviewDragOver="OnDragOver"
             PreviewDrop="OnDrop"
             IsHitTestVisible="True"
             Visibility="Collapsed">
    <!-- Note: Visibility is controlled by internal logic or external binding, 
         but we want it to capture events even when "inactive" if possible. 
         Actually, it must be visible to capture events, but we can make it transparent. -->
    
    <UserControl.Resources>
        <Storyboard x:Key="OverlayShowStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.98" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.98" To="1" Duration="0:0:0.4"/>
        </Storyboard>
        
        <Storyboard x:Key="DashedAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset" 
                             From="30" To="0" Duration="0:0:2"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <ScaleTransform />
        </Grid.RenderTransform>
        <Grid.RenderTransformOrigin>
            <Point X="0.5" Y="0.5"/>
        </Grid.RenderTransformOrigin>

        <!-- Semi-transparent background -->
        <Border Background="#AAFFFFFF" IsHitTestVisible="False"/>

        <!-- Central Drop Zone Card -->
        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="480" Height="320"
                Background="White" CornerRadius="32">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.15" Direction="270"/>
            </Border.Effect>
            
            <Grid Margin="12">
                <!-- Animated Dashed Border -->
                <Rectangle x:Name="DashedBorder"
                           Stroke="{StaticResource PrimaryBrush}" 
                           StrokeThickness="2" 
                           RadiusX="24" RadiusY="24"
                           StrokeDashArray="8 4">
                </Rectangle>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="80" Height="80" Background="#EEF2FF" CornerRadius="40" Margin="0,0,0,24">
                        <Image Source="{svgc:SvgImage Source=/icons/upload.svg, AppName=MPMS}" 
                               Width="36" Height="36" 
                               Opacity="0.9"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Отпустите для загрузки" 
                               FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
