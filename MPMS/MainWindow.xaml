<Window x:Class="MPMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:MPMS.Infrastructure"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="MPMS — Montage Project Management System"
        Height="768" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <infra:BoolToVisibilityConverter x:Key="StringToVis" IsStringMode="True"/>
        <infra:EqualityToBoolConverter x:Key="EqualityToBool"/>

        <!-- Nav button style (light theme, white sidebar) -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"     Value="#172B4D"/>
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Padding"        Value="0"/>
            <Setter Property="Height"         Value="46"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="GroupName"      Value="Navigation"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="6"
                                Margin="8,2"
                                Padding="0">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                <Setter Property="Foreground" Value="#172B4D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <!-- Активный пункт без синего цвета -->
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                <Setter Property="Foreground" Value="#172B4D"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Black create button for top bar -->
        <Style x:Key="TopCreateButton" TargetType="Button">
            <Setter Property="Background"      Value="Black"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top bar spanning full width -->
            <RowDefinition Height="56"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MAIN NAVIGATION BAR (общая верхняя панель) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="0,0,16,0">
                <Grid.ColumnDefinitions>
                    <!-- Левая зона совпадает по ширине с сайдбаром -->
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- MPMS rectangle (не кнопка) -->
                <Border Grid.Column="0"
                        Background="Black"
                        CornerRadius="6"
                        Padding="18,8"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="8,0,24,0">
                    <TextBlock Text="MPMS"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="15"/>
                </Border>

                <!-- Search box with focus animation + popup results -->
                <Grid Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border x:Name="SearchBorder"
                            Background="#F4F5F7"
                            CornerRadius="6" Padding="10,0"
                            Width="520"
                            Height="36"
                            BorderThickness="1.5" BorderBrush="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SearchIcon" Grid.Column="0" Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Grid Grid.Column="1">
                                <TextBlock Text="Поиск проектов, задач, этапов..."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13" VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="GlobalSearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" FontSize="13"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         GotFocus="GlobalSearch_GotFocus"
                                         LostFocus="GlobalSearch_LostFocus"
                                         KeyDown="GlobalSearch_KeyDown"
                                         TextChanged="GlobalSearch_TextChanged"/>
                            </Grid>
                            <!-- Clear button -->
                            <Button Grid.Column="2" x:Name="ClearSearchBtn"
                                    Click="ClearSearch_Click"
                                    Visibility="Collapsed"
                                    Width="20" Height="20" Margin="4,0,0,0"
                                    Style="{StaticResource IconButton}">
                                <TextBlock Text="✕" FontSize="11" Foreground="#6B778C"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Search Results Popup -->
                    <Popup x:Name="SearchResultsPopup"
                           PlacementTarget="{Binding ElementName=SearchBorder}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           Width="520">
                        <Border Background="White" CornerRadius="8"
                                BorderBrush="#DFE1E6" BorderThickness="1"
                                Margin="0,4,0,0" MaxHeight="480">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" Opacity="0.12"
                                                  ShadowDepth="4" Direction="270"/>
                            </Border.Effect>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="SearchResultsPanel" Margin="8">
                                    <!-- Projects section -->
                                    <StackPanel x:Name="SearchProjectsSection" Margin="0,0,0,8">
                                        <TextBlock Text="ПРОЕКТЫ" FontSize="10" FontWeight="Bold"
                                                   Foreground="#6B778C" Margin="8,8,8,6"/>
                                        <ItemsControl x:Name="SearchProjectsList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="Transparent" CornerRadius="6"
                                                            Padding="10,8" Cursor="Hand"
                                                            MouseLeftButtonDown="SearchResult_Click"
                                                            Tag="{Binding}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F4F5F7"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="6" Height="6" CornerRadius="3"
                                                                    Background="{Binding Status, Converter={StaticResource ProjectStatusToBrush}}"
                                                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                                       Foreground="#172B4D" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Client}" FontSize="12"
                                                                       Foreground="#6B778C" Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <Border x:Name="SearchProjectsDivider" Background="#F0F0F0" Height="1" Margin="8,0,8,8"/>

                                    <!-- Tasks section -->
                                    <StackPanel x:Name="SearchTasksSection" Margin="0,0,0,8">
                                        <TextBlock Text="ЗАДАЧИ" FontSize="10" FontWeight="Bold"
                                                   Foreground="#6B778C" Margin="8,0,8,6"/>
                                        <ItemsControl x:Name="SearchTasksList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="Transparent" CornerRadius="6"
                                                            Padding="10,8" Cursor="Hand"
                                                            MouseLeftButtonDown="SearchResult_Click"
                                                            Tag="{Binding}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F4F5F7"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border CornerRadius="3" Padding="5,2"
                                                                    Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}"
                                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToString}}"
                                                                           FontSize="9" Foreground="White"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                                       Foreground="#172B4D" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ProjectName}" FontSize="12"
                                                                       Foreground="#6B778C" Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <Border x:Name="SearchTasksDivider" Background="#F0F0F0" Height="1" Margin="8,0,8,8"/>

                                    <!-- Stages section -->
                                    <StackPanel x:Name="SearchStagesSection">
                                        <TextBlock Text="ЭТАПЫ" FontSize="10" FontWeight="Bold"
                                                   Foreground="#6B778C" Margin="8,0,8,6"/>
                                        <ItemsControl x:Name="SearchStagesList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="Transparent" CornerRadius="6"
                                                            Padding="10,8" Cursor="Hand"
                                                            MouseLeftButtonDown="SearchResult_Click"
                                                            Tag="{Binding}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F4F5F7"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="6" Height="6" CornerRadius="3"
                                                                    Background="{Binding Status, Converter={StaticResource StageStatusToBrush}}"
                                                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                                       Foreground="#172B4D" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding TaskName}" FontSize="12"
                                                                       Foreground="#6B778C" Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- No results -->
                                    <TextBlock x:Name="NoSearchResultsText"
                                               Text="Ничего не найдено" FontSize="13"
                                               Foreground="#6B778C" HorizontalAlignment="Center"
                                               Margin="0,16" Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Right: Create + icons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Create button (чёрная) -->
                    <Button Command="{Binding CreateCommand}"
                            Style="{StaticResource TopCreateButton}"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Создать" Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Divider -->
                    <Border Width="1" Height="20" Background="#DFE1E6" Margin="0,0,8,0" VerticalAlignment="Center"/>

                    <!-- Sync/connection status button with popup -->
                    <Border x:Name="SyncStatusBorder" Width="36" Height="36" Margin="0,0,0,0"
                            Cursor="Hand" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F4F5F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Click="SyncStatus_Click" Style="{StaticResource IconButton}">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Width="16" Height="16" Stretch="Uniform"
                                       Source="{svgc:SvgImage Source=/icons/update.svg, AppName=MPMS}">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Opacity" Value="0.7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <!-- Online/offline dot -->
                                <Ellipse Width="7" Height="7" HorizontalAlignment="Right"
                                         VerticalAlignment="Bottom" Margin="0,0,-1,-1">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#00C875"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="Fill" Value="#FF6B6B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Grid>
                        </Button>
                    </Border>

                    <!-- Sync popup (Popup control for rich design) -->
                    <Popup x:Name="SyncPopup"
                           PlacementTarget="{Binding ElementName=SyncStatusBorder}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           Width="340">
                        <Border Background="White" CornerRadius="10"
                                BorderBrush="#DFE1E6" BorderThickness="1"
                                Margin="0,4,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.12"
                                                  ShadowDepth="4" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Header -->
                                <Border x:Name="SyncPopupHeader" CornerRadius="10,10,0,0" Padding="16,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0FDF4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="Background" Value="#F8F9FA"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*" MinWidth="0"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Status icon circle -->
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                            <Setter Property="Background" Value="#F4F5F7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="✓"/>
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                <Setter Property="Text" Value="✕"/>
                                                                <Setter Property="Foreground" Value="#6B778C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                                <Setter Property="Text" Value="↻"/>
                                                                <Setter Property="Foreground" Value="#2563EB"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                            <TextBlock FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Синхронизировано"/>
                                                        <Setter Property="Foreground" Value="#172B4D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                <Setter Property="Text" Value="Нет подключения"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                                <Setter Property="Text" Value="Синхронизация..."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#6B778C"/>
                                                        <Setter Property="Text" Value="{Binding LastSyncText}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                <Setter Property="Text" Value="Изменения сохраняются локально"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- "Актуально" badge -->
                                        <Border Grid.Column="2" Margin="8,0,0,0" CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Актуально"/>
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                                <Setter Property="Text" Value="Синхр..."/>
                                                                <Setter Property="Foreground" Value="#2563EB"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Stats row (online only) -->
                                <Border BorderBrush="#F0F0F0" BorderThickness="0,1,0,0"
                                        Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="1" Background="#F0F0F0" Margin="0,8,0,8"/>
                                        <Border Grid.Column="3" Background="#F0F0F0" Margin="0,8,0,8"/>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,10">
                                            <TextBlock Text="{Binding SyncProjectCount}" FontSize="16" FontWeight="Bold"
                                                       Foreground="#172B4D" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Проектов" FontSize="10" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="0,10">
                                            <TextBlock Text="{Binding SyncTaskCount}" FontSize="16" FontWeight="Bold"
                                                       Foreground="#172B4D" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Задач" FontSize="10" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="0,10">
                                            <TextBlock Text="{Binding SyncStageCount}" FontSize="16" FontWeight="Bold"
                                                       Foreground="#172B4D" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Этапов" FontSize="10" Foreground="#6B778C" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Offline warning -->
                                <Border Margin="12,8,12,0" CornerRadius="8" Padding="12,10"
                                        Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                                        Visibility="{Binding IsOnline, Converter={StaticResource BoolToVisInv}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Top" Foreground="#D97706"/>
                                        <TextBlock Text="Изменения сохраняются локально и будут синхронизированы при восстановлении соединения."
                                                   FontSize="11" Foreground="#92400E" TextWrapping="Wrap" MaxWidth="280"/>
                                    </StackPanel>
                                </Border>

                                <!-- Footer with auto-sync info and sync button -->
                                <Border Padding="12,10,12,12" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Margin="0,8,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="🕐" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Авто-синхронизация каждые 5 мин"
                                                       FontSize="11" Foreground="#6B778C" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Row="1" HorizontalAlignment="Left" Click="SyncNow_Click"
                                                Height="30" Padding="12,0" MinWidth="140" FontSize="12">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="White" CornerRadius="6"
                                                            BorderBrush="#DFE1E6" BorderThickness="1"
                                                            Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="↻" FontSize="13" Margin="0,0,6,0"
                                                                       VerticalAlignment="Center" Foreground="#172B4D"/>
                                                            <TextBlock Text="Синхронизировать" Foreground="#172B4D"
                                                                       FontSize="12" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Settings button -->
                    <Border Width="36" Height="36" Margin="4,0,0,0"
                            Cursor="Hand" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F4F5F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Click="Settings_Click" Style="{StaticResource IconButton}" ToolTip="Настройки">
                            <Image Width="16" Height="16" Stretch="Uniform" Opacity="0.7"
                                   Source="{svgc:SvgImage Source=/icons/settings.svg, AppName=MPMS}"/>
                        </Button>
                    </Border>

                    <!-- Divider -->
                    <Border Width="1" Height="20" Background="#DFE1E6" Margin="4,0,8,0" VerticalAlignment="Center"/>

                    <!-- User panel: name + role + avatar — opens popup on click -->
                    <Border x:Name="UserPanelBorder" Cursor="Hand"
                            Margin="0,0,0,0" CornerRadius="6" Padding="8,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F4F5F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.ContextMenu>
                            <ContextMenu x:Name="UserContextMenu" Style="{StaticResource StatusMenu}">
                                <MenuItem Style="{StaticResource StatusMenuItem}" IsEnabled="False">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock Text="{Binding UserName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#172B4D"/>
                                            <TextBlock Text="{Binding UserRoleDisplay}"
                                                       FontSize="11" Foreground="#1B6EC2"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Мой профиль"
                                          Click="MyProfile_Click"
                                          Style="{StaticResource StatusMenuItem}"/>
                                <MenuItem Header="Настройки"
                                          Click="Settings_Click"
                                          Style="{StaticResource StatusMenuItem}"/>
                                <Separator/>
                                <MenuItem Header="Выйти из аккаунта"
                                          Command="{Binding SwitchAccountCommand}"
                                          Style="{StaticResource StatusMenuItem}"
                                          Foreground="#DE350B"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Button x:Name="UserPanelBtn" Click="UserPanel_Click"
                                Style="{StaticResource IconButton}" Padding="0" Background="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <!-- Avatar circle слева: photo if available, else initials -->
                                <Grid Width="30" Height="30" Margin="0,0,8,0"
                                      VerticalAlignment="Center">
                                    <!-- Initials fallback -->
                                    <Border Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="15">
                                        <TextBlock Text="{Binding UserInitials}"
                                                   Foreground="White" FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Photo overlay (EllipseGeometry для идеального круга) -->
                                    <Border x:Name="TopBarAvatarBorder"
                                            Style="{StaticResource AvatarCircle30}"
                                            Visibility="Collapsed">
                                        <Image x:Name="TopBarAvatarImage"
                                               Style="{StaticResource AvatarImage}"
                                               Width="30" Height="30"/>
                                    </Border>
                                </Grid>
                                <!-- Name + Role stacked -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UserName}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#172B4D"/>
                                    <TextBlock Text="{Binding UserRoleDisplay}"
                                               FontSize="10" Foreground="#6B778C"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             SITE NAVIGATION BAR (боковая панель)
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">
                <!-- Проекты (скрыт для Работника) -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Projects, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Projects"
                             Visibility="{Binding IsProjectsVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/project.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Проекты"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Задачи -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Tasks, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Tasks">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/tasks.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Задачи"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Этапы -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Stages, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Stages">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/stages.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Этапы"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Kanban -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Kanban, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Kanban">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/kanban.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Kanban"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Gantt -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Gantt, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Gantt">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/gantt.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Gantt"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Календарь -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Calendar, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Calendar">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/calendar.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Календарь"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Материалы -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Materials, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Materials">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/material.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Материалы"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Файлы -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Files, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Files">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/files.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Файлы"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Журнал (виден всем, кроме администратора) -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Journal, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Journal"
                             Visibility="{Binding IsAdminPanelVisible, Converter={StaticResource BoolToVisInv}}">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="20" Height="20"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Source="{svgc:SvgImage Source=/icons/journal.svg, AppName=MPMS}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Журнал"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- Администрирование (только для Administrator) -->
                <RadioButton IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Admin, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Admin"
                             Visibility="{Binding IsAdminPanelVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" Margin="12,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="🛡" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Opacity" Value="0.7"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Администрирование"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Content="{Binding CurrentPageViewModel}"
                        Background="{StaticResource BackgroundBrush}"/>

        <!-- ═══════ OVERLAY / DRAWER LAYER ════════════════════════════ -->
        <Grid x:Name="OverlayLayer"
              Grid.Row="0" Grid.Column="0"
              Grid.RowSpan="2" Grid.ColumnSpan="2"
              Panel.ZIndex="200"
              Visibility="Collapsed">

            <!-- Backdrop -->
            <Border x:Name="OverlayBackdrop"
                    Background="#80000000"
                    Opacity="0"
                    MouseLeftButtonDown="Backdrop_Click"/>

            <!-- Drawer panel slides from right -->
            <Border x:Name="DrawerPanel"
                    Background="White"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="520"
                    Margin="520,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40"
                                      Opacity="0.18" Direction="180" ShadowDepth="0"/>
                </Border.Effect>
                <ContentPresenter x:Name="DrawerContentPresenter"/>
            </Border>
        </Grid>
    </Grid>
</Window>
