<Window x:Class="MPMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:MPMS.Infrastructure"
        Title="MPMS — Montage Project Management System"
        Height="768" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <infra:BoolToVisibilityConverter x:Key="StringToVis" IsStringMode="True"/>
        <infra:EqualityToBoolConverter x:Key="EqualityToBool"/>

        <!-- Nav button style (light theme, white sidebar) -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"     Value="#172B4D"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Padding"        Value="0"/>
            <Setter Property="Height"         Value="40"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="GroupName"      Value="Navigation"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                Margin="8,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Icon" Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock x:Name="Label" Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="13"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"    Property="Background" Value="#F4F5F7"/>
                                <Setter TargetName="Icon"  Property="Foreground" Value="#172B4D"/>
                                <Setter TargetName="Label" Property="Foreground" Value="#172B4D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg"    Property="Background" Value="{StaticResource SidebarNavActiveBrush}"/>
                                <Setter TargetName="Icon"  Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="#172B4D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Black create button for top bar -->
        <Style x:Key="TopCreateButton" TargetType="Button">
            <Setter Property="Background"      Value="Black"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top bar spanning full width -->
            <RowDefinition Height="56"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MAIN NAVIGATION BAR (общая верхняя панель) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="0,0,16,0">
                <Grid.ColumnDefinitions>
                    <!-- Левая зона совпадает по ширине с сайдбаром -->
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- MPMS rectangle (не кнопка) -->
                <Border Grid.Column="0"
                        Background="{StaticResource PrimaryBrush}"
                        CornerRadius="6"
                        Padding="16,8"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,0,24,0">
                    <TextBlock Text="MPMS"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"/>
                </Border>

                <!-- Search box (center, фиксированная ширина) -->
                <Border Grid.Column="1" Background="#F4F5F7"
                        CornerRadius="6" Padding="10,0"
                        Width="520"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center" Height="36">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Grid Grid.Column="1">
                            <TextBlock Text="Поиск проектов, задач..."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalAlignment="Center" FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Right: Create + icons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Create button (чёрная) -->
                    <Button Command="{Binding CreateCommand}"
                            Style="{StaticResource TopCreateButton}"
                            Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Создать" Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Кружок онлайн/офлайн (не кнопка) -->
                    <Border Width="36" Height="36"
                            Margin="0,0,4,0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Онлайн"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="Text" Value="Офлайн"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#00C875"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                <Setter Property="Fill" Value="#FF6B6B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Border>

                    <!-- Кнопка обновления (доступна всегда) -->
                    <Border Width="36" Height="36" Margin="0,0,4,0"
                            Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Style.Triggers>
                                    <!-- Подсветка сохраняется и при нажатии,
                                         т.к. ховер висит на всём бордере -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Command="{Binding RefreshConnectionCommand}"
                                Style="{StaticResource IconButton}"
                                FontSize="14"
                                ToolTip="Проверить соединение">
                            ↻
                        </Button>
                    </Border>

                    <!-- Иконка настроек -->
                    <Border Width="36" Height="36" Cursor="Hand" Margin="0,0,4,0"
                            ToolTip="Настройки">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F4F5F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="#6B778C"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Аватар без выделения при ховере -->
                    <Border Width="36" Height="36" Cursor="Hand"
                            ToolTip="{Binding UserName}">
                        <Border Background="Transparent"
                                Width="36" Height="36"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border Background="{StaticResource PrimaryBrush}"
                                    Width="28" Height="28" CornerRadius="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserInitials}"
                                           Foreground="White" FontSize="11"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             SITE NAVIGATION BAR (боковая панель)
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">
                <!-- Проекты (document stack icon E8A5) -->
                <RadioButton Content="Проекты" Tag="&#xE8A5;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Projects, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Projects"/>
                <!-- Задачи (checkbox E73A) -->
                <RadioButton Content="Задачи" Tag="&#xE73A;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Tasks, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Tasks"/>
                <!-- Kanban (grid E8A1) -->
                <RadioButton Content="Kanban" Tag="&#xE8A1;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Kanban, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Kanban"/>
                <!-- Gantt (chart E9D9) -->
                <RadioButton Content="Gantt" Tag="&#xE9D9;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Gantt, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Gantt"/>
                <!-- Календарь (calendar E787) -->
                <RadioButton Content="Календарь" Tag="&#xE787;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Calendar, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Calendar"/>
                <!-- Материалы (package E8BF) -->
                <RadioButton Content="Материалы" Tag="&#xE8BF;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Materials, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Materials"/>
                <!-- Файлы (document E8A5) -->
                <RadioButton Content="Файлы" Tag="&#xE8A5;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Files, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Files"/>
                <!-- Журнал (history E81C) -->
                <RadioButton Content="Журнал" Tag="&#xE81C;"
                             IsChecked="{Binding CurrentPage, Converter={StaticResource EqualityToBool}, ConverterParameter=Journal, Mode=OneWay}"
                             Style="{StaticResource NavButton}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Journal"/>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Content="{Binding CurrentPageViewModel}"
                        Background="{StaticResource BackgroundBrush}"/>
    </Grid>
</Window>
