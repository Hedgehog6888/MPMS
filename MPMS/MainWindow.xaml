<Window x:Class="MPMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:MPMS.Infrastructure"
        xmlns:comp="clr-namespace:MPMS.Views.Components"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="MPMS — Montage Project Management System"
        Height="768" Width="1280"
        MinHeight="768" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <infra:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <infra:BoolToVisibilityConverter x:Key="StringToVis" IsStringMode="True"/>
        <infra:EqualityToBoolConverter x:Key="EqualityToBool"/>

        <!-- Nav button style (light theme, white sidebar) -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"     Value="#000000"/>
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Padding"        Value="0"/>
            <Setter Property="Height"         Value="46"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="GroupName"      Value="Navigation"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="6"
                                Margin="8,2"
                                Padding="0">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <!-- Активный пункт без синего цвета -->
                                <Setter TargetName="Bg" Property="Background" Value="#F4F5F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Black create button for top bar -->
        <Style x:Key="TopCreateButton" TargetType="Button">
            <Setter Property="Background"      Value="Black"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top bar spanning full width -->
            <RowDefinition Height="56"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MAIN NAVIGATION BAR (общая верхняя панель) -->
        <comp:MainTopBar Grid.Row="0" Grid.ColumnSpan="2"/>

        <!-- SITE NAVIGATION BAR (боковая панель) -->
        <comp:MainSidebar Grid.Row="1" Grid.Column="0"/>

        <!-- Основной контент -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Content="{Binding CurrentPageViewModel}"
                        Background="{StaticResource BackgroundBrush}"/>

        <!-- ═══════ OVERLAY / DRAWER LAYER ════════════════════════════ -->
        <Grid x:Name="OverlayLayer"
              Grid.Row="0" Grid.Column="0"
              Grid.RowSpan="2" Grid.ColumnSpan="2"
              Panel.ZIndex="200"
              Visibility="Collapsed">

            <!-- Backdrop -->
            <Border x:Name="OverlayBackdrop"
                    Background="#80000000"
                    Opacity="0"
                    MouseLeftButtonDown="Backdrop_Click"/>

            <!-- Drawer panel slides from right -->
            <Border x:Name="DrawerPanel"
                    Background="White"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="520"
                    Margin="520,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40"
                                      Opacity="0.18" Direction="180" ShadowDepth="0"/>
                </Border.Effect>
                <ContentPresenter x:Name="DrawerContentPresenter"/>
            </Border>

            <!-- Center modal -->
            <Border x:Name="ModalOverlayPanel"
                    Background="Transparent"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="840"
                    MaxWidth="900"
                    MaxHeight="720"
                    Margin="24"
                    Visibility="Collapsed"
                    Opacity="0"
                    ClipToBounds="False"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ModalOverlayTransform" Y="16"/>
                </Border.RenderTransform>
                <Border Background="White"
                        CornerRadius="12"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        BorderBrush="#DFE1E6"
                        BorderThickness="1">
                    <Border Background="Transparent"
                            SizeChanged="ModalOverlayContentClip_SizeChanged">
                        <ContentPresenter x:Name="ModalOverlayContentPresenter"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                    </Border>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
